public struct File {
    public Int fd;

    public Bool is_valid() {
        return fd >= 0;
    }

    public () close() {
        __intrinsic_print("closing fd=%lld\n", fd);
    }

    public File open(Int fd) {
        return File { fd: fd };
    }
}

public Bool exists(UInt8[] path) {
    return __intrinsic_file_exists(path);
}

public UInt8[] read_all(UInt8[] path) {
    return __intrinsic_read_file(path);
}
