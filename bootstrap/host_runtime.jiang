public Bool host_file_exists(UInt8[] path) {
    return __intrinsic_file_exists(path);
}

public UInt8[] host_read_file(UInt8[] path) {
    return __intrinsic_read_file(path);
}

public Int[] host_alloc_ints(Int length) {
    return __intrinsic_alloc_ints(length);
}

public UInt8[] host_alloc_bytes(Int length) {
    return __intrinsic_alloc_bytes(length);
}
