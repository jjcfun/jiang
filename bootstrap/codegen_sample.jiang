public Int add(Int left, Int right) {
    Int total = left + right;
    if (total >= 7) {
        total = total + 1;
    } else {
        total = total - 1;
    }
    while (left < right) {
        left = left + 1;
    }
    return total;
}

public Int main() {
    Int value = add(3, 4);
    print("%lld\n", value);
    return 0;
}
