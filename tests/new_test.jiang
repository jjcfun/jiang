// 测试 new 关键字的各种用法
struct Point {
    Int x, y;
    init(Int ix, Int iy) {
        x = ix;
        y = iy;
    }
}

// 1. 基础类型分配
Int* p_int = new 100;
print("p_int value: %lld\n", *p_int);

// 2. 结构体字面量分配
Point* p_struct1 = new Point { x: 10, y: 20 };
print("p_struct1: x=%lld, y=%lld\n", p_struct1.x, p_struct1.y);

// 3. 构造函数分配
Point* p_struct2 = new Point(30, 40);
print("p_struct2: x=%lld, y=%lld\n", p_struct2.x, p_struct2.y);
