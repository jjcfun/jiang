import std;

UInt8[] chinese = "你好";
UInt8[] mixed = "hi世界";
UInt8[] emoji = "🙂";
UInt8[] payload = std.fs.read_all("tests/utf8_payload.txt");

std.debug.assert(chinese.length == 6);
std.debug.assert(mixed.length == 8);
std.debug.assert(emoji.length == 4);

std.debug.assert(chinese[0] == 228);
std.debug.assert(chinese[1] == 189);
std.debug.assert(chinese[2] == 160);
std.debug.assert(emoji[0] == 240);
std.debug.assert(emoji[1] == 159);
std.debug.assert(emoji[2] == 153);
std.debug.assert(emoji[3] == 130);

std.debug.assert(payload.length >= 10);
std.debug.assert(payload[0] == 228);
std.debug.assert(payload[1] == 189);
std.debug.assert(payload[2] == 160);
std.debug.assert(payload[3] == 229);
std.debug.assert(payload[4] == 165);
std.debug.assert(payload[5] == 189);
std.debug.assert(payload[6] == 240);
std.debug.assert(payload[7] == 159);
std.debug.assert(payload[8] == 153);
std.debug.assert(payload[9] == 130);

print("你好 UTF-8\n");
std.io.print("hi世界");
std.io.print("🙂");
std.io.print("utf8_string_test passed");
