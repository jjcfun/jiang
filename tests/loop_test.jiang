// μΚ‘ξ»ΎλΟΗν―»ξ»ΙλΉΒ
Int! sum_while = 0;
Int! i = 0;

while (i < 5) {
    sum_while = sum_while + i;
    i = i + 1;
}
assert(sum_while == 10); // 0+1+2+3+4 = 10

Int! sum_for = 0;
for j in 0..5 {
    sum_for = sum_for + j;
}
assert(sum_for == 10); // 0+1+2+3+4 = 10

// λΚ’λΒ©λΟΗν―»μΚ‘ξ»Ύ
Int! count = 0;
for x in 0..3 {
    for y in 0..3 {
        count = count + 1;
    }
}
assert(count == 9);

print("loop_test passed!\n");
