// Test Enum support

enum PetKind {
    dog,
    cat,
}

enum Priority {
    low = 1,
    medium,
    high,
}

// Global variable with enum type
PetKind my_pet = PetKind.dog;
print("my_pet value: %lld", my_pet.value);

Priority p = .high;
print("priority value: %lld", p.value);

if (p == Priority.high) {
    print("Priority is high!");
}

if (my_pet == .dog) {
    print("It's a dog!");
}
