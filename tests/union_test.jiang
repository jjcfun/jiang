enum Kind {
    circle,
    square,
    rectangle,
}

union(Kind) Shape {
    (Float radius) circle;
    Float square;
    (Float width, Float height) rectangle;
}

Shape c = Shape.circle(10.5);
assert(c == Shape.circle);
assert(c == Shape.circle(_ x1));
assert($c.tag == Kind.circle);
assert(x1 == 10.5);

Shape s = Shape.square(20.0);
assert(s == Shape.square);
assert(s == Shape.square(_ x2));
assert($s.tag == Kind.square);

Shape r = Shape.rectangle(10.0, 20.0);
assert(r == Shape.rectangle);
assert(r == Shape.rectangle(_ x3, _ x4));
assert($r.tag == Kind.rectangle);

print("Union test passed!\n");
