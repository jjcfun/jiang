// 测试结构体功能
struct Point {
    Int x, y;

    init(Int ix, Int iy) {
        x = ix;
        y = iy;
    }

    Int distance(Point p) {
        return (x - p.x) * (x - p.x) + (y - p.y) * (y - p.y);
    }
}

Point p1 = Point(10, 20); // Uses custom init
Point p2 = Point { x: 5, y: 5 }; // Default init

Int dist = p1.distance(p2);
