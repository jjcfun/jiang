// Test basic slice support
(Int)[5] x = {1, 2, 3, 4, 5};

// Array to slice conversion
Int[] y = x[..];
print("y.length = %lld", y.length);

// Sub-slice
Int[] z = x[1..4];
print("z.length = %lld", z.length);
print("z[0] = %lld, z[1] = %lld, z[2] = %lld", z[0], z[1], z[2]);

// Modify through slice
z[0] = 100;
print("x[1] = %lld", x[1]);
