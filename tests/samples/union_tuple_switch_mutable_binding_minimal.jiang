enum Kind {
    c,
    e,
}

union(Kind) MyUnion {
    (Int, Int) c;
    () e;
}

Int choose(MyUnion value) {
    switch (value) {
        .c(_! left, _ right): {
            left = left + right;
            return left;
        }
        .e(): return 0;
        else: return 99;
    }
}

Int main() {
    return choose(.c((40, 2)));
}
