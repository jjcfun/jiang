enum Kind {
    a,
    b,
    e,
}

union(Kind) MyUnion {
    Int a;
    Int b;
    () e;
}

Int choose(MyUnion value) {
    switch (value) {
        .a(_ payload): return payload;
        .b(_ payload): return payload + 1;
        .e(): return 0;
        else: return 99;
    }
}

Int main() {
    return choose(.b(41));
}
