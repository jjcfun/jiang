enum Kind {
    c,
    e,
}

union(Kind) MyUnion {
    (Int, Int) c;
    () e;
}

Int choose(MyUnion value) {
    switch (value) {
        MyUnion.c(_ left, _ right): return left + right;
        MyUnion.e(): return 0;
        else: return 99;
    }
}

Int main() {
    return choose(MyUnion.c((40, 2)));
}
