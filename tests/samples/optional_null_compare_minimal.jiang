Int main() {
    Int? none = null;
    Int? some = 42;
    if (none != null) {
        return 1;
    }
    if (some == null) {
        return 2;
    }
    if (null == some) {
        return 3;
    }
    if (null != none) {
        return 4;
    }
    if (null == none) {
        if (null != some) {
            return 42;
        }
    }
    return 5;
}
