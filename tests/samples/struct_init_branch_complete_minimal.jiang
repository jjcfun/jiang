struct Pair {
    Int left;
    Int right;

    init(Bool flip) {
        if (flip) {
            self.left = 2;
            self.right = 40;
        } else {
            self.left = 40;
            self.right = 2;
        }
        return;
    }
}

Int main() {
    Pair pair = Pair(false);
    return pair.left + pair.right;
}
