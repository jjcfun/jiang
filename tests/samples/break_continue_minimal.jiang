Int loop_break_continue(Int n) {
    Int i = 0;
    Int sum = 0;
    while (i < n) {
        i = i + 1;
        if (i == 2) {
            continue;
        }
        if (i == 5) {
            break;
        }
        sum = sum + i;
    }
    return sum;
}

Int main() {
    return loop_break_continue(10);
}
