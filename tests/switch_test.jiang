enum(Int) Kind {
  a = 0,
  b = 1
}

union(Kind) MyUnion {
  Int a;
  Int b;
}

MyUnion x = MyUnion.a(123);
Int captured = 0;

switch (x) {
  MyUnion.a(_ value): {
    captured = value;
  }

  MyUnion.b(_ v): {
    captured = 999;
  }

  else: {
    captured = -1;
  }
}

assert(captured == 123);

MyUnion y = MyUnion.b(35);
Int seen = 0;

switch (y) {
  MyUnion.a(_ value): {
    captured = value;
  }

  MyUnion.b(_ value): {
    seen = value;
  }

  else: {
    captured = -1;
  }
}

assert(seen == 35);
print("switch_test passed!\n");
