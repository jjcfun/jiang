import std;

UInt8[] text = "hello std";
UInt8[] path_name = std.fs.path_identity("demo.txt");
UInt8[] utils_source = std.fs.read_all("tests/utils.jiang");
std.io.print(text);
print("%lld\n", utils_source.length);
std.fs.describe_path(path_name);
std.debug.assert(1 == 1);
std.debug.assert(std.fs.is_absolute("/tmp/demo"));
std.debug.assert(std.fs.exists("tests/utils.jiang"));
std.debug.assert(utils_source.length > 0);
std.debug.assert(utils_source[0] == 112);

std.io.print("std_import_test passed!");
