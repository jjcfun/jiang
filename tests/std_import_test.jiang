import std;

UInt8[] text = "hello std";
UInt8[] path_name = std.fs.path_identity("demo.txt");
UInt8[] utils_source = std.fs.read_all("tests/utils.jiang");
std.io.println(text);
std.fs.describe_path(path_name);
std.assert.require(1 == 1);
std.assert.require(std.fs.is_absolute("/tmp/demo"));
std.assert.require(std.fs.exists("tests/utils.jiang"));
std.assert.require(utils_source.length > 0);
std.assert.require(utils_source[0] == 112);

if (1 == 1) {
    _ file = std.fs.File.open(7);
    std.assert.require(file.fd == 7);
    std.assert.require(file.is_valid());
    file.close();
}

print("std_import_test passed!\n");
