import std;

UInt8[] text = std.string.identity("hello std");
UInt8[] path_name = std.path.path_identity("demo.txt");
std.io.println(text);
std.path.describe_path(path_name);
std.assert.require(1 == 1);
std.assert.require(std.path.is_absolute("/tmp/demo"));

if (1 == 1) {
    _ file = std.file.File.open(7);
    std.assert.require(file.fd == 7);
    std.assert.require(file.is_valid());
    file.close();
}

print("std_import_test passed!\n");
