// Test struct init semantic check (method call before init complete)
struct Point {
    Int x;
    Int y;
    Int? z; // Optional property

    // Error: Cannot call calculate() before y is initialized
    init(Int ix, Int iy) {
        x = ix;
        calculate(); // Semantic error here
        y = iy;
    }

    Int calculate() {
        return x + y;
    }
}

Point p = Point(10, 20);
