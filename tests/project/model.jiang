enum Kind {
    num,
    pair_sum,
}

public union(Kind) Payload {
    Int num;
    Int pair_sum;
}

public Payload make_pair_sum(Int value) {
    return Payload.pair_sum(value + 8);
}

public Int inspect(Int value) {
    Payload payload = make_pair_sum(value);
    Int seen = 0;

    switch (payload) {
        Payload.num(_ captured): {
            seen = captured;
        }
        Payload.pair_sum(_ captured): {
            seen = captured;
        }
        else: {
            seen = -1;
        }
    }

    return seen;
}
