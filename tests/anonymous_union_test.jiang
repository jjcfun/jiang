union Result {
    Int ok;
    UInt8[] err;
}

Result success = Result.ok(42);
assert(success == Result.ok(_ value));
assert(value == 42);

Result failure = Result.err("oops");
Int first_byte = 0;

switch (failure) {
    Result.ok(_ number): {
        first_byte = -1;
    }
    Result.err(_ message): {
        first_byte = message[0];
    }
    else: {
        first_byte = -2;
    }
}

assert(first_byte == 111);
print("anonymous_union_test passed!\n");
