public Int diagnostic_error_counter = 0;

public () diagnostic_reset() {
    diagnostic_error_counter = 0;
}

public () diagnostic_error(UInt8[] path, Int start, Int end, UInt8[] message) {
    diagnostic_error_counter = diagnostic_error_counter + 1;
    print("%s:%lld-%lld: error: %s\n", path, start, end, message);
}

public Bool diagnostic_has_error() {
    return diagnostic_error_counter != 0;
}

public Int diagnostic_error_count() {
    return diagnostic_error_counter;
}
