Int llvm_name_scratch = 0;

UInt8[] llvm_source = "";
Int llvm_root = 0;

() emit_llvm_reset_context() {
    llvm_function_name_ids = ints.buffer_int_new(64);
    llvm_function_refs = ints.buffer_int_new(64);
    llvm_function_types = ints.buffer_int_new(64);
    llvm_register_named_function(interns.intern_pool_intern("__intrinsic_malloc"), llvm_malloc_ref, llvm_malloc_type);
    llvm_register_named_function(interns.intern_pool_intern("__intrinsic_free"), llvm_free_ref, llvm_free_type);
    llvm_register_named_function(interns.intern_pool_intern("__intrinsic_memmove"), llvm_memmove_ref, llvm_memmove_type);
    llvm_struct_path_ids = ints.buffer_int_new(32);
    llvm_struct_name_ids = ints.buffer_int_new(32);
    llvm_struct_type_refs = ints.buffer_int_new(32);
    llvm_union_path_ids = ints.buffer_int_new(32);
    llvm_union_name_ids = ints.buffer_int_new(32);
    llvm_union_type_refs = ints.buffer_int_new(32);
    llvm_tuple_type_refs = ints.buffer_int_new(64);
    llvm_optional_type_refs = ints.buffer_int_new(64);
    llvm_union_member_owner_path_ids = ints.buffer_int_new(64);
    llvm_union_member_owner_name_ids = ints.buffer_int_new(64);
    llvm_union_member_name_ids = ints.buffer_int_new(64);
    llvm_union_member_field_indices = ints.buffer_int_new(64);
    llvm_field_owner_path_ids = ints.buffer_int_new(64);
    llvm_field_owner_name_ids = ints.buffer_int_new(64);
    llvm_field_name_ids = ints.buffer_int_new(64);
    llvm_field_ordinals = ints.buffer_int_new(64);
    llvm_global_name_ids = ints.buffer_int_new(32);
    llvm_global_refs = ints.buffer_int_new(32);
    llvm_slice_type_refs = ints.buffer_int_new(32);
    ints.buffer_int_set(llvm_slice_type_refs, types.type_store_builtin_uint8_slice, llvm_slice_uint8_type);
    llvm_loop_continue_blocks = ints.buffer_int_new(16);
    llvm_loop_break_blocks = ints.buffer_int_new(16);
    llvm_loop_block_count = 0;
}

Int llvm_current_continue_block() {
    if (llvm_loop_block_count == 0) {
        return 0;
    }
    return ints.buffer_int_get(llvm_loop_continue_blocks, llvm_loop_block_count - 1);
}

Int llvm_current_break_block() {
    if (llvm_loop_block_count == 0) {
        return 0;
    }
    return ints.buffer_int_get(llvm_loop_break_blocks, llvm_loop_block_count - 1);
}

Bool llvm_union_has_explicit_tag_node(Int node_id) {
    Int child = jir.jir_store_node_first_child[node_id];
    if (child == 0) {
        return 0;
    }
    return jir.jir_store_node_kinds[child] != jir.JirNode.ident;
}

Int llvm_union_name_node(Int node_id) {
    Int child = jir.jir_store_node_first_child[node_id];
    if (llvm_union_has_explicit_tag_node(node_id) != 0) {
        return jir.jir_store_node_next_sibling[child];
    }
    return child;
}

Int llvm_union_first_member(Int node_id) {
    return jir.jir_store_node_next_sibling[llvm_union_name_node(node_id)];
}

Int llvm_strip_mutable_type(Int type_id) {
    Int current = type_id;
    while (current > 0) {
        if (current >= types.type_store_count) {
            return current;
        }
        if (types.type_store_kinds[current] != types.TypeKind.mutable) {
            return current;
        }
        current = types.type_store_elem_type_ids[current];
    }
    return current;
}

Bool llvm_is_extern_func(Int func_node) {
    Int flags = jir.jir_store_node_aux[func_node];
    return llvm_decl_has_flag(flags, llvm_decl_flag_extern);
}

Bool llvm_is_generic_decl(Int node_id) {
    return llvm_decl_has_flag(jir.jir_store_node_aux[node_id], llvm_decl_flag_generic);
}

UInt8[] llvm_node_text(Int node_id) {
    return llvm_source[jir.jir_store_node_starts[node_id]..jir.jir_store_node_ends[node_id]];
}

Int llvm_int_lit_value(Int node_id) {
    if (jir.jir_store_node_starts[node_id] == jir.jir_store_node_ends[node_id]) {
        return jir.jir_store_node_aux[node_id];
    }
    Int value = 0;
    UInt8[] text = llvm_node_text(node_id);
    Int i = 0;
    while (i < text.length) {
        value = value * 10 + (text[i] - 48);
        i = i + 1;
    }
    return value;
}

UInt8[] llvm_symbol_text(Int symbol_id) {
    if (symbol_id == 0) {
        return "";
    }
    return interns.intern_pool_value(symbols.symbol_store_name_ids[symbol_id]);
}

UInt8[] llvm_loop_var_text(Int stmt_node, Int name_node) {
    Int symbol_id = jir.jir_store_node_symbol_ids[stmt_node];
    if (symbol_id != 0) {
        return llvm_symbol_text(symbol_id);
    }
    return llvm_node_text(name_node);
}

UInt8 llvm_string_lit_decoded_byte(Int index, Int end_pos) {
    if (llvm_source[index] != 92) {
        return llvm_source[index];
    }
    if (index + 1 >= end_pos) {
        return 92;
    }
    UInt8 escaped = llvm_source[index + 1];
    if (escaped == 110) {
        return 10;
    }
    if (escaped == 114) {
        return 13;
    }
    if (escaped == 116) {
        return 9;
    }
    if (escaped == 48) {
        return 0;
    }
    if (escaped == 34) {
        return 34;
    }
    if (escaped == 39) {
        return 39;
    }
    if (escaped == 92) {
        return 92;
    }
    return escaped;
}

Int llvm_string_lit_next_index(Int index, Int end_pos) {
    if (llvm_source[index] == 92) {
        if (index + 1 < end_pos) {
            return index + 2;
        }
    }
    return index + 1;
}

UInt8[] llvm_string_lit_value(Int node_id) {
    bytes.buffer_bytes_clear(llvm_string_scratch);
    Int i = jir.jir_store_node_starts[node_id] + 1;
    Int end_pos = jir.jir_store_node_ends[node_id] - 1;
    while (i < end_pos) {
        bytes.buffer_bytes_push(llvm_string_scratch, llvm_string_lit_decoded_byte(i, end_pos));
        i = llvm_string_lit_next_index(i, end_pos);
    }
    return bytes.buffer_bytes_slice(llvm_string_scratch);
}

Bool llvm_member_name_is(Int node_id, UInt8[] expected) {
    UInt8[] name = llvm_node_text(node_id);
    if (name.length != expected.length) {
        return 0;
    }
    Int i = 0;
    while (i < expected.length) {
        if (name[i] != expected[i]) {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

Bool llvm_node_text_is(Int node_id, UInt8[] expected) {
    UInt8[] name = llvm_node_text(node_id);
    if (name.length != expected.length) {
        return 0;
    }
    Int i = 0;
    while (i < expected.length) {
        if (name[i] != expected[i]) {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

Bool llvm_is_main_name(Int node_id) {
    UInt8[] name = llvm_node_text(node_id);
    if (name.length != 4) {
        return 0;
    }
    if (name[0] != 109) {
        return 0;
    }
    if (name[1] != 97) {
        return 0;
    }
    if (name[2] != 105) {
        return 0;
    }
    return name[3] == 110;
}

Int llvm_type_path_id(Int type_id) {
    if (type_id <= types.type_store_builtin_uint8_slice) {
        return 0;
    }
    Int module_id = types.type_store_module_ids[type_id];
    if (module_id <= 0) {
        return 0;
    }
    return interns.intern_pool_intern(module_loader.module_loader_module_path(module_id));
}

Int llvm_type_owner_symbol(Int type_id) {
    Int symbol_id = 1;
    while (symbol_id < symbols.symbol_store_count) {
        if (symbols.symbol_store_parent_ids[symbol_id] == 0) {
            Int kind = symbols.symbol_store_kinds[symbol_id];
            if (kind == symbols.SymbolKind.type_name) {
                if (symbols.symbol_store_type_ids[symbol_id] == type_id) {
                    return symbol_id;
                }
            }
            if (kind == symbols.SymbolKind.enum_name) {
                if (symbols.symbol_store_type_ids[symbol_id] == type_id) {
                    return symbol_id;
                }
            }
        }
        symbol_id = symbol_id + 1;
    }
    return 0;
}

Int llvm_type_ref_from_type_id(Int type_id, Bool is_main) {
    is_main = is_main;
    type_id = llvm_strip_mutable_type(type_id);
    if (type_id == types.type_store_builtin_void) {
        return llvm_void_type;
    }
    if (type_id == types.type_store_builtin_bool) {
        return llvm_i1_type;
    }
    if (type_id == types.type_store_builtin_uint8) {
        return llvm_i8_type;
    }
    if (type_id == types.type_store_builtin_uint8_slice) {
        return llvm_slice_uint8_type;
    }
    if (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.array) {
            return llvm.array_type(
                llvm_type_ref_from_type_id(types.type_store_elem_type_ids[type_id], 0),
                types.type_store_array_lengths[type_id]
            );
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.enum_type) {
            return llvm_i64_type;
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.pointer) {
            return llvm.type_ptr(
                llvm_type_ref_from_type_id(types.type_store_elem_type_ids[type_id], 0)
            );
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.struct_type) {
            Int struct_ref = llvm_find_struct_type_ref(llvm_type_path_id(type_id), types.type_store_name_ids[type_id]);
            if (struct_ref == 0) {
                diagnostic.diagnostic_error(llvm_source, 0, 0, "llvm backend missing struct type");
                return llvm_i64_type;
            }
            return struct_ref;
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.union_type) {
            Int union_ref = llvm_find_union_type_ref(llvm_type_path_id(type_id), types.type_store_name_ids[type_id]);
            if (union_ref == 0) {
                diagnostic.diagnostic_error(llvm_source, 0, 0, "llvm backend missing union type");
                return llvm_i64_type;
            }
            return union_ref;
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.tuple) {
            Int tuple_ref = llvm_find_tuple_type_ref(type_id);
            if (tuple_ref == 0) {
                diagnostic.diagnostic_error(llvm_source, 0, 0, "llvm backend missing tuple type");
                return llvm_i64_type;
            }
            return tuple_ref;
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.optional) {
            Int optional_ref = llvm_optional_type_ref(type_id);
            if (optional_ref == 0) {
                diagnostic.diagnostic_error(llvm_source, 0, 0, "llvm backend missing optional type");
                return llvm_i64_type;
            }
            return optional_ref;
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.slice) {
            Int slice_ref = llvm_slice_type_ref(type_id);
            if (slice_ref != 0) {
                return slice_ref;
            }
        }
    }
    return llvm_i64_type;
}

Int llvm_type_ref_from_type_node(Int type_node, Bool is_main) {
    if (is_main) {
        return llvm_i32_type;
    }
    return llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[type_node], 0);
}

Int llvm_find_function_index(Int name_id) {
    Int i = 0;
    while (i < ints.buffer_int_length(llvm_function_name_ids)) {
        if (ints.buffer_int_get(llvm_function_name_ids, i) == name_id) {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

Int llvm_find_function_ref_by_name_id(Int name_id) {
    Int index = llvm_find_function_index(name_id);
    if (index < 0) {
        return 0;
    }
    return ints.buffer_int_get(llvm_function_refs, index);
}

Int llvm_find_function_type_by_name_id(Int name_id) {
    Int index = llvm_find_function_index(name_id);
    if (index < 0) {
        return 0;
    }
    return ints.buffer_int_get(llvm_function_types, index);
}

() llvm_register_named_function(Int name_id, Int fn_ref, Int fn_type) {
    ints.buffer_int_push(llvm_function_name_ids, name_id);
    ints.buffer_int_push(llvm_function_refs, fn_ref);
    ints.buffer_int_push(llvm_function_types, fn_type);
}

Int llvm_find_struct_index(Int path_id, Int name_id) {
    Int i = 0;
    while (i < ints.buffer_int_length(llvm_struct_path_ids)) {
        if (ints.buffer_int_get(llvm_struct_path_ids, i) == path_id) {
            if (ints.buffer_int_get(llvm_struct_name_ids, i) == name_id) {
                return i;
            }
        }
        i = i + 1;
    }
    return -1;
}

Int llvm_find_struct_type_ref(Int path_id, Int name_id) {
    Int index = llvm_find_struct_index(path_id, name_id);
    if (index < 0) {
        return 0;
    }
    return ints.buffer_int_get(llvm_struct_type_refs, index);
}

Int llvm_find_union_index(Int path_id, Int name_id) {
    Int i = 0;
    while (i < ints.buffer_int_length(llvm_union_path_ids)) {
        if (ints.buffer_int_get(llvm_union_path_ids, i) == path_id) {
            if (ints.buffer_int_get(llvm_union_name_ids, i) == name_id) {
                return i;
            }
        }
        i = i + 1;
    }
    return -1;
}

Int llvm_find_union_type_ref(Int path_id, Int name_id) {
    Int index = llvm_find_union_index(path_id, name_id);
    if (index < 0) {
        return 0;
    }
    return ints.buffer_int_get(llvm_union_type_refs, index);
}

Int llvm_find_union_member_field_index(Int owner_path_id, Int owner_name_id, Int member_name_id) {
    Int i = 0;
    while (i < ints.buffer_int_length(llvm_union_member_owner_path_ids)) {
        if (ints.buffer_int_get(llvm_union_member_owner_path_ids, i) == owner_path_id) {
            if (ints.buffer_int_get(llvm_union_member_owner_name_ids, i) == owner_name_id) {
                if (ints.buffer_int_get(llvm_union_member_name_ids, i) == member_name_id) {
                    return ints.buffer_int_get(llvm_union_member_field_indices, i);
                }
            }
        }
        i = i + 1;
    }
    return -1;
}

Int llvm_find_field_index(Int owner_path_id, Int owner_name_id, Int field_name_id) {
    Int i = 0;
    while (i < ints.buffer_int_length(llvm_field_owner_path_ids)) {
        if (ints.buffer_int_get(llvm_field_owner_path_ids, i) == owner_path_id) {
            if (ints.buffer_int_get(llvm_field_owner_name_ids, i) == owner_name_id) {
                if (ints.buffer_int_get(llvm_field_name_ids, i) == field_name_id) {
                    return ints.buffer_int_get(llvm_field_ordinals, i);
                }
            }
        }
        i = i + 1;
    }
    return -1;
}

Int llvm_field_owner_path_id(Int symbol_id) {
    Int owner_symbol = symbols.symbol_store_parent_ids[symbol_id];
    if (owner_symbol == 0) {
        return 0;
    }
    Int module_id = symbols.symbol_store_module_ids[owner_symbol];
    if (module_id <= 0) {
        return 0;
    }
    return interns.intern_pool_intern(module_loader.module_loader_module_path(module_id));
}

Int llvm_field_index(Int symbol_id) {
    Int owner_symbol = symbols.symbol_store_parent_ids[symbol_id];
    if (owner_symbol == 0) {
        return -1;
    }
    return llvm_find_field_index(
        llvm_field_owner_path_id(symbol_id),
        symbols.symbol_store_name_ids[owner_symbol],
        symbols.symbol_store_name_ids[symbol_id]
    );
}

Int llvm_union_member_field_index(Int symbol_id) {
    if (symbol_id == 0) {
        return -1;
    }
    Int owner_symbol = symbols.symbol_store_parent_ids[symbol_id];
    if (owner_symbol == 0) {
        return -1;
    }
    Int owner_type = symbols.symbol_store_type_ids[owner_symbol];
    if (owner_type <= 0) {
        return -1;
    }
    return llvm_find_union_member_field_index(
        llvm_type_path_id(owner_type),
        types.type_store_name_ids[owner_type],
        symbols.symbol_store_name_ids[symbol_id]
    );
}

Int llvm_union_pattern_label(Int pattern_node) {
    return jir.jir_store_node_first_child[pattern_node];
}

Int llvm_union_pattern_binding(Int pattern_node) {
    Int label = llvm_union_pattern_label(pattern_node);
    if (label == 0) {
        return 0;
    }
    return jir.jir_store_node_next_sibling[label];
}

Int llvm_union_pattern_binding_count(Int pattern_node) {
    Int bind = llvm_union_pattern_binding(pattern_node);
    Int count = 0;
    while (bind != 0) {
        count = count + 1;
        bind = jir.jir_store_node_next_sibling[bind];
    }
    return count;
}

Int llvm_union_pattern_binding_item(Int pattern_node, Int index) {
    Int bind = llvm_union_pattern_binding(pattern_node);
    Int i = 0;
    while (bind != 0) {
        if (i == index) {
            return bind;
        }
        bind = jir.jir_store_node_next_sibling[bind];
        i = i + 1;
    }
    return 0;
}

() llvm_register_struct_type(Int struct_node, UInt8[] path) {
    Int path_id = interns.intern_pool_intern(path);
    Int type_id = jir.jir_store_node_type_ids[struct_node];
    Int name_id = types.type_store_name_ids[type_id];
    if (llvm_find_struct_type_ref(path_id, name_id) != 0) {
        return;
    }
    Int name_node = jir.jir_store_node_first_child[struct_node];
    Int struct_type = llvm.type_struct_named(llvm_context, llvm_node_text(name_node));
    ints.buffer_int_push(llvm_struct_path_ids, path_id);
    ints.buffer_int_push(llvm_struct_name_ids, name_id);
    ints.buffer_int_push(llvm_struct_type_refs, struct_type);
}

() llvm_register_union_type(Int union_node, UInt8[] path) {
    Int path_id = interns.intern_pool_intern(path);
    Int type_id = jir.jir_store_node_type_ids[union_node];
    Int name_id = types.type_store_name_ids[type_id];
    if (llvm_find_union_type_ref(path_id, name_id) != 0) {
        return;
    }
    Int name_node = llvm_union_name_node(union_node);
    Int union_type = llvm.type_struct_named(llvm_context, llvm_node_text(name_node));
    ints.buffer_int_push(llvm_union_path_ids, path_id);
    ints.buffer_int_push(llvm_union_name_ids, name_id);
    ints.buffer_int_push(llvm_union_type_refs, union_type);
}

() llvm_define_struct_body(Int struct_node, UInt8[] path) {
    Int path_id = interns.intern_pool_intern(path);
    Int type_id = jir.jir_store_node_type_ids[struct_node];
    Int name_id = types.type_store_name_ids[type_id];
    Int struct_type = llvm_find_struct_type_ref(path_id, name_id);
    if (struct_type == 0) {
        diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[struct_node], jir.jir_store_node_ends[struct_node], "llvm backend missing registered struct type");
        return;
    }
    Int field_types = ints.buffer_int_new(8);
    Int ordinal = 0;
    Int child = jir.jir_store_node_first_child[struct_node];
    child = jir.jir_store_node_next_sibling[child];
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] == jir.JirNode.field_decl) {
            Int type_node = jir.jir_store_node_first_child[child];
            ints.buffer_int_push(field_types, llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[type_node], 0));
            ints.buffer_int_push(llvm_field_owner_path_ids, path_id);
            ints.buffer_int_push(llvm_field_owner_name_ids, name_id);
            ints.buffer_int_push(llvm_field_name_ids, symbols.symbol_store_name_ids[jir.jir_store_node_symbol_ids[child]]);
            ints.buffer_int_push(llvm_field_ordinals, ordinal);
            ordinal = ordinal + 1;
        }
        child = jir.jir_store_node_next_sibling[child];
    }
    llvm.type_struct_set_body(struct_type, ints.buffer_int_slice(field_types));
}

() llvm_define_union_body(Int union_node, UInt8[] path) {
    Int path_id = interns.intern_pool_intern(path);
    Int type_id = jir.jir_store_node_type_ids[union_node];
    Int name_id = types.type_store_name_ids[type_id];
    Int union_type = llvm_find_union_type_ref(path_id, name_id);
    if (union_type == 0) {
        diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[union_node], jir.jir_store_node_ends[union_node], "llvm backend missing registered union type");
        return;
    }
    Int field_types = ints.buffer_int_new(8);
    ints.buffer_int_push(field_types, llvm_type_ref_from_type_id(types.type_store_elem_type_ids[type_id], 0));
    Int name_node = llvm_union_name_node(union_node);
    Int field = llvm_union_first_member(union_node);
    Int field_index = 1;
    while (field != 0) {
        Int field_type_node = jir.jir_store_node_first_child[field];
        Int payload_type = jir.jir_store_node_type_ids[field_type_node];
        if (payload_type == types.type_store_builtin_void) {
            ints.buffer_int_push(field_types, llvm_i8_type);
        } else {
            ints.buffer_int_push(field_types, llvm_type_ref_from_type_id(payload_type, 0));
        }
        if (jir.jir_store_node_symbol_ids[field] != 0) {
            ints.buffer_int_push(llvm_union_member_owner_path_ids, path_id);
            ints.buffer_int_push(llvm_union_member_owner_name_ids, name_id);
            ints.buffer_int_push(llvm_union_member_name_ids, symbols.symbol_store_name_ids[jir.jir_store_node_symbol_ids[field]]);
            ints.buffer_int_push(llvm_union_member_field_indices, field_index);
        }
        field_index = field_index + 1;
        field = jir.jir_store_node_next_sibling[field];
    }
    llvm.type_struct_set_body(union_type, ints.buffer_int_slice(field_types));
}

() llvm_register_tuple_types() {
    Int type_id = 1;
    while (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.tuple) {
            if (llvm_find_tuple_type_ref(type_id) == 0) {
                ints.buffer_int_set(llvm_tuple_type_refs, type_id, llvm.type_struct_named(llvm_context, llvm_tuple_type_name(type_id)));
            }
        }
        type_id = type_id + 1;
    }
}

() llvm_register_slice_types() {
    Int type_id = 1;
    while (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.slice) {
            if (llvm_slice_type_ref(type_id) == 0) {
                if (types.type_store_elem_type_ids[type_id] == types.type_store_builtin_int) {
                    ints.buffer_int_set(llvm_slice_type_refs, type_id, llvm_slice_int64_type);
                } else {
                    ints.buffer_int_set(llvm_slice_type_refs, type_id, llvm.type_struct_named(llvm_context, llvm_slice_type_name(type_id)));
                }
            }
        }
        type_id = type_id + 1;
    }
}

() llvm_register_optional_types() {
    Int type_id = 1;
    while (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.optional) {
            if (llvm_optional_type_ref(type_id) == 0) {
                ints.buffer_int_set(llvm_optional_type_refs, type_id, llvm.type_struct_named(llvm_context, llvm_optional_type_name(type_id)));
            }
        }
        type_id = type_id + 1;
    }
}

() llvm_define_slice_types() {
    Int type_id = 1;
    while (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.slice) {
            if (types.type_store_elem_type_ids[type_id] != types.type_store_builtin_uint8) {
                if (types.type_store_elem_type_ids[type_id] != types.type_store_builtin_int) {
                    Int slice_ref = llvm_slice_type_ref(type_id);
                    if (slice_ref != 0) {
                        Int field_types = ints.buffer_int_new(2);
                        ints.buffer_int_push(field_types, llvm.type_ptr(llvm_type_ref_from_type_id(types.type_store_elem_type_ids[type_id], 0)));
                        ints.buffer_int_push(field_types, llvm_i64_type);
                        llvm.type_struct_set_body(slice_ref, ints.buffer_int_slice(field_types));
                    }
                }
            }
        }
        type_id = type_id + 1;
    }
}

() llvm_define_tuple_types() {
    Int type_id = 1;
    while (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.tuple) {
            Int tuple_ref = llvm_find_tuple_type_ref(type_id);
            if (tuple_ref != 0) {
                Int field_types = ints.buffer_int_new(4);
                Int index = 0;
                while (index < types.type_store_tuple_count(type_id)) {
                    ints.buffer_int_push(field_types, llvm_type_ref_from_type_id(types.type_store_tuple_item_type(type_id, index), 0));
                    index = index + 1;
                }
                llvm.type_struct_set_body(tuple_ref, ints.buffer_int_slice(field_types));
            }
        }
        type_id = type_id + 1;
    }
}

() llvm_define_optional_types() {
    Int type_id = 1;
    while (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.optional) {
            Int optional_ref = llvm_optional_type_ref(type_id);
            if (optional_ref != 0) {
                Int field_types = ints.buffer_int_new(2);
                ints.buffer_int_push(field_types, llvm_i1_type);
                ints.buffer_int_push(field_types, llvm_type_ref_from_type_id(types.type_store_elem_type_ids[type_id], 0));
                llvm.type_struct_set_body(optional_ref, ints.buffer_int_slice(field_types));
            }
        }
        type_id = type_id + 1;
    }
}

Int llvm_heap_alloc_size(Int type_id) {
    type_id = llvm_strip_mutable_type(type_id);
    if (type_id == types.type_store_builtin_void) {
        return 1;
    }
    if (type_id == types.type_store_builtin_bool) {
        return 8;
    }
    if (type_id == types.type_store_builtin_uint8) {
        return 8;
    }
    if (type_id == types.type_store_builtin_int) {
        return 8;
    }
    if (type_id <= 0) {
        return 8;
    }
    if (type_id >= types.type_store_count) {
        return 8;
    }
    if (types.type_store_kinds[type_id] == types.TypeKind.pointer) {
        return 8;
    }
    if (types.type_store_kinds[type_id] == types.TypeKind.slice) {
        return 16;
    }
    if (types.type_store_kinds[type_id] == types.TypeKind.optional) {
        return 8 + llvm_heap_alloc_size(types.type_store_elem_type_ids[type_id]);
    }
    if (types.type_store_kinds[type_id] == types.TypeKind.array) {
        return types.type_store_array_lengths[type_id] * llvm_heap_alloc_size(types.type_store_elem_type_ids[type_id]);
    }
    if (types.type_store_kinds[type_id] == types.TypeKind.tuple) {
        Int total = 0;
        Int index = 0;
        while (index < types.type_store_tuple_count(type_id)) {
            total = total + llvm_heap_alloc_size(types.type_store_tuple_item_type(type_id, index));
            index = index + 1;
        }
        return total;
    }
    if (types.type_store_kinds[type_id] == types.TypeKind.struct_type) {
        Int total = 0;
        Int owner_symbol = llvm_type_owner_symbol(type_id);
        Int symbol_id = 1;
        while (symbol_id < symbols.symbol_store_count) {
            if (symbols.symbol_store_parent_ids[symbol_id] != 0) {
                if (symbols.symbol_store_parent_ids[symbol_id] == owner_symbol) {
                    if (symbols.symbol_store_kinds[symbol_id] == symbols.SymbolKind.field) {
                        total = total + llvm_heap_alloc_size(symbols.symbol_store_type_ids[symbol_id]);
                    }
                }
            }
            symbol_id = symbol_id + 1;
        }
        if (total == 0) {
            return 8;
        }
        return total;
    }
    if (types.type_store_kinds[type_id] == types.TypeKind.union_type) {
        Int total = 8;
        Int owner_symbol = llvm_type_owner_symbol(type_id);
        Int symbol_id = 1;
        while (symbol_id < symbols.symbol_store_count) {
            if (symbols.symbol_store_parent_ids[symbol_id] != 0) {
                if (symbols.symbol_store_parent_ids[symbol_id] == owner_symbol) {
                    if (symbols.symbol_store_kinds[symbol_id] == symbols.SymbolKind.union_member) {
                        Int payload_size = llvm_heap_alloc_size(symbols.symbol_store_type_ids[symbol_id]);
                        if (payload_size > total) {
                            total = payload_size;
                        }
                    }
                }
            }
            symbol_id = symbol_id + 1;
        }
        return 8 + total;
    }
    return 8;
}

Int llvm_symbol_name_id(Int symbol_id) {
    if (symbol_id == 0) {
        return 0;
    }
    if (llvm_symbol_is_struct_static_func(symbol_id) != 0) {
        return llvm_struct_method_name_id(symbol_id);
    }
    if (llvm_symbol_is_struct_instance_func(symbol_id) != 0) {
        return llvm_struct_method_name_id(symbol_id);
    }
    return symbols.symbol_store_name_ids[symbol_id];
}

Int llvm_find_global_index(Int name_id) {
    Int i = 0;
    while (i < ints.buffer_int_length(llvm_global_name_ids)) {
        if (ints.buffer_int_get(llvm_global_name_ids, i) == name_id) {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

Int llvm_find_global_ref_by_name_id(Int name_id) {
    Int index = llvm_find_global_index(name_id);
    if (index < 0) {
        return 0;
    }
    return ints.buffer_int_get(llvm_global_refs, index);
}

Int llvm_find_value(Int symbol_id) {
    if (symbol_id == 0) {
        return 0;
    }
    if (symbol_id >= ints.buffer_int_length(llvm_current_values)) {
        return llvm_find_global_ref_by_name_id(llvm_symbol_name_id(symbol_id));
    }
    Int value = ints.buffer_int_get(llvm_current_values, symbol_id);
    if (value != 0) {
        return value;
    }
    return llvm_find_global_ref_by_name_id(llvm_symbol_name_id(symbol_id));
}

Int llvm_lvalue_ptr(Int node_id) {
    if (jir.jir_store_node_kinds[node_id] == jir.JirNode.ident) {
        Int symbol_id = jir.jir_store_node_symbol_ids[node_id];
        if (symbol_id == 0) {
            if (llvm_current_init_self_symbol != 0) {
                if (llvm_node_text_is(node_id, "self")) {
                    symbol_id = llvm_current_init_self_symbol;
                }
            }
        }
        return llvm_find_value(symbol_id);
    }
    if (jir.jir_store_node_kinds[node_id] == jir.JirNode.member_expr) {
        Int field_symbol = jir.jir_store_node_symbol_ids[node_id];
        if (field_symbol != 0) {
            if (symbols.symbol_store_kinds[field_symbol] == symbols.SymbolKind.field) {
                Int base = jir.jir_store_node_first_child[node_id];
                Int field_index = llvm_field_index(field_symbol);
                if (field_index < 0) {
                    return 0;
                }
                Int base_type = llvm_strip_mutable_type(jir.jir_store_node_type_ids[base]);
                if (base_type < types.type_store_count) {
                    if (types.type_store_kinds[base_type] == types.TypeKind.pointer) {
                        Int base_value = llvm_emit_expr(base);
                        Int gep_indices = ints.buffer_int_new(2);
                        ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, 0));
                        ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, field_index));
                        return llvm.build_gep(
                            llvm_builder,
                            llvm_type_ref_from_type_id(types.type_store_elem_type_ids[base_type], 0),
                            base_value,
                            ints.buffer_int_slice(gep_indices),
                            "field.ptr"
                        );
                    }
                }
                Int base_ptr = llvm_lvalue_ptr(base);
                if (base_ptr != 0) {
                    Int gep_indices = ints.buffer_int_new(2);
                    ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, 0));
                    ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, field_index));
                    return llvm.build_gep(
                        llvm_builder,
                        llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[base], 0),
                        base_ptr,
                        ints.buffer_int_slice(gep_indices),
                        "field.ptr"
                    );
                }
            }
            if (symbols.symbol_store_kinds[field_symbol] == symbols.SymbolKind.union_member) {
                Int base = jir.jir_store_node_first_child[node_id];
                Int field_index = llvm_union_member_field_index(field_symbol);
                if (field_index < 0) {
                    return 0;
                }
                Int base_type = llvm_strip_mutable_type(jir.jir_store_node_type_ids[base]);
                if (base_type < types.type_store_count) {
                    if (types.type_store_kinds[base_type] == types.TypeKind.pointer) {
                        Int base_value = llvm_emit_expr(base);
                        Int gep_indices = ints.buffer_int_new(2);
                        ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, 0));
                        ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, field_index));
                        return llvm.build_gep(
                            llvm_builder,
                            llvm_type_ref_from_type_id(types.type_store_elem_type_ids[base_type], 0),
                            base_value,
                            ints.buffer_int_slice(gep_indices),
                            "union.member.ptr"
                        );
                    }
                }
                Int base_ptr = llvm_lvalue_ptr(base);
                if (base_ptr != 0) {
                    Int gep_indices = ints.buffer_int_new(2);
                    ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, 0));
                    ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, field_index));
                    return llvm.build_gep(
                        llvm_builder,
                        llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[base], 0),
                        base_ptr,
                        ints.buffer_int_slice(gep_indices),
                        "union.member.ptr"
                    );
                }
            }
        }
    }
    if (jir.jir_store_node_kinds[node_id] == jir.JirNode.index_expr) {
        Int base = jir.jir_store_node_first_child[node_id];
        Int index_node = jir.jir_store_node_next_sibling[base];
        Int base_type = jir.jir_store_node_type_ids[base];
        if (types.type_store_kinds[base_type] == types.TypeKind.slice) {
            Int elem_type = types.type_store_elem_type_ids[base_type];
            Int base_value = llvm_emit_expr(base);
            Int ptr_value = llvm.build_extract_value(llvm_builder, base_value, 0, "slice.ptr");
            Int gep_indices = ints.buffer_int_new(1);
            ints.buffer_int_push(gep_indices, llvm_emit_expr(index_node));
            return llvm.build_gep(
                llvm_builder,
                llvm_type_ref_from_type_id(elem_type, 0),
                ptr_value,
                ints.buffer_int_slice(gep_indices),
                "slice.index.ptr"
            );
        }
        if (types.type_store_kinds[base_type] == types.TypeKind.array) {
            Int base_ptr = llvm_lvalue_ptr(base);
            if (base_ptr != 0) {
                Int gep_indices = ints.buffer_int_new(2);
                ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, 0));
                ints.buffer_int_push(gep_indices, llvm_emit_expr(index_node));
                return llvm.build_gep(
                    llvm_builder,
                    llvm_type_ref_from_type_id(base_type, 0),
                    base_ptr,
                    ints.buffer_int_slice(gep_indices),
                    "array.index.ptr"
                );
            }
        }
    }
    if (jir.jir_store_node_kinds[node_id] == jir.JirNode.array_to_slice_expr) {
        Int base = jir.jir_store_node_first_child[node_id];
        Int base_ptr = llvm_lvalue_ptr(base);
        Int base_type = jir.jir_store_node_type_ids[base];
        if (base_ptr == 0) {
            return 0;
        }
        Int gep_indices = ints.buffer_int_new(2);
        ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, 0));
        ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, 0));
        return llvm.build_gep(
            llvm_builder,
            llvm_type_ref_from_type_id(base_type, 0),
            base_ptr,
            ints.buffer_int_slice(gep_indices),
            "array.slice.ptr"
        );
    }
    if (jir.jir_store_node_kinds[node_id] == jir.JirNode.unary_expr) {
        if (jir.jir_store_node_aux[node_id] == jir.JirUnaryOp.deref) {
            return llvm_emit_expr(jir.jir_store_node_first_child[node_id]);
        }
    }
    return 0;
}

() llvm_set_value(Int symbol_id, Int value) {
    if (symbol_id == 0) {
        return;
    }
    ints.buffer_int_set(llvm_current_values, symbol_id, value);
}

Int llvm_const_expr(Int node_id, Int expected_type) {
    Int kind = jir.jir_store_node_kinds[node_id];
    expected_type = llvm_strip_mutable_type(expected_type);
    if (kind == jir.JirNode.int_lit) {
        Int value = llvm_int_lit_value(node_id);
        if (expected_type == types.type_store_builtin_uint8) {
            return llvm.const_i8(llvm_context, value);
        }
        if (expected_type < types.type_store_count) {
            if (types.type_store_kinds[expected_type] == types.TypeKind.pointer) {
                if (value == 0) {
                    return llvm.const_null(llvm_type_ref_from_type_id(expected_type, 0));
                }
            }
        }
        return llvm.const_i64(llvm_context, value);
    }
    if (kind == jir.JirNode.bool_lit) {
        return llvm.const_i1(llvm_context, jir.jir_store_node_aux[node_id] != 0);
    }
    if (kind == jir.JirNode.null_lit) {
        if (expected_type < types.type_store_count) {
            if (types.type_store_kinds[expected_type] == types.TypeKind.optional) {
                Int values = ints.buffer_int_new(2);
                ints.buffer_int_push(values, llvm.const_i1(llvm_context, 0));
                ints.buffer_int_push(values, llvm.const_undef(llvm_type_ref_from_type_id(types.type_store_elem_type_ids[expected_type], 0)));
                return llvm.const_named_struct(llvm_type_ref_from_type_id(expected_type, 0), ints.buffer_int_slice(values));
            }
        }
        return llvm.const_i64(llvm_context, 0);
    }
    if (kind == jir.JirNode.string_lit) {
        if (expected_type == types.type_store_builtin_uint8_slice) {
            Int length = jir.jir_store_node_ends[node_id] - jir.jir_store_node_starts[node_id] - 2;
            if (length == 0) {
                Int values = ints.buffer_int_new(2);
                ints.buffer_int_push(values, llvm.const_null(llvm_i8_ptr_type));
                ints.buffer_int_push(values, llvm.const_i64(llvm_context, 0));
                return llvm.const_named_struct(llvm_slice_uint8_type, ints.buffer_int_slice(values));
            }
        }
    }
    if (kind == jir.JirNode.tuple_lit) {
        if (types.type_store_kinds[expected_type] == types.TypeKind.tuple) {
            Int values = ints.buffer_int_new(4);
            Int child = jir.jir_store_node_first_child[node_id];
            Int index = 0;
            while (child != 0) {
                Int item_type = types.type_store_tuple_item_type(expected_type, index);
                ints.buffer_int_push(values, llvm_const_expr(child, item_type));
                child = jir.jir_store_node_next_sibling[child];
                index = index + 1;
            }
            return llvm.const_named_struct(llvm_type_ref_from_type_id(expected_type, 0), ints.buffer_int_slice(values));
        }
    }
    if (kind == jir.JirNode.optional_wrap_expr) {
        if (expected_type < types.type_store_count) {
            if (types.type_store_kinds[expected_type] == types.TypeKind.optional) {
                Int child = jir.jir_store_node_first_child[node_id];
                Int values = ints.buffer_int_new(2);
                ints.buffer_int_push(values, llvm.const_i1(llvm_context, 1));
                ints.buffer_int_push(values, llvm_const_expr(child, types.type_store_elem_type_ids[expected_type]));
                return llvm.const_named_struct(llvm_type_ref_from_type_id(expected_type, 0), ints.buffer_int_slice(values));
            }
        }
    }
    diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[node_id], jir.jir_store_node_ends[node_id], "llvm backend unsupported global initializer");
    return 0;
}

() llvm_declare_global(Int global_node) {
    Int type_node = jir.jir_store_node_first_child[global_node];
    Int name_node = jir.jir_store_node_next_sibling[type_node];
    Int symbol_id = jir.jir_store_node_symbol_ids[global_node];
    Int name_id = llvm_symbol_name_id(symbol_id);
    if (llvm_find_global_ref_by_name_id(name_id) != 0) {
        return;
    }
    Int global_ref = llvm.add_global(
        llvm_module,
        llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[type_node], 0),
        llvm_node_text(name_node)
    );
    ints.buffer_int_push(llvm_global_name_ids, name_id);
    ints.buffer_int_push(llvm_global_refs, global_ref);
}

() llvm_define_global(Int global_node) {
    Int type_node = jir.jir_store_node_first_child[global_node];
    Int name_node = jir.jir_store_node_next_sibling[type_node];
    Int init_expr = jir.jir_store_node_next_sibling[name_node];
    Int symbol_id = jir.jir_store_node_symbol_ids[global_node];
    Int global_ref = llvm_find_global_ref_by_name_id(llvm_symbol_name_id(symbol_id));
    if (global_ref == 0) {
        diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[global_node], jir.jir_store_node_ends[global_node], "llvm backend missing global");
        return;
    }
    Int init_value = llvm_const_expr(init_expr, jir.jir_store_node_type_ids[type_node]);
    if (init_value == 0) {
        return;
    }
    llvm.set_initializer(global_ref, init_value);
}

() llvm_require_scalar_node(Int node_id, UInt8[] message) {
    Int type_id = jir.jir_store_node_type_ids[node_id];
    if (type_id == types.type_store_builtin_int) {
        return;
    }
    if (type_id == types.type_store_builtin_bool) {
        return;
    }
    if (type_id == types.type_store_builtin_uint8) {
        return;
    }
    if (type_id == types.type_store_builtin_void) {
        return;
    }
    diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[node_id], jir.jir_store_node_ends[node_id], message);
}

Int llvm_enum_member_value(Int symbol_id) {
    if (symbol_id != 0) {
        if (symbols.symbol_store_kinds[symbol_id] == symbols.SymbolKind.enum_member) {
            return symbols.symbol_store_aux[symbol_id];
        }
    }
    Int node_id = 1;
    while (node_id < jir.jir_store_node_count) {
        if (jir.jir_store_node_kinds[node_id] == jir.JirNode.enum_member) {
            if (jir.jir_store_node_symbol_ids[node_id] == symbol_id) {
                return jir.jir_store_node_aux[node_id];
            }
        }
        node_id = node_id + 1;
    }
    return 0;
}

Int llvm_uint8_array_from_string(Int array_type, Int string_node) {
    UInt8[] string_value = llvm_string_lit_value(string_node);
    Int aggregate = llvm.const_undef(llvm_type_ref_from_type_id(array_type, 0));
    Int i = 0;
    while (i < string_value.length) {
        aggregate = llvm.build_insert_value(
            llvm_builder,
            aggregate,
            llvm.const_i8(llvm_context, string_value[i]),
            i,
            "arraystr"
        );
        i = i + 1;
    }
    return aggregate;
}

Int llvm_update_lvalue(Int node_id, Int value) {
    Int kind = jir.jir_store_node_kinds[node_id];
    Int ptr_value = llvm_lvalue_ptr(node_id);
    if (ptr_value != 0) {
        llvm.build_store(llvm_builder, value, ptr_value);
        return value;
    }
    if (kind == jir.JirNode.ident) {
        ptr_value = llvm_find_value(jir.jir_store_node_symbol_ids[node_id]);
        llvm.build_store(llvm_builder, value, ptr_value);
        return value;
    }
    if (kind == jir.JirNode.member_expr) {
        Int field_symbol = jir.jir_store_node_symbol_ids[node_id];
        if (field_symbol != 0) {
            if (symbols.symbol_store_kinds[field_symbol] == symbols.SymbolKind.field) {
                Int base = jir.jir_store_node_first_child[node_id];
                Int base_ptr = llvm_lvalue_ptr(base);
                if (base_ptr != 0) {
                    Int field_index = llvm_field_index(field_symbol);
                    if (field_index < 0) {
                        diagnostic.diagnostic_error(
                            llvm_source,
                            jir.jir_store_node_starts[node_id],
                            jir.jir_store_node_ends[node_id],
                            "llvm backend missing field index"
                        );
                        return value;
                    }
                    Int base_value = llvm.build_load(
                        llvm_builder,
                        llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[base], 0),
                        base_ptr,
                        "field.base"
                    );
                    Int updated = llvm.build_insert_value(
                        llvm_builder,
                        base_value,
                        value,
                        field_index,
                        "field.set"
                    );
                    return llvm_update_lvalue(base, updated);
                }
            }
        }
    }
    if (kind == jir.JirNode.index_expr) {
        ptr_value = llvm_lvalue_ptr(node_id);
        if (ptr_value == 0) {
            diagnostic.diagnostic_error(
                llvm_source,
                jir.jir_store_node_starts[node_id],
                jir.jir_store_node_ends[node_id],
                "llvm backend unsupported assignment target"
            );
            return value;
        }
        llvm.build_store(llvm_builder, value, ptr_value);
        return value;
    }
    diagnostic.diagnostic_error(
        llvm_source,
        jir.jir_store_node_starts[node_id],
        jir.jir_store_node_ends[node_id],
        "llvm backend unsupported assignment target"
    );
    return value;
}

Int llvm_emit_optional_chain_member_value(Int node_id, Int base_value) {
    Int base = jir.jir_store_node_first_child[node_id];
    Int member = jir.jir_store_node_next_sibling[base];
    Int payload_type = types.type_store_elem_type_ids[llvm_strip_mutable_type(jir.jir_store_node_type_ids[base])];
    Int payload_value = llvm.build_extract_value(llvm_builder, base_value, 1, "optional.chain.payload");
    Int symbol_id = jir.jir_store_node_symbol_ids[node_id];
    if (payload_type < types.type_store_count) {
        if (types.type_store_kinds[payload_type] == types.TypeKind.slice) {
            if (llvm_member_name_is(member, "length")) {
                return llvm.build_extract_value(llvm_builder, payload_value, 1, "optional.chain.slice.len");
            }
        }
        if (types.type_store_kinds[payload_type] == types.TypeKind.union_type) {
            if (llvm_member_name_is(member, "tag")) {
                return llvm.build_extract_value(llvm_builder, payload_value, 0, "optional.chain.union.tag");
            }
        }
        if (types.type_store_kinds[payload_type] == types.TypeKind.enum_type) {
            if (llvm_member_name_is(member, "value")) {
                return payload_value;
            }
        }
    }
    if (symbol_id != 0) {
        if (symbols.symbol_store_kinds[symbol_id] == symbols.SymbolKind.field) {
            Int field_index = llvm_field_index(symbol_id);
            if (field_index < 0) {
                diagnostic.diagnostic_error(
                    llvm_source,
                    jir.jir_store_node_starts[node_id],
                    jir.jir_store_node_ends[node_id],
                    "llvm backend missing field index"
                );
                return 0;
            }
            return llvm.build_extract_value(llvm_builder, payload_value, field_index, "optional.chain.field");
        }
    }
    diagnostic.diagnostic_error(
        llvm_source,
        jir.jir_store_node_starts[node_id],
        jir.jir_store_node_ends[node_id],
        "llvm backend unsupported optional member chain"
    );
    return 0;
}

Int llvm_emit_optional_chain_index_value(Int node_id, Int base_value) {
    Int base = jir.jir_store_node_first_child[node_id];
    Int index_expr = jir.jir_store_node_next_sibling[base];
    Int payload_type = types.type_store_elem_type_ids[llvm_strip_mutable_type(jir.jir_store_node_type_ids[base])];
    Int payload_value = llvm.build_extract_value(llvm_builder, base_value, 1, "optional.chain.payload");
    if (payload_type < types.type_store_count) {
        if (types.type_store_kinds[payload_type] == types.TypeKind.tuple) {
            return llvm.build_extract_value(llvm_builder, payload_value, jir.jir_store_node_aux[node_id], "optional.chain.tuple.item");
        }
        if (types.type_store_kinds[payload_type] == types.TypeKind.slice) {
            Int payload_ptr = llvm.build_extract_value(llvm_builder, payload_value, 0, "optional.chain.slice.ptr");
            Int gep_indices = ints.buffer_int_new(1);
            ints.buffer_int_push(gep_indices, llvm_emit_expr(index_expr));
            Int elem_ptr = llvm.build_gep(
                llvm_builder,
                llvm_type_ref_from_type_id(types.type_store_elem_type_ids[payload_type], 0),
                payload_ptr,
                ints.buffer_int_slice(gep_indices),
                "optional.chain.slice.elem.ptr"
            );
            return llvm.build_load(
                llvm_builder,
                llvm_type_ref_from_type_id(types.type_store_elem_type_ids[payload_type], 0),
                elem_ptr,
                "optional.chain.slice.elem"
            );
        }
        if (types.type_store_kinds[payload_type] == types.TypeKind.array) {
            Int payload_ptr = llvm.build_alloca(
                llvm_builder,
                llvm_type_ref_from_type_id(payload_type, 0),
                "optional.chain.array.ptr"
            );
            llvm.build_store(llvm_builder, payload_value, payload_ptr);
            Int gep_indices = ints.buffer_int_new(2);
            ints.buffer_int_push(gep_indices, llvm.const_i32(llvm_context, 0));
            ints.buffer_int_push(gep_indices, llvm_emit_expr(index_expr));
            Int elem_ptr = llvm.build_gep(
                llvm_builder,
                llvm_type_ref_from_type_id(payload_type, 0),
                payload_ptr,
                ints.buffer_int_slice(gep_indices),
                "optional.chain.array.elem.ptr"
            );
            return llvm.build_load(
                llvm_builder,
                llvm_type_ref_from_type_id(types.type_store_elem_type_ids[payload_type], 0),
                elem_ptr,
                "optional.chain.array.elem"
            );
        }
    }
    diagnostic.diagnostic_error(
        llvm_source,
        jir.jir_store_node_starts[node_id],
        jir.jir_store_node_ends[node_id],
        "llvm backend unsupported optional index chain"
    );
    return 0;
}

Int llvm_emit_expr(Int node_id) {
    Int kind = jir.jir_store_node_kinds[node_id];
    if (kind == jir.JirNode.int_lit) {
        return llvm.const_i64(llvm_context, llvm_int_lit_value(node_id));
    }
    if (kind == jir.JirNode.bool_lit) {
        return llvm.const_i1(llvm_context, jir.jir_store_node_aux[node_id] != 0);
    }
    if (kind == jir.JirNode.null_lit) {
        Int node_type = llvm_strip_mutable_type(jir.jir_store_node_type_ids[node_id]);
        if (node_type < types.type_store_count) {
            if (types.type_store_kinds[node_type] == types.TypeKind.optional) {
                Int aggregate = llvm.const_undef(llvm_type_ref_from_type_id(node_type, 0));
                aggregate = llvm.build_insert_value(llvm_builder, aggregate, llvm.const_i1(llvm_context, 0), 0, "optional.none.tag");
                return aggregate;
            }
        }
        return llvm.const_i64(llvm_context, 0);
    }
    if (kind == jir.JirNode.string_lit) {
        Int ptr_value = llvm.build_global_string_ptr(llvm_builder, llvm_string_lit_value(node_id), "str");
        Int aggregate = llvm.const_undef(llvm_slice_uint8_type);
        aggregate = llvm.build_insert_value(llvm_builder, aggregate, ptr_value, 0, "str.ptr");
        aggregate = llvm.build_insert_value(
            llvm_builder,
            aggregate,
            llvm.const_i64(llvm_context, llvm_string_lit_value(node_id).length),
            1,
            "str.len"
        );
        return aggregate;
    }
    if (kind == jir.JirNode.array_lit) {
        Int aggregate = llvm.const_undef(llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[node_id], 0));
        Int child = jir.jir_store_node_first_child[node_id];
        Int ordinal = 0;
        while (child != 0) {
            aggregate = llvm.build_insert_value(
                llvm_builder,
                aggregate,
                llvm_emit_expr(child),
                ordinal,
                "arrayinit"
            );
            ordinal = ordinal + 1;
            child = jir.jir_store_node_next_sibling[child];
        }
        return aggregate;
    }
    if (kind == jir.JirNode.array_init_expr) {
        Int aggregate = llvm.const_undef(llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[node_id], 0));
        Int child = jir.jir_store_node_first_child[node_id];
        child = jir.jir_store_node_next_sibling[child];
        Int ordinal = 0;
        while (child != 0) {
            aggregate = llvm.build_insert_value(
                llvm_builder,
                aggregate,
                llvm_emit_expr(child),
                ordinal,
                "arrayinit"
            );
            ordinal = ordinal + 1;
            child = jir.jir_store_node_next_sibling[child];
        }
        return aggregate;
    }
    if (kind == jir.JirNode.tuple_lit) {
        Int aggregate = llvm.const_undef(llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[node_id], 0));
        Int child = jir.jir_store_node_first_child[node_id];
        Int ordinal = 0;
        while (child != 0) {
            aggregate = llvm.build_insert_value(
                llvm_builder,
                aggregate,
                llvm_emit_expr(child),
                ordinal,
                "tupleinit"
            );
            ordinal = ordinal + 1;
            child = jir.jir_store_node_next_sibling[child];
        }
        return aggregate;
    }
    if (kind == jir.JirNode.optional_wrap_expr) {
        Int node_type = llvm_strip_mutable_type(jir.jir_store_node_type_ids[node_id]);
        Int aggregate = llvm.const_undef(llvm_type_ref_from_type_id(node_type, 0));
        Int child = jir.jir_store_node_first_child[node_id];
        aggregate = llvm.build_insert_value(llvm_builder, aggregate, llvm.const_i1(llvm_context, 1), 0, "optional.some.tag");
        aggregate = llvm.build_insert_value(
            llvm_builder,
            aggregate,
            llvm_emit_expr(child),
            1,
            "optional.some.value"
        );
        return aggregate;
    }
    if (kind == jir.JirNode.optional_member_expr) {
        Int base = jir.jir_store_node_first_child[node_id];
        Int member = jir.jir_store_node_next_sibling[base];
        Int node_type = llvm_strip_mutable_type(jir.jir_store_node_type_ids[node_id]);
        Int payload_type = types.type_store_elem_type_ids[llvm_strip_mutable_type(jir.jir_store_node_type_ids[base])];
        Int symbol_id = jir.jir_store_node_symbol_ids[node_id];
        Int base_value = llvm_emit_expr(base);
        Int base_tag = llvm.build_extract_value(llvm_builder, base_value, 0, "optional.chain.tag");
        Int value_expr = llvm_emit_optional_chain_member_value(node_id, base_value);
        Int aggregate = llvm.const_undef(llvm_type_ref_from_type_id(node_type, 0));
        Int flatten_optional = 0;
        if (payload_type < types.type_store_count) {
            if (types.type_store_kinds[payload_type] == types.TypeKind.slice) {
                flatten_optional = 0;
            } else if (types.type_store_kinds[payload_type] == types.TypeKind.union_type) {
                flatten_optional = 0;
            } else if (types.type_store_kinds[payload_type] == types.TypeKind.enum_type) {
                flatten_optional = 0;
            } else if (symbol_id != 0) {
                if (symbols.symbol_store_kinds[symbol_id] == symbols.SymbolKind.field) {
                    if (llvm_strip_mutable_type(symbols.symbol_store_type_ids[symbol_id]) == node_type) {
                        flatten_optional = 1;
                    }
                }
            }
        }
        if (flatten_optional == 0) {
            if (symbol_id == 0) {
                if (payload_type < types.type_store_count) {
                    if (types.type_store_kinds[payload_type] == types.TypeKind.enum_type) {
                        if (llvm_member_name_is(member, "value")) {
                            flatten_optional = 0;
                        }
                    }
                }
            }
        }
        if (flatten_optional != 0) {
            Int inner_tag = llvm.build_extract_value(llvm_builder, value_expr, 0, "optional.chain.inner.tag");
            aggregate = llvm.build_insert_value(
                llvm_builder,
                aggregate,
