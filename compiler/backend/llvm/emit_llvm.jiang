import bytes = "../../support/buffer_bytes.jiang";
import text = "../../support/text_buffer.jiang";
import diagnostic = "../../support/diagnostic.jiang";
import llvm = "../../ffi/llvm/core.jiang";

Int llvm_decl_flag_extern = 2;
Int llvm_decl_flag_generic = 1024;

Bool llvm_decl_has_flag(Int flags, Int flag) {
    Int scaled = flags / flag;
    return scaled - (flags / (flag + flag)) * 2 != 0;
}

Int llvm_context = 0;
Int llvm_module = 0;
Int llvm_builder = 0;
Int llvm_i1_type = 0;
Int llvm_i8_type = 0;
Int llvm_i8_ptr_type = 0;
Int llvm_i32_type = 0;
Int llvm_i64_type = 0;
