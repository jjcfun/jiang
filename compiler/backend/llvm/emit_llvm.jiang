                field_type = symbols.symbol_store_type_ids[field_symbol];
            }
            Int field_value = jir.jir_store_node_next_sibling[jir.jir_store_node_first_child[child]];
            Int field_index = llvm_field_index(field_symbol);
            Int inserted_value = 0;
            if (field_index < 0) {
                diagnostic.diagnostic_error(
                    llvm_source,
                    jir.jir_store_node_starts[child],
                    jir.jir_store_node_ends[child],
                    "llvm backend missing field index"
                );
                return 0;
            }
            if (jir.jir_store_node_kinds[field_value] == jir.JirNode.string_lit) {
                if (types.type_store_kinds[field_type] == types.TypeKind.array) {
                    if (types.type_store_elem_type_ids[field_type] == types.type_store_builtin_uint8) {
                        inserted_value = llvm_uint8_array_from_string(field_type, field_value);
                    }
                }
            }
            if (inserted_value == 0) {
                inserted_value = llvm_emit_expr(field_value);
            }
            aggregate = llvm.build_insert_value(
                llvm_builder,
                aggregate,
                inserted_value,
                field_index,
                "structinit"
            );
            child = jir.jir_store_node_next_sibling[child];
        }
        return aggregate;
    }
    if (kind == jir.JirNode.unary_expr) {
        Int op = jir.jir_store_node_aux[node_id];
        if (op == jir.JirUnaryOp.new_expr) {
            Int operand_node = jir.jir_store_node_first_child[node_id];
            if (jir.jir_store_node_kinds[operand_node] == jir.JirNode.call_expr) {
                Int callee = jir.jir_store_node_first_child[operand_node];
                Int callee_symbol = jir.jir_store_node_symbol_ids[callee];
                if (callee_symbol != 0) {
                    if (symbols.symbol_store_kinds[callee_symbol] == symbols.SymbolKind.func) {
                        if (symbols.symbol_store_name_ids[callee_symbol] == interns.intern_pool_intern("init")) {
                            Int owner_symbol = symbols.symbol_store_parent_ids[callee_symbol];
                            Int new_name_id = llvm_struct_new_name_id(owner_symbol);
                            Int new_ref = llvm_find_function_ref_by_name_id(new_name_id);
                            Int new_type = llvm_find_function_type_by_name_id(new_name_id);
                            if (new_ref == 0) {
                                diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[node_id], jir.jir_store_node_ends[node_id], "llvm backend missing struct new helper");
                                return 0;
                            }
                            Int args_handle = ints.buffer_int_new(8);
                            Int arg = jir.jir_store_node_next_sibling[callee];
                            while (arg != 0) {
                                ints.buffer_int_push(args_handle, llvm_emit_expr(arg));
                                arg = jir.jir_store_node_next_sibling[arg];
                            }
                            return llvm.build_call(llvm_builder, new_type, new_ref, ints.buffer_int_slice(args_handle), "newtmp");
                        }
                    }
                }
            }
            Int owner_symbol = llvm_type_owner_symbol(llvm_strip_mutable_type(jir.jir_store_node_type_ids[operand_node]));
            Int new_value_name_id = llvm_struct_new_value_name_id(owner_symbol);
            Int new_value_ref = llvm_find_function_ref_by_name_id(new_value_name_id);
            Int new_value_type = llvm_find_function_type_by_name_id(new_value_name_id);
            if (new_value_ref == 0) {
                diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[node_id], jir.jir_store_node_ends[node_id], "llvm backend missing struct new value helper");
                return 0;
            }
            Int args_handle = ints.buffer_int_new(1);
            ints.buffer_int_push(args_handle, llvm_emit_expr(operand_node));
            return llvm.build_call(llvm_builder, new_value_type, new_value_ref, ints.buffer_int_slice(args_handle), "newtmp");
        }
        if (op == jir.JirUnaryOp.addr) {
            Int ptr_value = llvm_lvalue_ptr(jir.jir_store_node_first_child[node_id]);
            if (ptr_value == 0) {
                diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[node_id], jir.jir_store_node_ends[node_id], "llvm backend unsupported address-of");
            }
            return ptr_value;
        }
        Int operand = llvm_emit_expr(jir.jir_store_node_first_child[node_id]);
        if (op == jir.JirUnaryOp.neg) {
            return llvm.build_sub(llvm_builder, llvm.const_i64(llvm_context, 0), operand, "negtmp");
        }
        if (op == jir.JirUnaryOp.deref) {
            return llvm.build_load(
                llvm_builder,
                llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[node_id], 0),
                operand,
                "dereftmp"
            );
        }
        return llvm.build_icmp_eq(llvm_builder, operand, llvm.const_i1(llvm_context, 0), "nottmp");
    }
    if (kind == jir.JirNode.binary_expr) {
        Int left_node = jir.jir_store_node_first_child[node_id];
        Int right_node = jir.jir_store_node_next_sibling[left_node];
        Int op = jir.jir_store_node_aux[node_id];
        if (op == jir.JirBinaryOp.assign) {
            Int right_value = llvm_emit_expr(right_node);
            return llvm_update_lvalue(left_node, right_value);
        }
        if (op == jir.JirBinaryOp.coalesce) {
            Int left_value = llvm_emit_expr(left_node);
            Int tag_value = llvm.build_extract_value(llvm_builder, left_value, 0, "optional.coalesce.tag");
            Int payload_value = llvm.build_extract_value(llvm_builder, left_value, 1, "optional.coalesce.value");
            Int result_type = llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[node_id], 0);
            Int result_ptr = llvm.build_alloca(llvm_builder, result_type, "coalesce.tmp");
            Int then_block = llvm.append_block(llvm_context, llvm_current_function_ref, "coalesce.some");
            Int else_block = llvm.append_block(llvm_context, llvm_current_function_ref, "coalesce.none");
            Int merge_block = llvm.append_block(llvm_context, llvm_current_function_ref, "coalesce.merge");
            llvm.build_cond_br(llvm_builder, tag_value, then_block, else_block);

            llvm.position_builder(llvm_builder, then_block);
            llvm.build_store(llvm_builder, payload_value, result_ptr);
            llvm.build_br(llvm_builder, merge_block);

            llvm.position_builder(llvm_builder, else_block);
            llvm.build_store(llvm_builder, llvm_emit_expr(right_node), result_ptr);
            llvm.build_br(llvm_builder, merge_block);

            llvm.position_builder(llvm_builder, merge_block);
            return llvm.build_load(llvm_builder, result_type, result_ptr, "coalesce.load");
        }
        if (jir.jir_store_node_kinds[right_node] == jir.JirNode.union_pattern_expr) {
            Int left_value = llvm_emit_expr(left_node);
            Int tag_value = llvm.build_extract_value(llvm_builder, left_value, 0, "union.pattern.tag");
            Int label_value = llvm_emit_expr(llvm_union_pattern_label(right_node));
            if (op == jir.JirBinaryOp.eq) {
                return llvm.build_icmp_eq(llvm_builder, tag_value, label_value, "eqtmp");
            }
            if (op == jir.JirBinaryOp.ne) {
                return llvm.build_icmp_ne(llvm_builder, tag_value, label_value, "netmp");
            }
        }
        Int left_type = llvm_strip_mutable_type(jir.jir_store_node_type_ids[left_node]);
        Int right_type = llvm_strip_mutable_type(jir.jir_store_node_type_ids[right_node]);
        if (op == jir.JirBinaryOp.eq) {
            if (jir.jir_store_node_kinds[left_node] == jir.JirNode.null_lit) {
                if (right_type < types.type_store_count) {
                    if (types.type_store_kinds[right_type] == types.TypeKind.optional) {
                        Int right_value = llvm_emit_expr(right_node);
                        Int tag_value = llvm.build_extract_value(llvm_builder, right_value, 0, "optional.tag");
                        return llvm.build_icmp_eq(llvm_builder, tag_value, llvm.const_i1(llvm_context, 0), "eqtmp");
                    }
                }
            }
            if (jir.jir_store_node_kinds[right_node] == jir.JirNode.null_lit) {
                if (left_type < types.type_store_count) {
                    if (types.type_store_kinds[left_type] == types.TypeKind.optional) {
                        Int left_value = llvm_emit_expr(left_node);
                        Int tag_value = llvm.build_extract_value(llvm_builder, left_value, 0, "optional.tag");
                        return llvm.build_icmp_eq(llvm_builder, tag_value, llvm.const_i1(llvm_context, 0), "eqtmp");
                    }
                }
            }
        } else if (op == jir.JirBinaryOp.ne) {
            if (jir.jir_store_node_kinds[left_node] == jir.JirNode.null_lit) {
                if (right_type < types.type_store_count) {
                    if (types.type_store_kinds[right_type] == types.TypeKind.optional) {
                        Int right_value = llvm_emit_expr(right_node);
                        Int tag_value = llvm.build_extract_value(llvm_builder, right_value, 0, "optional.tag");
                        return llvm.build_icmp_ne(llvm_builder, tag_value, llvm.const_i1(llvm_context, 0), "netmp");
                    }
                }
            }
            if (jir.jir_store_node_kinds[right_node] == jir.JirNode.null_lit) {
                if (left_type < types.type_store_count) {
                    if (types.type_store_kinds[left_type] == types.TypeKind.optional) {
                        Int left_value = llvm_emit_expr(left_node);
                        Int tag_value = llvm.build_extract_value(llvm_builder, left_value, 0, "optional.tag");
                        return llvm.build_icmp_ne(llvm_builder, tag_value, llvm.const_i1(llvm_context, 0), "netmp");
                    }
                }
            }
        }
        Int left = llvm_emit_expr(left_node);
        Int right = llvm_emit_expr(right_node);
        if (op == jir.JirBinaryOp.add) {
            return llvm.build_add(llvm_builder, left, right, "addtmp");
        }
        if (op == jir.JirBinaryOp.sub) {
            return llvm.build_sub(llvm_builder, left, right, "subtmp");
        }
        if (op == jir.JirBinaryOp.mul) {
            return llvm.build_mul(llvm_builder, left, right, "multmp");
        }
        if (op == jir.JirBinaryOp.div) {
            return llvm.build_sdiv(llvm_builder, left, right, "divtmp");
        }
        if (op == jir.JirBinaryOp.eq) {
            return llvm.build_icmp_eq(llvm_builder, left, right, "eqtmp");
        }
        if (op == jir.JirBinaryOp.ne) {
            return llvm.build_icmp_ne(llvm_builder, left, right, "netmp");
        }
        if (op == jir.JirBinaryOp.lt) {
            return llvm.build_icmp_slt(llvm_builder, left, right, "lttmp");
        }
        if (op == jir.JirBinaryOp.le) {
            return llvm.build_icmp_sle(llvm_builder, left, right, "letmp");
        }
        if (op == jir.JirBinaryOp.gt) {
            return llvm.build_icmp_sgt(llvm_builder, left, right, "gttmp");
        }
        return llvm.build_icmp_sge(llvm_builder, left, right, "getmp");
    }
    if (kind == jir.JirNode.ternary_expr) {
        Int condition = jir.jir_store_node_first_child[node_id];
        Int then_expr = jir.jir_store_node_next_sibling[condition];
        Int else_expr = jir.jir_store_node_next_sibling[then_expr];
        Int result_type = llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[node_id], 0);
        Int result_ptr = llvm.build_alloca(llvm_builder, result_type, "ternary.tmp");
        Int then_block = llvm.append_block(llvm_context, llvm_current_function_ref, "ternary.then");
        Int else_block = llvm.append_block(llvm_context, llvm_current_function_ref, "ternary.else");
        Int merge_block = llvm.append_block(llvm_context, llvm_current_function_ref, "ternary.merge");
        llvm.build_cond_br(llvm_builder, llvm_emit_expr(condition), then_block, else_block);

        llvm.position_builder(llvm_builder, then_block);
        llvm.build_store(llvm_builder, llvm_emit_expr(then_expr), result_ptr);
        llvm.build_br(llvm_builder, merge_block);

        llvm.position_builder(llvm_builder, else_block);
        llvm.build_store(llvm_builder, llvm_emit_expr(else_expr), result_ptr);
        llvm.build_br(llvm_builder, merge_block);

        llvm.position_builder(llvm_builder, merge_block);
        return llvm.build_load(llvm_builder, result_type, result_ptr, "ternary.load");
    }
    diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[node_id], jir.jir_store_node_ends[node_id], "llvm backend unsupported expression");
    return 0;
}

() llvm_emit_stmt(Int function_ref, Int return_type, Int stmt_node, Int exit_block) {
    function_ref = function_ref;
    Int kind = jir.jir_store_node_kinds[stmt_node];
    if (kind == jir.JirNode.return_stmt) {
        Int expr = jir.jir_store_node_first_child[stmt_node];
        if (expr == 0) {
            llvm.build_ret_void(llvm_builder);
            return;
        }
        Int value = llvm_emit_expr(expr);
        if (return_type == llvm_i32_type) {
            Int expr_type = jir.jir_store_node_type_ids[expr];
            if (expr_type == types.type_store_builtin_bool) {
                value = llvm.build_zext(llvm_builder, value, llvm_i32_type, "main.ret");
            } else if (expr_type == types.type_store_builtin_uint8) {
                value = llvm.build_zext(llvm_builder, value, llvm_i32_type, "main.ret");
            } else {
                value = llvm.build_trunc(llvm_builder, value, llvm_i32_type, "main.ret");
            }
        }
        llvm.build_ret(llvm_builder, value);
        return;
    }
    if (kind == jir.JirNode.expr_stmt) {
        llvm_emit_expr(jir.jir_store_node_first_child[stmt_node]);
        return;
    }
    if (kind == jir.JirNode.tuple_local_decl) {
        Int child = jir.jir_store_node_first_child[stmt_node];
        while (child != 0) {
            llvm_emit_stmt(function_ref, return_type, child, exit_block);
            child = jir.jir_store_node_next_sibling[child];
        }
        return;
    }
    if (kind == jir.JirNode.local_decl) {
        Int type_node = jir.jir_store_node_first_child[stmt_node];
        Int name_node = jir.jir_store_node_next_sibling[type_node];
        Int init_expr = jir.jir_store_node_next_sibling[name_node];
        Int declared_type = jir.jir_store_node_type_ids[type_node];
        UInt8[] local_name = llvm_node_text(name_node);
        if (jir.jir_store_node_symbol_ids[stmt_node] != 0) {
            local_name = llvm_symbol_text(jir.jir_store_node_symbol_ids[stmt_node]);
        }
        Int ptr_value = llvm.build_alloca(
            llvm_builder,
            llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[stmt_node], 0),
            local_name
        );
        llvm_set_value(jir.jir_store_node_symbol_ids[stmt_node], ptr_value);
        if (types.type_store_kinds[declared_type] == types.TypeKind.array) {
            if (types.type_store_elem_type_ids[declared_type] == types.type_store_builtin_uint8) {
                if (jir.jir_store_node_kinds[init_expr] == jir.JirNode.string_lit) {
                    Int aggregate = llvm_uint8_array_from_string(declared_type, init_expr);
                    llvm.build_store(llvm_builder, aggregate, ptr_value);
                    return;
                }
            }
        }
        llvm.build_store(llvm_builder, llvm_emit_expr(init_expr), ptr_value);
        return;
    }
    if (kind == jir.JirNode.if_stmt) {
        Int condition_node = jir.jir_store_node_first_child[stmt_node];
        Int then_block_node = jir.jir_store_node_next_sibling[condition_node];
        Int else_block_node = jir.jir_store_node_next_sibling[then_block_node];
        Bool is_union_pattern = 0;
        Int left_value_node = 0;
        Int pattern_node = 0;
        Int pattern_bind_count = 0;
        if (jir.jir_store_node_kinds[condition_node] == jir.JirNode.binary_expr) {
            left_value_node = jir.jir_store_node_first_child[condition_node];
            Int right_value_node = jir.jir_store_node_next_sibling[left_value_node];
            if (right_value_node != 0) {
                if (jir.jir_store_node_kinds[right_value_node] == jir.JirNode.union_pattern_expr) {
                    is_union_pattern = 1;
                    pattern_node = right_value_node;
                    pattern_bind_count = llvm_union_pattern_binding_count(pattern_node);
                }
            }
        }
        Int then_block = llvm.append_block(llvm_context, function_ref, "then");
        Int else_block = llvm.append_block(llvm_context, function_ref, "else");
        Int merge_block = llvm.append_block(llvm_context, function_ref, "endif");
        if (is_union_pattern != 0) {
            Int union_value = llvm_emit_expr(left_value_node);
            Int union_alloca = llvm.build_alloca(llvm_builder, llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[left_value_node], 0), "if.pattern.union");
            llvm.build_store(llvm_builder, union_value, union_alloca);
            Int condition_value = llvm.build_load(llvm_builder, llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[left_value_node], 0), union_alloca, "if.pattern.load");
            Int tag_value = llvm.build_extract_value(llvm_builder, condition_value, 0, "if.pattern.tag");
            Int label_value = llvm_emit_expr(llvm_union_pattern_label(pattern_node));
            Int left_type = llvm_strip_mutable_type(jir.jir_store_node_type_ids[left_value_node]);
            Int predicate = 0;
            if (jir.jir_store_node_aux[condition_node] == jir.JirBinaryOp.eq) {
                predicate = llvm.build_icmp_eq(llvm_builder, tag_value, label_value, "if.pattern.eq");
            } else {
                predicate = llvm.build_icmp_ne(llvm_builder, tag_value, label_value, "if.pattern.ne");
            }
            llvm.build_cond_br(llvm_builder, predicate, then_block, else_block);
            llvm.position_builder(llvm_builder, then_block);
            if (pattern_bind_count == 1) {
                Int pattern_bind = llvm_union_pattern_binding_item(pattern_node, 0);
                Int payload_index = 1;
                if (left_type < types.type_store_count) {
                    if (types.type_store_kinds[left_type] != types.TypeKind.optional) {
                        Int label_symbol = jir.jir_store_node_symbol_ids[llvm_union_pattern_label(pattern_node)];
                        payload_index = llvm_union_member_field_index(label_symbol);
                    }
                }
                Int payload_value = llvm.build_extract_value(llvm_builder, condition_value, payload_index, "union.payload");
                Int local_ptr = llvm.build_alloca(llvm_builder, llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[pattern_bind], 0), "pattern.bind");
                llvm.build_store(llvm_builder, payload_value, local_ptr);
                llvm_set_value(jir.jir_store_node_symbol_ids[pattern_bind], local_ptr);
            } else if (pattern_bind_count > 1) {
                Int payload_index = 1;
                if (left_type < types.type_store_count) {
                    if (types.type_store_kinds[left_type] != types.TypeKind.optional) {
                        Int label_symbol = jir.jir_store_node_symbol_ids[llvm_union_pattern_label(pattern_node)];
                        payload_index = llvm_union_member_field_index(label_symbol);
                    }
                }
                Int payload_value = llvm.build_extract_value(llvm_builder, condition_value, payload_index, "union.payload");
                Int i = 0;
                while (i < pattern_bind_count) {
                    Int pattern_bind = llvm_union_pattern_binding_item(pattern_node, i);
                    Int item_value = llvm.build_extract_value(llvm_builder, payload_value, i, "tuple.item");
                    Int local_ptr = llvm.build_alloca(llvm_builder, llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[pattern_bind], 0), "pattern.bind");
                    llvm.build_store(llvm_builder, item_value, local_ptr);
                    llvm_set_value(jir.jir_store_node_symbol_ids[pattern_bind], local_ptr);
                    i = i + 1;
                }
            }
        } else {
            llvm.build_cond_br(llvm_builder, llvm_emit_expr(condition_node), then_block, else_block);
            llvm.position_builder(llvm_builder, then_block);
        }
        Int stmt = jir.jir_store_node_first_child[then_block_node];
        while (stmt != 0) {
            llvm_emit_stmt(function_ref, return_type, stmt, exit_block);
            if (llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                break;
            }
            stmt = jir.jir_store_node_next_sibling[stmt];
        }
        if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
            llvm.build_br(llvm_builder, merge_block);
        }

        llvm.position_builder(llvm_builder, else_block);
        if (else_block_node != 0) {
            if (jir.jir_store_node_kinds[else_block_node] == jir.JirNode.block) {
                stmt = jir.jir_store_node_first_child[else_block_node];
                while (stmt != 0) {
                    llvm_emit_stmt(function_ref, return_type, stmt, exit_block);
                    if (llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                        break;
                    }
                    stmt = jir.jir_store_node_next_sibling[stmt];
                }
            } else {
                llvm_emit_stmt(function_ref, return_type, else_block_node, exit_block);
            }
        }
        if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
            llvm.build_br(llvm_builder, merge_block);
        }

        llvm.position_builder(llvm_builder, merge_block);
        exit_block = exit_block;
        return;
    }
    if (kind == jir.JirNode.while_stmt) {
        Int condition_node = jir.jir_store_node_first_child[stmt_node];
        Int body_node = jir.jir_store_node_next_sibling[condition_node];
        Int cond_block = llvm.append_block(llvm_context, function_ref, "while.cond");
        Int body_block = llvm.append_block(llvm_context, function_ref, "while.body");
        Int after_block = llvm.append_block(llvm_context, function_ref, "while.end");
        llvm.build_br(llvm_builder, cond_block);

        llvm.position_builder(llvm_builder, cond_block);
        llvm.build_cond_br(llvm_builder, llvm_emit_expr(condition_node), body_block, after_block);

        llvm.position_builder(llvm_builder, body_block);
        ints.buffer_int_set(llvm_loop_continue_blocks, llvm_loop_block_count, cond_block);
        ints.buffer_int_set(llvm_loop_break_blocks, llvm_loop_block_count, after_block);
        llvm_loop_block_count = llvm_loop_block_count + 1;
        Int stmt = jir.jir_store_node_first_child[body_node];
        while (stmt != 0) {
            llvm_emit_stmt(function_ref, return_type, stmt, exit_block);
            if (llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                break;
            }
            stmt = jir.jir_store_node_next_sibling[stmt];
        }
        llvm_loop_block_count = llvm_loop_block_count - 1;
        if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
            llvm.build_br(llvm_builder, cond_block);
        }

        llvm.position_builder(llvm_builder, after_block);
        return;
    }
    if (kind == jir.JirNode.for_stmt) {
        Int mode = jir.jir_store_node_aux[stmt_node];
        if (mode == 0) {
            Int name_node = 0;
            Int start_expr = 0;
            Int end_expr = 0;
            Int body_node = 0;
            Int declared_type = jir.jir_store_node_type_ids[stmt_node];
            Int type_node = jir.jir_store_node_first_child[stmt_node];
            name_node = jir.jir_store_node_next_sibling[type_node];
            start_expr = jir.jir_store_node_next_sibling[name_node];
            end_expr = jir.jir_store_node_next_sibling[start_expr];
            body_node = jir.jir_store_node_next_sibling[end_expr];
            declared_type = jir.jir_store_node_type_ids[type_node];
            Int llvm_declared_type = llvm_type_ref_from_type_id(declared_type, 0);
            Int loop_ptr = llvm.build_alloca(
                llvm_builder,
                llvm_declared_type,
                llvm_loop_var_text(stmt_node, name_node)
            );
            llvm_set_value(jir.jir_store_node_symbol_ids[stmt_node], loop_ptr);
            llvm.build_store(llvm_builder, llvm_emit_expr(start_expr), loop_ptr);
            Int end_ptr = llvm.build_alloca(
                llvm_builder,
                llvm_declared_type,
                "for.end"
            );
            llvm.build_store(llvm_builder, llvm_emit_expr(end_expr), end_ptr);

            Int cond_block = llvm.append_block(llvm_context, function_ref, "for.cond");
            Int body_block = llvm.append_block(llvm_context, function_ref, "for.body");
            Int step_block = llvm.append_block(llvm_context, function_ref, "for.step");
            Int after_block = llvm.append_block(llvm_context, function_ref, "for.end");
            llvm.build_br(llvm_builder, cond_block);

            llvm.position_builder(llvm_builder, cond_block);
            Int current_value = llvm.build_load(llvm_builder, llvm_declared_type, loop_ptr, "for.cur");
            Int end_value = llvm.build_load(llvm_builder, llvm_declared_type, end_ptr, "for.end");
            Int cond_value = llvm.build_icmp_slt(llvm_builder, current_value, end_value, "for.cmp");
            llvm.build_cond_br(llvm_builder, cond_value, body_block, after_block);

            llvm.position_builder(llvm_builder, body_block);
            ints.buffer_int_set(llvm_loop_continue_blocks, llvm_loop_block_count, step_block);
            ints.buffer_int_set(llvm_loop_break_blocks, llvm_loop_block_count, after_block);
            llvm_loop_block_count = llvm_loop_block_count + 1;
            Int stmt = jir.jir_store_node_first_child[body_node];
            while (stmt != 0) {
                llvm_emit_stmt(function_ref, return_type, stmt, exit_block);
                if (llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                    break;
                }
                stmt = jir.jir_store_node_next_sibling[stmt];
            }
            llvm_loop_block_count = llvm_loop_block_count - 1;
            if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                llvm.build_br(llvm_builder, step_block);
            }

            llvm.position_builder(llvm_builder, step_block);
            current_value = llvm.build_load(llvm_builder, llvm_declared_type, loop_ptr, "for.step.cur");
            Int next_value = llvm.build_add(
                llvm_builder,
                current_value,
                llvm.const_i64(llvm_context, 1),
                "for.next"
            );
            llvm.build_store(llvm_builder, next_value, loop_ptr);
            llvm.build_br(llvm_builder, cond_block);

            llvm.position_builder(llvm_builder, after_block);
        } else {
            if (mode == 1) {
                Int name_node = jir.jir_store_node_first_child[stmt_node];
                Int start_expr = jir.jir_store_node_next_sibling[name_node];
                Int end_expr = jir.jir_store_node_next_sibling[start_expr];
                Int body_node = jir.jir_store_node_next_sibling[end_expr];
                Int declared_type = jir.jir_store_node_type_ids[stmt_node];
                Int llvm_declared_type = llvm_type_ref_from_type_id(declared_type, 0);
                Int loop_ptr = llvm.build_alloca(
                    llvm_builder,
                    llvm_declared_type,
                    llvm_loop_var_text(stmt_node, name_node)
                );
                llvm_set_value(jir.jir_store_node_symbol_ids[stmt_node], loop_ptr);
                llvm.build_store(llvm_builder, llvm_emit_expr(start_expr), loop_ptr);
                Int end_ptr = llvm.build_alloca(
                    llvm_builder,
                    llvm_declared_type,
                    "for.end"
                );
                llvm.build_store(llvm_builder, llvm_emit_expr(end_expr), end_ptr);

                Int cond_block = llvm.append_block(llvm_context, function_ref, "for.cond");
                Int body_block = llvm.append_block(llvm_context, function_ref, "for.body");
                Int step_block = llvm.append_block(llvm_context, function_ref, "for.step");
                Int after_block = llvm.append_block(llvm_context, function_ref, "for.end");
                llvm.build_br(llvm_builder, cond_block);

                llvm.position_builder(llvm_builder, cond_block);
                Int current_value = llvm.build_load(llvm_builder, llvm_declared_type, loop_ptr, "for.cur");
                Int end_value = llvm.build_load(llvm_builder, llvm_declared_type, end_ptr, "for.end");
                Int cond_value = llvm.build_icmp_slt(llvm_builder, current_value, end_value, "for.cmp");
                llvm.build_cond_br(llvm_builder, cond_value, body_block, after_block);

                llvm.position_builder(llvm_builder, body_block);
                ints.buffer_int_set(llvm_loop_continue_blocks, llvm_loop_block_count, step_block);
                ints.buffer_int_set(llvm_loop_break_blocks, llvm_loop_block_count, after_block);
                llvm_loop_block_count = llvm_loop_block_count + 1;
                Int stmt = jir.jir_store_node_first_child[body_node];
                while (stmt != 0) {
                    llvm_emit_stmt(function_ref, return_type, stmt, exit_block);
                    if (llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                        break;
                    }
                    stmt = jir.jir_store_node_next_sibling[stmt];
                }
                llvm_loop_block_count = llvm_loop_block_count - 1;
                if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                    llvm.build_br(llvm_builder, step_block);
                }

                llvm.position_builder(llvm_builder, step_block);
                current_value = llvm.build_load(llvm_builder, llvm_declared_type, loop_ptr, "for.step.cur");
                Int next_value = llvm.build_add(
                    llvm_builder,
                    current_value,
                    llvm.const_i64(llvm_context, 1),
                    "for.next"
                );
                llvm.build_store(llvm_builder, next_value, loop_ptr);
                llvm.build_br(llvm_builder, cond_block);

                llvm.position_builder(llvm_builder, after_block);
            } else if (mode == 5) {
                Int index_name_node = jir.jir_store_node_first_child[stmt_node];
                Int item_name_node = jir.jir_store_node_next_sibling[index_name_node];
                Int iterable_expr = jir.jir_store_node_next_sibling[item_name_node];
                Int body_node = jir.jir_store_node_next_sibling[iterable_expr];
                Int index_binding_ptr = llvm.build_alloca(
                    llvm_builder,
                    llvm_i64_type,
                    llvm_node_text(index_name_node)
                );
                Int item_binding_ptr = llvm.build_alloca(
                    llvm_builder,
                    llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[item_name_node], 0),
                    llvm_node_text(item_name_node)
                );
                llvm_set_value(jir.jir_store_node_symbol_ids[index_name_node], index_binding_ptr);
                llvm_set_value(jir.jir_store_node_symbol_ids[item_name_node], item_binding_ptr);

                Int iterable_value = llvm_emit_expr(iterable_expr);
                Int iterable_type = jir.jir_store_node_type_ids[iterable_expr];
                Int index_ptr = llvm.build_alloca(
                    llvm_builder,
                    llvm_i64_type,
                    "for.index"
                );
                llvm.build_store(llvm_builder, llvm.const_i64(llvm_context, 0), index_ptr);

                Int cond_block = llvm.append_block(llvm_context, function_ref, "for.cond");
                Int body_block = llvm.append_block(llvm_context, function_ref, "for.body");
                Int step_block = llvm.append_block(llvm_context, function_ref, "for.step");
                Int after_block = llvm.append_block(llvm_context, function_ref, "for.end");
                llvm.build_br(llvm_builder, cond_block);

                llvm.position_builder(llvm_builder, cond_block);
                Int current_index = llvm.build_load(llvm_builder, llvm_i64_type, index_ptr, "for.index.cur");
                Int length_value = llvm.build_extract_value(llvm_builder, iterable_value, 1, "for.len");
                Int cond_value = llvm.build_icmp_slt(llvm_builder, current_index, length_value, "for.cmp");
                llvm.build_cond_br(llvm_builder, cond_value, body_block, after_block);

                llvm.position_builder(llvm_builder, body_block);
                llvm.build_store(llvm_builder, current_index, index_binding_ptr);
                Int ptr_value = llvm.build_extract_value(llvm_builder, iterable_value, 0, "for.ptr");
                Int gep_indices = ints.buffer_int_new(1);
                ints.buffer_int_push(gep_indices, current_index);
                Int item_ptr = llvm.build_gep(
                    llvm_builder,
                    llvm_type_ref_from_type_id(types.type_store_elem_type_ids[iterable_type], 0),
                    ptr_value,
                    ints.buffer_int_slice(gep_indices),
                    "for.item.ptr"
                );
                Int item_value = llvm.build_load(
                    llvm_builder,
                    llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[item_name_node], 0),
                    item_ptr,
                    "for.item"
                );
                llvm.build_store(llvm_builder, item_value, item_binding_ptr);
                ints.buffer_int_set(llvm_loop_continue_blocks, llvm_loop_block_count, step_block);
                ints.buffer_int_set(llvm_loop_break_blocks, llvm_loop_block_count, after_block);
                llvm_loop_block_count = llvm_loop_block_count + 1;
                Int stmt = jir.jir_store_node_first_child[body_node];
                while (stmt != 0) {
                    llvm_emit_stmt(function_ref, return_type, stmt, exit_block);
                    if (llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                        break;
                    }
                    stmt = jir.jir_store_node_next_sibling[stmt];
                }
                llvm_loop_block_count = llvm_loop_block_count - 1;
                if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                    llvm.build_br(llvm_builder, step_block);
                }

                llvm.position_builder(llvm_builder, step_block);
                Int next_index = llvm.build_add(
                    llvm_builder,
                    llvm.build_load(llvm_builder, llvm_i64_type, index_ptr, "for.step.cur"),
                    llvm.const_i64(llvm_context, 1),
                    "for.next"
                );
                llvm.build_store(llvm_builder, next_index, index_ptr);
                llvm.build_br(llvm_builder, cond_block);

                llvm.position_builder(llvm_builder, after_block);
            } else {
                Int name_node = 0;
                Int iterable_expr = 0;
                Int body_node = 0;
                if (mode == 2) {
                    name_node = jir.jir_store_node_first_child[stmt_node];
                    iterable_expr = jir.jir_store_node_next_sibling[name_node];
                    body_node = jir.jir_store_node_next_sibling[iterable_expr];
                } else {
                    Int type_node = jir.jir_store_node_first_child[stmt_node];
                    name_node = jir.jir_store_node_next_sibling[type_node];
                    iterable_expr = jir.jir_store_node_next_sibling[name_node];
                    body_node = jir.jir_store_node_next_sibling[iterable_expr];
                }
                Int loop_type = jir.jir_store_node_type_ids[stmt_node];
                Int loop_ptr = llvm.build_alloca(
                    llvm_builder,
                    llvm_type_ref_from_type_id(loop_type, 0),
                    llvm_loop_var_text(stmt_node, name_node)
                );
                llvm_set_value(jir.jir_store_node_symbol_ids[stmt_node], loop_ptr);

                Int iterable_value = llvm_emit_expr(iterable_expr);
                Int iterable_type = jir.jir_store_node_type_ids[iterable_expr];
                Int index_ptr = llvm.build_alloca(
                    llvm_builder,
                    llvm_i64_type,
                    "for.index"
                );
                llvm.build_store(llvm_builder, llvm.const_i64(llvm_context, 0), index_ptr);

            Int cond_block = llvm.append_block(llvm_context, function_ref, "for.cond");
            Int body_block = llvm.append_block(llvm_context, function_ref, "for.body");
            Int step_block = llvm.append_block(llvm_context, function_ref, "for.step");
            Int after_block = llvm.append_block(llvm_context, function_ref, "for.end");
            llvm.build_br(llvm_builder, cond_block);

            llvm.position_builder(llvm_builder, cond_block);
            Int current_index = llvm.build_load(llvm_builder, llvm_i64_type, index_ptr, "for.index.cur");
            Int length_value = llvm.build_extract_value(llvm_builder, iterable_value, 1, "for.len");
            Int cond_value = llvm.build_icmp_slt(llvm_builder, current_index, length_value, "for.cmp");
            llvm.build_cond_br(llvm_builder, cond_value, body_block, after_block);

            llvm.position_builder(llvm_builder, body_block);
            Int ptr_value = llvm.build_extract_value(llvm_builder, iterable_value, 0, "for.ptr");
            Int gep_indices = ints.buffer_int_new(1);
            ints.buffer_int_push(gep_indices, current_index);
            Int item_ptr = llvm.build_gep(
                llvm_builder,
                llvm_type_ref_from_type_id(types.type_store_elem_type_ids[iterable_type], 0),
                ptr_value,
                ints.buffer_int_slice(gep_indices),
                "for.item.ptr"
            );
            Int item_value = llvm.build_load(
                llvm_builder,
                llvm_type_ref_from_type_id(loop_type, 0),
                item_ptr,
                "for.item"
            );
            llvm.build_store(llvm_builder, item_value, loop_ptr);
            ints.buffer_int_set(llvm_loop_continue_blocks, llvm_loop_block_count, step_block);
            ints.buffer_int_set(llvm_loop_break_blocks, llvm_loop_block_count, after_block);
            llvm_loop_block_count = llvm_loop_block_count + 1;
            Int stmt = jir.jir_store_node_first_child[body_node];
            while (stmt != 0) {
                llvm_emit_stmt(function_ref, return_type, stmt, exit_block);
                if (llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                    break;
                }
                stmt = jir.jir_store_node_next_sibling[stmt];
            }
            llvm_loop_block_count = llvm_loop_block_count - 1;
            if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                llvm.build_br(llvm_builder, step_block);
            }

            llvm.position_builder(llvm_builder, step_block);
            Int next_index = llvm.build_add(
                llvm_builder,
                llvm.build_load(llvm_builder, llvm_i64_type, index_ptr, "for.step.cur"),
                llvm.const_i64(llvm_context, 1),
                "for.next"
            );
            llvm.build_store(llvm_builder, next_index, index_ptr);
            llvm.build_br(llvm_builder, cond_block);

                llvm.position_builder(llvm_builder, after_block);
            }
        }
        return;
    }
    if (kind == jir.JirNode.switch_stmt) {
        Int condition_node = jir.jir_store_node_first_child[stmt_node];
        Int condition_value = llvm_emit_expr(condition_node);
        Int switch_value = condition_value;
        Int condition_type = jir.jir_store_node_type_ids[condition_node];
        if (condition_type < types.type_store_count) {
            if (types.type_store_kinds[condition_type] == types.TypeKind.union_type) {
                condition_value = llvm.build_extract_value(llvm_builder, condition_value, 0, "switch.union.tag");
            } else if (types.type_store_kinds[condition_type] == types.TypeKind.optional) {
                condition_value = llvm.build_extract_value(llvm_builder, condition_value, 0, "switch.union.tag");
            }
        }
        Int after_block = llvm.append_block(llvm_context, function_ref, "switch.end");
        Int else_node = 0;
        Int case_count = 0;
        Int child = jir.jir_store_node_next_sibling[condition_node];
        while (child != 0) {
            if (jir.jir_store_node_kinds[child] == jir.JirNode.switch_case) {
                case_count = case_count + 1;
            }
            if (jir.jir_store_node_kinds[child] == jir.JirNode.switch_else) {
                else_node = child;
            }
            child = jir.jir_store_node_next_sibling[child];
        }
        if (case_count == 0) {
            if (else_node != 0) {
                Int else_body = jir.jir_store_node_first_child[else_node];
                if (jir.jir_store_node_kinds[else_body] == jir.JirNode.block) {
                    Int stmt = jir.jir_store_node_first_child[else_body];
                    while (stmt != 0) {
                        llvm_emit_stmt(function_ref, return_type, stmt, exit_block);
                        if (llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                            break;
                        }
                        stmt = jir.jir_store_node_next_sibling[stmt];
                    }
                } else {
                    llvm_emit_stmt(function_ref, return_type, else_body, exit_block);
                }
                if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                    llvm.build_br(llvm_builder, after_block);
                }
            } else {
                llvm.build_br(llvm_builder, after_block);
            }
            llvm.position_builder(llvm_builder, after_block);
            return;
        }

        Int check_block = llvm.current_block(llvm_builder);
        child = jir.jir_store_node_next_sibling[condition_node];
        while (child != 0) {
            if (jir.jir_store_node_kinds[child] == jir.JirNode.switch_case) {
                Int label_node = jir.jir_store_node_first_child[child];
                Int bind_node = 0;
                Int body_node = jir.jir_store_node_next_sibling[label_node];
                if (body_node != 0) {
                    if (jir.jir_store_node_next_sibling[body_node] != 0) {
                        bind_node = body_node;
                        body_node = jir.jir_store_node_next_sibling[bind_node];
                    }
                }
                Int next_relevant = jir.jir_store_node_next_sibling[child];
                while (next_relevant != 0) {
                    Int next_kind = jir.jir_store_node_kinds[next_relevant];
                    if (next_kind == jir.JirNode.switch_case) {
                        break;
                    }
                    if (next_kind == jir.JirNode.switch_else) {
                        break;
                    }
                    next_relevant = jir.jir_store_node_next_sibling[next_relevant];
                }
                Int case_block = llvm.append_block(llvm_context, function_ref, "switch.case");
                Int false_block = after_block;
                Bool false_is_after = 1;
                if (next_relevant != 0) {
                    false_block = llvm.append_block(llvm_context, function_ref, "switch.next");
                    false_is_after = 0;
                }

                llvm.position_builder(llvm_builder, check_block);
                Int compare_value = llvm.build_icmp_eq(llvm_builder, condition_value, llvm_emit_expr(label_node), "switch.cmp");
                llvm.build_cond_br(llvm_builder, compare_value, case_block, false_block);

                llvm.position_builder(llvm_builder, case_block);
                if (bind_node != 0) {
                    Int label_symbol = jir.jir_store_node_symbol_ids[label_node];
                    Int payload_index = 1;
                    if (condition_type < types.type_store_count) {
                        if (types.type_store_kinds[condition_type] != types.TypeKind.optional) {
                            payload_index = llvm_union_member_field_index(label_symbol);
                        }
                    }
                    if (payload_index < 0) {
                        diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[bind_node], jir.jir_store_node_ends[bind_node], "llvm backend missing union payload field");
                    } else {
                        Int payload_value = llvm.build_extract_value(llvm_builder, switch_value, payload_index, "union.payload");
                        Int bind_ptr = llvm.build_alloca(
                            llvm_builder,
                            llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[bind_node], 0),
                            llvm_node_text(bind_node)
                        );
                        llvm_set_value(jir.jir_store_node_symbol_ids[bind_node], bind_ptr);
                        llvm.build_store(llvm_builder, payload_value, bind_ptr);
                    }
                } else if (jir.jir_store_node_kinds[label_node] == jir.JirNode.union_pattern_expr) {
                    Int pattern_bind_count = llvm_union_pattern_binding_count(label_node);
                    if (pattern_bind_count == 1) {
                        Int label_symbol = jir.jir_store_node_symbol_ids[llvm_union_pattern_label(label_node)];
                        Int payload_index = 1;
                        if (condition_type < types.type_store_count) {
                            if (types.type_store_kinds[condition_type] != types.TypeKind.optional) {
                                payload_index = llvm_union_member_field_index(label_symbol);
                            }
                        }
                        if (payload_index < 0) {
                            diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[label_node], jir.jir_store_node_ends[label_node], "llvm backend missing union payload field");
                        } else {
                            Int pattern_bind = llvm_union_pattern_binding_item(label_node, 0);
                            Int payload_value = llvm.build_extract_value(llvm_builder, switch_value, payload_index, "union.payload");
                            Int bind_ptr = llvm.build_alloca(
                                llvm_builder,
                                llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[pattern_bind], 0),
                                llvm_node_text(pattern_bind)
                            );
                            llvm_set_value(jir.jir_store_node_symbol_ids[pattern_bind], bind_ptr);
                            llvm.build_store(llvm_builder, payload_value, bind_ptr);
                        }
                    } else if (pattern_bind_count > 1) {
                        Int label_symbol = jir.jir_store_node_symbol_ids[llvm_union_pattern_label(label_node)];
                        Int payload_index = 1;
                        if (condition_type < types.type_store_count) {
                            if (types.type_store_kinds[condition_type] != types.TypeKind.optional) {
                                payload_index = llvm_union_member_field_index(label_symbol);
                            }
                        }
                        if (payload_index < 0) {
                            diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[label_node], jir.jir_store_node_ends[label_node], "llvm backend missing union payload field");
                        } else {
                            Int payload_value = llvm.build_extract_value(llvm_builder, switch_value, payload_index, "union.payload");
                            Int i = 0;
                            while (i < pattern_bind_count) {
                                Int pattern_bind = llvm_union_pattern_binding_item(label_node, i);
                                Int item_value = llvm.build_extract_value(llvm_builder, payload_value, i, "tuple.item");
                                Int bind_ptr = llvm.build_alloca(
                                    llvm_builder,
                                    llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[pattern_bind], 0),
                                    llvm_node_text(pattern_bind)
                                );
                                llvm_set_value(jir.jir_store_node_symbol_ids[pattern_bind], bind_ptr);
                                llvm.build_store(llvm_builder, item_value, bind_ptr);
                                i = i + 1;
                            }
                        }
                    }
                }
                if (jir.jir_store_node_kinds[body_node] == jir.JirNode.block) {
                    Int stmt = jir.jir_store_node_first_child[body_node];
                    while (stmt != 0) {
                        llvm_emit_stmt(function_ref, return_type, stmt, exit_block);
                        if (llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                            break;
                        }
                        stmt = jir.jir_store_node_next_sibling[stmt];
                    }
                } else {
                    llvm_emit_stmt(function_ref, return_type, body_node, exit_block);
                }
                if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                    llvm.build_br(llvm_builder, after_block);
                }

                if (!false_is_after) {
                    check_block = false_block;
                }
            }
            child = jir.jir_store_node_next_sibling[child];
        }

        if (else_node != 0) {
            Int else_body = jir.jir_store_node_first_child[else_node];
            llvm.position_builder(llvm_builder, check_block);
            if (jir.jir_store_node_kinds[else_body] == jir.JirNode.block) {
                Int stmt = jir.jir_store_node_first_child[else_body];
                while (stmt != 0) {
                    llvm_emit_stmt(function_ref, return_type, stmt, exit_block);
                    if (llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                        break;
                    }
                    stmt = jir.jir_store_node_next_sibling[stmt];
                }
            } else {
                llvm_emit_stmt(function_ref, return_type, else_body, exit_block);
            }
            if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
                llvm.build_br(llvm_builder, after_block);
            }
        }

        llvm.position_builder(llvm_builder, after_block);
        return;
    }
    if (kind == jir.JirNode.break_stmt) {
        Int target = llvm_current_break_block();
        if (target == 0) {
            diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[stmt_node], jir.jir_store_node_ends[stmt_node], "llvm backend break outside loop");
            return;
        }
        llvm.build_br(llvm_builder, target);
        return;
    }
    if (kind == jir.JirNode.continue_stmt) {
        Int target = llvm_current_continue_block();
        if (target == 0) {
            diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[stmt_node], jir.jir_store_node_ends[stmt_node], "llvm backend continue outside loop");
            return;
        }
        llvm.build_br(llvm_builder, target);
        return;
    }
    diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[stmt_node], jir.jir_store_node_ends[stmt_node], "llvm backend unsupported statement");
}

() llvm_declare_function(Int func_node) {
    Int type_node = jir.jir_store_node_first_child[func_node];
    Int name_node = jir.jir_store_node_next_sibling[type_node];
    Int child = jir.jir_store_node_next_sibling[name_node];
    Int param_types = ints.buffer_int_new(8);
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] != jir.JirNode.param) {
            break;
        }
        Int param_type = jir.jir_store_node_first_child[child];
        ints.buffer_int_push(param_types, llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[param_type], 0));
        child = jir.jir_store_node_next_sibling[child];
    }
    Int fn_type = llvm.function_type(
        llvm_type_ref_from_type_node(type_node, llvm_is_main_name(name_node)),
        ints.buffer_int_slice(param_types),
        0
    );
    Int func_symbol = jir.jir_store_node_symbol_ids[func_node];
    Int name_id = llvm_symbol_name_id(func_symbol);
    if (llvm_find_function_ref_by_name_id(name_id) != 0) {
        return;
    }
    UInt8[] fn_name = llvm_node_text(name_node);
    if (llvm_symbol_is_struct_static_func(func_symbol) != 0) {
        fn_name = llvm_struct_method_name(func_symbol);
    } else if (llvm_symbol_is_struct_instance_func(func_symbol) != 0) {
        fn_name = llvm_struct_method_name(func_symbol);
    }
    Int fn_ref = llvm.add_function(llvm_module, fn_name, fn_type);
    llvm_register_named_function(name_id, fn_ref, fn_type);
}

Int llvm_struct_init_into_name_id(Int owner_symbol) {
    return llvm_struct_helper_name_id(owner_symbol, "_init_into");
}

Int llvm_struct_init_name_id(Int owner_symbol) {
    return llvm_struct_helper_name_id(owner_symbol, "_init");
}

Int llvm_struct_new_name_id(Int owner_symbol) {
    return llvm_struct_helper_name_id(owner_symbol, "_new");
}

Int llvm_struct_new_value_name_id(Int owner_symbol) {
    return llvm_struct_helper_name_id(owner_symbol, "_new_value");
}

() llvm_declare_struct_new_value_wrapper(Int struct_node) {
    Int owner_symbol = jir.jir_store_node_symbol_ids[struct_node];
    Int owner_type = jir.jir_store_node_type_ids[struct_node];
    Int name_id = llvm_struct_new_value_name_id(owner_symbol);
    if (llvm_find_function_ref_by_name_id(name_id) != 0) {
        return;
    }
    Int param_types = ints.buffer_int_new(1);
    ints.buffer_int_push(param_types, llvm_type_ref_from_type_id(owner_type, 0));
    Int fn_type = llvm.function_type(
        llvm.type_ptr(llvm_type_ref_from_type_id(owner_type, 0)),
        ints.buffer_int_slice(param_types),
        0
    );
    Int fn_ref = llvm.add_function(llvm_module, llvm_struct_helper_name(owner_symbol, "_new_value"), fn_type);
    llvm_register_named_function(name_id, fn_ref, fn_type);
}

() llvm_declare_struct_init_wrappers(Int struct_node) {
    Int init_node = llvm_find_struct_init(struct_node);
    if (init_node == 0) {
        return;
    }
    Int owner_symbol = jir.jir_store_node_symbol_ids[struct_node];
    Int owner_type = jir.jir_store_node_type_ids[struct_node];
    Int owner_ptr_type = llvm.type_ptr(llvm_type_ref_from_type_id(owner_type, 0));
    Int explicit_param_types = ints.buffer_int_new(8);
    Int child = jir.jir_store_node_first_child[init_node];
    child = jir.jir_store_node_next_sibling[child];
    child = jir.jir_store_node_next_sibling[child];
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] != jir.JirNode.param) {
            break;
        }
        Int param_type = jir.jir_store_node_first_child[child];
        ints.buffer_int_push(explicit_param_types, llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[param_type], 0));
        child = jir.jir_store_node_next_sibling[child];
    }

    Int into_name_id = llvm_struct_init_into_name_id(owner_symbol);
    if (llvm_find_function_ref_by_name_id(into_name_id) == 0) {
        Int into_param_types = ints.buffer_int_new(8);
        ints.buffer_int_push(into_param_types, owner_ptr_type);
        child = 0;
        while (child < ints.buffer_int_length(explicit_param_types)) {
            ints.buffer_int_push(into_param_types, ints.buffer_int_get(explicit_param_types, child));
            child = child + 1;
        }
        Int into_type = llvm.function_type(llvm_void_type, ints.buffer_int_slice(into_param_types), 0);
        Int into_ref = llvm.add_function(llvm_module, llvm_struct_helper_name(owner_symbol, "_init_into"), into_type);
        llvm_register_named_function(into_name_id, into_ref, into_type);
    }

    Int init_name_id = llvm_struct_init_name_id(owner_symbol);
    if (llvm_find_function_ref_by_name_id(init_name_id) == 0) {
        Int init_type = llvm.function_type(
            llvm_type_ref_from_type_id(owner_type, 0),
            ints.buffer_int_slice(explicit_param_types),
            0
        );
        Int init_ref = llvm.add_function(llvm_module, llvm_struct_helper_name(owner_symbol, "_init"), init_type);
        llvm_register_named_function(init_name_id, init_ref, init_type);
    }

    Int new_name_id = llvm_struct_new_name_id(owner_symbol);
    if (llvm_find_function_ref_by_name_id(new_name_id) == 0) {
        Int new_type = llvm.function_type(
            owner_ptr_type,
            ints.buffer_int_slice(explicit_param_types),
            0
        );
        Int new_ref = llvm.add_function(llvm_module, llvm_struct_helper_name(owner_symbol, "_new"), new_type);
        llvm_register_named_function(new_name_id, new_ref, new_type);
    }
}

() llvm_define_struct_init_into(Int struct_node) {
    Int init_node = llvm_find_struct_init(struct_node);
    if (init_node == 0) {
        return;
    }
    Int owner_symbol = jir.jir_store_node_symbol_ids[struct_node];
    Int func_symbol = jir.jir_store_node_symbol_ids[init_node];
    Int fn_ref = llvm_find_function_ref_by_name_id(llvm_struct_init_into_name_id(owner_symbol));
    if (fn_ref == 0) {
        diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[init_node], jir.jir_store_node_ends[init_node], "llvm backend missing init_into helper");
        return;
    }
    llvm_current_function_ref = fn_ref;
    Int entry_block = llvm.append_block(llvm_context, fn_ref, "entry");
    llvm.position_builder(llvm_builder, entry_block);
    llvm_current_values = ints.buffer_int_new(128);
    llvm_entry_block = entry_block;

    Int self_symbol = symbols.symbol_store_find_symbol_by_name_id(
        interns.intern_pool_intern("self"),
        symbols.SymbolKind.param,
        func_symbol
    );
    if (self_symbol == 0) {
        diagnostic.diagnostic_error(llvm_source, jir.jir_store_node_starts[init_node], jir.jir_store_node_ends[init_node], "llvm backend missing init self");
        return;
    }
    llvm_current_init_self_symbol = self_symbol;
    Int self_ptr = llvm.build_alloca(
        llvm_builder,
        llvm_type_ref_from_type_id(symbols.symbol_store_type_ids[self_symbol], 0),
        "self"
    );
    llvm_set_value(self_symbol, self_ptr);
    llvm.build_store(llvm_builder, llvm.get_param(fn_ref, 0), self_ptr);

    Int child = jir.jir_store_node_first_child[init_node];
    child = jir.jir_store_node_next_sibling[child];
    child = jir.jir_store_node_next_sibling[child];
    Int param_index = 1;
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] != jir.JirNode.param) {
            break;
        }
        Int param_type_node = jir.jir_store_node_first_child[child];
        Int param_name_node = jir.jir_store_node_next_sibling[param_type_node];
        Int alloca_value = llvm.build_alloca(
            llvm_builder,
            llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[param_type_node], 0),
            llvm_node_text(param_name_node)
        );
        llvm_set_value(jir.jir_store_node_symbol_ids[child], alloca_value);
        llvm.build_store(llvm_builder, llvm.get_param(fn_ref, param_index), alloca_value);
        param_index = param_index + 1;
        child = jir.jir_store_node_next_sibling[child];
    }

    Int field = jir.jir_store_node_first_child[struct_node];
    field = jir.jir_store_node_next_sibling[field];
    while (field != 0) {
        if (jir.jir_store_node_kinds[field] == jir.JirNode.field_decl) {
            Int type_node = jir.jir_store_node_first_child[field];
            Int field_name = jir.jir_store_node_next_sibling[type_node];
            Int default_expr = jir.jir_store_node_next_sibling[field_name];
            if (default_expr != 0) {
                Int field_node = jir.jir_store_new_node(jir.JirNode.member_expr, jir.jir_store_node_starts[field], jir.jir_store_node_ends[field]);
                Int self_ident = jir.jir_store_new_node(jir.JirNode.ident, jir.jir_store_node_starts[field], jir.jir_store_node_ends[field]);
                jir.jir_store_set_symbol_id(self_ident, self_symbol);
                jir.jir_store_set_type_id(self_ident, symbols.symbol_store_type_ids[self_symbol]);
                Int field_ident = jir.jir_store_new_node(jir.JirNode.ident, jir.jir_store_node_starts[field_name], jir.jir_store_node_ends[field_name]);
                jir.jir_store_set_symbol_id(field_ident, jir.jir_store_node_symbol_ids[field]);
                jir.jir_store_set_type_id(field_ident, jir.jir_store_node_type_ids[field]);
                jir.jir_store_append_child(field_node, self_ident);
                jir.jir_store_append_child(field_node, field_ident);
                jir.jir_store_set_symbol_id(field_node, jir.jir_store_node_symbol_ids[field]);
                jir.jir_store_set_type_id(field_node, jir.jir_store_node_type_ids[field]);
                llvm_update_lvalue(field_node, llvm_emit_expr(default_expr));
            }
        }
        field = jir.jir_store_node_next_sibling[field];
    }

    Int block_node = child;
    Int stmt = jir.jir_store_node_first_child[block_node];
    while (stmt != 0) {
        llvm_emit_stmt(fn_ref, llvm_void_type, stmt, 0);
        stmt = jir.jir_store_node_next_sibling[stmt];
    }
    if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
        llvm.build_ret_void(llvm_builder);
    }
    llvm_current_init_self_symbol = 0;
}

() llvm_define_struct_init_value(Int struct_node) {
    Int init_node = llvm_find_struct_init(struct_node);
    if (init_node == 0) {
        return;
    }
    Int owner_symbol = jir.jir_store_node_symbol_ids[struct_node];
    Int owner_type = jir.jir_store_node_type_ids[struct_node];
    Int struct_ref = llvm_type_ref_from_type_id(owner_type, 0);
    Int fn_ref = llvm_find_function_ref_by_name_id(llvm_struct_init_name_id(owner_symbol));
    Int into_ref = llvm_find_function_ref_by_name_id(llvm_struct_init_into_name_id(owner_symbol));
    Int into_type = llvm_find_function_type_by_name_id(llvm_struct_init_into_name_id(owner_symbol));
    llvm_current_function_ref = fn_ref;
    llvm_current_init_self_symbol = 0;
    Int entry_block = llvm.append_block(llvm_context, fn_ref, "entry");
    llvm.position_builder(llvm_builder, entry_block);
    llvm_current_values = ints.buffer_int_new(32);
    llvm_entry_block = entry_block;
    Int tmp_ptr = llvm.build_alloca(llvm_builder, struct_ref, "init.tmp");
    llvm.build_store(llvm_builder, llvm.const_null(struct_ref), tmp_ptr);
    Int args = ints.buffer_int_new(8);
    ints.buffer_int_push(args, tmp_ptr);
    Int child = jir.jir_store_node_first_child[init_node];
    child = jir.jir_store_node_next_sibling[child];
    child = jir.jir_store_node_next_sibling[child];
    Int param_index = 0;
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] != jir.JirNode.param) {
            break;
        }
        ints.buffer_int_push(args, llvm.get_param(fn_ref, param_index));
        param_index = param_index + 1;
        child = jir.jir_store_node_next_sibling[child];
    }
    llvm.build_call(llvm_builder, into_type, into_ref, ints.buffer_int_slice(args), "");
    llvm.build_ret(llvm_builder, llvm.build_load(llvm_builder, struct_ref, tmp_ptr, "init.load"));
}

() llvm_define_struct_new(Int struct_node) {
    Int init_node = llvm_find_struct_init(struct_node);
    if (init_node == 0) {
        return;
    }
    Int owner_symbol = jir.jir_store_node_symbol_ids[struct_node];
    Int owner_type = jir.jir_store_node_type_ids[struct_node];
    Int struct_ref = llvm_type_ref_from_type_id(owner_type, 0);
    Int struct_ptr_type = llvm.type_ptr(struct_ref);
    Int fn_ref = llvm_find_function_ref_by_name_id(llvm_struct_new_name_id(owner_symbol));
    Int into_ref = llvm_find_function_ref_by_name_id(llvm_struct_init_into_name_id(owner_symbol));
    Int into_type = llvm_find_function_type_by_name_id(llvm_struct_init_into_name_id(owner_symbol));
    llvm_current_function_ref = fn_ref;
    llvm_current_init_self_symbol = 0;
    Int entry_block = llvm.append_block(llvm_context, fn_ref, "entry");
    llvm.position_builder(llvm_builder, entry_block);
    llvm_current_values = ints.buffer_int_new(32);
    llvm_entry_block = entry_block;
    Int malloc_args = ints.buffer_int_new(1);
    ints.buffer_int_push(malloc_args, llvm.const_i64(llvm_context, llvm_heap_alloc_size(owner_type)));
    Int raw_ptr = llvm.build_call(llvm_builder, llvm_malloc_type, llvm_malloc_ref, ints.buffer_int_slice(malloc_args), "malloc.ptr");
    Int typed_ptr = llvm.build_bitcast(llvm_builder, raw_ptr, struct_ptr_type, "malloc.typed");
    llvm.build_store(llvm_builder, llvm.const_null(struct_ref), typed_ptr);
    Int args = ints.buffer_int_new(8);
    ints.buffer_int_push(args, typed_ptr);
    Int child = jir.jir_store_node_first_child[init_node];
    child = jir.jir_store_node_next_sibling[child];
    child = jir.jir_store_node_next_sibling[child];
    Int param_index = 0;
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] != jir.JirNode.param) {
            break;
        }
        ints.buffer_int_push(args, llvm.get_param(fn_ref, param_index));
        param_index = param_index + 1;
        child = jir.jir_store_node_next_sibling[child];
    }
    llvm.build_call(llvm_builder, into_type, into_ref, ints.buffer_int_slice(args), "");
    llvm.build_ret(llvm_builder, typed_ptr);
}

() llvm_define_struct_new_value(Int struct_node) {
    Int owner_symbol = jir.jir_store_node_symbol_ids[struct_node];
    Int owner_type = jir.jir_store_node_type_ids[struct_node];
    Int struct_ref = llvm_type_ref_from_type_id(owner_type, 0);
    Int struct_ptr_type = llvm.type_ptr(struct_ref);
    Int fn_ref = llvm_find_function_ref_by_name_id(llvm_struct_new_value_name_id(owner_symbol));
    llvm_current_function_ref = fn_ref;
    llvm_current_init_self_symbol = 0;
    Int entry_block = llvm.append_block(llvm_context, fn_ref, "entry");
    llvm.position_builder(llvm_builder, entry_block);
    llvm_current_values = ints.buffer_int_new(32);
    llvm_entry_block = entry_block;
    Int malloc_args = ints.buffer_int_new(1);
    ints.buffer_int_push(malloc_args, llvm.const_i64(llvm_context, llvm_heap_alloc_size(owner_type)));
    Int raw_ptr = llvm.build_call(llvm_builder, llvm_malloc_type, llvm_malloc_ref, ints.buffer_int_slice(malloc_args), "malloc.ptr");
    Int typed_ptr = llvm.build_bitcast(llvm_builder, raw_ptr, struct_ptr_type, "malloc.typed");
    llvm.build_store(llvm_builder, llvm.get_param(fn_ref, 0), typed_ptr);
    llvm.build_ret(llvm_builder, typed_ptr);
}

() llvm_define_function(Int func_node) {
    Int type_node = jir.jir_store_node_first_child[func_node];
    Int name_node = jir.jir_store_node_next_sibling[type_node];
    Int func_symbol = jir.jir_store_node_symbol_ids[func_node];
    Int name_id = llvm_symbol_name_id(func_symbol);
    Int fn_ref = llvm_find_function_ref_by_name_id(name_id);
    llvm_current_function_ref = fn_ref;
    llvm_current_init_self_symbol = 0;
    Int return_type = llvm_type_ref_from_type_node(type_node, llvm_is_main_name(name_node));
    Int entry_block = llvm.append_block(llvm_context, fn_ref, "entry");
    llvm.position_builder(llvm_builder, entry_block);
    llvm_current_values = ints.buffer_int_new(128);
    llvm_entry_block = entry_block;

    Int child = jir.jir_store_node_next_sibling[name_node];
    Int param_index = 0;
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] != jir.JirNode.param) {
            break;
        }
        Int param_type_node = jir.jir_store_node_first_child[child];
        Int param_name_node = jir.jir_store_node_next_sibling[param_type_node];
        Int alloca_value = llvm.build_alloca(
            llvm_builder,
            llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[param_type_node], 0),
            llvm_node_text(param_name_node)
        );
        llvm_set_value(jir.jir_store_node_symbol_ids[child], alloca_value);
        llvm.build_store(llvm_builder, llvm.get_param(fn_ref, param_index), alloca_value);
        param_index = param_index + 1;
        child = jir.jir_store_node_next_sibling[child];
    }

    Int block_node = child;
    Int stmt = jir.jir_store_node_first_child[block_node];
    while (stmt != 0) {
        llvm_emit_stmt(fn_ref, return_type, stmt, 0);
        stmt = jir.jir_store_node_next_sibling[stmt];
    }

    if (!llvm.block_has_terminator(llvm.current_block(llvm_builder))) {
        if (return_type == llvm_void_type) {
            llvm.build_ret_void(llvm_builder);
        } else if (return_type == llvm_i32_type) {
            llvm.build_ret(llvm_builder, llvm.const_i32(llvm_context, 0));
        } else if (jir.jir_store_node_type_ids[type_node] < types.type_store_count) {
            Int return_kind = types.type_store_kinds[jir.jir_store_node_type_ids[type_node]];
            if (return_kind == types.TypeKind.struct_type) {
                llvm.build_ret(
                    llvm_builder,
                    llvm.const_undef(llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[type_node], 0))
                );
            } else if (return_kind == types.TypeKind.union_type) {
                llvm.build_ret(
                    llvm_builder,
                    llvm.const_undef(llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[type_node], 0))
                );
            } else if (return_kind == types.TypeKind.tuple) {
                llvm.build_ret(
                    llvm_builder,
                    llvm.const_undef(llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[type_node], 0))
                );
            } else if (return_kind == types.TypeKind.optional) {
                llvm.build_ret(
                    llvm_builder,
                    llvm.const_undef(llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[type_node], 0))
                );
            } else if (return_kind == types.TypeKind.slice) {
                llvm.build_ret(
                    llvm_builder,
                    llvm.const_undef(llvm_type_ref_from_type_id(jir.jir_store_node_type_ids[type_node], 0))
                );
            } else {
                llvm.build_ret(llvm_builder, llvm.const_i64(llvm_context, 0));
            }
        } else {
            llvm.build_ret(llvm_builder, llvm.const_i64(llvm_context, 0));
        }
    }
}

Bool llvm_is_struct_method_node(Int func_node) {
    Int symbol_id = jir.jir_store_node_symbol_ids[func_node];
    if (llvm_symbol_is_struct_static_func(symbol_id) != 0) {
        return 1;
    }
    return llvm_symbol_is_struct_instance_func(symbol_id);
}

Int llvm_nominal_member_start(Int node_id) {
    if (jir.jir_store_node_kinds[node_id] == jir.JirNode.union_decl) {
        return llvm_union_first_member(node_id);
    }
    Int child = jir.jir_store_node_first_child[node_id];
    return jir.jir_store_node_next_sibling[child];
}

() llvm_declare_nominal_methods(Int node_id) {
    Int child = llvm_nominal_member_start(node_id);
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] == jir.JirNode.func_decl) {
            if (llvm_is_generic_decl(child) == 0) {
                if (llvm_is_struct_method_node(child) != 0) {
                    llvm_declare_function(child);
                }
            }
        }
        child = jir.jir_store_node_next_sibling[child];
    }
}

() llvm_define_nominal_methods(Int node_id) {
    Int child = llvm_nominal_member_start(node_id);
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] == jir.JirNode.func_decl) {
            if (llvm_is_generic_decl(child) == 0) {
                if (llvm_is_struct_method_node(child) != 0) {
                    llvm_define_function(child);
                }
            }
        }
        child = jir.jir_store_node_next_sibling[child];
    }
}

public () emit_llvm_begin() {
    llvm_context = llvm.context_create();
    llvm_module = llvm.module_create(llvm_context, "jiang_stage2");
    llvm_builder = llvm.builder_create(llvm_context);
    llvm_void_type = llvm.type_void(llvm_context);
    llvm_i1_type = llvm.type_i1(llvm_context);
    llvm_i8_type = llvm.type_i8(llvm_context);
    llvm_i8_ptr_type = llvm.type_ptr(llvm_i8_type);
    llvm_i32_type = llvm.type_i32(llvm_context);
    llvm_i64_type = llvm.type_i64(llvm_context);
    Int malloc_params = ints.buffer_int_new(1);
    ints.buffer_int_push(malloc_params, llvm_i64_type);
    llvm_malloc_type = llvm.function_type(llvm_i8_ptr_type, ints.buffer_int_slice(malloc_params), 0);
    llvm_malloc_ref = llvm.add_function(llvm_module, "malloc", llvm_malloc_type);
    Int free_params = ints.buffer_int_new(1);
    ints.buffer_int_push(free_params, llvm_i8_ptr_type);
    llvm_free_type = llvm.function_type(llvm_void_type, ints.buffer_int_slice(free_params), 0);
    llvm_free_ref = llvm.add_function(llvm_module, "free", llvm_free_type);
    Int memmove_params = ints.buffer_int_new(3);
    ints.buffer_int_push(memmove_params, llvm_i8_ptr_type);
    ints.buffer_int_push(memmove_params, llvm_i8_ptr_type);
    ints.buffer_int_push(memmove_params, llvm_i64_type);
    llvm_memmove_type = llvm.function_type(llvm_void_type, ints.buffer_int_slice(memmove_params), 0);
    llvm_memmove_ref = llvm.add_function(llvm_module, "memmove", llvm_memmove_type);
    llvm_slice_uint8_type = llvm.type_struct_named(llvm_context, "Slice_uint8_t");
    llvm_slice_int64_type = llvm.type_struct_named(llvm_context, "Slice_int64_t");
    llvm_string_scratch = bytes.buffer_bytes_new(256);
    bytes.buffer_bytes_clear(llvm_string_scratch);
    llvm_name_scratch = bytes.buffer_bytes_new(64);
    bytes.buffer_bytes_clear(llvm_name_scratch);
    Int slice_uint8_fields = ints.buffer_int_new(2);
    ints.buffer_int_push(slice_uint8_fields, llvm_i8_ptr_type);
    ints.buffer_int_push(slice_uint8_fields, llvm_i64_type);
    llvm.type_struct_set_body(llvm_slice_uint8_type, ints.buffer_int_slice(slice_uint8_fields));
    Int slice_int64_fields = ints.buffer_int_new(2);
    ints.buffer_int_push(slice_int64_fields, llvm.type_ptr(llvm_i64_type));
    ints.buffer_int_push(slice_int64_fields, llvm_i64_type);
    llvm.type_struct_set_body(llvm_slice_int64_type, ints.buffer_int_slice(slice_int64_fields));
    emit_llvm_reset_context();
}

public Bool emit_llvm_append_program(UInt8[] source, UInt8[] path, Int root) {
    llvm_source = source;
    llvm_root = root;

    llvm_register_tuple_types();
    llvm_register_slice_types();
    llvm_register_optional_types();

    Int child = jir.jir_store_node_first_child[root];
    while (child != 0) {
        Int kind = jir.jir_store_node_kinds[child];
        if (kind == jir.JirNode.struct_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_register_struct_type(child, path);
            }
        }
        if (kind == jir.JirNode.union_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_register_union_type(child, path);
            }
        }
        if (kind == jir.JirNode.global_decl) {
            llvm_declare_global(child);
        }
        if (kind == jir.JirNode.tuple_global_decl) {
            Int part = jir.jir_store_node_first_child[child];
            while (part != 0) {
                llvm_declare_global(part);
                part = jir.jir_store_node_next_sibling[part];
            }
        }
        if (kind == jir.JirNode.func_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_declare_function(child);
            }
        }
        if (kind == jir.JirNode.struct_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_declare_struct_new_value_wrapper(child);
                llvm_declare_struct_init_wrappers(child);
                llvm_declare_nominal_methods(child);
            }
        }
        if (kind == jir.JirNode.union_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_declare_nominal_methods(child);
            }
        }
        if (kind == jir.JirNode.enum_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_declare_nominal_methods(child);
            }
        }
        child = jir.jir_store_node_next_sibling[child];
    }

    child = jir.jir_store_node_first_child[root];
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] == jir.JirNode.struct_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_define_struct_body(child, path);
            }
        }
        if (jir.jir_store_node_kinds[child] == jir.JirNode.union_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_define_union_body(child, path);
            }
        }
        child = jir.jir_store_node_next_sibling[child];
    }

    llvm_define_slice_types();
    llvm_define_tuple_types();
    llvm_define_optional_types();

    child = jir.jir_store_node_first_child[root];
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] == jir.JirNode.global_decl) {
            llvm_define_global(child);
        }
        if (jir.jir_store_node_kinds[child] == jir.JirNode.tuple_global_decl) {
            Int part = jir.jir_store_node_first_child[child];
            while (part != 0) {
                llvm_define_global(part);
                part = jir.jir_store_node_next_sibling[part];
            }
        }
        child = jir.jir_store_node_next_sibling[child];
    }

    child = jir.jir_store_node_first_child[root];
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] == jir.JirNode.struct_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_define_struct_new_value(child);
                llvm_define_struct_init_into(child);
                llvm_define_struct_init_value(child);
                llvm_define_struct_new(child);
            }
        }
        if (jir.jir_store_node_kinds[child] == jir.JirNode.func_decl) {
            if (!llvm_is_generic_decl(child)) {
                if (!llvm_is_extern_func(child)) {
                    llvm_define_function(child);
                }
            }
        }
        if (jir.jir_store_node_kinds[child] == jir.JirNode.struct_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_define_nominal_methods(child);
            }
        }
        if (jir.jir_store_node_kinds[child] == jir.JirNode.union_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_define_nominal_methods(child);
            }
        }
        if (jir.jir_store_node_kinds[child] == jir.JirNode.enum_decl) {
            if (!llvm_is_generic_decl(child)) {
                llvm_define_nominal_methods(child);
            }
        }
        child = jir.jir_store_node_next_sibling[child];
    }

    if (diagnostic.diagnostic_has_error()) {
        return 0;
    }
    return 1;
}

public Bool emit_llvm_finish() {
    if (diagnostic.diagnostic_has_error()) {
        return 0;
    }
    if (!llvm.verify_module(llvm_module)) {
        diagnostic.diagnostic_error(llvm_source, 0, 0, "llvm verify failed");
        return 0;
    }
    llvm.print_module(llvm_module);
    return 1;
}

public Bool emit_llvm_program(UInt8[] source, Int root) {
    emit_llvm_begin();
    if (!emit_llvm_append_program(source, "", root)) {
        return 0;
    }
    return emit_llvm_finish();
}
