Int llvm_malloc_type = 0;
Int llvm_free_ref = 0;
Int llvm_free_type = 0;
Int llvm_memmove_ref = 0;
Int llvm_memmove_type = 0;
Int llvm_current_init_self_symbol = 0;

Bool llvm_is_ident_char(UInt8 value) {
    if (value >= 48) {
        if (value <= 57) {
            return 1;
        }
    }
    if (value >= 65) {
        if (value <= 90) {
            return 1;
        }
    }
    if (value >= 97) {
        if (value <= 122) {
            return 1;
        }
    }
    return value == 95;
}

UInt8[] llvm_slice_type_name(Int type_id) {
    Int buffer = text.text_buffer_new(16);
    text.text_buffer_clear(buffer);
    text.text_buffer_push_text(buffer, "Slice_");
    Int value = type_id;
    if (value == 0) {
        text.text_buffer_push_text(buffer, "0_t");
        return text.text_buffer_slice(buffer);
    }
    if (value < 0) {
        text.text_buffer_push_text(buffer, "_");
        value = 0 - value;
    }
    Int divisor = 1;
    UInt8[] digits = "0123456789";
    while (divisor <= value / 10) {
        divisor = divisor * 10;
    }
    while (divisor > 0) {
        text.text_buffer_push_byte(buffer, digits[value / divisor]);
        value = value - (value / divisor) * divisor;
        divisor = divisor / 10;
    }
    text.text_buffer_push_text(buffer, "_t");
    return text.text_buffer_slice(buffer);
}

Int llvm_slice_type_ref(Int type_id) {
    if (type_id == 0) {
        return 0;
    }
    if (type_id < ints.buffer_int_length(llvm_slice_type_refs)) {
        return ints.buffer_int_get(llvm_slice_type_refs, type_id);
    }
    return 0;
}

UInt8[] llvm_optional_type_name(Int type_id) {
    Int buffer = text.text_buffer_new(16);
    text.text_buffer_clear(buffer);
    text.text_buffer_push_text(buffer, "Optional_");
    Int value = type_id;
    if (value == 0) {
        text.text_buffer_push_text(buffer, "0_t");
        return text.text_buffer_slice(buffer);
    }
    if (value < 0) {
        text.text_buffer_push_text(buffer, "_");
        value = 0 - value;
    }
    Int divisor = 1;
    UInt8[] digits = "0123456789";
    while (divisor <= value / 10) {
        divisor = divisor * 10;
    }
    while (divisor > 0) {
        text.text_buffer_push_byte(buffer, digits[value / divisor]);
        value = value - (value / divisor) * divisor;
        divisor = divisor / 10;
    }
    text.text_buffer_push_text(buffer, "_t");
    return text.text_buffer_slice(buffer);
}

Int llvm_optional_type_ref(Int type_id) {
    if (type_id == 0) {
        return 0;
    }
    if (type_id < ints.buffer_int_length(llvm_optional_type_refs)) {
        return ints.buffer_int_get(llvm_optional_type_refs, type_id);
    }
    return 0;
}

Int llvm_member_base_type(Int type_id) {
    type_id = llvm_strip_mutable_type(type_id);
    if (type_id > 0) {
        if (type_id < types.type_store_count) {
            if (types.type_store_kinds[type_id] == types.TypeKind.pointer) {
                return llvm_strip_mutable_type(types.type_store_elem_type_ids[type_id]);
            }
        }
    }
    return type_id;
}

UInt8[] llvm_tuple_type_name(Int type_id) {
    Int buffer = text.text_buffer_new(16);
    text.text_buffer_clear(buffer);
    text.text_buffer_push_text(buffer, "Tuple_");
    Int value = type_id;
    if (value == 0) {
        text.text_buffer_push_text(buffer, "0");
        return text.text_buffer_slice(buffer);
    }
    if (value < 0) {
        text.text_buffer_push_text(buffer, "_");
        value = 0 - value;
    }
    Int divisor = 1;
    UInt8[] digits = "0123456789";
    while (divisor <= value / 10) {
        divisor = divisor * 10;
    }
    while (divisor > 0) {
        text.text_buffer_push_byte(buffer, digits[value / divisor]);
        value = value - (value / divisor) * divisor;
        divisor = divisor / 10;
    }
    return text.text_buffer_slice(buffer);
}

UInt8[] llvm_struct_helper_name(Int owner_symbol, UInt8[] suffix) {
    Int buffer = text.text_buffer_new(32);
    text.text_buffer_clear(buffer);
    Int module_id = symbols.symbol_store_module_ids[owner_symbol];
    if (module_id > 0) {
        UInt8[] path = module_loader.module_loader_module_path(module_id);
        text.text_buffer_push_text(buffer, "_m_");
        Int i = 0;
        while (i < path.length) {
            if (llvm_is_ident_char(path[i])) {
                text.text_buffer_push_byte(buffer, path[i]);
            } else {
                text.text_buffer_push_text(buffer, "_");
            }
            i = i + 1;
        }
        text.text_buffer_push_text(buffer, "__");
    }
    text.text_buffer_push_text(buffer, interns.intern_pool_value(symbols.symbol_store_name_ids[owner_symbol]));
    text.text_buffer_push_text(buffer, suffix);
    return text.text_buffer_slice(buffer);
}

Int llvm_struct_helper_name_id(Int owner_symbol, UInt8[] suffix) {
    return interns.intern_pool_intern(llvm_struct_helper_name(owner_symbol, suffix));
}

Bool llvm_symbol_is_struct_static_func(Int symbol_id) {
    if (symbol_id == 0) {
        return 0;
    }
    if (symbols.symbol_store_kinds[symbol_id] != symbols.SymbolKind.func) {
        return 0;
    }
    return symbols.symbol_store_aux[symbol_id] == symbols.func_aux_struct_static;
}

Bool llvm_symbol_is_struct_instance_func(Int symbol_id) {
    if (symbol_id == 0) {
        return 0;
    }
    if (symbols.symbol_store_kinds[symbol_id] != symbols.SymbolKind.func) {
        return 0;
    }
    return symbols.symbol_store_aux[symbol_id] == symbols.func_aux_struct_instance;
}

UInt8[] llvm_struct_method_name(Int symbol_id) {
    Int owner_symbol = symbols.symbol_store_parent_ids[symbol_id];
    Int buffer = text.text_buffer_new(32);
    text.text_buffer_clear(buffer);
    text.text_buffer_push_text(buffer, llvm_struct_helper_name(owner_symbol, "_"));
    text.text_buffer_push_text(buffer, interns.intern_pool_value(symbols.symbol_store_name_ids[symbol_id]));
    return text.text_buffer_slice(buffer);
}

Int llvm_struct_method_name_id(Int symbol_id) {
    return interns.intern_pool_intern(llvm_struct_method_name(symbol_id));
}

Int llvm_find_tuple_type_ref(Int type_id) {
    if (type_id < 0) {
        return 0;
    }
    if (type_id >= ints.buffer_int_length(llvm_tuple_type_refs)) {
        return 0;
    }
    return ints.buffer_int_get(llvm_tuple_type_refs, type_id);
}

Int llvm_find_struct_init(Int struct_node) {
    Int child = jir.jir_store_node_first_child[struct_node];
    child = jir.jir_store_node_next_sibling[child];
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] == jir.JirNode.func_decl) {
            Int symbol_id = jir.jir_store_node_symbol_ids[child];
            if (symbol_id != 0) {
                if (symbols.symbol_store_kinds[symbol_id] == symbols.SymbolKind.func) {
                    if (symbols.symbol_store_parent_ids[symbol_id] == jir.jir_store_node_symbol_ids[struct_node]) {
                        if (symbols.symbol_store_name_ids[symbol_id] == interns.intern_pool_intern("init")) {
                            return child;
                        }
                    }
                }
            }
        }
        child = jir.jir_store_node_next_sibling[child];
    }
    return 0;
}

Int llvm_function_name_ids = 0;
