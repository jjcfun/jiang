import jir = "../../ir/jir/jir_store.jiang";
import text = "../../support/text_buffer.jiang";
import ints = "../../support/buffer_int.jiang";
import interns = "../../support/intern_pool.jiang";
import types = "../../frontend/type_store.jiang";
import symbols = "../../frontend/symbol_store.jiang";
import module_loader = "../../frontend/module_loader.jiang";

Bool emit_c_is_ident_char(UInt8 value) {
    if (value >= 48) {
        if (value <= 57) {
            return 1;
        }
    }
    if (value >= 65) {
        if (value <= 90) {
            return 1;
        }
    }
    if (value >= 97) {
        if (value <= 122) {
            return 1;
        }
    }
    return value == 95;
}

Int emit_c_string_lit_decoded_byte(UInt8[] source, Int index, Int end_pos) {
    if (source[index] != 92) {
        return source[index];
    }
    if (index + 1 >= end_pos) {
        return 92;
    }
    UInt8 escaped = source[index + 1];
    if (escaped == 110) {
        return 10;
    }
    if (escaped == 114) {
        return 13;
    }
    if (escaped == 116) {
        return 9;
    }
    if (escaped == 48) {
        return 0;
    }
    if (escaped == 34) {
        return 34;
    }
    if (escaped == 39) {
        return 39;
    }
    if (escaped == 92) {
        return 92;
    }
    return escaped;
}

Int emit_c_string_lit_next_index(UInt8[] source, Int index, Int end_pos) {
    if (source[index] == 92) {
        if (index + 1 < end_pos) {
            return index + 2;
        }
    }
    return index + 1;
}

() emit_c_buffer_push_module_prefix(Int buffer, Int module_id) {
    text.text_buffer_push_text(buffer, "_m_");
    UInt8[] path = module_loader.module_loader_module_path(module_id);
    Int i = 0;
    while (i < path.length) {
        if (emit_c_is_ident_char(path[i])) {
            text.text_buffer_push_byte(buffer, path[i]);
        } else {
            text.text_buffer_push_text(buffer, "_");
        }
        i = i + 1;
    }
    text.text_buffer_push_text(buffer, "__");
}

Bool emit_c_span_eq(UInt8[] source, Int start, Int end_pos, UInt8[] expected) {
    if (end_pos - start != expected.length) {
        return 0;
    }
    Int i = 0;
    while (i < expected.length) {
        if (source[start + i] != expected[i]) {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

() emit_c_buffer_push_span(Int buffer, UInt8[] source, Int start, Int end_pos) {
    Int i = start;
    while (i < end_pos) {
        text.text_buffer_push_byte(buffer, source[i]);
        i = i + 1;
    }
}

Bool emit_c_is_main_name(UInt8[] source, Int node_id) {
    return emit_c_span_eq(
        source,
        jir.jir_store_node_starts[node_id],
        jir.jir_store_node_ends[node_id],
        "main"
    );
}

Bool emit_c_member_name_is(UInt8[] source, Int node_id, UInt8[] expected) {
    return emit_c_span_eq(
        source,
        jir.jir_store_node_starts[node_id],
        jir.jir_store_node_ends[node_id],
        expected
    );
}

() emit_c_buffer_push_name_id(Int buffer, Int name_id) {
    text.text_buffer_push_text(buffer, interns.intern_pool_value(name_id));
}

Bool emit_c_symbol_name_is(Int symbol_id, UInt8[] expected) {
    if (symbol_id == 0) {
        return 0;
    }
    UInt8[] name = interns.intern_pool_value(symbols.symbol_store_name_ids[symbol_id]);
    if (name.length != expected.length) {
        return 0;
    }
    Int i = 0;
    while (i < expected.length) {
        if (name[i] != expected[i]) {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

Bool emit_c_symbol_should_mangle(Int symbol_id) {
    if (symbol_id == 0) {
        return 0;
    }
    symbol_id = symbols.symbol_store_resolve_target(symbol_id);
    if (symbols.symbol_store_parent_ids[symbol_id] != 0) {
        return 0;
    }
    Int kind = symbols.symbol_store_kinds[symbol_id];
    if (kind != symbols.SymbolKind.func) {
        if (kind != symbols.SymbolKind.global) {
            if (kind != symbols.SymbolKind.type_name) {
                if (kind != symbols.SymbolKind.enum_name) {
                    return 0;
                }
            }
        }
    }
    if (emit_c_symbol_name_is(symbol_id, "main")) {
        return 0;
    }
    if (emit_c_symbol_name_is(symbol_id, "compile_entry")) {
        return 0;
    }
    if (emit_c_symbol_name_is(symbol_id, "compile_entry_llvm")) {
        return 0;
    }
    if (emit_c_symbol_name_is(symbol_id, "__intrinsic_assert")) {
        return 0;
    }
    if (emit_c_symbol_name_is(symbol_id, "__intrinsic_file_exists")) {
        return 0;
    }
    if (emit_c_symbol_name_is(symbol_id, "__intrinsic_read_file")) {
        return 0;
    }
    if (emit_c_symbol_name_is(symbol_id, "__intrinsic_write_stdout")) {
        return 0;
    }
    return !emit_c_symbol_name_is(symbol_id, "print");
}

() emit_c_buffer_push_symbol_name(Int buffer, Int symbol_id) {
    symbol_id = symbols.symbol_store_resolve_target(symbol_id);
    if (emit_c_symbol_name_is(symbol_id, "print") != 0) {
        text.text_buffer_push_text(buffer, "__intrinsic_print");
        return;
    }
    if (emit_c_symbol_should_mangle(symbol_id)) {
        emit_c_buffer_push_module_prefix(buffer, symbols.symbol_store_module_ids[symbol_id]);
    }
    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[symbol_id]);
}

() emit_c_buffer_push_loop_name(Int buffer, UInt8[] source, Int stmt_node, Int name_node) {
    Int symbol_id = jir.jir_store_node_symbol_ids[stmt_node];
    if (symbol_id != 0) {
        emit_c_buffer_push_symbol_name(buffer, symbol_id);
        return;
    }
    emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
}

() emit_c_buffer_push_type_name(Int buffer, Int type_id) {
    type_id = emit_c_strip_mutable_type(type_id);
    if (type_id > 0) {
        if (type_id < types.type_store_count) {
            if (types.type_store_kinds[type_id] == types.TypeKind.tuple) {
                text.text_buffer_push_text(buffer, "Tuple_");
                emit_c_buffer_push_int(buffer, type_id);
                return;
            }
            if (types.type_store_kinds[type_id] == types.TypeKind.optional) {
                emit_c_optional_type_name(buffer, type_id);
                return;
            }
        }
    }
    Int owner_symbol = 0;
    Int symbol_id = 1;
    while (symbol_id < symbols.symbol_store_count) {
        if (symbols.symbol_store_type_ids[symbol_id] == type_id) {
            if (symbols.symbol_store_parent_ids[symbol_id] == 0) {
                Int kind = symbols.symbol_store_kinds[symbol_id];
                if (kind == symbols.SymbolKind.type_name) {
                    owner_symbol = symbol_id;
                    break;
                }
                if (kind == symbols.SymbolKind.enum_name) {
                    owner_symbol = symbol_id;
                    break;
                }
            }
        }
        symbol_id = symbol_id + 1;
    }
    if (owner_symbol != 0) {
        emit_c_buffer_push_symbol_name(buffer, owner_symbol);
        return;
    }
    emit_c_buffer_push_name_id(buffer, types.type_store_name_ids[type_id]);
}

() emit_c_buffer_push_slice_type_suffix(Int buffer, Int type_id) {
    text.text_buffer_push_text(buffer, "Slice_");
    emit_c_buffer_push_int(buffer, type_id);
    text.text_buffer_push_text(buffer, "_t");
}

() emit_c_tuple_field_name(Int buffer, Int index) {
    text.text_buffer_push_text(buffer, "_");
    emit_c_buffer_push_int(buffer, index);
}

() emit_c_buffer_push_int(Int buffer, Int value) {
    if (value < 0) {
        text.text_buffer_push_text(buffer, "-");
        emit_c_buffer_push_int(buffer, 0 - value);
        return;
    }
    if (value >= 10) {
        emit_c_buffer_push_int(buffer, value / 10);
    }
    Int digit = value;
    if (value >= 10) {
        digit = value - ((value / 10) * 10);
    }
    if (digit == 0) {
        text.text_buffer_push_text(buffer, "0");
        return;
    }
    if (digit == 1) {
        text.text_buffer_push_text(buffer, "1");
        return;
    }
    if (digit == 2) {
        text.text_buffer_push_text(buffer, "2");
        return;
    }
    if (digit == 3) {
        text.text_buffer_push_text(buffer, "3");
        return;
    }
    if (digit == 4) {
        text.text_buffer_push_text(buffer, "4");
        return;
    }
    if (digit == 5) {
        text.text_buffer_push_text(buffer, "5");
        return;
    }
    if (digit == 6) {
        text.text_buffer_push_text(buffer, "6");
        return;
    }
    if (digit == 7) {
        text.text_buffer_push_text(buffer, "7");
        return;
    }
    if (digit == 8) {
        text.text_buffer_push_text(buffer, "8");
        return;
    }
    text.text_buffer_push_text(buffer, "9");
}

Bool emit_c_is_slice_type(Int type_id) {
    while (type_id > 0) {
        if (type_id >= types.type_store_count) {
            return 0;
        }
        if (types.type_store_kinds[type_id] != types.TypeKind.mutable) {
            break;
        }
        type_id = types.type_store_elem_type_ids[type_id];
    }
    if (type_id <= 0) {
        return 0;
    }
    if (type_id >= types.type_store_count) {
        return 0;
    }
    return types.type_store_kinds[type_id] == types.TypeKind.slice;
}

Bool emit_c_is_u8_slice_type(Int type_id) {
    if (emit_c_is_slice_type(type_id) == 0) {
        return 0;
    }
    return types.type_store_elem_type_ids[type_id] == types.type_store_builtin_uint8;
}

Bool emit_c_is_extern_func(Int func_node) {
    Int flags = jir.jir_store_node_aux[func_node];
    if (flags == 2) {
        return 1;
    }
    return flags == 3;
}

Bool emit_c_is_enum_type(Int type_id) {
    while (type_id > 0) {
        if (type_id >= types.type_store_count) {
            return 0;
        }
        if (types.type_store_kinds[type_id] != types.TypeKind.mutable) {
            break;
        }
        type_id = types.type_store_elem_type_ids[type_id];
    }
    if (type_id <= 0) {
        return 0;
    }
    if (type_id >= types.type_store_count) {
        return 0;
    }
    return types.type_store_kinds[type_id] == types.TypeKind.enum_type;
}

Int emit_c_strip_mutable_type(Int type_id) {
    Int current = type_id;
    while (current > 0) {
        if (current >= types.type_store_count) {
            return current;
        }
        if (types.type_store_kinds[current] != types.TypeKind.mutable) {
            return current;
        }
        current = types.type_store_elem_type_ids[current];
    }
    return current;
}

Bool emit_c_is_optional_type(Int type_id) {
    type_id = emit_c_strip_mutable_type(type_id);
    if (type_id <= 0) {
        return 0;
    }
    if (type_id >= types.type_store_count) {
        return 0;
    }
    return types.type_store_kinds[type_id] == types.TypeKind.optional;
}

() emit_c_optional_type_name(Int buffer, Int type_id) {
    text.text_buffer_push_text(buffer, "Optional_");
    emit_c_buffer_push_int(buffer, type_id);
    text.text_buffer_push_text(buffer, "_t");
}

() emit_c_optional_none_expr(Int buffer, Int type_id) {
    text.text_buffer_push_text(buffer, "(");
    emit_c_optional_type_name(buffer, type_id);
    text.text_buffer_push_text(buffer, "){ .is_some = 0 }");
}

() emit_c_optional_payload_value_expr(Int buffer, UInt8[] source, Int root, Int base_node) {
    source = source;
    root = root;
    text.text_buffer_push_text(buffer, "((");
    emit_c_expr_buffered(buffer, source, root, base_node);
    text.text_buffer_push_text(buffer, ").value)");
}

() emit_c_array_value_expr(Int buffer, UInt8[] source, Int root, Int node_id, Int array_type) {
    if (types.type_store_elem_type_ids[array_type] == types.type_store_builtin_uint8) {
        if (jir.jir_store_node_kinds[node_id] == jir.JirNode.string_lit) {
            emit_c_string_init_bytes(buffer, source, node_id);
            return;
        }
    }
    if (jir.jir_store_node_kinds[node_id] == jir.JirNode.array_init_expr) {
        emit_c_array_init_items_buffered(buffer, source, root, node_id);
        return;
    }
    emit_c_expr_buffered(buffer, source, root, node_id);
}

Bool emit_c_is_union_type(Int type_id) {
    if (type_id <= 0) {
        return 0;
    }
    if (type_id >= types.type_store_count) {
        return 0;
    }
    return types.type_store_kinds[type_id] == types.TypeKind.union_type;
}

Int emit_c_switch_case_binding(Int case_node) {
    Int label = jir.jir_store_node_first_child[case_node];
    if (label == 0) {
        return 0;
    }
    Int next = jir.jir_store_node_next_sibling[label];
    if (next == 0) {
        return 0;
    }
    if (jir.jir_store_node_next_sibling[next] != 0) {
        return next;
    }
    return 0;
}

Int emit_c_switch_case_body(Int case_node) {
    Int label = jir.jir_store_node_first_child[case_node];
    if (label == 0) {
        return 0;
    }
    Int next = jir.jir_store_node_next_sibling[label];
    if (next == 0) {
        return 0;
    }
    if (jir.jir_store_node_next_sibling[next] != 0) {
        return jir.jir_store_node_next_sibling[next];
    }
    return next;
}

Int emit_c_union_pattern_label(Int pattern_node) {
    return jir.jir_store_node_first_child[pattern_node];
}

Int emit_c_union_pattern_binding(Int pattern_node) {
    Int label = emit_c_union_pattern_label(pattern_node);
    if (label == 0) {
        return 0;
    }
    return jir.jir_store_node_next_sibling[label];
}

Int emit_c_union_pattern_binding_count(Int pattern_node) {
    Int bind = emit_c_union_pattern_binding(pattern_node);
    Int count = 0;
    while (bind != 0) {
        count = count + 1;
        bind = jir.jir_store_node_next_sibling[bind];
    }
    return count;
}

Int emit_c_union_pattern_binding_item(Int pattern_node, Int index) {
    Int bind = emit_c_union_pattern_binding(pattern_node);
    Int i = 0;
    while (bind != 0) {
        if (i == index) {
            return bind;
        }
        bind = jir.jir_store_node_next_sibling[bind];
        i = i + 1;
    }
    return 0;
}

() emit_c_type_id_buffered(Int buffer, Int type_id) {
    type_id = emit_c_strip_mutable_type(type_id);
    if (type_id == types.type_store_builtin_bool) {
        text.text_buffer_push_text(buffer, "int");
        return;
    }
    if (type_id == types.type_store_builtin_int) {
        text.text_buffer_push_text(buffer, "long long");
        return;
    }
    if (type_id == types.type_store_builtin_uint8) {
        text.text_buffer_push_text(buffer, "uint8_t");
        return;
    }
    if (emit_c_is_slice_type(type_id) != 0) {
        emit_c_slice_type_name(buffer, type_id);
        return;
    }
    if (emit_c_is_enum_type(type_id) != 0) {
        emit_c_buffer_push_type_name(buffer, type_id);
        return;
    }
    if (emit_c_is_optional_type(type_id) != 0) {
        emit_c_optional_type_name(buffer, type_id);
        return;
    }
    if (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.tuple) {
            emit_c_buffer_push_type_name(buffer, type_id);
            return;
        }
    }
    emit_c_buffer_push_type_name(buffer, type_id);
}

() emit_c_slice_type_name(Int buffer, Int type_id) {
    if (types.type_store_elem_type_ids[type_id] == types.type_store_builtin_uint8) {
        text.text_buffer_push_text(buffer, "Slice_uint8_t");
        return;
    }
    if (types.type_store_elem_type_ids[type_id] == types.type_store_builtin_int) {
        text.text_buffer_push_text(buffer, "Slice_int64_t");
        return;
    }
    emit_c_buffer_push_slice_type_suffix(buffer, type_id);
}

Bool emit_c_slice_uses_void_ptr(Int type_id) {
    Int elem_type = types.type_store_elem_type_ids[type_id];
    if (elem_type == types.type_store_builtin_uint8) {
        return 0;
    }
    return elem_type != types.type_store_builtin_int;
}

() emit_c_slice_elem_ptr_cast(Int buffer, Int type_id) {
    text.text_buffer_push_text(buffer, "(");
    emit_c_type_id_buffered(buffer, types.type_store_elem_type_ids[type_id]);
    text.text_buffer_push_text(buffer, "*)");
}

() emit_c_slice_decl(Int buffer, Int type_id) {
    text.text_buffer_push_text(buffer, "typedef struct {\n");
    text.text_buffer_push_text(buffer, "    ");
    if (emit_c_slice_uses_void_ptr(type_id) != 0) {
        text.text_buffer_push_text(buffer, "void* ptr;\n");
    } else {
        emit_c_type_id_buffered(buffer, types.type_store_elem_type_ids[type_id]);
        text.text_buffer_push_text(buffer, "* ptr;\n");
    }
    text.text_buffer_push_text(buffer, "    long long length;\n");
    text.text_buffer_push_text(buffer, "} ");
    emit_c_slice_type_name(buffer, type_id);
    text.text_buffer_push_text(buffer, ";\n\n");
}

public () emit_c_slice_prelude(Int buffer) {
    Int type_id = 1;
    while (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.slice) {
            emit_c_slice_decl(buffer, type_id);
        }
        type_id = type_id + 1;
    }
}

public () emit_c_nonbuiltin_slice_prelude(Int buffer) {
    Int type_id = 1;
    while (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.slice) {
            if (emit_c_slice_uses_void_ptr(type_id) != 0) {
                emit_c_slice_decl(buffer, type_id);
            }
        }
        type_id = type_id + 1;
    }
}

() emit_c_type_buffered(Int buffer, UInt8[] source, Int type_node) {
    Int type_id = jir.jir_store_node_type_ids[type_node];
    type_id = emit_c_strip_mutable_type(type_id);
    if (type_id == types.type_store_builtin_void) {
        text.text_buffer_push_text(buffer, "void");
        return;
    }
    if (type_id == types.type_store_builtin_bool) {
        text.text_buffer_push_text(buffer, "int");
        return;
    }
    if (type_id == types.type_store_builtin_int) {
        text.text_buffer_push_text(buffer, "long long");
        return;
    }
    if (type_id == types.type_store_builtin_uint8) {
        text.text_buffer_push_text(buffer, "uint8_t");
        return;
    }
    if (emit_c_is_slice_type(type_id) != 0) {
        emit_c_slice_type_name(buffer, type_id);
        return;
    }
    if (emit_c_is_optional_type(type_id) != 0) {
        emit_c_optional_type_name(buffer, type_id);
        return;
    }
    if (type_id != 0) {
        if (types.type_store_kinds[type_id] == types.TypeKind.pointer) {
            emit_c_type_buffered(buffer, source, jir.jir_store_node_first_child[type_node]);
            text.text_buffer_push_text(buffer, "*");
            return;
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.array) {
            emit_c_type_buffered(buffer, source, jir.jir_store_node_first_child[type_node]);
            return;
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.struct_type) {
            emit_c_buffer_push_type_name(buffer, type_id);
            return;
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.union_type) {
            emit_c_buffer_push_type_name(buffer, type_id);
            return;
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.enum_type) {
            emit_c_buffer_push_type_name(buffer, type_id);
            return;
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.tuple) {
            emit_c_buffer_push_type_name(buffer, type_id);
            return;
        }
    }
    Int builtin = types.type_store_builtin_from_name(
        source,
        jir.jir_store_node_starts[type_node],
        jir.jir_store_node_ends[type_node]
    );
    if (builtin == types.type_store_builtin_void) {
        text.text_buffer_push_text(buffer, "void");
        return;
    }
    if (builtin == types.type_store_builtin_bool) {
        text.text_buffer_push_text(buffer, "int");
        return;
    }
    if (builtin == types.type_store_builtin_int) {
        text.text_buffer_push_text(buffer, "long long");
        return;
    }
    if (builtin == types.type_store_builtin_uint8) {
        text.text_buffer_push_text(buffer, "uint8_t");
        return;
    }
    emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[type_node], jir.jir_store_node_ends[type_node]);
}

Int emit_c_decl_base_type_node(Int type_node) {
    Int current = type_node;
    while (1 == 1) {
        Int type_id = jir.jir_store_node_type_ids[current];
        if (type_id == 0) {
            return current;
        }
        type_id = emit_c_strip_mutable_type(type_id);
        if (type_id == 0) {
            return current;
        }
        if (types.type_store_kinds[type_id] == types.TypeKind.mutable) {
            current = jir.jir_store_node_first_child[current];
            continue;
        }
        if (types.type_store_kinds[type_id] != types.TypeKind.array) {
            return current;
        }
        current = jir.jir_store_node_first_child[current];
    }
    return current;
}

Int emit_c_decl_base_type_id(Int type_id) {
    Int current = type_id;
    while (1 == 1) {
        if (current == 0) {
            return current;
        }
        if (current >= types.type_store_count) {
            return current;
        }
        if (types.type_store_kinds[current] == types.TypeKind.mutable) {
            current = types.type_store_elem_type_ids[current];
            continue;
        }
        if (types.type_store_kinds[current] != types.TypeKind.array) {
            return current;
        }
        current = types.type_store_elem_type_ids[current];
    }
    return current;
}

() emit_c_decl_array_suffixes(Int buffer, Int type_node) {
    Int type_id = jir.jir_store_node_type_ids[type_node];
    if (type_id == 0) {
        return;
    }
    if (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.mutable) {
            emit_c_decl_array_suffixes(buffer, jir.jir_store_node_first_child[type_node]);
            return;
        }
    }
    type_id = emit_c_strip_mutable_type(type_id);
    if (type_id == 0) {
        return;
    }
    if (type_id >= types.type_store_count) {
        return;
    }
    if (types.type_store_kinds[type_id] == types.TypeKind.mutable) {
        emit_c_decl_array_suffixes(buffer, jir.jir_store_node_first_child[type_node]);
        return;
    }
    if (types.type_store_kinds[type_id] != types.TypeKind.array) {
        return;
    }
    text.text_buffer_push_text(buffer, "[");
    emit_c_buffer_push_int(buffer, types.type_store_array_lengths[type_id]);
    text.text_buffer_push_text(buffer, "]");
    emit_c_decl_array_suffixes(buffer, jir.jir_store_node_first_child[type_node]);
}

() emit_c_decl_array_suffixes_from_type_id(Int buffer, Int type_id) {
    if (type_id == 0) {
        return;
    }
    if (type_id >= types.type_store_count) {
        return;
    }
    if (types.type_store_kinds[type_id] == types.TypeKind.mutable) {
        emit_c_decl_array_suffixes_from_type_id(buffer, types.type_store_elem_type_ids[type_id]);
        return;
    }
    if (types.type_store_kinds[type_id] != types.TypeKind.array) {
        return;
    }
    text.text_buffer_push_text(buffer, "[");
    emit_c_buffer_push_int(buffer, types.type_store_array_lengths[type_id]);
    text.text_buffer_push_text(buffer, "]");
    emit_c_decl_array_suffixes_from_type_id(buffer, types.type_store_elem_type_ids[type_id]);
}

() emit_c_decl_buffered(Int buffer, UInt8[] source, Int type_node, Int name_node) {
    Int base_type_node = emit_c_decl_base_type_node(type_node);
    emit_c_type_buffered(buffer, source, base_type_node);
    text.text_buffer_push_text(buffer, " ");
    emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
    emit_c_decl_array_suffixes(buffer, type_node);
}

() emit_c_decl_type_id_buffered(Int buffer, Int type_id, UInt8[] name) {
    Int base_type_id = emit_c_decl_base_type_id(type_id);
    emit_c_type_id_buffered(buffer, base_type_id);
    text.text_buffer_push_text(buffer, " ");
    text.text_buffer_push_text(buffer, name);
    emit_c_decl_array_suffixes_from_type_id(buffer, type_id);
}

Bool emit_c_type_node_uses_type_id(UInt8[] source, Int type_node) {
    if (jir.jir_store_node_starts[type_node] == jir.jir_store_node_ends[type_node]) {
        return 1;
    }
    if (jir.jir_store_node_ends[type_node] == jir.jir_store_node_starts[type_node] + 1) {
        return source[jir.jir_store_node_starts[type_node]] == 95;
    }
    return 0;
}

() emit_c_string_init_bytes(Int buffer, UInt8[] source, Int string_node) {
    text.text_buffer_push_text(buffer, "{ ");
    Int i = jir.jir_store_node_starts[string_node] + 1;
    Int end_pos = jir.jir_store_node_ends[string_node] - 1;
    Int first = 1;
    while (i < end_pos) {
        if (first == 0) {
            text.text_buffer_push_text(buffer, ", ");
        }
        emit_c_buffer_push_int(buffer, emit_c_string_lit_decoded_byte(source, i, end_pos));
        first = 0;
        i = emit_c_string_lit_next_index(source, i, end_pos);
    }
    text.text_buffer_push_text(buffer, " }");
}

UInt8[] emit_c_binary_op_text(Int op) {
    if (op == jir.JirBinaryOp.assign) {
        return " = ";
    }
    if (op == jir.JirBinaryOp.eq) {
        return " == ";
    }
    if (op == jir.JirBinaryOp.ne) {
        return " != ";
    }
    if (op == jir.JirBinaryOp.lt) {
        return " < ";
    }
    if (op == jir.JirBinaryOp.le) {
        return " <= ";
    }
    if (op == jir.JirBinaryOp.gt) {
        return " > ";
    }
    if (op == jir.JirBinaryOp.ge) {
        return " >= ";
    }
    if (op == jir.JirBinaryOp.add) {
        return " + ";
    }
    if (op == jir.JirBinaryOp.sub) {
        return " - ";
    }
    if (op == jir.JirBinaryOp.mul) {
        return " * ";
    }
    return " / ";
}

UInt8[] emit_c_unary_op_text(Int op) {
    if (op == jir.JirUnaryOp.neg) {
        return "-";
    }
    if (op == jir.JirUnaryOp.not) {
        return "!";
    }
    if (op == jir.JirUnaryOp.addr) {
        return "&";
    }
    return "*";
}

() emit_c_print_arg_buffered(Int buffer, UInt8[] source, Int root, Int arg_node, Int is_format) {
    Int arg_type = jir.jir_store_node_type_ids[arg_node];
    if (is_format != 0) {
        if (jir.jir_store_node_kinds[arg_node] == jir.JirNode.string_lit) {
            emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[arg_node], jir.jir_store_node_ends[arg_node]);
            return;
        }
        if (emit_c_is_u8_slice_type(arg_type) != 0) {
            text.text_buffer_push_text(buffer, "jiang_emit_to_cstr(");
            emit_c_expr_buffered(buffer, source, root, arg_node);
            text.text_buffer_push_text(buffer, ")");
            return;
        }
    }
    if (emit_c_is_u8_slice_type(arg_type) != 0) {
        text.text_buffer_push_text(buffer, "jiang_emit_to_cstr(");
        emit_c_expr_buffered(buffer, source, root, arg_node);
        text.text_buffer_push_text(buffer, ")");
        return;
    }
    emit_c_expr_buffered(buffer, source, root, arg_node);
}

() emit_c_array_init_items_buffered(Int buffer, UInt8[] source, Int root, Int node_id) {
    text.text_buffer_push_text(buffer, "{ ");
    Int child = jir.jir_store_node_first_child[node_id];
    if (jir.jir_store_node_kinds[node_id] == jir.JirNode.array_init_expr) {
        child = jir.jir_store_node_next_sibling[child];
    }
    Int first = 1;
    while (child != 0) {
        if (first == 0) {
            text.text_buffer_push_text(buffer, ", ");
        }
        emit_c_expr_buffered(buffer, source, root, child);
        first = 0;
        child = jir.jir_store_node_next_sibling[child];
    }
    text.text_buffer_push_text(buffer, " }");
}

() emit_c_expr_buffered(Int buffer, UInt8[] source, Int root, Int node_id) {
    Int kind = jir.jir_store_node_kinds[node_id];
    Int node_type = emit_c_strip_mutable_type(jir.jir_store_node_type_ids[node_id]);
    if (kind == jir.JirNode.int_lit) {
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[node_id], jir.jir_store_node_ends[node_id]);
        return;
    }
    if (kind == jir.JirNode.bool_lit) {
        if (jir.jir_store_node_aux[node_id] != 0) {
            text.text_buffer_push_text(buffer, "1");
        } else {
            text.text_buffer_push_text(buffer, "0");
        }
        return;
    }
    if (kind == jir.JirNode.null_lit) {
        if (emit_c_is_optional_type(node_type) != 0) {
            text.text_buffer_push_text(buffer, "(");
            emit_c_optional_type_name(buffer, node_type);
            text.text_buffer_push_text(buffer, "){ .is_some = 0 }");
        } else {
            text.text_buffer_push_text(buffer, "0");
        }
        return;
    }
    if (kind == jir.JirNode.string_lit) {
        Int length = 0;
        Int i = jir.jir_store_node_starts[node_id] + 1;
        Int end_pos = jir.jir_store_node_ends[node_id] - 1;
        while (i < end_pos) {
            length = length + 1;
            i = emit_c_string_lit_next_index(source, i, end_pos);
        }
        text.text_buffer_push_text(buffer, "(Slice_uint8_t){ .ptr = (uint8_t*)");
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[node_id], jir.jir_store_node_ends[node_id]);
        text.text_buffer_push_text(buffer, ", .length = ");
        emit_c_buffer_push_int(buffer, length);
        text.text_buffer_push_text(buffer, " }");
        return;
    }
    if (kind == jir.JirNode.ident) {
        Int symbol_id = jir.jir_store_node_symbol_ids[node_id];
        if (symbol_id != 0) {
            if (symbols.symbol_store_kinds[symbol_id] == symbols.SymbolKind.union_member) {
                Int tag_symbol = symbols.symbol_store_target_ids[symbol_id];
                if (tag_symbol != 0) {
                    Int owner_symbol = symbols.symbol_store_parent_ids[tag_symbol];
                    emit_c_buffer_push_symbol_name(buffer, owner_symbol);
                    text.text_buffer_push_text(buffer, "_");
                    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[tag_symbol]);
                    return;
                }
            }
            if (symbols.symbol_store_kinds[symbol_id] == symbols.SymbolKind.enum_member) {
                Int owner_symbol = symbols.symbol_store_parent_ids[symbol_id];
                if (owner_symbol != 0) {
                    emit_c_buffer_push_symbol_name(buffer, owner_symbol);
                    text.text_buffer_push_text(buffer, "_");
                    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[symbol_id]);
                    return;
                }
            }
            emit_c_buffer_push_symbol_name(buffer, symbol_id);
        } else {
            emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[node_id], jir.jir_store_node_ends[node_id]);
        }
        return;
    }
    if (kind == jir.JirNode.shorthand_member_expr) {
        Int symbol_id = jir.jir_store_node_symbol_ids[node_id];
        if (symbol_id != 0) {
            if (symbols.symbol_store_kinds[symbol_id] == symbols.SymbolKind.union_member) {
                Int tag_symbol = symbols.symbol_store_target_ids[symbol_id];
                if (tag_symbol != 0) {
                    Int owner_symbol = symbols.symbol_store_parent_ids[tag_symbol];
                    emit_c_buffer_push_symbol_name(buffer, owner_symbol);
                    text.text_buffer_push_text(buffer, "_");
                    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[tag_symbol]);
                    return;
                }
            }
            if (symbols.symbol_store_kinds[symbol_id] == symbols.SymbolKind.enum_member) {
                Int owner_symbol = symbols.symbol_store_parent_ids[symbol_id];
                if (owner_symbol != 0) {
                    emit_c_buffer_push_symbol_name(buffer, owner_symbol);
                    text.text_buffer_push_text(buffer, "_");
                    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[symbol_id]);
                    return;
                }
            }
            emit_c_buffer_push_symbol_name(buffer, symbol_id);
            return;
        }
        Int member = jir.jir_store_node_first_child[node_id];
        if (member != 0) {
            emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[member], jir.jir_store_node_ends[member]);
            return;
        }
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[node_id], jir.jir_store_node_ends[node_id]);
        return;
    }
    if (kind == jir.JirNode.call_expr) {
        Int child = jir.jir_store_node_first_child[node_id];
        Int callee_symbol = jir.jir_store_node_symbol_ids[child];
        if (callee_symbol != 0) {
            if (symbols.symbol_store_kinds[callee_symbol] == symbols.SymbolKind.union_member) {
                Int owner_symbol = symbols.symbol_store_parent_ids[callee_symbol];
                text.text_buffer_push_text(buffer, "((");
                emit_c_buffer_push_symbol_name(buffer, owner_symbol);
                text.text_buffer_push_text(buffer, "){ .tag = ");
                if (symbols.symbol_store_target_ids[callee_symbol] != 0) {
                    Int tag_symbol = symbols.symbol_store_target_ids[callee_symbol];
                    Int tag_owner = symbols.symbol_store_parent_ids[tag_symbol];
                    emit_c_buffer_push_symbol_name(buffer, tag_owner);
                    text.text_buffer_push_text(buffer, "_");
                    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[tag_symbol]);
                } else {
                    emit_c_buffer_push_int(buffer, symbols.symbol_store_aux[callee_symbol]);
                }
                Int payload = jir.jir_store_node_next_sibling[child];
                if (payload != 0) {
                    text.text_buffer_push_text(buffer, ", .");
                    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[callee_symbol]);
                    text.text_buffer_push_text(buffer, " = ");
                    emit_c_expr_buffered(buffer, source, root, payload);
                }
                text.text_buffer_push_text(buffer, " })");
                return;
            }
        }
        emit_c_expr_buffered(buffer, source, root, child);
        text.text_buffer_push_text(buffer, "(");
        child = jir.jir_store_node_next_sibling[child];
        Int first = 1;
        Bool is_print = emit_c_symbol_name_is(callee_symbol, "print");
        while (child != 0) {
            if (first == 0) {
                text.text_buffer_push_text(buffer, ", ");
            }
            if (is_print) {
                emit_c_print_arg_buffered(buffer, source, root, child, first);
            } else {
                emit_c_expr_buffered(buffer, source, root, child);
            }
            first = 0;
            child = jir.jir_store_node_next_sibling[child];
        }
        text.text_buffer_push_text(buffer, ")");
        return;
    }
    if (kind == jir.JirNode.member_expr) {
        Int base = jir.jir_store_node_first_child[node_id];
        Int member = jir.jir_store_node_next_sibling[base];
        Int member_symbol = jir.jir_store_node_symbol_ids[node_id];
        if (emit_c_is_enum_type(jir.jir_store_node_type_ids[base]) != 0) {
            if (emit_c_member_name_is(source, member, "value")) {
                if (jir.jir_store_node_symbol_ids[base] == 0) {
                    emit_c_expr_buffered(buffer, source, root, base);
                    return;
                }
                if (symbols.symbol_store_kinds[jir.jir_store_node_symbol_ids[base]] != symbols.SymbolKind.enum_name) {
                    emit_c_expr_buffered(buffer, source, root, base);
                    return;
                }
            }
        }
        if (jir.jir_store_node_symbol_ids[base] != 0) {
            Int base_symbol = jir.jir_store_node_symbol_ids[base];
            if (symbols.symbol_store_kinds[base_symbol] == symbols.SymbolKind.module_alias) {
                if (member_symbol != 0) {
                    Int member_kind = symbols.symbol_store_kinds[member_symbol];
                    if (member_kind == symbols.SymbolKind.func) {
                        emit_c_buffer_push_symbol_name(buffer, member_symbol);
                        return;
                    }
                    if (member_kind == symbols.SymbolKind.global) {
                        emit_c_buffer_push_symbol_name(buffer, member_symbol);
                        return;
                    }
                    if (member_kind == symbols.SymbolKind.type_name) {
                        emit_c_buffer_push_symbol_name(buffer, member_symbol);
                        return;
                    }
                    if (member_kind == symbols.SymbolKind.enum_name) {
                        emit_c_buffer_push_symbol_name(buffer, member_symbol);
                        return;
                    }
                    if (member_kind == symbols.SymbolKind.enum_member) {
                        emit_c_buffer_push_symbol_name(buffer, member_symbol);
                        return;
                    }
                    if (member_kind == symbols.SymbolKind.union_member) {
                        Int tag_symbol = symbols.symbol_store_target_ids[member_symbol];
                        if (tag_symbol != 0) {
                            Int tag_owner = symbols.symbol_store_parent_ids[tag_symbol];
                            emit_c_buffer_push_symbol_name(buffer, tag_owner);
                            text.text_buffer_push_text(buffer, "_");
                            emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[tag_symbol]);
                            return;
                        }
                    }
                }
            }
        }
        if (member_symbol != 0) {
            if (symbols.symbol_store_kinds[member_symbol] == symbols.SymbolKind.enum_member) {
                emit_c_expr_buffered(buffer, source, root, base);
                text.text_buffer_push_text(buffer, "_");
                emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[member_symbol]);
                return;
            }
            if (symbols.symbol_store_kinds[member_symbol] == symbols.SymbolKind.union_member) {
                Int tag_symbol = symbols.symbol_store_target_ids[member_symbol];
                if (tag_symbol != 0) {
                    Int tag_owner = symbols.symbol_store_parent_ids[tag_symbol];
                    emit_c_buffer_push_symbol_name(buffer, tag_owner);
                    text.text_buffer_push_text(buffer, "_");
                    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[tag_symbol]);
                    return;
                }
            }
        }
        if (jir.jir_store_node_symbol_ids[base] != 0) {
            Int base_symbol = jir.jir_store_node_symbol_ids[base];
                if (symbols.symbol_store_kinds[base_symbol] == symbols.SymbolKind.enum_name) {
                emit_c_buffer_push_symbol_name(buffer, base_symbol);
                text.text_buffer_push_text(buffer, "_");
                if (member_symbol != 0) {
                    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[member_symbol]);
                } else {
                    emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[member], jir.jir_store_node_ends[member]);
                }
                return;
            }
        }
        if (emit_c_is_slice_type(jir.jir_store_node_type_ids[base]) != 0) {
            if (emit_c_member_name_is(source, member, "length")) {
                emit_c_expr_buffered(buffer, source, root, base);
                text.text_buffer_push_text(buffer, ".length");
                return;
            }
        }
        if (emit_c_is_union_type(jir.jir_store_node_type_ids[base]) != 0) {
            if (emit_c_member_name_is(source, member, "tag")) {
                emit_c_expr_buffered(buffer, source, root, base);
                text.text_buffer_push_text(buffer, ".tag");
                return;
            }
        }
        if (member_symbol != 0) {
            if (symbols.symbol_store_kinds[member_symbol] == symbols.SymbolKind.field) {
                emit_c_expr_buffered(buffer, source, root, base);
                text.text_buffer_push_text(buffer, ".");
                emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[member_symbol]);
                return;
            }
        }
        emit_c_expr_buffered(buffer, source, root, base);
        text.text_buffer_push_text(buffer, ".");
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[member], jir.jir_store_node_ends[member]);
        return;
    }
    if (kind == jir.JirNode.index_expr) {
        Int base = jir.jir_store_node_first_child[node_id];
        Int index_expr = jir.jir_store_node_next_sibling[base];
        Int base_type = jir.jir_store_node_type_ids[base];
        text.text_buffer_push_text(buffer, "(");
        if (base_type < types.type_store_count) {
            if (types.type_store_kinds[base_type] == types.TypeKind.tuple) {
                emit_c_expr_buffered(buffer, source, root, base);
                text.text_buffer_push_text(buffer, "._");
                emit_c_buffer_push_int(buffer, jir.jir_store_node_aux[node_id]);
                text.text_buffer_push_text(buffer, ")");
                return;
            }
        }
        if (emit_c_is_slice_type(base_type) != 0) {
            if (emit_c_slice_uses_void_ptr(base_type) != 0) {
                text.text_buffer_push_text(buffer, "(");
                emit_c_slice_elem_ptr_cast(buffer, base_type);
                text.text_buffer_push_text(buffer, "(");
                emit_c_expr_buffered(buffer, source, root, base);
                text.text_buffer_push_text(buffer, ").ptr)[");
            } else {
                emit_c_expr_buffered(buffer, source, root, base);
                text.text_buffer_push_text(buffer, ".ptr[");
            }
        } else {
            emit_c_expr_buffered(buffer, source, root, base);
            text.text_buffer_push_text(buffer, "[");
        }
        emit_c_expr_buffered(buffer, source, root, index_expr);
        text.text_buffer_push_text(buffer, "])");
        return;
    }
    if (kind == jir.JirNode.range_expr) {
        Int base = jir.jir_store_node_first_child[node_id];
        Int start_expr = jir.jir_store_node_next_sibling[base];
        Int end_expr = jir.jir_store_node_next_sibling[start_expr];
        Int result_type = jir.jir_store_node_type_ids[node_id];
        text.text_buffer_push_text(buffer, "(");
        emit_c_slice_type_name(buffer, result_type);
        text.text_buffer_push_text(buffer, "){ .ptr = ");
        if (emit_c_slice_uses_void_ptr(result_type) != 0) {
            text.text_buffer_push_text(buffer, "(void*)(");
            if (emit_c_is_slice_type(jir.jir_store_node_type_ids[base]) != 0) {
                emit_c_slice_elem_ptr_cast(buffer, result_type);
                text.text_buffer_push_text(buffer, "(");
                emit_c_expr_buffered(buffer, source, root, base);
                text.text_buffer_push_text(buffer, ").ptr");
            } else {
                emit_c_expr_buffered(buffer, source, root, base);
            }
        } else {
            text.text_buffer_push_text(buffer, "(");
            if (emit_c_is_slice_type(jir.jir_store_node_type_ids[base]) != 0) {
                emit_c_expr_buffered(buffer, source, root, base);
                text.text_buffer_push_text(buffer, ".ptr");
            } else {
                emit_c_expr_buffered(buffer, source, root, base);
            }
        }
        text.text_buffer_push_text(buffer, ") + ");
        emit_c_expr_buffered(buffer, source, root, start_expr);
        text.text_buffer_push_text(buffer, ", .length = ");
        emit_c_expr_buffered(buffer, source, root, end_expr);
        text.text_buffer_push_text(buffer, " - ");
        emit_c_expr_buffered(buffer, source, root, start_expr);
        text.text_buffer_push_text(buffer, " }");
        return;
    }
    if (kind == jir.JirNode.array_to_slice_expr) {
        Int base = jir.jir_store_node_first_child[node_id];
        Int base_type = jir.jir_store_node_type_ids[base];
        text.text_buffer_push_text(buffer, "(");
        emit_c_slice_type_name(buffer, jir.jir_store_node_type_ids[node_id]);
        text.text_buffer_push_text(buffer, "){ .ptr = ");
        if (types.type_store_elem_type_ids[base_type] == types.type_store_builtin_uint8) {
            text.text_buffer_push_text(buffer, "(uint8_t*)");
        }
        emit_c_expr_buffered(buffer, source, root, base);
        text.text_buffer_push_text(buffer, ", .length = ");
        emit_c_buffer_push_int(buffer, types.type_store_array_lengths[base_type]);
        text.text_buffer_push_text(buffer, " }");
        return;
    }
    if (kind == jir.JirNode.struct_init_expr) {
        Int child = jir.jir_store_node_first_child[node_id];
        text.text_buffer_push_text(buffer, "(");
        emit_c_expr_buffered(buffer, source, root, child);
        text.text_buffer_push_text(buffer, "){ ");
        child = jir.jir_store_node_next_sibling[child];
        Int first = 1;
        while (child != 0) {
            if (first == 0) {
                text.text_buffer_push_text(buffer, ", ");
            }
            Int field_name = jir.jir_store_node_first_child[child];
            Int field_value = jir.jir_store_node_next_sibling[field_name];
            Int field_symbol = jir.jir_store_node_symbol_ids[child];
            text.text_buffer_push_text(buffer, ".");
            if (field_symbol != 0) {
                emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[field_symbol]);
            } else {
                emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[field_name], jir.jir_store_node_ends[field_name]);
            }
            text.text_buffer_push_text(buffer, " = ");
            if (field_symbol != 0) {
                Int field_type = symbols.symbol_store_type_ids[field_symbol];
                if (types.type_store_kinds[field_type] == types.TypeKind.array) {
                    if (types.type_store_elem_type_ids[field_type] == types.type_store_builtin_uint8) {
                        if (jir.jir_store_node_kinds[field_value] == jir.JirNode.string_lit) {
                            emit_c_string_init_bytes(buffer, source, field_value);
                        } else if (jir.jir_store_node_kinds[field_value] == jir.JirNode.array_init_expr) {
                            emit_c_array_init_items_buffered(buffer, source, root, field_value);
                        } else {
                            emit_c_expr_buffered(buffer, source, root, field_value);
                        }
                    } else {
                        if (jir.jir_store_node_kinds[field_value] == jir.JirNode.array_init_expr) {
                            emit_c_array_init_items_buffered(buffer, source, root, field_value);
                        } else {
                            emit_c_expr_buffered(buffer, source, root, field_value);
                        }
                    }
                } else {
                    emit_c_expr_buffered(buffer, source, root, field_value);
                }
            } else {
                emit_c_expr_buffered(buffer, source, root, field_value);
            }
            first = 0;
            child = jir.jir_store_node_next_sibling[child];
        }
        text.text_buffer_push_text(buffer, " }");
        return;
    }
    if (kind == jir.JirNode.array_init_expr) {
        text.text_buffer_push_text(buffer, "(");
        emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[node_id]);
        text.text_buffer_push_text(buffer, ")");
        emit_c_array_init_items_buffered(buffer, source, root, node_id);
        return;
    }
    if (kind == jir.JirNode.array_lit) {
        emit_c_array_init_items_buffered(buffer, source, root, node_id);
        return;
    }
    if (kind == jir.JirNode.tuple_lit) {
        text.text_buffer_push_text(buffer, "(");
        emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[node_id]);
        text.text_buffer_push_text(buffer, "){ ");
        Int child = jir.jir_store_node_first_child[node_id];
        Int first = 1;
        Int index = 0;
        while (child != 0) {
            if (first == 0) {
                text.text_buffer_push_text(buffer, ", ");
            }
            text.text_buffer_push_text(buffer, "._");
            emit_c_buffer_push_int(buffer, index);
            text.text_buffer_push_text(buffer, " = ");
            emit_c_expr_buffered(buffer, source, root, child);
            first = 0;
            index = index + 1;
            child = jir.jir_store_node_next_sibling[child];
        }
        text.text_buffer_push_text(buffer, " }");
        return;
    }
    if (kind == jir.JirNode.optional_wrap_expr) {
        Int child = jir.jir_store_node_first_child[node_id];
        text.text_buffer_push_text(buffer, "(");
        emit_c_optional_type_name(buffer, node_type);
        text.text_buffer_push_text(buffer, "){ .is_some = 1, .value = ");
        Int payload_type = types.type_store_elem_type_ids[node_type];
        if (payload_type < types.type_store_count) {
            if (types.type_store_kinds[payload_type] == types.TypeKind.array) {
                emit_c_array_value_expr(buffer, source, root, child, payload_type);
            } else {
                emit_c_expr_buffered(buffer, source, root, child);
            }
        } else {
            emit_c_expr_buffered(buffer, source, root, child);
        }
        text.text_buffer_push_text(buffer, " }");
        return;
    }
    if (kind == jir.JirNode.optional_member_expr) {
        Int base = jir.jir_store_node_first_child[node_id];
        Int member = jir.jir_store_node_next_sibling[base];
        Int base_type = emit_c_strip_mutable_type(jir.jir_store_node_type_ids[base]);
        Int payload_type = types.type_store_elem_type_ids[base_type];
        Int member_symbol = jir.jir_store_node_symbol_ids[node_id];
        Int flatten_optional = 0;
        if (member_symbol != 0) {
            if (emit_c_is_optional_type(symbols.symbol_store_type_ids[member_symbol]) != 0) {
                flatten_optional = 1;
            }
        }
        text.text_buffer_push_text(buffer, "(((");
        emit_c_expr_buffered(buffer, source, root, base);
        text.text_buffer_push_text(buffer, ").is_some != 0) ? ");
        if (flatten_optional == 0) {
            text.text_buffer_push_text(buffer, "(");
            emit_c_optional_type_name(buffer, node_type);
            text.text_buffer_push_text(buffer, "){ .is_some = 1, .value = ");
        }
        if (payload_type < types.type_store_count) {
            if (types.type_store_kinds[payload_type] == types.TypeKind.slice) {
                if (emit_c_member_name_is(source, member, "length")) {
                    emit_c_optional_payload_value_expr(buffer, source, root, base);
                    text.text_buffer_push_text(buffer, ".length");
                } else {
                    emit_c_optional_payload_value_expr(buffer, source, root, base);
                }
            } else if (types.type_store_kinds[payload_type] == types.TypeKind.union_type) {
                if (emit_c_member_name_is(source, member, "tag")) {
                    emit_c_optional_payload_value_expr(buffer, source, root, base);
                    text.text_buffer_push_text(buffer, ".tag");
                } else {
                    emit_c_optional_payload_value_expr(buffer, source, root, base);
                }
            } else if (types.type_store_kinds[payload_type] == types.TypeKind.enum_type) {
                if (emit_c_member_name_is(source, member, "value")) {
                    emit_c_optional_payload_value_expr(buffer, source, root, base);
                } else {
                    emit_c_optional_payload_value_expr(buffer, source, root, base);
                }
            } else {
                emit_c_optional_payload_value_expr(buffer, source, root, base);
                text.text_buffer_push_text(buffer, ".");
                if (member_symbol != 0) {
                    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[member_symbol]);
                } else {
                    emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[member], jir.jir_store_node_ends[member]);
                }
            }
        } else {
            emit_c_optional_payload_value_expr(buffer, source, root, base);
        }
        if (flatten_optional == 0) {
            text.text_buffer_push_text(buffer, " } : ");
        } else {
            text.text_buffer_push_text(buffer, " : ");
        }
        emit_c_optional_none_expr(buffer, node_type);
        text.text_buffer_push_text(buffer, ")");
        return;
    }
    if (kind == jir.JirNode.optional_index_expr) {
        Int base = jir.jir_store_node_first_child[node_id];
        Int index_expr = jir.jir_store_node_next_sibling[base];
        Int base_type = emit_c_strip_mutable_type(jir.jir_store_node_type_ids[base]);
        Int payload_type = types.type_store_elem_type_ids[base_type];
        Int value_type = 0;
        Int flatten_optional = 0;
        if (payload_type < types.type_store_count) {
            if (types.type_store_kinds[payload_type] == types.TypeKind.tuple) {
                value_type = types.type_store_tuple_item_type(payload_type, jir.jir_store_node_aux[node_id]);
            } else {
                if (types.type_store_kinds[payload_type] == types.TypeKind.slice) {
                    value_type = types.type_store_elem_type_ids[payload_type];
                } else if (types.type_store_kinds[payload_type] == types.TypeKind.array) {
                    value_type = types.type_store_elem_type_ids[payload_type];
                }
            }
        }
        if (emit_c_is_optional_type(value_type) != 0) {
            flatten_optional = 1;
        }
        text.text_buffer_push_text(buffer, "(((");
        emit_c_expr_buffered(buffer, source, root, base);
        text.text_buffer_push_text(buffer, ").is_some != 0) ? ");
        if (flatten_optional == 0) {
            text.text_buffer_push_text(buffer, "(");
            emit_c_optional_type_name(buffer, node_type);
            text.text_buffer_push_text(buffer, "){ .is_some = 1, .value = ");
        }
        if (payload_type < types.type_store_count) {
            if (types.type_store_kinds[payload_type] == types.TypeKind.tuple) {
                emit_c_optional_payload_value_expr(buffer, source, root, base);
                text.text_buffer_push_text(buffer, "._");
                emit_c_buffer_push_int(buffer, jir.jir_store_node_aux[node_id]);
            } else if (types.type_store_kinds[payload_type] == types.TypeKind.slice) {
                emit_c_optional_payload_value_expr(buffer, source, root, base);
                text.text_buffer_push_text(buffer, ".ptr[");
                emit_c_expr_buffered(buffer, source, root, index_expr);
                text.text_buffer_push_text(buffer, "]");
            } else {
                emit_c_optional_payload_value_expr(buffer, source, root, base);
                text.text_buffer_push_text(buffer, "[");
                emit_c_expr_buffered(buffer, source, root, index_expr);
                text.text_buffer_push_text(buffer, "]");
            }
        } else {
            emit_c_optional_payload_value_expr(buffer, source, root, base);
        }
        if (flatten_optional == 0) {
            text.text_buffer_push_text(buffer, " } : ");
        } else {
            text.text_buffer_push_text(buffer, " : ");
        }
        emit_c_optional_none_expr(buffer, node_type);
        text.text_buffer_push_text(buffer, ")");
        return;
    }
    if (kind == jir.JirNode.unary_expr) {
        text.text_buffer_push_text(buffer, "(");
        text.text_buffer_push_text(buffer, emit_c_unary_op_text(jir.jir_store_node_aux[node_id]));
        emit_c_expr_buffered(buffer, source, root, jir.jir_store_node_first_child[node_id]);
        text.text_buffer_push_text(buffer, ")");
        return;
    }
    if (kind == jir.JirNode.union_pattern_expr) {
        emit_c_expr_buffered(buffer, source, root, emit_c_union_pattern_label(node_id));
        return;
    }
    if (kind == jir.JirNode.binary_expr) {
        Int left = jir.jir_store_node_first_child[node_id];
        Int right = jir.jir_store_node_next_sibling[left];
        if (jir.jir_store_node_kinds[right] == jir.JirNode.union_pattern_expr) {
            text.text_buffer_push_text(buffer, "(");
            emit_c_expr_buffered(buffer, source, root, left);
            text.text_buffer_push_text(buffer, ".tag");
            text.text_buffer_push_text(buffer, emit_c_binary_op_text(jir.jir_store_node_aux[node_id]));
            emit_c_expr_buffered(buffer, source, root, emit_c_union_pattern_label(right));
            text.text_buffer_push_text(buffer, ")");
            return;
        }
        Int op = jir.jir_store_node_aux[node_id];
        Int left_type = emit_c_strip_mutable_type(jir.jir_store_node_type_ids[left]);
        Int right_type = emit_c_strip_mutable_type(jir.jir_store_node_type_ids[right]);
        if (op == jir.JirBinaryOp.eq) {
            if (jir.jir_store_node_kinds[left] == jir.JirNode.null_lit) {
                if (emit_c_is_optional_type(right_type) != 0) {
                    text.text_buffer_push_text(buffer, "((");
                    emit_c_expr_buffered(buffer, source, root, right);
                    text.text_buffer_push_text(buffer, ").is_some");
                    text.text_buffer_push_text(buffer, " == 0)");
                    return;
                }
            }
            if (jir.jir_store_node_kinds[right] == jir.JirNode.null_lit) {
                if (emit_c_is_optional_type(left_type) != 0) {
                    text.text_buffer_push_text(buffer, "((");
                    emit_c_expr_buffered(buffer, source, root, left);
                    text.text_buffer_push_text(buffer, ").is_some");
                    text.text_buffer_push_text(buffer, " == 0)");
                    return;
                }
            }
        } else if (op == jir.JirBinaryOp.ne) {
            if (jir.jir_store_node_kinds[left] == jir.JirNode.null_lit) {
                if (emit_c_is_optional_type(right_type) != 0) {
                    text.text_buffer_push_text(buffer, "((");
                    emit_c_expr_buffered(buffer, source, root, right);
                    text.text_buffer_push_text(buffer, ").is_some != 0)");
                    return;
                }
            }
            if (jir.jir_store_node_kinds[right] == jir.JirNode.null_lit) {
                if (emit_c_is_optional_type(left_type) != 0) {
                    text.text_buffer_push_text(buffer, "((");
                    emit_c_expr_buffered(buffer, source, root, left);
                    text.text_buffer_push_text(buffer, ").is_some != 0)");
                    return;
                }
            }
        }
        text.text_buffer_push_text(buffer, "(");
        emit_c_expr_buffered(buffer, source, root, left);
        text.text_buffer_push_text(buffer, emit_c_binary_op_text(op));
        emit_c_expr_buffered(buffer, source, root, right);
        text.text_buffer_push_text(buffer, ")");
        return;
    }
    if (kind == jir.JirNode.ternary_expr) {
        Int condition = jir.jir_store_node_first_child[node_id];
        Int then_expr = jir.jir_store_node_next_sibling[condition];
        Int else_expr = jir.jir_store_node_next_sibling[then_expr];
        text.text_buffer_push_text(buffer, "(");
        emit_c_expr_buffered(buffer, source, root, condition);
        text.text_buffer_push_text(buffer, " ? ");
        emit_c_expr_buffered(buffer, source, root, then_expr);
        text.text_buffer_push_text(buffer, " : ");
        emit_c_expr_buffered(buffer, source, root, else_expr);
        text.text_buffer_push_text(buffer, ")");
        return;
    }
    __intrinsic_assert(0);
}

() emit_c_union_decl(Int buffer, UInt8[] source, Int node_id) {
    Int tag_type = jir.jir_store_node_first_child[node_id];
    Int name_node = jir.jir_store_node_next_sibling[tag_type];
    text.text_buffer_push_text(buffer, "typedef struct ");
    if (jir.jir_store_node_symbol_ids[node_id] != 0) {
        emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[node_id]);
    } else {
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
    }
    text.text_buffer_push_text(buffer, " {\n    ");
    emit_c_type_buffered(buffer, source, tag_type);
    text.text_buffer_push_text(buffer, " tag;\n");
    Int field = jir.jir_store_node_next_sibling[name_node];
    while (field != 0) {
        Int field_type = jir.jir_store_node_first_child[field];
        Int field_name = jir.jir_store_node_next_sibling[field_type];
        if (jir.jir_store_node_type_ids[field_type] != types.type_store_builtin_void) {
            text.text_buffer_push_text(buffer, "    ");
            emit_c_type_buffered(buffer, source, field_type);
            text.text_buffer_push_text(buffer, " ");
            if (jir.jir_store_node_symbol_ids[field] != 0) {
                emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[jir.jir_store_node_symbol_ids[field]]);
            } else {
                emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[field_name], jir.jir_store_node_ends[field_name]);
            }
            text.text_buffer_push_text(buffer, ";\n");
        }
        field = jir.jir_store_node_next_sibling[field];
    }
    text.text_buffer_push_text(buffer, "} ");
    if (jir.jir_store_node_symbol_ids[node_id] != 0) {
        emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[node_id]);
    } else {
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
    }
    text.text_buffer_push_text(buffer, ";\n\n");
}

() emit_c_tuple_decl(Int buffer, Int type_id) {
    text.text_buffer_push_text(buffer, "typedef struct {\n");
    Int index = 0;
    while (index < types.type_store_tuple_count(type_id)) {
        text.text_buffer_push_text(buffer, "    ");
        Int item_type = types.type_store_tuple_item_type(type_id, index);
        Int name_buffer = text.text_buffer_new(16);
        text.text_buffer_clear(name_buffer);
        emit_c_tuple_field_name(name_buffer, index);
        emit_c_decl_type_id_buffered(buffer, item_type, text.text_buffer_slice(name_buffer));
        text.text_buffer_push_text(buffer, ";\n");
        index = index + 1;
    }
    text.text_buffer_push_text(buffer, "} ");
    emit_c_buffer_push_type_name(buffer, type_id);
    text.text_buffer_push_text(buffer, ";\n\n");
}

public () emit_c_tuple_prelude(Int buffer) {
    Int tuple_type_id = 1;
    while (tuple_type_id < types.type_store_count) {
        if (types.type_store_kinds[tuple_type_id] == types.TypeKind.tuple) {
            emit_c_tuple_decl(buffer, tuple_type_id);
        }
        tuple_type_id = tuple_type_id + 1;
    }
}

() emit_c_optional_decl(Int buffer, Int type_id) {
    text.text_buffer_push_text(buffer, "typedef struct {\n");
    text.text_buffer_push_text(buffer, "    int is_some;\n");
    text.text_buffer_push_text(buffer, "    ");
    Int payload_type = emit_c_strip_mutable_type(types.type_store_elem_type_ids[type_id]);
    if (payload_type < types.type_store_count) {
        if (types.type_store_kinds[payload_type] == types.TypeKind.struct_type) {
            text.text_buffer_push_text(buffer, "struct ");
            emit_c_buffer_push_type_name(buffer, payload_type);
            text.text_buffer_push_text(buffer, " value");
        } else if (types.type_store_kinds[payload_type] == types.TypeKind.union_type) {
            text.text_buffer_push_text(buffer, "struct ");
            emit_c_buffer_push_type_name(buffer, payload_type);
            text.text_buffer_push_text(buffer, " value");
        } else {
            emit_c_decl_type_id_buffered(buffer, types.type_store_elem_type_ids[type_id], "value");
        }
    } else {
        emit_c_decl_type_id_buffered(buffer, types.type_store_elem_type_ids[type_id], "value");
    }
    text.text_buffer_push_text(buffer, ";\n");
    text.text_buffer_push_text(buffer, "} ");
    emit_c_optional_type_name(buffer, type_id);
    text.text_buffer_push_text(buffer, ";\n\n");
}

() emit_c_named_type_forward_decl(Int buffer, UInt8[] source, Int node_id) {
    Int kind = jir.jir_store_node_kinds[node_id];
    if (kind != jir.JirNode.struct_decl) {
        if (kind != jir.JirNode.union_decl) {
            return;
        }
    }
    Int name_node = jir.jir_store_node_first_child[node_id];
    if (kind == jir.JirNode.union_decl) {
        name_node = jir.jir_store_node_next_sibling[name_node];
    }
    text.text_buffer_push_text(buffer, "struct ");
    if (jir.jir_store_node_symbol_ids[node_id] != 0) {
        emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[node_id]);
    } else {
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
    }
    text.text_buffer_push_text(buffer, ";\n");
}

() emit_c_named_type_forward_prelude(Int buffer, UInt8[] source, Int root) {
    Int child = jir.jir_store_node_first_child[root];
    Int emitted = 0;
    while (child != 0) {
        Int kind = jir.jir_store_node_kinds[child];
        if (kind == jir.JirNode.struct_decl) {
            emit_c_named_type_forward_decl(buffer, source, child);
            emitted = 1;
        } else if (kind == jir.JirNode.union_decl) {
            emit_c_named_type_forward_decl(buffer, source, child);
            emitted = 1;
        }
        child = jir.jir_store_node_next_sibling[child];
    }
    if (emitted != 0) {
        text.text_buffer_push_text(buffer, "\n");
    }
}

public () emit_c_optional_prelude(Int buffer) {
    Int type_id = 1;
    while (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.optional) {
            emit_c_optional_decl(buffer, type_id);
        }
        type_id = type_id + 1;
    }
}

Bool emit_c_type_is_completed(Int type_id, Int completed_types_handle) {
    type_id = emit_c_strip_mutable_type(type_id);
    if (type_id == 0) {
        return 0;
    }
    if (type_id == types.type_store_builtin_void) {
        return 1;
    }
    if (type_id == types.type_store_builtin_bool) {
        return 1;
    }
    if (type_id == types.type_store_builtin_int) {
        return 1;
    }
    if (type_id == types.type_store_builtin_uint8) {
        return 1;
    }
    if (type_id >= types.type_store_count) {
        return 1;
    }
    Int kind = types.type_store_kinds[type_id];
    if (kind == types.TypeKind.slice) {
        return 1;
    }
    if (kind == types.TypeKind.pointer) {
        return 1;
    }
    if (kind == types.TypeKind.optional) {
        return emit_c_type_is_completed(types.type_store_elem_type_ids[type_id], completed_types_handle);
    }
    if (kind == types.TypeKind.array) {
        return emit_c_type_is_completed(types.type_store_elem_type_ids[type_id], completed_types_handle);
    }
    if (kind == types.TypeKind.tuple) {
        Int index = 0;
        while (index < types.type_store_tuple_count(type_id)) {
            if (emit_c_type_is_completed(types.type_store_tuple_item_type(type_id, index), completed_types_handle) == 0) {
                return 0;
            }
            index = index + 1;
        }
        return 1;
    }
    if (kind == types.TypeKind.enum_type) {
        return ints.buffer_int_get(completed_types_handle, type_id) != 0;
    }
    if (kind == types.TypeKind.struct_type) {
        return ints.buffer_int_get(completed_types_handle, type_id) != 0;
    }
    if (kind == types.TypeKind.union_type) {
        return ints.buffer_int_get(completed_types_handle, type_id) != 0;
    }
    return 1;
}

() emit_c_optional_decls_ready(Int buffer, Int completed_types_handle, Int emitted_optionals_handle) {
    Int type_id = 1;
    while (type_id < types.type_store_count) {
        if (types.type_store_kinds[type_id] == types.TypeKind.optional) {
            if (ints.buffer_int_get(emitted_optionals_handle, type_id) == 0) {
                if (emit_c_type_is_completed(types.type_store_elem_type_ids[type_id], completed_types_handle) != 0) {
                    emit_c_optional_decl(buffer, type_id);
                    ints.buffer_int_set(emitted_optionals_handle, type_id, 1);
                }
            }
        }
        type_id = type_id + 1;
    }
}

Int emit_c_decl_type_id(Int node_id) {
    Int symbol_id = jir.jir_store_node_symbol_ids[node_id];
    if (symbol_id != 0) {
        return symbols.symbol_store_type_ids[symbol_id];
    }
    return 0;
}

() emit_c_stmt_buffered(Int buffer, UInt8[] source, Int root, Int node_id) {
    Int kind = jir.jir_store_node_kinds[node_id];
    if (kind == jir.JirNode.if_stmt) {
        Int condition = jir.jir_store_node_first_child[node_id];
        Int then_block = jir.jir_store_node_next_sibling[condition];
        Int else_block = jir.jir_store_node_next_sibling[then_block];
        Bool is_union_pattern = 0;
        Int pattern = 0;
        Int pattern_bind_count = 0;
        Int left_value = 0;
        if (jir.jir_store_node_kinds[condition] == jir.JirNode.binary_expr) {
            left_value = jir.jir_store_node_first_child[condition];
            Int right_value = jir.jir_store_node_next_sibling[left_value];
            if (right_value != 0) {
                if (jir.jir_store_node_kinds[right_value] == jir.JirNode.union_pattern_expr) {
                    is_union_pattern = 1;
                    pattern = right_value;
                    pattern_bind_count = emit_c_union_pattern_binding_count(pattern);
                }
            }
        }
        if (is_union_pattern != 0) {
            text.text_buffer_push_text(buffer, "    {\n");
            text.text_buffer_push_text(buffer, "    ");
            emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[left_value]);
            text.text_buffer_push_text(buffer, " __jiang_if_pattern_");
            emit_c_buffer_push_int(buffer, node_id);
            text.text_buffer_push_text(buffer, " = ");
            emit_c_expr_buffered(buffer, source, root, left_value);
            text.text_buffer_push_text(buffer, ";\n");
            text.text_buffer_push_text(buffer, "    if (__jiang_if_pattern_");
            emit_c_buffer_push_int(buffer, node_id);
            text.text_buffer_push_text(buffer, ".tag");
            text.text_buffer_push_text(buffer, emit_c_binary_op_text(jir.jir_store_node_aux[condition]));
            emit_c_expr_buffered(buffer, source, root, emit_c_union_pattern_label(pattern));
            text.text_buffer_push_text(buffer, ") {\n");
            if (pattern_bind_count == 1) {
                Int pattern_bind = emit_c_union_pattern_binding_item(pattern, 0);
                text.text_buffer_push_text(buffer, "    ");
                emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[pattern_bind]);
                text.text_buffer_push_text(buffer, " ");
                emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[pattern_bind]);
                text.text_buffer_push_text(buffer, " = __jiang_if_pattern_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, ".");
                emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[jir.jir_store_node_symbol_ids[emit_c_union_pattern_label(pattern)]]);
                text.text_buffer_push_text(buffer, ";\n");
            } else if (pattern_bind_count > 1) {
                Int i = 0;
                while (i < pattern_bind_count) {
                    Int pattern_bind = emit_c_union_pattern_binding_item(pattern, i);
                    text.text_buffer_push_text(buffer, "    ");
                    emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[pattern_bind]);
                    text.text_buffer_push_text(buffer, " ");
                    emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[pattern_bind]);
                    text.text_buffer_push_text(buffer, " = (__jiang_if_pattern_");
                    emit_c_buffer_push_int(buffer, node_id);
                    text.text_buffer_push_text(buffer, ".");
                    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[jir.jir_store_node_symbol_ids[emit_c_union_pattern_label(pattern)]]);
                    text.text_buffer_push_text(buffer, "._");
                    emit_c_buffer_push_int(buffer, i);
                    text.text_buffer_push_text(buffer, ");\n");
                    i = i + 1;
                }
            }
            Int stmt = jir.jir_store_node_first_child[then_block];
            while (stmt != 0) {
                emit_c_stmt_buffered(buffer, source, root, stmt);
                stmt = jir.jir_store_node_next_sibling[stmt];
            }
            text.text_buffer_push_text(buffer, "    }");
            if (else_block != 0) {
                if (jir.jir_store_node_kinds[else_block] == jir.JirNode.block) {
                    text.text_buffer_push_text(buffer, " else {\n");
                    stmt = jir.jir_store_node_first_child[else_block];
                    while (stmt != 0) {
                        emit_c_stmt_buffered(buffer, source, root, stmt);
                        stmt = jir.jir_store_node_next_sibling[stmt];
                    }
                    text.text_buffer_push_text(buffer, "    }");
                } else {
                    text.text_buffer_push_text(buffer, " else\n");
                    emit_c_stmt_buffered(buffer, source, root, else_block);
                }
            }
            text.text_buffer_push_text(buffer, "\n    }\n");
            return;
        }
        text.text_buffer_push_text(buffer, "    if ");
        if (jir.jir_store_node_kinds[condition] == jir.JirNode.binary_expr) {
            emit_c_expr_buffered(buffer, source, root, condition);
        } else {
            text.text_buffer_push_text(buffer, "(");
            emit_c_expr_buffered(buffer, source, root, condition);
            text.text_buffer_push_text(buffer, ")");
        }
        text.text_buffer_push_text(buffer, " {\n");
        Int stmt = jir.jir_store_node_first_child[then_block];
        while (stmt != 0) {
            emit_c_stmt_buffered(buffer, source, root, stmt);
            stmt = jir.jir_store_node_next_sibling[stmt];
        }
        text.text_buffer_push_text(buffer, "    }");
        if (else_block != 0) {
            if (jir.jir_store_node_kinds[else_block] == jir.JirNode.block) {
                text.text_buffer_push_text(buffer, " else {\n");
                stmt = jir.jir_store_node_first_child[else_block];
                while (stmt != 0) {
                    emit_c_stmt_buffered(buffer, source, root, stmt);
                    stmt = jir.jir_store_node_next_sibling[stmt];
                }
                text.text_buffer_push_text(buffer, "    }");
            } else {
                text.text_buffer_push_text(buffer, " else\n");
                emit_c_stmt_buffered(buffer, source, root, else_block);
            }
        }
        text.text_buffer_push_text(buffer, "\n");
        return;
    }
    if (kind == jir.JirNode.while_stmt) {
        Int condition = jir.jir_store_node_first_child[node_id];
        Int body = jir.jir_store_node_next_sibling[condition];
        text.text_buffer_push_text(buffer, "    while ");
        if (jir.jir_store_node_kinds[condition] == jir.JirNode.binary_expr) {
            emit_c_expr_buffered(buffer, source, root, condition);
        } else {
            text.text_buffer_push_text(buffer, "(");
            emit_c_expr_buffered(buffer, source, root, condition);
            text.text_buffer_push_text(buffer, ")");
        }
        text.text_buffer_push_text(buffer, " {\n");
        Int stmt = jir.jir_store_node_first_child[body];
        while (stmt != 0) {
            emit_c_stmt_buffered(buffer, source, root, stmt);
            stmt = jir.jir_store_node_next_sibling[stmt];
        }
        text.text_buffer_push_text(buffer, "    }\n");
        return;
    }
    if (kind == jir.JirNode.for_stmt) {
        Int mode = jir.jir_store_node_aux[node_id];
        text.text_buffer_push_text(buffer, "    {\n");
        if (mode == 0) {
            Int name_node = 0;
            Int start_expr = 0;
            Int end_expr = 0;
            Int body = 0;
            Int type_node = jir.jir_store_node_first_child[node_id];
            name_node = jir.jir_store_node_next_sibling[type_node];
            start_expr = jir.jir_store_node_next_sibling[name_node];
            end_expr = jir.jir_store_node_next_sibling[start_expr];
            body = jir.jir_store_node_next_sibling[end_expr];
            text.text_buffer_push_text(buffer, "    ");
            emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[node_id]);
            text.text_buffer_push_text(buffer, " __jiang_for_end_");
            emit_c_buffer_push_int(buffer, node_id);
            text.text_buffer_push_text(buffer, " = ");
            emit_c_expr_buffered(buffer, source, root, end_expr);
            text.text_buffer_push_text(buffer, ";\n");
            text.text_buffer_push_text(buffer, "    for (");
            emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[node_id]);
            text.text_buffer_push_text(buffer, " ");
            emit_c_buffer_push_loop_name(buffer, source, node_id, name_node);
            text.text_buffer_push_text(buffer, " = ");
            emit_c_expr_buffered(buffer, source, root, start_expr);
            text.text_buffer_push_text(buffer, "; ");
            emit_c_buffer_push_loop_name(buffer, source, node_id, name_node);
            text.text_buffer_push_text(buffer, " < __jiang_for_end_");
            emit_c_buffer_push_int(buffer, node_id);
            text.text_buffer_push_text(buffer, "; ");
            emit_c_buffer_push_loop_name(buffer, source, node_id, name_node);
            text.text_buffer_push_text(buffer, " = ");
            emit_c_buffer_push_loop_name(buffer, source, node_id, name_node);
            text.text_buffer_push_text(buffer, " + 1) {\n");
            Int stmt = jir.jir_store_node_first_child[body];
            while (stmt != 0) {
                emit_c_stmt_buffered(buffer, source, root, stmt);
                stmt = jir.jir_store_node_next_sibling[stmt];
            }
            text.text_buffer_push_text(buffer, "    }\n");
        } else {
            if (mode == 1) {
                Int name_node = jir.jir_store_node_first_child[node_id];
                Int start_expr = jir.jir_store_node_next_sibling[name_node];
                Int end_expr = jir.jir_store_node_next_sibling[start_expr];
                Int body = jir.jir_store_node_next_sibling[end_expr];
                text.text_buffer_push_text(buffer, "    ");
                emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[node_id]);
                text.text_buffer_push_text(buffer, " __jiang_for_end_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, " = ");
                emit_c_expr_buffered(buffer, source, root, end_expr);
                text.text_buffer_push_text(buffer, ";\n");
                text.text_buffer_push_text(buffer, "    for (");
                emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[node_id]);
                text.text_buffer_push_text(buffer, " ");
                emit_c_buffer_push_loop_name(buffer, source, node_id, name_node);
                text.text_buffer_push_text(buffer, " = ");
                emit_c_expr_buffered(buffer, source, root, start_expr);
                text.text_buffer_push_text(buffer, "; ");
                emit_c_buffer_push_loop_name(buffer, source, node_id, name_node);
                text.text_buffer_push_text(buffer, " < __jiang_for_end_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, "; ");
                emit_c_buffer_push_loop_name(buffer, source, node_id, name_node);
                text.text_buffer_push_text(buffer, " = ");
                emit_c_buffer_push_loop_name(buffer, source, node_id, name_node);
                text.text_buffer_push_text(buffer, " + 1) {\n");
                Int stmt = jir.jir_store_node_first_child[body];
                while (stmt != 0) {
                    emit_c_stmt_buffered(buffer, source, root, stmt);
                    stmt = jir.jir_store_node_next_sibling[stmt];
                }
                text.text_buffer_push_text(buffer, "    }\n");
            } else if (mode == 5) {
                Int index_name_node = jir.jir_store_node_first_child[node_id];
                Int item_name_node = jir.jir_store_node_next_sibling[index_name_node];
                Int iterable_expr = jir.jir_store_node_next_sibling[item_name_node];
                Int body = jir.jir_store_node_next_sibling[iterable_expr];
                Int iterable_type = jir.jir_store_node_type_ids[iterable_expr];
                text.text_buffer_push_text(buffer, "    ");
                emit_c_slice_type_name(buffer, iterable_type);
                text.text_buffer_push_text(buffer, " __jiang_iter_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, " = ");
                emit_c_expr_buffered(buffer, source, root, iterable_expr);
                text.text_buffer_push_text(buffer, ";\n");
                text.text_buffer_push_text(buffer, "    for (long long __jiang_index_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, " = 0; __jiang_index_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, " < __jiang_iter_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, ".length; __jiang_index_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, " = __jiang_index_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, " + 1) {\n");
                text.text_buffer_push_text(buffer, "    long long ");
                if (jir.jir_store_node_symbol_ids[index_name_node] != 0) {
                    emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[index_name_node]);
                } else {
                    emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[index_name_node], jir.jir_store_node_ends[index_name_node]);
                }
                text.text_buffer_push_text(buffer, " = __jiang_index_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, ";\n");
                text.text_buffer_push_text(buffer, "    ");
                emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[item_name_node]);
                text.text_buffer_push_text(buffer, " ");
                if (jir.jir_store_node_symbol_ids[item_name_node] != 0) {
                    emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[item_name_node]);
                } else {
                    emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[item_name_node], jir.jir_store_node_ends[item_name_node]);
                }
                text.text_buffer_push_text(buffer, " = ");
                if (emit_c_slice_uses_void_ptr(iterable_type) != 0) {
                    text.text_buffer_push_text(buffer, "((");
                    emit_c_slice_elem_ptr_cast(buffer, iterable_type);
                    text.text_buffer_push_text(buffer, "__jiang_iter_");
                    emit_c_buffer_push_int(buffer, node_id);
                    text.text_buffer_push_text(buffer, ".ptr)[__jiang_index_");
                } else {
                    text.text_buffer_push_text(buffer, "(__jiang_iter_");
                    emit_c_buffer_push_int(buffer, node_id);
                    text.text_buffer_push_text(buffer, ".ptr[__jiang_index_");
                }
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, "]);\n");
                Int stmt = jir.jir_store_node_first_child[body];
                while (stmt != 0) {
                    emit_c_stmt_buffered(buffer, source, root, stmt);
                    stmt = jir.jir_store_node_next_sibling[stmt];
                }
                text.text_buffer_push_text(buffer, "    }\n");
            } else {
                Int name_node = 0;
                Int iterable_expr = 0;
                Int body = 0;
                if (mode == 2) {
                    name_node = jir.jir_store_node_first_child[node_id];
                    iterable_expr = jir.jir_store_node_next_sibling[name_node];
                    body = jir.jir_store_node_next_sibling[iterable_expr];
                } else {
                    Int type_node = jir.jir_store_node_first_child[node_id];
                    name_node = jir.jir_store_node_next_sibling[type_node];
                    iterable_expr = jir.jir_store_node_next_sibling[name_node];
                    body = jir.jir_store_node_next_sibling[iterable_expr];
                }
                Int iterable_type = jir.jir_store_node_type_ids[iterable_expr];
                text.text_buffer_push_text(buffer, "    ");
                emit_c_slice_type_name(buffer, iterable_type);
                text.text_buffer_push_text(buffer, " __jiang_iter_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, " = ");
                emit_c_expr_buffered(buffer, source, root, iterable_expr);
                text.text_buffer_push_text(buffer, ";\n");
                text.text_buffer_push_text(buffer, "    for (long long __jiang_index_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, " = 0; __jiang_index_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, " < __jiang_iter_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, ".length; __jiang_index_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, " = __jiang_index_");
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, " + 1) {\n");
                text.text_buffer_push_text(buffer, "    ");
                emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[node_id]);
                text.text_buffer_push_text(buffer, " ");
                emit_c_buffer_push_loop_name(buffer, source, node_id, name_node);
                text.text_buffer_push_text(buffer, " = ");
                if (emit_c_slice_uses_void_ptr(iterable_type) != 0) {
                    text.text_buffer_push_text(buffer, "((");
                    emit_c_slice_elem_ptr_cast(buffer, iterable_type);
                    text.text_buffer_push_text(buffer, "__jiang_iter_");
                    emit_c_buffer_push_int(buffer, node_id);
                    text.text_buffer_push_text(buffer, ".ptr)[__jiang_index_");
                } else {
                    text.text_buffer_push_text(buffer, "(__jiang_iter_");
                    emit_c_buffer_push_int(buffer, node_id);
                    text.text_buffer_push_text(buffer, ".ptr[__jiang_index_");
                }
                emit_c_buffer_push_int(buffer, node_id);
                text.text_buffer_push_text(buffer, "]);\n");
                Int stmt = jir.jir_store_node_first_child[body];
                while (stmt != 0) {
                    emit_c_stmt_buffered(buffer, source, root, stmt);
                    stmt = jir.jir_store_node_next_sibling[stmt];
                }
                text.text_buffer_push_text(buffer, "    }\n");
            }
        }
        text.text_buffer_push_text(buffer, "    }\n");
        return;
    }
    if (kind == jir.JirNode.switch_stmt) {
        Int condition = jir.jir_store_node_first_child[node_id];
        Int child = jir.jir_store_node_next_sibling[condition];
        Int condition_type = jir.jir_store_node_type_ids[condition];
        text.text_buffer_push_text(buffer, "    {\n");
        text.text_buffer_push_text(buffer, "    ");
        emit_c_type_id_buffered(buffer, condition_type);
        text.text_buffer_push_text(buffer, " __jiang_switch_");
        emit_c_buffer_push_int(buffer, node_id);
        text.text_buffer_push_text(buffer, " = ");
        emit_c_expr_buffered(buffer, source, root, condition);
        text.text_buffer_push_text(buffer, ";\n");
        Int emitted_case = 0;
        while (child != 0) {
            Int child_kind = jir.jir_store_node_kinds[child];
            if (child_kind == jir.JirNode.switch_case) {
                Int label = jir.jir_store_node_first_child[child];
                Int bind = emit_c_switch_case_binding(child);
                Int body = emit_c_switch_case_body(child);
                if (emitted_case == 0) {
                    text.text_buffer_push_text(buffer, "    if (__jiang_switch_");
                } else {
                    text.text_buffer_push_text(buffer, "    else if (__jiang_switch_");
                }
                emit_c_buffer_push_int(buffer, node_id);
                if (emit_c_is_union_type(condition_type) != 0) {
                    text.text_buffer_push_text(buffer, ".tag == ");
                } else {
                    text.text_buffer_push_text(buffer, " == ");
                }
                emit_c_expr_buffered(buffer, source, root, label);
                text.text_buffer_push_text(buffer, ") {\n");
                if (bind != 0) {
                    text.text_buffer_push_text(buffer, "    ");
                    emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[bind]);
                    text.text_buffer_push_text(buffer, " ");
                    emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[bind]);
                    text.text_buffer_push_text(buffer, " = __jiang_switch_");
                    emit_c_buffer_push_int(buffer, node_id);
                    text.text_buffer_push_text(buffer, ".");
                    emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[jir.jir_store_node_symbol_ids[label]]);
                    text.text_buffer_push_text(buffer, ";\n");
                } else if (jir.jir_store_node_kinds[label] == jir.JirNode.union_pattern_expr) {
                    Int pattern_bind_count = emit_c_union_pattern_binding_count(label);
                    if (pattern_bind_count == 1) {
                        Int label_value = emit_c_union_pattern_label(label);
                        Int pattern_bind = emit_c_union_pattern_binding_item(label, 0);
                        text.text_buffer_push_text(buffer, "    ");
                        emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[pattern_bind]);
                        text.text_buffer_push_text(buffer, " ");
                        emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[pattern_bind]);
                        text.text_buffer_push_text(buffer, " = __jiang_switch_");
                        emit_c_buffer_push_int(buffer, node_id);
                        text.text_buffer_push_text(buffer, ".");
                        emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[jir.jir_store_node_symbol_ids[label_value]]);
                        text.text_buffer_push_text(buffer, ";\n");
                    } else if (pattern_bind_count > 1) {
                        Int label_value = emit_c_union_pattern_label(label);
                        Int i = 0;
                        while (i < pattern_bind_count) {
                            Int pattern_bind = emit_c_union_pattern_binding_item(label, i);
                            text.text_buffer_push_text(buffer, "    ");
                            emit_c_type_id_buffered(buffer, jir.jir_store_node_type_ids[pattern_bind]);
                            text.text_buffer_push_text(buffer, " ");
                            emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[pattern_bind]);
                            text.text_buffer_push_text(buffer, " = (__jiang_switch_");
                            emit_c_buffer_push_int(buffer, node_id);
                            text.text_buffer_push_text(buffer, ".");
                            emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[jir.jir_store_node_symbol_ids[label_value]]);
                            text.text_buffer_push_text(buffer, "._");
                            emit_c_buffer_push_int(buffer, i);
                            text.text_buffer_push_text(buffer, ");\n");
                            i = i + 1;
                        }
                    }
                }
                if (jir.jir_store_node_kinds[body] == jir.JirNode.block) {
                    Int stmt = jir.jir_store_node_first_child[body];
                    while (stmt != 0) {
                        emit_c_stmt_buffered(buffer, source, root, stmt);
                        stmt = jir.jir_store_node_next_sibling[stmt];
                    }
                } else {
                    emit_c_stmt_buffered(buffer, source, root, body);
                }
                text.text_buffer_push_text(buffer, "    }");
                emitted_case = 1;
            }
            if (child_kind == jir.JirNode.switch_else) {
                Int body = jir.jir_store_node_first_child[child];
                if (emitted_case == 0) {
                    text.text_buffer_push_text(buffer, "    {\n");
                } else {
                    text.text_buffer_push_text(buffer, " else {\n");
                }
                if (jir.jir_store_node_kinds[body] == jir.JirNode.block) {
                    Int stmt = jir.jir_store_node_first_child[body];
                    while (stmt != 0) {
                        emit_c_stmt_buffered(buffer, source, root, stmt);
                        stmt = jir.jir_store_node_next_sibling[stmt];
                    }
                } else {
                    emit_c_stmt_buffered(buffer, source, root, body);
                }
                text.text_buffer_push_text(buffer, "    }");
            }
            child = jir.jir_store_node_next_sibling[child];
        }
        text.text_buffer_push_text(buffer, "\n");
        text.text_buffer_push_text(buffer, "    }\n");
        return;
    }
    if (kind == jir.JirNode.break_stmt) {
        text.text_buffer_push_text(buffer, "    break;\n");
        return;
    }
    if (kind == jir.JirNode.continue_stmt) {
        text.text_buffer_push_text(buffer, "    continue;\n");
        return;
    }
    if (kind == jir.JirNode.return_stmt) {
        Int expr = jir.jir_store_node_first_child[node_id];
        if (expr == 0) {
            text.text_buffer_push_text(buffer, "    return;\n");
            return;
        }
        text.text_buffer_push_text(buffer, "    return ");
        emit_c_expr_buffered(buffer, source, root, expr);
        text.text_buffer_push_text(buffer, ";\n");
        return;
    }
    if (kind == jir.JirNode.expr_stmt) {
        text.text_buffer_push_text(buffer, "    ");
        emit_c_expr_buffered(buffer, source, root, jir.jir_store_node_first_child[node_id]);
        text.text_buffer_push_text(buffer, ";\n");
        return;
    }
    if (kind == jir.JirNode.tuple_local_decl) {
        Int child = jir.jir_store_node_first_child[node_id];
        while (child != 0) {
            emit_c_stmt_buffered(buffer, source, root, child);
            child = jir.jir_store_node_next_sibling[child];
        }
        return;
    }
    if (kind == jir.JirNode.local_decl) {
        Int type_node = jir.jir_store_node_first_child[node_id];
        Int name_node = jir.jir_store_node_next_sibling[type_node];
        Int init_expr = jir.jir_store_node_next_sibling[name_node];
        Int declared_type = emit_c_strip_mutable_type(jir.jir_store_node_type_ids[type_node]);
        text.text_buffer_push_text(buffer, "    ");
        if (emit_c_type_node_uses_type_id(source, type_node) != 0) {
            emit_c_decl_type_id_buffered(
                buffer,
                declared_type,
                interns.intern_pool_value(symbols.symbol_store_name_ids[jir.jir_store_node_symbol_ids[node_id]])
            );
        } else {
            emit_c_decl_buffered(buffer, source, type_node, name_node);
        }
        text.text_buffer_push_text(buffer, " = ");
        if (types.type_store_kinds[declared_type] == types.TypeKind.array) {
            if (types.type_store_elem_type_ids[declared_type] == types.type_store_builtin_uint8) {
                if (jir.jir_store_node_kinds[init_expr] == jir.JirNode.string_lit) {
                    emit_c_string_init_bytes(buffer, source, init_expr);
                } else if (jir.jir_store_node_kinds[init_expr] == jir.JirNode.array_init_expr) {
                    emit_c_array_init_items_buffered(buffer, source, root, init_expr);
                } else {
                    emit_c_expr_buffered(buffer, source, root, init_expr);
                }
            } else {
                if (jir.jir_store_node_kinds[init_expr] == jir.JirNode.array_init_expr) {
                    emit_c_array_init_items_buffered(buffer, source, root, init_expr);
                } else {
                    emit_c_expr_buffered(buffer, source, root, init_expr);
                }
            }
        } else {
            emit_c_expr_buffered(buffer, source, root, init_expr);
        }
        text.text_buffer_push_text(buffer, ";\n");
        return;
    }
    __intrinsic_assert(0);
}

() emit_c_global_decl(Int buffer, UInt8[] source, Int root, Int node_id) {
    Int type_node = jir.jir_store_node_first_child[node_id];
    Int name_node = jir.jir_store_node_next_sibling[type_node];
    Int init_expr = jir.jir_store_node_next_sibling[name_node];
    if (emit_c_type_node_uses_type_id(source, type_node) != 0) {
        Int type_id = jir.jir_store_node_type_ids[type_node];
        emit_c_type_id_buffered(buffer, emit_c_decl_base_type_id(type_id));
        text.text_buffer_push_text(buffer, " ");
        if (jir.jir_store_node_symbol_ids[node_id] != 0) {
            emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[node_id]);
        } else {
            emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
        }
        emit_c_decl_array_suffixes_from_type_id(buffer, type_id);
    } else {
        emit_c_type_buffered(buffer, source, emit_c_decl_base_type_node(type_node));
        text.text_buffer_push_text(buffer, " ");
        if (jir.jir_store_node_symbol_ids[node_id] != 0) {
            emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[node_id]);
        } else {
            emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
        }
        emit_c_decl_array_suffixes(buffer, type_node);
    }
    if (init_expr == 0) {
        text.text_buffer_push_text(buffer, ";\n");
        return;
    }
    text.text_buffer_push_text(buffer, " = ");
    Int declared_type = emit_c_strip_mutable_type(jir.jir_store_node_type_ids[type_node]);
    if (declared_type == types.type_store_builtin_uint8_slice) {
        if (jir.jir_store_node_kinds[init_expr] == jir.JirNode.string_lit) {
            Int length = 0;
            Int i = jir.jir_store_node_starts[init_expr] + 1;
            Int end_pos = jir.jir_store_node_ends[init_expr] - 1;
            while (i < end_pos) {
                length = length + 1;
                i = emit_c_string_lit_next_index(source, i, end_pos);
            }
            if (length == 0) {
                text.text_buffer_push_text(buffer, "(Slice_uint8_t){ .ptr = 0, .length = 0 }");
            } else {
                emit_c_expr_buffered(buffer, source, root, init_expr);
            }
        } else {
            emit_c_expr_buffered(buffer, source, root, init_expr);
        }
    } else if (types.type_store_kinds[declared_type] == types.TypeKind.array) {
        if (types.type_store_elem_type_ids[declared_type] == types.type_store_builtin_uint8) {
            if (jir.jir_store_node_kinds[init_expr] == jir.JirNode.string_lit) {
                emit_c_string_init_bytes(buffer, source, init_expr);
            } else if (jir.jir_store_node_kinds[init_expr] == jir.JirNode.array_init_expr) {
                emit_c_array_init_items_buffered(buffer, source, root, init_expr);
            } else {
                emit_c_expr_buffered(buffer, source, root, init_expr);
            }
        } else {
            if (jir.jir_store_node_kinds[init_expr] == jir.JirNode.array_init_expr) {
                emit_c_array_init_items_buffered(buffer, source, root, init_expr);
            } else {
                emit_c_expr_buffered(buffer, source, root, init_expr);
            }
        }
    } else {
        emit_c_expr_buffered(buffer, source, root, init_expr);
    }
    text.text_buffer_push_text(buffer, ";\n");
}

() emit_c_struct_decl(Int buffer, UInt8[] source, Int node_id) {
    Int name_node = jir.jir_store_node_first_child[node_id];
    text.text_buffer_push_text(buffer, "typedef struct ");
    if (jir.jir_store_node_symbol_ids[node_id] != 0) {
        emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[node_id]);
    } else {
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
    }
    text.text_buffer_push_text(buffer, " {\n");
    Int child = jir.jir_store_node_next_sibling[name_node];
    while (child != 0) {
        Int type_node = jir.jir_store_node_first_child[child];
        Int field_name = jir.jir_store_node_next_sibling[type_node];
        text.text_buffer_push_text(buffer, "    ");
        emit_c_decl_buffered(buffer, source, type_node, field_name);
        text.text_buffer_push_text(buffer, ";\n");
        child = jir.jir_store_node_next_sibling[child];
    }
    text.text_buffer_push_text(buffer, "} ");
    if (jir.jir_store_node_symbol_ids[node_id] != 0) {
        emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[node_id]);
    } else {
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
    }
    text.text_buffer_push_text(buffer, ";\n\n");
}

() emit_c_enum_decl(Int buffer, UInt8[] source, Int node_id) {
    Int name_node = jir.jir_store_node_first_child[node_id];
    text.text_buffer_push_text(buffer, "typedef enum ");
    if (jir.jir_store_node_symbol_ids[node_id] != 0) {
        emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[node_id]);
    } else {
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
    }
    text.text_buffer_push_text(buffer, " {\n");
    Int child = jir.jir_store_node_next_sibling[name_node];
    Int first = 1;
    while (child != 0) {
        Int member_name = jir.jir_store_node_first_child[child];
        text.text_buffer_push_text(buffer, "    ");
        if (jir.jir_store_node_symbol_ids[child] != 0) {
            emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[node_id]);
            text.text_buffer_push_text(buffer, "_");
            emit_c_buffer_push_name_id(buffer, symbols.symbol_store_name_ids[jir.jir_store_node_symbol_ids[child]]);
        } else {
            emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
            text.text_buffer_push_text(buffer, "_");
            emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[member_name], jir.jir_store_node_ends[member_name]);
        }
        text.text_buffer_push_text(buffer, " = ");
        emit_c_buffer_push_int(buffer, jir.jir_store_node_aux[child]);
        if (jir.jir_store_node_next_sibling[child] != 0) {
            text.text_buffer_push_text(buffer, ",");
        }
        text.text_buffer_push_text(buffer, "\n");
        first = 0;
        child = jir.jir_store_node_next_sibling[child];
    }
    first = first;
    text.text_buffer_push_text(buffer, "} ");
    if (jir.jir_store_node_symbol_ids[node_id] != 0) {
        emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[node_id]);
    } else {
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
    }
    text.text_buffer_push_text(buffer, ";\n\n");
}

() emit_c_func_signature_buffered(Int buffer, UInt8[] source, Int func_node, Int prototype_only, Int root) {
    root = root;
    Int child = jir.jir_store_node_first_child[func_node];
    Int type_node = child;
    child = jir.jir_store_node_next_sibling[child];
    Int name_node = child;
    child = jir.jir_store_node_next_sibling[child];

    if (emit_c_is_main_name(source, name_node)) {
        text.text_buffer_push_text(buffer, "int ");
    } else {
        emit_c_type_buffered(buffer, source, type_node);
        text.text_buffer_push_text(buffer, " ");
    }
    if (jir.jir_store_node_symbol_ids[func_node] != 0) {
        emit_c_buffer_push_symbol_name(buffer, jir.jir_store_node_symbol_ids[func_node]);
    } else {
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[name_node], jir.jir_store_node_ends[name_node]);
    }
    text.text_buffer_push_text(buffer, "(");

    Int first = 1;
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] != jir.JirNode.param) {
            break;
        }
        Int param_type = jir.jir_store_node_first_child[child];
        Int param_name = jir.jir_store_node_next_sibling[param_type];
        if (first == 0) {
            text.text_buffer_push_text(buffer, ", ");
        }
        emit_c_type_buffered(buffer, source, param_type);
        text.text_buffer_push_text(buffer, " ");
        emit_c_buffer_push_span(buffer, source, jir.jir_store_node_starts[param_name], jir.jir_store_node_ends[param_name]);
        first = 0;
        child = jir.jir_store_node_next_sibling[child];
    }
    if (first != 0) {
        text.text_buffer_push_text(buffer, "void");
    }
    text.text_buffer_push_text(buffer, ")");
    if (prototype_only != 0) {
        text.text_buffer_push_text(buffer, ";\n");
        return;
    }

    text.text_buffer_push_text(buffer, " {\n");
    Int block = child;
    Int stmt = jir.jir_store_node_first_child[block];
    while (stmt != 0) {
        emit_c_stmt_buffered(buffer, source, root, stmt);
        stmt = jir.jir_store_node_next_sibling[stmt];
    }
    text.text_buffer_push_text(buffer, "}\n");
}

public UInt8[] emit_c_module_text(UInt8[] source, Int root) {
    Int buffer = text.text_buffer_new(256);
    text.text_buffer_clear(buffer);
    Int completed_types_handle = ints.buffer_int_new(16);
    Int emitted_optionals_handle = ints.buffer_int_new(16);
    Int init_type_id = 0;
    while (init_type_id <= types.type_store_count) {
        ints.buffer_int_set(completed_types_handle, init_type_id, 0);
        ints.buffer_int_set(emitted_optionals_handle, init_type_id, 0);
        init_type_id = init_type_id + 1;
    }
    emit_c_nonbuiltin_slice_prelude(buffer);
    emit_c_tuple_prelude(buffer);
    emit_c_named_type_forward_prelude(buffer, source, root);
    emit_c_optional_decls_ready(buffer, completed_types_handle, emitted_optionals_handle);

    Int child = jir.jir_store_node_first_child[root];
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] == jir.JirNode.struct_decl) {
            emit_c_struct_decl(buffer, source, child);
            Int type_id = emit_c_decl_type_id(child);
            if (type_id != 0) {
                ints.buffer_int_set(completed_types_handle, type_id, 1);
                emit_c_optional_decls_ready(buffer, completed_types_handle, emitted_optionals_handle);
            }
        }
        if (jir.jir_store_node_kinds[child] == jir.JirNode.union_decl) {
            emit_c_union_decl(buffer, source, child);
            Int type_id = emit_c_decl_type_id(child);
            if (type_id != 0) {
                ints.buffer_int_set(completed_types_handle, type_id, 1);
                emit_c_optional_decls_ready(buffer, completed_types_handle, emitted_optionals_handle);
            }
        }
        if (jir.jir_store_node_kinds[child] == jir.JirNode.enum_decl) {
            emit_c_enum_decl(buffer, source, child);
            Int type_id = emit_c_decl_type_id(child);
            if (type_id != 0) {
                ints.buffer_int_set(completed_types_handle, type_id, 1);
                emit_c_optional_decls_ready(buffer, completed_types_handle, emitted_optionals_handle);
            }
        }
        child = jir.jir_store_node_next_sibling[child];
    }

    child = jir.jir_store_node_first_child[root];
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] == jir.JirNode.global_decl) {
            emit_c_global_decl(buffer, source, root, child);
        }
        if (jir.jir_store_node_kinds[child] == jir.JirNode.tuple_global_decl) {
            Int part = jir.jir_store_node_first_child[child];
            while (part != 0) {
                emit_c_global_decl(buffer, source, root, part);
                part = jir.jir_store_node_next_sibling[part];
            }
        }
        child = jir.jir_store_node_next_sibling[child];
    }

    if (jir.jir_store_node_first_child[root] != 0) {
        text.text_buffer_push_text(buffer, "\n");
    }

    child = jir.jir_store_node_first_child[root];
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] == jir.JirNode.func_decl) {
            emit_c_func_signature_buffered(buffer, source, child, 1, root);
        }
        child = jir.jir_store_node_next_sibling[child];
    }

    text.text_buffer_push_text(buffer, "\n");
    child = jir.jir_store_node_first_child[root];
    while (child != 0) {
        if (jir.jir_store_node_kinds[child] == jir.JirNode.func_decl) {
            if (emit_c_is_extern_func(child) == 0) {
                emit_c_func_signature_buffered(buffer, source, child, 0, root);
                text.text_buffer_push_text(buffer, "\n");
            }
        }
        child = jir.jir_store_node_next_sibling[child];
    }
    return text.text_buffer_slice(buffer);
}

public UInt8[] emit_c_program_text(UInt8[] source, Int root) {
    Int buffer = text.text_buffer_new(256);
    text.text_buffer_clear(buffer);
    text.text_buffer_push_text(buffer, "#include <stdint.h>\n");
    text.text_buffer_push_text(buffer, "#include <stdlib.h>\n");
    text.text_buffer_push_text(buffer, "#include <string.h>\n\n");
    emit_c_slice_prelude(buffer);
    emit_c_tuple_prelude(buffer);
    text.text_buffer_push_text(buffer, "void __intrinsic_print(const char* fmt, ...);\n");
    text.text_buffer_push_text(buffer, "void __intrinsic_write_stdout(Slice_uint8_t value);\n");
    text.text_buffer_push_text(buffer, "void __intrinsic_assert(int cond);\n\n");
    text.text_buffer_push_text(buffer, "static char* __attribute__((unused)) jiang_emit_to_cstr(Slice_uint8_t value) {\n");
    text.text_buffer_push_text(buffer, "    char* text = (char*)malloc((size_t)value.length + 1);\n");
    text.text_buffer_push_text(buffer, "    if (!text) return NULL;\n");
    text.text_buffer_push_text(buffer, "    if (value.length > 0 && value.ptr) memcpy(text, value.ptr, (size_t)value.length);\n");
    text.text_buffer_push_text(buffer, "    text[value.length] = '\\0';\n");
    text.text_buffer_push_text(buffer, "    return text;\n");
    text.text_buffer_push_text(buffer, "}\n\n");
    text.text_buffer_push_text(buffer, emit_c_module_text(source, root));
    return text.text_buffer_slice(buffer);
}

public () emit_c_program(UInt8[] source, Int root) {
    print("%s", emit_c_program_text(source, root));
}
