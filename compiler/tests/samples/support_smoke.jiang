import ints = "../../support/buffer_int.jiang";
import bytes = "../../support/buffer_bytes.jiang";
import interns = "../../support/intern_pool.jiang";
import text = "../../support/text_buffer.jiang";

() test_buffer_int() {
    ints.buffer_int_reset();
    Int int_buffer = ints.buffer_int_new(2);
    ints.buffer_int_push(int_buffer, 7);
    ints.buffer_int_push(int_buffer, 8);
    ints.buffer_int_set(int_buffer, 5, 99);
    assert(ints.buffer_int_get(int_buffer, 0) == 7);
    assert(ints.buffer_int_get(int_buffer, 1) == 8);
    assert(ints.buffer_int_get(int_buffer, 5) == 99);
    assert(ints.buffer_int_length(int_buffer) == 6);
    assert(ints.buffer_int_capacity(int_buffer) >= 6);
    Int[] view = ints.buffer_int_slice(int_buffer);
    assert(view[5] == 99);
}

() test_buffer_bytes() {
    bytes.buffer_bytes_reset();
    Int byte_buffer = bytes.buffer_bytes_new(2);
    bytes.buffer_bytes_push(byte_buffer, 65);
    bytes.buffer_bytes_push(byte_buffer, 66);
    bytes.buffer_bytes_push(byte_buffer, 67);
    UInt8[] view = bytes.buffer_bytes_slice(byte_buffer);
    assert(view.length == 3);
    assert(view[0] == 65);
    assert(view[2] == 67);
}

() test_intern_pool() {
    interns.intern_pool_reset();
    Int a = interns.intern_pool_intern("x");
    Int b = interns.intern_pool_intern("x");
    Int c = interns.intern_pool_intern("xyz");
    assert(a == b);
    assert(a != c);
    UInt8[] value = interns.intern_pool_value(c);
    assert(value.length == 3);
    assert(value[0] == 120);
    assert(value[2] == 122);
}

() test_text_buffer() {
    text.text_buffer_reset();
    Int handle = text.text_buffer_new(4);
    text.text_buffer_push_text(handle, "stage2");
    text.text_buffer_push_byte(handle, 32);
    text.text_buffer_push_text(handle, "ok");
    text.text_buffer_push_newline(handle);
    UInt8[] value = text.text_buffer_slice(handle);
    assert(text.text_buffer_length(handle) == 10);
    assert(value[0] == 115);
    assert(value[6] == 32);
    assert(value[7] == 111);
    assert(value[9] == 10);
}

test_buffer_int();
test_buffer_bytes();
test_intern_pool();
test_text_buffer();
print("stage2 support smoke passed\n");
