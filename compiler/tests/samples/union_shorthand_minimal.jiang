enum Kind {
    a,
    b,
}

union(Kind) MyUnion {
    Int a;
    Int b;
}

Int unwrap(MyUnion value) {
    if (value == MyUnion.a(_ payload)) {
        return payload;
    }
    return 0;
}

MyUnion make_value() {
    return .a(42);
}

Int main() {
    MyUnion value = .a(42);
    return unwrap(value) + unwrap(make_value()) - 42;
}
