enum Kind {
    a,
    b,
    e,
}

union(Kind) MyUnion {
    Int a;
    Int b;
    () e;
}

Int choose(MyUnion value) {
    switch (value) {
        MyUnion.a(_ payload): return payload;
        MyUnion.b(_ payload): return payload + 1;
        MyUnion.e(): return 0;
        else: return 99;
    }
}

Int main() {
    MyUnion value = MyUnion.b(41);
    return choose(value);
}
