public struct MethodBox {
    Int value;

    public init(Int value) {
        self.value = value;
        return;
    }

    public Int public_value() {
        return self.value;
    }

    Int private_value() {
        return self.value;
    }

    public static Int public_answer() {
        return 42;
    }

    static Int private_answer() {
        return 42;
    }
}
