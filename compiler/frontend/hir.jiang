Bool parse_node_has_generic_items(Int parse_node) {
    if (parse_node == 0) {
        return 0;
    }
    return parser.parser_store_node_generic_item_counts[parse_node] != 0;
}

Bool parse_node_is_generic_decl(Int parse_node) {
    if (!parse_node_has_generic_items(parse_node)) {
        return 0;
    }
    Int kind = parser.parser_store_node_kinds[parse_node];
    if (kind == parser.ParserNode.struct_decl) {
        return 1;
    }
    if (kind == parser.ParserNode.union_decl) {
        return 1;
    }
    if (kind == parser.ParserNode.enum_decl) {
        return 1;
    }
    return kind == parser.ParserNode.func_decl;
}

Int generic_decl_first_type_id(Int decl_parse) {
    if (decl_parse >= ints.buffer_int_length(generic_decl_first_type_id_handle)) {
        return 0;
    }
    return ints.buffer_int_get(generic_decl_first_type_id_handle, decl_parse);
}

Int generic_decl_type_count(Int decl_parse) {
    if (decl_parse >= ints.buffer_int_length(generic_decl_type_count_handle)) {
        return 0;
    }
    return ints.buffer_int_get(generic_decl_type_count_handle, decl_parse);
}

() generic_context_reset() {
    if (generic_decl_first_type_id_handle == 0) {
        generic_decl_first_type_id_handle = ints.buffer_int_new(256);
        generic_decl_type_count_handle = ints.buffer_int_new(256);
        generic_template_decl_parse_handle = ints.buffer_int_new(256);
        generic_template_first_type_id_handle = ints.buffer_int_new(256);
        generic_template_type_count_handle = ints.buffer_int_new(256);
        current_generic_context_handle = ints.buffer_int_new(16);
        generic_struct_template_symbol_handle = ints.buffer_int_new(64);
        generic_struct_inst_arg_offset_handle = ints.buffer_int_new(64);
        generic_struct_inst_arg_count_handle = ints.buffer_int_new(64);
        generic_struct_inst_arg_type_ids_handle = ints.buffer_int_new(256);
        generic_struct_inst_type_id_handle = ints.buffer_int_new(64);
        generic_struct_inst_owner_symbol_handle = ints.buffer_int_new(64);
        generic_func_inst_template_symbol_handle = ints.buffer_int_new(64);
        generic_func_inst_arg_offset_handle = ints.buffer_int_new(64);
        generic_func_inst_arg_count_handle = ints.buffer_int_new(64);
        generic_func_inst_arg_type_ids_handle = ints.buffer_int_new(256);
        generic_func_inst_symbol_handle = ints.buffer_int_new(64);
        freed_symbol_state_handle = ints.buffer_int_new(64);
    }
    ints.buffer_int_clear(generic_decl_first_type_id_handle);
    ints.buffer_int_clear(generic_decl_type_count_handle);
    ints.buffer_int_clear(generic_template_decl_parse_handle);
    ints.buffer_int_clear(generic_template_first_type_id_handle);
    ints.buffer_int_clear(generic_template_type_count_handle);
    ints.buffer_int_clear(current_generic_context_handle);
    ints.buffer_int_clear(generic_struct_template_symbol_handle);
    ints.buffer_int_clear(generic_struct_inst_arg_offset_handle);
    ints.buffer_int_clear(generic_struct_inst_arg_count_handle);
    ints.buffer_int_clear(generic_struct_inst_arg_type_ids_handle);
    ints.buffer_int_clear(generic_struct_inst_type_id_handle);
    ints.buffer_int_clear(generic_struct_inst_owner_symbol_handle);
    ints.buffer_int_clear(generic_func_inst_template_symbol_handle);
    ints.buffer_int_clear(generic_func_inst_arg_offset_handle);
    ints.buffer_int_clear(generic_func_inst_arg_count_handle);
    ints.buffer_int_clear(generic_func_inst_arg_type_ids_handle);
    ints.buffer_int_clear(generic_func_inst_symbol_handle);
    ints.buffer_int_clear(freed_symbol_state_handle);
    current_generic_context_count = 0;
    generic_struct_inst_count = 0;
    generic_func_inst_count = 0;
    current_generic_func_lowering_parse = 0;
    current_generic_func_lowering_symbol = 0;
    current_generic_subst_first_type_id = 0;
    current_generic_subst_type_count = 0;
    current_generic_subst_arg_types_handle = 0;
    current_parse_snapshot_id = 0;
}

() free_state_reset() {
    if (freed_symbol_state_handle == 0) {
        freed_symbol_state_handle = ints.buffer_int_new(64);
    }
    ints.buffer_int_clear(freed_symbol_state_handle);
}

Bool symbol_is_freed(Int symbol_id) {
    if (symbol_id <= 0) {
        return 0;
    }
    if (symbol_id >= ints.buffer_int_length(freed_symbol_state_handle)) {
        return 0;
    }
    return ints.buffer_int_get(freed_symbol_state_handle, symbol_id) != 0;
}

() mark_symbol_freed(Int symbol_id) {
    if (symbol_id <= 0) {
        return;
    }
    ints.buffer_int_set(freed_symbol_state_handle, symbol_id, 1);
}

() generic_decl_ensure_types(UInt8[] source, Int decl_parse) {
    if (!parse_node_has_generic_items(decl_parse)) {
        return;
    }
    if (generic_decl_type_count(decl_parse) != 0) {
        return;
    }
    Int count = parser.parser_store_node_generic_item_counts[decl_parse];
    Int offset = parser.parser_store_node_generic_item_offsets[decl_parse];
    Int first_type_id = 0;
    Int i = 0;
    while (i < count) {
        Int item = parser.parser_store_generic_item_ids[offset + i];
        Int type_id = type_store.type_store_new_generic_param_type(
            source,
            parser.parser_store_node_starts[item],
            parser.parser_store_node_ends[item]
        );
        if (i == 0) {
            first_type_id = type_id;
        }
        i = i + 1;
    }
    ints.buffer_int_set(generic_decl_first_type_id_handle, decl_parse, first_type_id);
    ints.buffer_int_set(generic_decl_type_count_handle, decl_parse, count);
}

() generic_context_push(UInt8[] source, Int decl_parse) {
    if (!parse_node_has_generic_items(decl_parse)) {
        return;
    }
    generic_decl_ensure_types(source, decl_parse);
    ints.buffer_int_set(current_generic_context_handle, current_generic_context_count, decl_parse);
    current_generic_context_count = current_generic_context_count + 1;
}

() generic_context_pop(Int decl_parse) {
    decl_parse = decl_parse;
    if (current_generic_context_count == 0) {
        return;
    }
    current_generic_context_count = current_generic_context_count - 1;
}

Int resolve_generic_param_type(UInt8[] source, Int parse_node) {
    source = source;
    if (current_generic_context_count == 0) {
        return type_store.type_store_builtin_unknown;
    }
    if (parser.parser_store_node_kinds[parse_node] != parser.ParserNode.type_name) {
        return type_store.type_store_builtin_unknown;
    }
    if (parse_node_has_generic_items(parse_node)) {
        return type_store.type_store_builtin_unknown;
    }
    Int name_id = intern_pool.intern_pool_intern(
        source[parser.parser_store_node_starts[parse_node]..parser.parser_store_node_ends[parse_node]]
    );
    Int i = current_generic_context_count - 1;
    while (i >= 0) {
        Int decl_parse = ints.buffer_int_get(current_generic_context_handle, i);
        Int count = generic_decl_type_count(decl_parse);
        Int first_type_id = generic_decl_first_type_id(decl_parse);
        Int j = 0;
        while (j < count) {
            if (type_store.type_store_name_ids[first_type_id + j] == name_id) {
                return first_type_id + j;
            }
            j = j + 1;
        }
        i = i - 1;
    }
    return type_store.type_store_builtin_unknown;
}

Int substitute_active_generic_param_type(Int type_id) {
    if (current_generic_subst_type_count == 0) {
        return type_id;
    }
    if (type_id <= 0) {
        return type_id;
    }
    if (type_id >= type_store.type_store_count) {
        return type_id;
    }
    if (type_store.type_store_kinds[type_id] != type_store.TypeKind.generic_param) {
        return type_id;
    }
    Int index = type_id - current_generic_subst_first_type_id;
    if (index < 0) {
        return type_id;
    }
    if (index >= current_generic_subst_type_count) {
        return type_id;
    }
    return ints.buffer_int_get(current_generic_subst_arg_types_handle, index);
}

Int generic_struct_inst_find(Int template_symbol, Int[] arg_types) {
    Int arg_count = arg_types.length;
    Int inst_id = 1;
    while (inst_id <= generic_struct_inst_count) {
        if (ints.buffer_int_get(generic_struct_template_symbol_handle, inst_id) == template_symbol) {
            if (ints.buffer_int_get(generic_struct_inst_arg_count_handle, inst_id) == arg_count) {
                Int offset = ints.buffer_int_get(generic_struct_inst_arg_offset_handle, inst_id);
                Int i = 0;
                Bool same = 1;
                while (i < arg_count) {
                    if (ints.buffer_int_get(generic_struct_inst_arg_type_ids_handle, offset + i) != arg_types[i]) {
                        same = 0;
                        break;
                    }
                    i = i + 1;
                }
                if (same != 0) {
                    return inst_id;
                }
            }
        }
        inst_id = inst_id + 1;
    }
    return 0;
}

UInt8[] generic_struct_inst_name(Int template_symbol, Int[] arg_types) {
    Int buffer = text.text_buffer_new(64);
    text.text_buffer_clear(buffer);
    text.text_buffer_push_text(buffer, "__jiang_g_");
    hir_text_buffer_push_int(buffer, template_symbol);
    Int i = 0;
    while (i < arg_types.length) {
        text.text_buffer_push_text(buffer, "_");
        hir_text_buffer_push_int(buffer, arg_types[i]);
        i = i + 1;
    }
    return text.text_buffer_slice(buffer);
}

Int generic_func_inst_find(Int template_symbol, Int[] arg_types) {
    Int arg_count = arg_types.length;
    Int inst_id = 1;
    while (inst_id <= generic_func_inst_count) {
        if (ints.buffer_int_get(generic_func_inst_template_symbol_handle, inst_id) == template_symbol) {
            if (ints.buffer_int_get(generic_func_inst_arg_count_handle, inst_id) == arg_count) {
                Int offset = ints.buffer_int_get(generic_func_inst_arg_offset_handle, inst_id);
                Int i = 0;
                Bool same = 1;
                while (i < arg_count) {
                    if (ints.buffer_int_get(generic_func_inst_arg_type_ids_handle, offset + i) != arg_types[i]) {
                        same = 0;
                        break;
                    }
                    i = i + 1;
                }
                if (same != 0) {
                    return inst_id;
                }
            }
        }
        inst_id = inst_id + 1;
    }
    return 0;
}

() symbol_set_generic_template(UInt8[] source, Int symbol_id, Int decl_parse) {
    generic_decl_ensure_types(source, decl_parse);
    ints.buffer_int_set(generic_template_decl_parse_handle, symbol_id, decl_parse);
    ints.buffer_int_set(generic_template_first_type_id_handle, symbol_id, generic_decl_first_type_id(decl_parse));
    ints.buffer_int_set(generic_template_type_count_handle, symbol_id, generic_decl_type_count(decl_parse));
}

Int symbol_generic_template_first_type_id(Int symbol_id) {
    if (symbol_id >= ints.buffer_int_length(generic_template_first_type_id_handle)) {
        return 0;
    }
    return ints.buffer_int_get(generic_template_first_type_id_handle, symbol_id);
}

Int symbol_generic_template_type_count(Int symbol_id) {
    if (symbol_id >= ints.buffer_int_length(generic_template_type_count_handle)) {
        return 0;
    }
    return ints.buffer_int_get(generic_template_type_count_handle, symbol_id);
}

Bool symbol_is_generic_template(Int symbol_id) {
    return symbol_generic_template_type_count(symbol_id) > 0;
}

Int symbol_generic_template_decl(Int symbol_id) {
    Int decl_parse = 0;
    if (symbol_id < ints.buffer_int_length(generic_template_decl_parse_handle)) {
        decl_parse = ints.buffer_int_get(generic_template_decl_parse_handle, symbol_id);
    }
    if (decl_parse <= 0) {
        return 0;
    }
    if (symbol_store.symbol_store_module_ids[symbol_id] != current_module_id) {
        return 0;
    }
    if (decl_parse >= parser.parser_store_node_count) {
        return 0;
    }
    if (!parse_node_is_generic_decl(decl_parse)) {
        return 0;
    }
    return decl_parse;
}

Int collect_visible_import_modules_for_parse(UInt8[] source, UInt8[] path, Int parse_root) {
    Int imports = ints.buffer_int_new(8);
    Int child = parser.parser_store_node_first_child[parse_root];
    while (child != 0) {
        if (parser.parser_store_node_kinds[child] == parser.ParserNode.import_decl) {
            Int path_node = import_decl_path_node(child);
            UInt8[] import_path = import_string_value(source, path_node);
            if (path_utils.is_relative_import(import_path)) {
                UInt8[] resolved_import = path_utils.resolve_local_import(path, import_path);
                Int child_module_id = module_loader.module_loader_ensure_module(resolved_import);
                if (import_decl_alias_node(child) == 0) {
                    ints.buffer_int_push(imports, child_module_id);
                }
            }
        }
        child = parser.parser_store_node_next_sibling[child];
    }
    return imports;
}

UInt8[] generic_func_inst_name(Int template_symbol, Int[] arg_types) {
    Int buffer = text.text_buffer_new(64);
    text.text_buffer_clear(buffer);
    text.text_buffer_push_text(buffer, "__jiang_f_");
    hir_text_buffer_push_int(buffer, template_symbol);
    Int i = 0;
    while (i < arg_types.length) {
        text.text_buffer_push_text(buffer, "_");
        hir_text_buffer_push_int(buffer, arg_types[i]);
        i = i + 1;
    }
    return text.text_buffer_slice(buffer);
}

Int substitute_generic_type(Int type_id, Int template_first_type_id, Int template_type_count, Int[] arg_types) {
    if (type_id <= 0) {
        return type_id;
    }
    if (type_id >= type_store.type_store_count) {
        return type_id;
    }
    if (type_store.type_store_kinds[type_id] == type_store.TypeKind.generic_param) {
        Int index = type_id - template_first_type_id;
        if (index >= 0) {
            if (index < template_type_count) {
                return arg_types[index];
            }
        }
        return type_id;
    }
    if (type_store.type_store_kinds[type_id] == type_store.TypeKind.slice) {
        return type_store.type_store_new_slice_type(
            substitute_generic_type(type_store.type_store_elem_type_ids[type_id], template_first_type_id, template_type_count, arg_types)
        );
    }
    if (type_store.type_store_kinds[type_id] == type_store.TypeKind.pointer) {
        return type_store.type_store_new_pointer_type(
            substitute_generic_type(type_store.type_store_elem_type_ids[type_id], template_first_type_id, template_type_count, arg_types)
        );
    }
    if (type_store.type_store_kinds[type_id] == type_store.TypeKind.optional) {
        return type_store.type_store_new_optional_type(
            substitute_generic_type(type_store.type_store_elem_type_ids[type_id], template_first_type_id, template_type_count, arg_types)
        );
    }
    if (type_store.type_store_kinds[type_id] == type_store.TypeKind.mutable) {
        return type_store.type_store_new_mutable_type(
            substitute_generic_type(type_store.type_store_elem_type_ids[type_id], template_first_type_id, template_type_count, arg_types)
        );
    }
    if (type_store.type_store_kinds[type_id] == type_store.TypeKind.array) {
        return type_store.type_store_new_array_type(
            substitute_generic_type(type_store.type_store_elem_type_ids[type_id], template_first_type_id, template_type_count, arg_types),
            type_store.type_store_array_lengths[type_id]
        );
    }
    if (type_store.type_store_kinds[type_id] == type_store.TypeKind.tuple) {
        Int item_types_handle = ints.buffer_int_new(type_store.type_store_tuple_count(type_id));
        Int i = 0;
        while (i < type_store.type_store_tuple_count(type_id)) {
            ints.buffer_int_push(
                item_types_handle,
                substitute_generic_type(type_store.type_store_tuple_item_type(type_id, i), template_first_type_id, template_type_count, arg_types)
            );
            i = i + 1;
        }
        return type_store.type_store_new_tuple_type(ints.buffer_int_slice(item_types_handle));
    }
    return type_id;
}

Int instantiate_generic_struct_type(UInt8[] source, Int template_symbol, Int[] arg_types) {
    Int existing = generic_struct_inst_find(template_symbol, arg_types);
    if (existing != 0) {
        return ints.buffer_int_get(generic_struct_inst_type_id_handle, existing);
    }
    Int template_first_type_id = symbol_generic_template_first_type_id(template_symbol);
    Int template_type_count = symbol_generic_template_type_count(template_symbol);
    Int template_module_id = symbol_store.symbol_store_module_ids[template_symbol];
    UInt8[] inst_name = generic_struct_inst_name(template_symbol, arg_types);
    Int type_id = type_store.type_store_new_named_type_from_name(
        inst_name,
        type_store.TypeKind.struct_type,
        template_module_id
    );
    Int owner_symbol = symbol_store.symbol_store_new_symbol(
        inst_name,
        symbol_store.SymbolKind.type_name,
        0,
        inst_name.length,
        type_id,
        0,
        template_module_id
    );
    Int child_symbol = 1;
    while (child_symbol < symbol_store.symbol_store_count) {
        if (symbol_store.symbol_store_parent_ids[child_symbol] == template_symbol) {
            if (symbol_store.symbol_store_kinds[child_symbol] == symbol_store.SymbolKind.field) {
                UInt8[] field_name = intern_pool.intern_pool_value(symbol_store.symbol_store_name_ids[child_symbol]);
                Int field_type = substitute_generic_type(
                    symbol_store.symbol_store_type_ids[child_symbol],
                    template_first_type_id,
                    template_type_count,
                    arg_types
                );
                Int field_symbol = symbol_store.symbol_store_new_symbol(
                    field_name,
                    symbol_store.SymbolKind.field,
                    0,
                    field_name.length,
                    field_type,
                    owner_symbol,
                    template_module_id
                );
                symbol_store.symbol_store_name_ids[field_symbol] = symbol_store.symbol_store_name_ids[child_symbol];
                symbol_store.symbol_store_starts[field_symbol] = symbol_store.symbol_store_starts[child_symbol];
                symbol_store.symbol_store_ends[field_symbol] = symbol_store.symbol_store_ends[child_symbol];
            }
        }
        child_symbol = child_symbol + 1;
    }
    generic_struct_inst_count = generic_struct_inst_count + 1;
    Int inst_id = generic_struct_inst_count;
    ints.buffer_int_set(generic_struct_template_symbol_handle, inst_id, template_symbol);
    ints.buffer_int_set(generic_struct_inst_arg_offset_handle, inst_id, ints.buffer_int_length(generic_struct_inst_arg_type_ids_handle));
    ints.buffer_int_set(generic_struct_inst_arg_count_handle, inst_id, arg_types.length);
    Int i = 0;
    while (i < arg_types.length) {
        ints.buffer_int_push(generic_struct_inst_arg_type_ids_handle, arg_types[i]);
        i = i + 1;
    }
    ints.buffer_int_set(generic_struct_inst_type_id_handle, inst_id, type_id);
    ints.buffer_int_set(generic_struct_inst_owner_symbol_handle, inst_id, owner_symbol);
    source = source;
    return type_id;
}

Int instantiate_generic_func_symbol(UInt8[] source, Int template_symbol, Int[] arg_types) {
    Int existing = generic_func_inst_find(template_symbol, arg_types);
    if (existing != 0) {
        return ints.buffer_int_get(generic_func_inst_symbol_handle, existing);
    }
    Int template_module_id = symbol_store.symbol_store_module_ids[template_symbol];
    Int saved_module_id = current_module_id;
    Int saved_register_module_id = register_module_id;
    UInt8[] saved_source = current_source;
    UInt8[] saved_path = current_path;
    Int saved_visible_import_module_ids = visible_import_module_ids;
    Int saved_parse_snapshot_id = current_parse_snapshot_id;
    Int template_snapshot_id = 0;
    if (template_module_id != current_module_id) {
        template_snapshot_id = module_loader.module_loader_find_parse_snapshot(template_module_id);
        if (template_snapshot_id == 0) {
            return 0;
        }
        parser.parser_store_restore_snapshot(template_snapshot_id);
        current_parse_snapshot_id = template_snapshot_id;
        current_module_id = template_module_id;
        register_module_id = template_module_id;
        current_path = module_loader.module_loader_module_path(template_module_id);
        current_source = module_loader.load_source(current_path);
        source = current_source;
        visible_import_module_ids = collect_visible_import_modules_for_parse(current_source, current_path, 1);
    }
    Int template_decl = symbol_generic_template_decl(template_symbol);
    Int template_first_type_id = symbol_generic_template_first_type_id(template_symbol);
    Int template_type_count = symbol_generic_template_type_count(template_symbol);
    UInt8[] inst_name = generic_func_inst_name(template_symbol, arg_types);
    Int return_type = substitute_generic_type(
        symbol_store.symbol_store_type_ids[template_symbol],
        template_first_type_id,
        template_type_count,
        arg_types
    );
    Int func_symbol = symbol_store.symbol_store_new_symbol(
        inst_name,
        symbol_store.SymbolKind.func,
        0,
        inst_name.length,
        return_type,
        0,
        current_module_id
    );
    Int saved_subst_first_type_id = current_generic_subst_first_type_id;
    Int saved_subst_type_count = current_generic_subst_type_count;
    Int saved_subst_arg_types_handle = current_generic_subst_arg_types_handle;
    current_generic_subst_first_type_id = template_first_type_id;
    current_generic_subst_type_count = template_type_count;
    current_generic_subst_arg_types_handle = ints.buffer_int_new(arg_types.length);
    Int subst_i = 0;
    while (subst_i < arg_types.length) {
        ints.buffer_int_push(current_generic_subst_arg_types_handle, arg_types[subst_i]);
        subst_i = subst_i + 1;
    }
    generic_context_push(source, template_decl);
    register_param_symbols_in_func_subtree(source, template_decl, func_symbol);
    register_local_symbols_in_func_subtree(source, template_decl, func_symbol);
    generic_context_pop(template_decl);
    current_generic_subst_first_type_id = saved_subst_first_type_id;
    current_generic_subst_type_count = saved_subst_type_count;
    current_generic_subst_arg_types_handle = saved_subst_arg_types_handle;
    generic_func_inst_count = generic_func_inst_count + 1;
    Int inst_id = generic_func_inst_count;
    ints.buffer_int_set(generic_func_inst_template_symbol_handle, inst_id, template_symbol);
    ints.buffer_int_set(generic_func_inst_arg_offset_handle, inst_id, ints.buffer_int_length(generic_func_inst_arg_type_ids_handle));
    ints.buffer_int_set(generic_func_inst_arg_count_handle, inst_id, arg_types.length);
    Int i = 0;
    while (i < arg_types.length) {
        ints.buffer_int_push(generic_func_inst_arg_type_ids_handle, arg_types[i]);
        i = i + 1;
    }
    ints.buffer_int_set(generic_func_inst_symbol_handle, inst_id, func_symbol);
    if (template_module_id != saved_module_id) {
        parser.parser_store_restore_snapshot(saved_parse_snapshot_id);
        current_parse_snapshot_id = saved_parse_snapshot_id;
        current_module_id = saved_module_id;
        register_module_id = saved_register_module_id;
        current_source = saved_source;
        current_path = saved_path;
        visible_import_module_ids = saved_visible_import_module_ids;
    }
    source = source;
    return func_symbol;
}

Int infer_generic_func_symbol(UInt8[] source, Int template_symbol, Int call_node) {
    Int template_module_id = symbol_store.symbol_store_module_ids[template_symbol];
    Int saved_module_id = current_module_id;
    Int saved_register_module_id = register_module_id;
    UInt8[] saved_source = current_source;
    UInt8[] saved_path = current_path;
    Int saved_visible_import_module_ids = visible_import_module_ids;
    Int saved_parse_snapshot_id = current_parse_snapshot_id;
    if (template_module_id != current_module_id) {
        Int template_snapshot_id = module_loader.module_loader_find_parse_snapshot(template_module_id);
        if (template_snapshot_id == 0) {
            return 0;
        }
        parser.parser_store_restore_snapshot(template_snapshot_id);
        current_parse_snapshot_id = template_snapshot_id;
        current_module_id = template_module_id;
        register_module_id = template_module_id;
        current_path = module_loader.module_loader_module_path(template_module_id);
        current_source = module_loader.load_source(current_path);
        source = current_source;
        visible_import_module_ids = collect_visible_import_modules_for_parse(current_source, current_path, 1);
    }
    Int template_decl = symbol_generic_template_decl(template_symbol);
    if (template_decl == 0) {
        if (template_module_id != saved_module_id) {
            parser.parser_store_restore_snapshot(saved_parse_snapshot_id);
            current_parse_snapshot_id = saved_parse_snapshot_id;
            current_module_id = saved_module_id;
            register_module_id = saved_register_module_id;
            current_source = saved_source;
            current_path = saved_path;
            visible_import_module_ids = saved_visible_import_module_ids;
        }
        return 0;
    }
    Int template_first_type_id = symbol_generic_template_first_type_id(template_symbol);
    Int template_type_count = symbol_generic_template_type_count(template_symbol);
    if (template_type_count == 0) {
        return 0;
    }
    Int inferred_arg_types = ints.buffer_int_new(template_type_count);
    Int i = 0;
    while (i < template_type_count) {
        ints.buffer_int_push(inferred_arg_types, 0);
        i = i + 1;
    }
    Int arg = hir.hir_store_node_next_sibling[hir.hir_store_node_first_child[call_node]];
    Int param_parse = parser.parser_store_node_first_child[template_decl];
    if (param_parse != 0) {
        param_parse = parser.parser_store_node_next_sibling[param_parse];
    }
    if (param_parse != 0) {
        param_parse = parser.parser_store_node_next_sibling[param_parse];
    }
    Int param_count = 0;
    generic_context_push(source, template_decl);
    while (param_parse != 0) {
        if (parser.parser_store_node_kinds[param_parse] != parser.ParserNode.param) {
            break;
        }
        if (arg == 0) {
            generic_context_pop(template_decl);
            return 0;
        }
        Int param_type_parse = parser.parser_store_node_first_child[param_parse];
        Int generic_param_type = resolve_generic_param_type(source, param_type_parse);
        if (generic_param_type == type_store.type_store_builtin_unknown) {
            generic_context_pop(template_decl);
            return 0;
        }
        Int generic_index = generic_param_type - template_first_type_id;
        if (generic_index < 0) {
            generic_context_pop(template_decl);
            return 0;
        }
        if (generic_index >= template_type_count) {
            generic_context_pop(template_decl);
            return 0;
        }
        Int arg_type = type_strip_mutable(hir.hir_store_node_type_ids[arg]);
        if (!is_known_type(arg_type)) {
            generic_context_pop(template_decl);
            return 0;
        }
        Int previous = ints.buffer_int_get(inferred_arg_types, generic_index);
        if (previous == 0) {
            ints.buffer_int_set(inferred_arg_types, generic_index, arg_type);
        } else if (type_strip_mutable(previous) != arg_type) {
            generic_context_pop(template_decl);
            return 0;
        }
        param_count = param_count + 1;
        arg = hir.hir_store_node_next_sibling[arg];
        param_parse = parser.parser_store_node_next_sibling[param_parse];
    }
    generic_context_pop(template_decl);
    if (arg != 0) {
        return 0;
    }
    i = 0;
    while (i < template_type_count) {
        if (ints.buffer_int_get(inferred_arg_types, i) == 0) {
            if (template_module_id != saved_module_id) {
                parser.parser_store_restore_snapshot(saved_parse_snapshot_id);
                current_parse_snapshot_id = saved_parse_snapshot_id;
                current_module_id = saved_module_id;
                register_module_id = saved_register_module_id;
                current_source = saved_source;
                current_path = saved_path;
                visible_import_module_ids = saved_visible_import_module_ids;
            }
            return 0;
        }
        i = i + 1;
    }
    Int result = instantiate_generic_func_symbol(source, template_symbol, ints.buffer_int_slice(inferred_arg_types));
    if (template_module_id != saved_module_id) {
        parser.parser_store_restore_snapshot(saved_parse_snapshot_id);
        current_parse_snapshot_id = saved_parse_snapshot_id;
        current_module_id = saved_module_id;
        register_module_id = saved_register_module_id;
        current_source = saved_source;
        current_path = saved_path;
        visible_import_module_ids = saved_visible_import_module_ids;
    }
    return result;
}

Int resolve_generic_template_symbol(UInt8[] source, Int parse_node) {
    Int kind = parser.parser_store_node_kinds[parse_node];
    if (kind == parser.ParserNode.type_name) {
        Int start = parser.parser_store_node_starts[parse_node];
        Int end_pos = parser.parser_store_node_ends[parse_node];
        Int name_id = intern_pool.intern_pool_intern(source[start..end_pos]);
        return resolve_visible_top_level_symbol(name_id, symbol_store.SymbolKind.type_name);
    }
    if (kind == parser.ParserNode.ident) {
        Int start = parser.parser_store_node_starts[parse_node];
        Int end_pos = parser.parser_store_node_ends[parse_node];
        Int name_id = intern_pool.intern_pool_intern(source[start..end_pos]);
        return resolve_visible_top_level_symbol(name_id, symbol_store.SymbolKind.type_name);
    }
    if (kind == parser.ParserNode.member_expr) {
        Int base = parser.parser_store_node_first_child[parse_node];
        Int member = parser.parser_store_node_next_sibling[base];
        Int base_symbol = resolve_symbol(source, base, symbol_store.SymbolKind.module_alias, 0);
        if (base_symbol == 0) {
            return 0;
        }
        return resolve_top_level_symbol_in_module(source, member, symbol_store.symbol_store_type_ids[base_symbol]);
    }
    return 0;
}

Int instantiate_generic_type_from_parse(UInt8[] source, Int parse_node, Int template_symbol) {
    Int start = parser.parser_store_node_starts[parse_node];
    Int end_pos = parser.parser_store_node_ends[parse_node];
    if (symbol_generic_template_type_count(template_symbol) == 0) {
        diagnostic.diagnostic_error(current_path, start, end_pos, "type is not generic");
        return type_store.type_store_builtin_unknown;
    }
    if (type_store.type_store_kinds[symbol_store.symbol_store_type_ids[template_symbol]] != type_store.TypeKind.struct_type) {
        diagnostic.diagnostic_error(current_path, start, end_pos, "only generic struct instantiation is supported");
        return type_store.type_store_builtin_unknown;
    }
    Int generic_offset = parser.parser_store_node_generic_item_offsets[parse_node];
    Int generic_count = parser.parser_store_node_generic_item_counts[parse_node];
    if (symbol_generic_template_type_count(template_symbol) != generic_count) {
        diagnostic.diagnostic_error(current_path, start, end_pos, "generic argument count mismatch");
        return type_store.type_store_builtin_unknown;
    }
    Int arg_types_handle = ints.buffer_int_new(generic_count);
    Int i = 0;
    while (i < generic_count) {
        Int arg_type = resolve_type_node_from_source(source, parser.parser_store_generic_item_ids[generic_offset + i]);
        if (!is_known_type(arg_type)) {
            return type_store.type_store_builtin_unknown;
        }
        if (arg_type < type_store.type_store_count) {
            if (type_store.type_store_kinds[arg_type] == type_store.TypeKind.generic_param) {
                diagnostic.diagnostic_error(current_path, start, end_pos, "concrete generic arguments are required here");
                return type_store.type_store_builtin_unknown;
            }
        }
        ints.buffer_int_push(arg_types_handle, arg_type);
        i = i + 1;
    }
    return instantiate_generic_struct_type(source, template_symbol, ints.buffer_int_slice(arg_types_handle));
}

