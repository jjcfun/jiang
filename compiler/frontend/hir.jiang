    return symbol_id == builtin_print_symbol;
}

Bool is_builtin_assert_symbol(Int symbol_id) {
    return symbol_id == builtin_assert_symbol;
}

Bool is_builtin_write_stdout_symbol(Int symbol_id) {
    return symbol_id == builtin_write_stdout_symbol;
}

Bool is_builtin_file_exists_symbol(Int symbol_id) {
    return symbol_id == builtin_file_exists_symbol;
}

Bool is_builtin_read_file_symbol(Int symbol_id) {
    return symbol_id == builtin_read_file_symbol;
}

Bool is_builtin_malloc_symbol(Int symbol_id) {
    return symbol_id == builtin_malloc_symbol;
}

Bool is_builtin_free_symbol(Int symbol_id) {
    return symbol_id == builtin_free_symbol;
}

Bool is_builtin_memmove_symbol(Int symbol_id) {
    return symbol_id == builtin_memmove_symbol;
}

Bool is_known_type(Int type_id) {
    if (type_id == 0) {
        return 0;
    }
    return type_id != type_store.type_store_builtin_unknown;
}

Int type_strip_mutable(Int type_id) {
    Int current = type_id;
    while (current > 0) {
        if (current >= type_store.type_store_count) {
            return current;
        }
        if (type_store.type_store_kinds[current] != type_store.TypeKind.mutable) {
            return current;
        }
        current = type_store.type_store_elem_type_ids[current];
    }
    return current;
}

Bool type_is_optional(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (type_id <= 0) {
        return 0;
    }
    if (type_id >= type_store.type_store_count) {
        return 0;
    }
    return type_store.type_store_kinds[type_id] == type_store.TypeKind.optional;
}

Bool parse_node_is_mutable_binding(Int parse_node) {
    return parser.parser_store_node_aux[parse_node] == parser.mutable_binding_aux;
}

Int mutable_binding_type(Int parse_node, Int type_id) {
    if (!parse_node_is_mutable_binding(parse_node)) {
        return type_id;
    }
    return type_store.type_store_new_mutable_type(type_id);
}

Int type_optional_payload(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (!type_is_optional(type_id)) {
        return type_store.type_store_builtin_unknown;
    }
    return type_store.type_store_elem_type_ids[type_id];
}

Int type_narrow_optional_binding(Int type_id) {
    Int payload = type_optional_payload(type_id);
    if (!is_known_type(payload)) {
        return payload;
    }
    if (type_id > 0) {
        if (type_id < type_store.type_store_count) {
            if (type_store.type_store_kinds[type_id] == type_store.TypeKind.mutable) {
                return type_store.type_store_new_mutable_type(payload);
            }
        }
    }
    return payload;
}

Int type_optional_chain_result(Int value_type) {
    if (!is_known_type(value_type)) {
        return value_type;
    }
    if (type_is_optional(value_type)) {
        return value_type;
    }
    return type_store.type_store_new_optional_type(value_type);
}

Bool is_null_like_expr(Int node_id) {
    return hir.hir_store_node_kinds[node_id] == hir.HirNode.null_lit;
}

Bool type_parse_is_infer(UInt8[] source, Int parse_node) {
    if (parser.parser_store_node_kinds[parse_node] == parser.ParserNode.mutable_type) {
        Int child = parser.parser_store_node_first_child[parse_node];
        if (child != 0) {
            return type_parse_is_infer(source, child);
        }
    }
    if (parser.parser_store_node_kinds[parse_node] == parser.ParserNode.type_name) {
        if (parser.parser_store_node_aux[parse_node] == parser.infer_type_aux) {
            return 1;
        }
    }
    return parse_node_is(source, parse_node, "_");
}

Int infer_wrapped_type_from_parse(Int parse_node, Int value_type) {
    if (!is_known_type(value_type)) {
        return value_type;
    }
    if (parser.parser_store_node_kinds[parse_node] == parser.ParserNode.mutable_type) {
        Int child = parser.parser_store_node_first_child[parse_node];
        Int wrapped = infer_wrapped_type_from_parse(child, value_type);
        if (!is_known_type(wrapped)) {
            return wrapped;
        }
        return type_store.type_store_new_mutable_type(wrapped);
    }
    return value_type;
}

() set_inferred_type_on_lowered_type_node(Int lowered_type_node, Int declared_type) {
    hir.hir_store_set_type_id(lowered_type_node, declared_type);
    if (hir.hir_store_node_kinds[lowered_type_node] == hir.HirNode.mutable_type) {
        Int child = hir.hir_store_node_first_child[lowered_type_node];
        if (child != 0) {
            set_inferred_type_on_lowered_type_node(child, type_strip_mutable(declared_type));
        }
    }
}

Bool parse_array_type_has_infer_length(Int parse_node) {
    if (parser.parser_store_node_kinds[parse_node] != parser.ParserNode.array_type) {
        return 0;
    }
    return parser.parser_store_node_aux[parse_node] == parser.infer_array_length_aux;
}

Bool is_builtin_type_name(UInt8[] source, Int parse_node) {
    if (type_parse_is_infer(source, parse_node)) {
        return 0;
    }
    Int builtin = type_store.type_store_builtin_from_name(
        source,
        parser.parser_store_node_starts[parse_node],
        parser.parser_store_node_ends[parse_node]
    );
    return builtin != type_store.type_store_builtin_unknown;
}

Bool symbol_is_public(Int symbol_id) {
    return nominal.symbol_is_public(symbol_id);
}

Bool decl_is_public(Int flags) {
    return nominal.decl_is_public(flags);
}

Bool decl_is_extern(Int flags) {
    return nominal.decl_is_extern(flags);
}

Bool decl_is_static(Int flags) {
    return nominal.decl_is_static(flags);
}

Int decl_node_flags(Int parse_node) {
    return nominal.decl_node_flags(parse_node);
}

Bool top_level_symbol_visible(Int symbol_id) {
    return nominal.top_level_symbol_visible(symbol_id, current_module_id);
}

Bool nominal_method_visible(Int symbol_id) {
    return nominal.nominal_method_visible(symbol_id, current_module_id);
}

Bool type_visible(Int type_id) {
    if (!is_known_type(type_id)) {
        return 0;
    }
    if (type_id == type_store.type_store_builtin_unknown) {
        return 0;
    }
    if (type_id == type_store.type_store_builtin_void) {
        return 1;
    }
    if (type_id == type_store.type_store_builtin_bool) {
        return 1;
    }
    if (type_id == type_store.type_store_builtin_int) {
        return 1;
    }
    if (type_id == type_store.type_store_builtin_uint8) {
        return 1;
    }
    if (type_id == type_store.type_store_builtin_uint8_slice) {
        return 1;
    }
    if (type_id < type_store.type_store_count) {
        if (type_store.type_store_kinds[type_id] == type_store.TypeKind.generic_param) {
            return 1;
        }
        if (type_store.type_store_kinds[type_id] == type_store.TypeKind.slice) {
            return type_visible(type_store.type_store_elem_type_ids[type_id]);
        }
        if (type_store.type_store_kinds[type_id] == type_store.TypeKind.array) {
            return type_visible(type_store.type_store_elem_type_ids[type_id]);
        }
        if (type_store.type_store_kinds[type_id] == type_store.TypeKind.pointer) {
            return type_visible(type_store.type_store_elem_type_ids[type_id]);
        }
        if (type_store.type_store_kinds[type_id] == type_store.TypeKind.optional) {
            return type_visible(type_store.type_store_elem_type_ids[type_id]);
        }
        if (type_store.type_store_kinds[type_id] == type_store.TypeKind.mutable) {
            return type_visible(type_store.type_store_elem_type_ids[type_id]);
        }
        if (type_store.type_store_kinds[type_id] == type_store.TypeKind.tuple) {
            Int i = 0;
            while (i < type_store.type_store_tuple_count(type_id)) {
                if (!type_visible(type_store.type_store_tuple_item_type(type_id, i))) {
                    return 0;
                }
                i = i + 1;
            }
            return 1;
        }
    }
    Int owner_symbol = find_type_owner_symbol(type_id);
    return top_level_symbol_visible(owner_symbol);
}

Int resolve_type_node_from_source(UInt8[] source, Int parse_node) {
    if (parser.parser_store_node_aux[parse_node] == parser.type_aux_builtin_void) {
        return type_store.type_store_builtin_void;
    }
    if (type_parse_is_infer(source, parse_node)) {
        return type_store.type_store_builtin_unknown;
    }
    if (parse_node_has_generic_items(parse_node)) {
        Int kind = parser.parser_store_node_kinds[parse_node];
        if (kind == parser.ParserNode.type_name) {
            Int template_symbol = resolve_generic_template_symbol(source, parse_node);
            if (template_symbol == 0) {
                return type_store.type_store_builtin_unknown;
            }
            return instantiate_generic_type_from_parse(source, parse_node, template_symbol);
        }
        if (kind == parser.ParserNode.ident) {
            Int template_symbol = resolve_generic_template_symbol(source, parse_node);
            if (template_symbol == 0) {
                return type_store.type_store_builtin_unknown;
            }
            return instantiate_generic_type_from_parse(source, parse_node, template_symbol);
        }
        if (kind == parser.ParserNode.member_expr) {
            Int template_symbol = resolve_generic_template_symbol(source, parse_node);
            if (template_symbol == 0) {
                return type_store.type_store_builtin_unknown;
            }
            return instantiate_generic_type_from_parse(source, parse_node, template_symbol);
        }
        diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[parse_node], parser.parser_store_node_ends[parse_node], "generic type arguments are only supported on named types");
        return type_store.type_store_builtin_unknown;
    }
    Int generic_param_type = resolve_generic_param_type(source, parse_node);
    if (generic_param_type != type_store.type_store_builtin_unknown) {
        return substitute_active_generic_param_type(generic_param_type);
    }
    if (parser.parser_store_node_kinds[parse_node] == parser.ParserNode.slice_type) {
        Int elem_node = parser.parser_store_node_first_child[parse_node];
        Int elem_type = resolve_type_node_from_source(source, elem_node);
        if (!is_known_type(elem_type)) {
            return type_store.type_store_builtin_unknown;
        }
        return type_store.type_store_new_slice_type(elem_type);
    }
    if (parser.parser_store_node_kinds[parse_node] == parser.ParserNode.array_type) {
        Int elem_node = parser.parser_store_node_first_child[parse_node];
        Int elem_type = resolve_type_node_from_source(source, elem_node);
        if (!is_known_type(elem_type)) {
            return type_store.type_store_builtin_unknown;
        }
        return type_store.type_store_new_array_type(elem_type, parser.parser_store_node_aux[parse_node]);
    }
    if (parser.parser_store_node_kinds[parse_node] == parser.ParserNode.pointer_type) {
        Int elem_node = parser.parser_store_node_first_child[parse_node];
        Int elem_type = resolve_type_node_from_source(source, elem_node);
        if (!is_known_type(elem_type)) {
            return type_store.type_store_builtin_unknown;
        }
        return type_store.type_store_new_pointer_type(elem_type);
    }
    if (parser.parser_store_node_kinds[parse_node] == parser.ParserNode.optional_type) {
        Int elem_node = parser.parser_store_node_first_child[parse_node];
        Int elem_type = resolve_type_node_from_source(source, elem_node);
        if (!is_known_type(elem_type)) {
            return type_store.type_store_builtin_unknown;
        }
        return type_store.type_store_new_optional_type(elem_type);
    }
    if (parser.parser_store_node_kinds[parse_node] == parser.ParserNode.mutable_type) {
        Int elem_node = parser.parser_store_node_first_child[parse_node];
        Int elem_type = resolve_type_node_from_source(source, elem_node);
        if (!is_known_type(elem_type)) {
            return type_store.type_store_builtin_unknown;
        }
        return type_store.type_store_new_mutable_type(elem_type);
    }
    if (parser.parser_store_node_kinds[parse_node] == parser.ParserNode.tuple_type) {
        Int item_types = ints.buffer_int_new(4);
        Int child = parser.parser_store_node_first_child[parse_node];
        while (child != 0) {
            Int item_type = resolve_type_node_from_source(source, child);
            if (!is_known_type(item_type)) {
                return type_store.type_store_builtin_unknown;
            }
            ints.buffer_int_push(item_types, item_type);
            child = parser.parser_store_node_next_sibling[child];
        }
        return type_store.type_store_new_tuple_type(ints.buffer_int_slice(item_types));
    }
    if (parser.parser_store_node_kinds[parse_node] == parser.ParserNode.member_expr) {
        Int base = parser.parser_store_node_first_child[parse_node];
        Int member = parser.parser_store_node_next_sibling[base];
        Int base_symbol = resolve_ident_symbol(base);
        if (base_symbol != 0) {
            if (symbol_store.symbol_store_kinds[base_symbol] == symbol_store.SymbolKind.module_alias) {
                Int resolved_symbol = resolve_top_level_symbol_in_module(
                    source,
                    member,
                    symbol_store.symbol_store_type_ids[base_symbol]
                );
                if (resolved_symbol != 0) {
                    Int resolved_kind = symbol_store.symbol_store_kinds[resolved_symbol];
                    if (resolved_kind == symbol_store.SymbolKind.type_name) {
                        return symbol_store.symbol_store_type_ids[resolved_symbol];
                    }
                    if (resolved_kind == symbol_store.SymbolKind.enum_name) {
                        return symbol_store.symbol_store_type_ids[resolved_symbol];
                    }
                }
            }
        }
        return type_store.type_store_builtin_unknown;
    }
    Int start = parser.parser_store_node_starts[parse_node];
    Int end_pos = parser.parser_store_node_ends[parse_node];
    if (register_module_id != current_module_id) {
        Int registered = type_store.type_store_find_named_type_in_module(source, start, end_pos, register_module_id);
        if (registered != type_store.type_store_builtin_unknown) {
            return registered;
        }
    }
    Int resolved = type_store.type_store_find_named_type_in_module(source, start, end_pos, current_module_id);
    if (type_visible(resolved)) {
        return resolved;
    }
    Int name_id = intern_pool.intern_pool_intern(source[start..end_pos]);
    Int resolved_symbol = resolve_visible_top_level_symbol(name_id, symbol_store.SymbolKind.type_name);
    if (resolved_symbol != 0) {
        return symbol_store.symbol_store_type_ids[resolved_symbol];
    }
    resolved_symbol = resolve_visible_top_level_symbol(name_id, symbol_store.SymbolKind.enum_name);
    if (resolved_symbol != 0) {
        return symbol_store.symbol_store_type_ids[resolved_symbol];
    }
    if (visible_import_module_ids != 0) {
        Int i = 0;
        while (i < ints.buffer_int_length(visible_import_module_ids)) {
            resolved = type_store.type_store_find_named_type_in_module(
                source,
                start,
                end_pos,
                ints.buffer_int_get(visible_import_module_ids, i)
            );
            if (type_visible(resolved)) {
                return resolved;
            }
            i = i + 1;
        }
    }
    return type_store.type_store_builtin_from_name(source, start, end_pos);
}

Int resolve_type_node(Int parse_node) {
    return resolve_type_node_from_source(current_source, parse_node);
}

Int resolve_visible_top_level_symbol(Int name_id, Int kind) {
    Int resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, kind, 0, current_module_id);
    if (resolved != 0) {
        return symbol_store.symbol_store_resolve_target(resolved);
    }
    if (kind == symbol_store.SymbolKind.global) {
        resolved = symbol_store.symbol_store_find_symbol_by_name_id(name_id, kind, 0);
        if (resolved != 0) {
            return symbol_store.symbol_store_resolve_target(resolved);
        }
    }
    if (visible_import_module_ids != 0) {
        Int i = 0;
        while (i < ints.buffer_int_length(visible_import_module_ids)) {
            resolved = module_loader.module_loader_find_export(
                ints.buffer_int_get(visible_import_module_ids, i),
                name_id,
                kind
            );
            if (resolved != 0) {
                return symbol_store.symbol_store_resolve_target(resolved);
            }
            resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(
                name_id,
                kind,
                0,
                ints.buffer_int_get(visible_import_module_ids, i)
            );
            if (resolved != 0) {
                if (symbol_is_public(resolved)) {
                    return symbol_store.symbol_store_resolve_target(resolved);
                }
            }
            i = i + 1;
        }
    }
    return 0;
}

Int resolve_symbol(UInt8[] source, Int parse_node, Int kind, Int parent_id) {
    Int start = parser.parser_store_node_starts[parse_node];
    Int end_pos = parser.parser_store_node_ends[parse_node];
    Int name_id = intern_pool.intern_pool_intern(source[start..end_pos]);
    if (parent_id != 0) {
        return symbol_store.symbol_store_find_symbol_by_name_id(name_id, kind, parent_id);
    }
    return resolve_visible_top_level_symbol(name_id, kind);
}

Int find_type_owner_symbol(Int type_id) {
    Int i = 1;
    while (i < symbol_store.symbol_store_count) {
        if (symbol_store.symbol_store_type_ids[i] == type_id) {
            Int kind = symbol_store.symbol_store_kinds[i];
            if (kind == symbol_store.SymbolKind.type_name) {
                return i;
            }
            if (kind == symbol_store.SymbolKind.enum_name) {
                return i;
            }
        }
        i = i + 1;
    }
    return 0;
}

Int hir_kind_from_parser_kind(Int kind) {
    if (kind == parser.ParserNode.array_init_expr) {
        return hir.HirNode.array_init_expr;
    }
    if (kind == parser.ParserNode.null_lit) {
        return hir.HirNode.null_lit;
    }
    if (kind == parser.ParserNode.optional_type) {
        return hir.HirNode.optional_type;
    }
    if (kind == parser.ParserNode.mutable_type) {
        return hir.HirNode.mutable_type;
    }
    return kind;
}

Int count_child_symbols_of_kind(Int owner_symbol, Int kind) {
    Int count = 0;
    Int i = 1;
    while (i < symbol_store.symbol_store_count) {
        if (symbol_store.symbol_store_parent_ids[i] == owner_symbol) {
            if (symbol_store.symbol_store_kinds[i] == kind) {
                count = count + 1;
            }
        }
        i = i + 1;
    }
    return count;
}

Int switch_case_label_hir(Int switch_case_node) {
    return hir.hir_store_node_first_child[switch_case_node];
}

Int switch_case_binding_hir(Int switch_case_node) {
    Int label = switch_case_label_hir(switch_case_node);
    if (label == 0) {
        return 0;
    }
    Int next = hir.hir_store_node_next_sibling[label];
    if (next == 0) {
        return 0;
    }
    if (hir.hir_store_node_next_sibling[next] != 0) {
        return next;
    }
    return 0;
}

Int switch_case_body_hir(Int switch_case_node) {
    Int label = switch_case_label_hir(switch_case_node);
    if (label == 0) {
        return 0;
    }
    Int next = hir.hir_store_node_next_sibling[label];
    if (next == 0) {
        return 0;
    }
    if (hir.hir_store_node_next_sibling[next] != 0) {
        return hir.hir_store_node_next_sibling[next];
    }
    return next;
}

Int union_pattern_label_hir(Int pattern_node) {
    return hir.hir_store_node_first_child[pattern_node];
}

Int union_pattern_binding_hir(Int pattern_node) {
    Int label = union_pattern_label_hir(pattern_node);
    if (label == 0) {
        return 0;
    }
    return hir.hir_store_node_next_sibling[label];
}

Int union_pattern_binding_count_hir(Int pattern_node) {
    Int bind = union_pattern_binding_hir(pattern_node);
    Int count = 0;
    while (bind != 0) {
        count = count + 1;
        bind = hir.hir_store_node_next_sibling[bind];
    }
    return count;
}

Int union_pattern_binding_hir_item(Int pattern_node, Int index) {
    Int bind = union_pattern_binding_hir(pattern_node);
    Int i = 0;
    while (bind != 0) {
        if (i == index) {
            return bind;
        }
        bind = hir.hir_store_node_next_sibling[bind];
        i = i + 1;
    }
    return 0;
}

Bool switch_stmt_has_member_case(Int switch_node, Int member_symbol) {
    Int child = hir.hir_store_node_next_sibling[hir.hir_store_node_first_child[switch_node]];
    while (child != 0) {
        if (hir.hir_store_node_kinds[child] == hir.HirNode.switch_case) {
            Int label = switch_case_label_hir(child);
            if (label != 0) {
                if (hir.hir_store_node_symbol_ids[label] == member_symbol) {
                    return 1;
                }
            }
        }
        child = hir.hir_store_node_next_sibling[child];
    }
    return 0;
}

Int optional_case_kind_hir(Int label_node) {
    if (label_node == 0) {
        return 0;
    }
    if (hir.hir_store_node_kinds[label_node] == hir.HirNode.union_pattern_expr) {
        Int pattern_label = union_pattern_label_hir(label_node);
        if (pattern_label != 0) {
            if (hir.hir_store_node_kinds[pattern_label] == hir.HirNode.bool_lit) {
                if (hir.hir_store_node_aux[pattern_label] != 0) {
                    return 1;
                }
                return 2;
            }
        }
        return 0;
    }
    if (hir.hir_store_node_kinds[label_node] == hir.HirNode.null_lit) {
        return 2;
    }
    return 0;
}

Bool switch_stmt_has_optional_case(Int switch_node, Int case_kind) {
    Int child = hir.hir_store_node_next_sibling[hir.hir_store_node_first_child[switch_node]];
    while (child != 0) {
        if (hir.hir_store_node_kinds[child] == hir.HirNode.switch_case) {
            if (optional_case_kind_hir(switch_case_label_hir(child)) == case_kind) {
                return 1;
            }
        }
        child = hir.hir_store_node_next_sibling[child];
    }
    return 0;
}

Int local_scope_id(Int parse_node) {
    Int cursor = parser.parser_store_node_parent[parse_node];
    while (cursor != 0) {
        Int kind = parser.parser_store_node_kinds[cursor];
        if (kind == parser.ParserNode.block) {
            return 0 - cursor;
        }
        if (kind == parser.ParserNode.func_decl) {
            return 0 - cursor;
        }
        cursor = parser.parser_store_node_parent[cursor];
    }
    return 0;
}

Int resolve_local_symbol(Int parse_node) {
    Int cursor = parse_node;
    while (cursor != 0) {
        if (parser.parser_store_node_kinds[cursor] == parser.ParserNode.switch_case) {
            Int resolved_in_case = resolve_symbol(current_source, parse_node, symbol_store.SymbolKind.local, 0 - cursor);
            if (resolved_in_case != 0) {
                return resolved_in_case;
            }
        }
        if (parser.parser_store_node_kinds[cursor] == parser.ParserNode.block) {
            Int resolved = resolve_symbol(current_source, parse_node, symbol_store.SymbolKind.local, 0 - cursor);
            if (resolved != 0) {
                return resolved;
            }
        }
        if (parser.parser_store_node_kinds[cursor] == parser.ParserNode.func_decl) {
            break;
        }
        cursor = parser.parser_store_node_parent[cursor];
    }
    return 0;
}

Int switch_case_label_parse(Int parse_node) {
    return parser.parser_store_node_first_child[parse_node];
}

Int switch_case_binding_parse(Int parse_node) {
    Int label = switch_case_label_parse(parse_node);
    if (label == 0) {
        return 0;
    }
    Int next = parser.parser_store_node_next_sibling[label];
    if (next == 0) {
        return 0;
    }
    if (parser.parser_store_node_next_sibling[next] != 0) {
        return next;
    }
    return 0;
}

Int switch_case_body_parse(Int parse_node) {
    Int label = switch_case_label_parse(parse_node);
    if (label == 0) {
        return 0;
    }
    Int next = parser.parser_store_node_next_sibling[label];
    if (next == 0) {
        return 0;
    }
    if (parser.parser_store_node_next_sibling[next] != 0) {
        return parser.parser_store_node_next_sibling[next];
    }
    return next;
}

Int tuple_decl_binding_count(Int parse_node) {
    Int aux = parser.parser_store_node_aux[parse_node];
    if (parser.parser_store_node_kinds[parse_node] == parser.ParserNode.tuple_global_decl) {
        return aux / parser.decl_aux_stride;
    }
    return aux;
}

Int tuple_decl_binding_type_parse(Int parse_node, Int index) {
    Int child = parser.parser_store_node_first_child[parse_node];
    Int i = 0;
    while (i < index) {
        if (child == 0) {
            return 0;
        }
        Int name_node = parser.parser_store_node_next_sibling[child];
        if (name_node == 0) {
            return 0;
        }
        child = parser.parser_store_node_next_sibling[name_node];
        i = i + 1;
    }
    return child;
}

Int tuple_decl_binding_name_parse(Int parse_node, Int index) {
    Int type_node = tuple_decl_binding_type_parse(parse_node, index);
    if (type_node == 0) {
        return 0;
    }
    return parser.parser_store_node_next_sibling[type_node];
}

Bool for_binding_parse_is_tuple(Int parse_node) {
    return parser.parser_store_node_kinds[parse_node] == parser.ParserNode.tuple_local_decl;
}

Bool for_binding_parse_is_leaf(Int parse_node) {
    return parser.parser_store_node_kinds[parse_node] == parser.ParserNode.local_decl;
}

Int for_binding_parse_count(Int parse_node) {
    if (for_binding_parse_is_tuple(parse_node)) {
        return parser.parser_store_node_aux[parse_node];
    }
    if (for_binding_parse_is_leaf(parse_node)) {
        return 1;
    }
    return 0;
}

Int for_binding_parse_child(Int parse_node, Int index) {
    if (!for_binding_parse_is_tuple(parse_node)) {
        if (index == 0) {
            return parse_node;
        }
        return 0;
    }
    Int child = parser.parser_store_node_first_child[parse_node];
    Int i = 0;
    while (child != 0) {
        if (i == index) {
            return child;
        }
        child = parser.parser_store_node_next_sibling[child];
        i = i + 1;
    }
    return 0;
}

Int for_binding_leaf_type_parse(Int parse_node) {
    if (!for_binding_parse_is_leaf(parse_node)) {
        return 0;
    }
    return parser.parser_store_node_first_child[parse_node];
}

Int for_binding_leaf_name_parse(Int parse_node) {
    Int type_node = for_binding_leaf_type_parse(parse_node);
    if (type_node == 0) {
        return 0;
    }
    return parser.parser_store_node_next_sibling[type_node];
}

Bool parse_is_indexed_call(Int parse_node) {
    if (parse_node == 0) {
        return 0;
    }
    if (parser.parser_store_node_kinds[parse_node] != parser.ParserNode.call_expr) {
        return 0;
    }
    Int callee = parser.parser_store_node_first_child[parse_node];
    if (callee == 0) {
        return 0;
    }
    if (parser.parser_store_node_kinds[callee] != parser.ParserNode.member_expr) {
        return 0;
    }
    if (parser.parser_store_node_next_sibling[callee] != 0) {
        return 0;
    }
    Int member = parser.parser_store_node_next_sibling[parser.parser_store_node_first_child[callee]];
    if (member == 0) {
        return 0;
    }
    return member_name_is(current_source, member, "indexed");
}

Int parse_indexed_call_base(Int parse_node) {
    Int callee = parser.parser_store_node_first_child[parse_node];
    if (callee == 0) {
        return 0;
    }
    return parser.parser_store_node_first_child[callee];
}

Int tuple_decl_init_parse(Int parse_node) {
    Int count = tuple_decl_binding_count(parse_node);
    Int child = parser.parser_store_node_first_child[parse_node];
    Int i = 0;
    while (i < count) {
        if (child == 0) {
            return 0;
        }
        Int name_node = parser.parser_store_node_next_sibling[child];
        if (name_node == 0) {
            return 0;
        }
        child = parser.parser_store_node_next_sibling[name_node];
        i = i + 1;
    }
    return child;
}

Int tuple_lit_item_parse(Int parse_node, Int index) {
    Int child = parser.parser_store_node_first_child[parse_node];
    Int i = 0;
    while (child != 0) {
        if (i == index) {
            return child;
        }
        child = parser.parser_store_node_next_sibling[child];
        i = i + 1;
    }
    return 0;
}

Int union_pattern_label_parse(Int parse_node) {
    return parser.parser_store_node_first_child[parse_node];
}

Int union_pattern_binding_parse(Int parse_node) {
    Int label = union_pattern_label_parse(parse_node);
    if (label == 0) {
        return 0;
    }
    return parser.parser_store_node_next_sibling[label];
}

Int union_pattern_binding_count_parse(Int parse_node) {
    Int bind = union_pattern_binding_parse(parse_node);
    Int count = 0;
    while (bind != 0) {
        count = count + 1;
        bind = parser.parser_store_node_next_sibling[bind];
    }
    return count;
}

Int union_pattern_binding_parse_item(Int parse_node, Int index) {
    Int bind = union_pattern_binding_parse(parse_node);
    Int i = 0;
    while (bind != 0) {
        if (i == index) {
            return bind;
        }
        bind = parser.parser_store_node_next_sibling[bind];
        i = i + 1;
    }
    return 0;
}

Int resolve_ident_symbol(Int parse_node) {
    Int resolved = 0;
    if (current_func_symbol != 0) {
        resolved = resolve_local_symbol(parse_node);
        if (resolved == 0) {
            resolved = resolve_symbol(current_source, parse_node, symbol_store.SymbolKind.param, current_func_symbol);
        }
    }
    if (resolved == 0) {
        if (current_type_owner_symbol != 0) {
            resolved = resolve_symbol(current_source, parse_node, symbol_store.SymbolKind.field, current_type_owner_symbol);
            if (resolved == 0) {
                resolved = resolve_symbol(current_source, parse_node, symbol_store.SymbolKind.enum_member, current_type_owner_symbol);
            }
        }
    }
    if (resolved == 0) {
        resolved = resolve_symbol(current_source, parse_node, symbol_store.SymbolKind.type_name, 0);
    }
    if (resolved == 0) {
        resolved = resolve_symbol(current_source, parse_node, symbol_store.SymbolKind.enum_name, 0);
    }
    if (resolved == 0) {
        resolved = resolve_symbol(current_source, parse_node, symbol_store.SymbolKind.func, 0);
    }
    if (resolved == 0) {
        resolved = resolve_symbol(current_source, parse_node, symbol_store.SymbolKind.global, 0);
    }
    if (resolved == 0) {
        resolved = resolve_symbol(current_source, parse_node, symbol_store.SymbolKind.module_alias, 0);
    }
    if (resolved == 0) {
        if (parse_node_is(current_source, parse_node, "__intrinsic_assert")) {
            resolved = builtin_assert_symbol;
        }
    }
    if (resolved == 0) {
        if (parse_node_is(current_source, parse_node, "print")) {
            resolved = builtin_print_symbol;
        }
    }
    if (resolved == 0) {
        if (parse_node_is(current_source, parse_node, "__intrinsic_write_stdout")) {
            resolved = builtin_write_stdout_symbol;
        }
    }
    if (resolved == 0) {
        if (parse_node_is(current_source, parse_node, "__intrinsic_file_exists")) {
            resolved = builtin_file_exists_symbol;
        }
    }
    if (resolved == 0) {
        if (parse_node_is(current_source, parse_node, "__intrinsic_read_file")) {
            resolved = builtin_read_file_symbol;
        }
    }
    if (resolved == 0) {
        if (parse_node_is(current_source, parse_node, "__intrinsic_malloc")) {
            resolved = builtin_malloc_symbol;
        }
    }
    if (resolved == 0) {
        if (parse_node_is(current_source, parse_node, "__intrinsic_free")) {
            resolved = builtin_free_symbol;
        }
    }
    if (resolved == 0) {
        if (parse_node_is(current_source, parse_node, "__intrinsic_memmove")) {
            resolved = builtin_memmove_symbol;
        }
    }
    if (resolved == 0) {
        return 0;
    }
    resolved = symbol_store.symbol_store_resolve_target(resolved);
    if (symbol_is_freed(resolved)) {
        diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[parse_node], parser.parser_store_node_ends[parse_node], "symbol was freed");
    }
    return resolved;
}

() expect_type(Int node_id, Int expected_type, UInt8[] message) {
    Int actual_type = type_strip_mutable(hir.hir_store_node_type_ids[node_id]);
    expected_type = type_strip_mutable(expected_type);
    if (!is_known_type(actual_type)) {
        return;
    }
    if (actual_type != expected_type) {
        diagnostic.diagnostic_error(
            current_path,
            hir.hir_store_node_starts[node_id],
            hir.hir_store_node_ends[node_id],
            message
        );
    }
}

() expect_same_type(Int left_node, Int right_node, UInt8[] message) {
    Int left_type = type_strip_mutable(hir.hir_store_node_type_ids[left_node]);
    Int right_type = type_strip_mutable(hir.hir_store_node_type_ids[right_node]);
    if (!is_known_type(left_type)) {
        return;
    }
    if (!is_known_type(right_type)) {
        return;
    }
    if (left_type != right_type) {
        diagnostic.diagnostic_error(
            current_path,
            hir.hir_store_node_starts[right_node],
            hir.hir_store_node_ends[right_node],
            message
        );
    }
}

Bool is_assignable_symbol_kind(Int kind) {
    if (kind == symbol_store.SymbolKind.global) {
        return 1;
    }
    if (kind == symbol_store.SymbolKind.local) {
        return 1;
    }
    if (kind == symbol_store.SymbolKind.param) {
        return 1;
    }
    return kind == symbol_store.SymbolKind.field;
}

Bool is_assignable_node(Int node_id) {
    Int node_kind = hir.hir_store_node_kinds[node_id];
    if (node_kind == hir.HirNode.ident) {
        Int symbol_id = hir.hir_store_node_symbol_ids[node_id];
        if (symbol_id == 0) {
            return 0;
        }
        return is_assignable_symbol_kind(symbol_store.symbol_store_kinds[symbol_id]);
    }
    if (node_kind == hir.HirNode.member_expr) {
        Int symbol_id = hir.hir_store_node_symbol_ids[node_id];
        if (symbol_id == 0) {
            return 0;
        }
        return is_assignable_symbol_kind(symbol_store.symbol_store_kinds[symbol_id]);
    }
    if (node_kind == hir.HirNode.index_expr) {
        Int base = hir.hir_store_node_first_child[node_id];
        Int base_type = hir.hir_store_node_type_ids[base];
        if (type_is_slice(base_type)) {
            return 1;
        }
        return type_is_array(base_type);
    }
    if (node_kind == hir.HirNode.unary_expr) {
        if (hir.hir_store_node_aux[node_id] == hir.HirUnaryOp.deref) {
            Int operand = hir.hir_store_node_first_child[node_id];
            Int operand_type = type_strip_mutable(hir.hir_store_node_type_ids[operand]);
            if (operand_type <= 0) {
                return 0;
            }
            if (operand_type >= type_store.type_store_count) {
                return 0;
            }
            return type_store.type_store_kinds[operand_type] == type_store.TypeKind.pointer;
        }
    }
    return 0;
}

Bool is_simple_optional_chain_base(Int node_id) {
    Int kind = hir.hir_store_node_kinds[node_id];
    if (kind == hir.HirNode.ident) {
        return 1;
    }
    if (kind == hir.HirNode.member_expr) {
        Int base = hir.hir_store_node_first_child[node_id];
        return is_simple_optional_chain_base(base);
    }
    if (kind == hir.HirNode.index_expr) {
        Int base = hir.hir_store_node_first_child[node_id];
        Int index_expr = hir.hir_store_node_next_sibling[base];
        if (is_simple_optional_chain_base(base) == 0) {
            return 0;
        }
        return is_simple_optional_chain_base(index_expr);
    }
    if (kind == hir.HirNode.optional_member_expr) {
        Int base = hir.hir_store_node_first_child[node_id];
        return is_simple_optional_chain_base(base);
    }
    if (kind == hir.HirNode.optional_index_expr) {
        Int base = hir.hir_store_node_first_child[node_id];
        Int index_expr = hir.hir_store_node_next_sibling[base];
        if (is_simple_optional_chain_base(base) == 0) {
            return 0;
        }
        return is_simple_optional_chain_base(index_expr);
    }
    if (kind == hir.HirNode.int_lit) {
        return 1;
    }
    if (kind == hir.HirNode.bool_lit) {
        return 1;
    }
    if (kind == hir.HirNode.string_lit) {
        return 1;
    }
    if (kind == hir.HirNode.null_lit) {
        return 1;
    }
    if (kind == hir.HirNode.shorthand_member_expr) {
        return 1;
    }
    return 0;
}

Bool node_requires_symbol(Int kind) {
    if (kind == hir.HirNode.struct_decl) {
        return 1;
    }
    if (kind == hir.HirNode.union_decl) {
        return 1;
    }
    if (kind == hir.HirNode.enum_decl) {
        return 1;
    }
    if (kind == hir.HirNode.enum_member) {
        return 1;
    }
    if (kind == hir.HirNode.field_decl) {
        return 1;
    }
    if (kind == hir.HirNode.func_decl) {
        return 1;
    }
    if (kind == hir.HirNode.param) {
        return 1;
    }
    if (kind == hir.HirNode.field_init) {
        return 1;
    }
    if (kind == hir.HirNode.local_decl) {
        return 1;
    }
    if (kind == hir.HirNode.global_decl) {
        return 1;
    }
    if (kind == hir.HirNode.ident) {
        return 1;
    }
    if (kind == hir.HirNode.member_expr) {
        return 1;
    }
    return kind == hir.HirNode.optional_member_expr;
}

Bool node_requires_known_type(Int kind) {
    if (kind == hir.HirNode.struct_decl) {
        return 1;
    }
    if (kind == hir.HirNode.union_decl) {
        return 1;
    }
    if (kind == hir.HirNode.enum_decl) {
        return 1;
    }
    if (kind == hir.HirNode.enum_member) {
        return 1;
    }
    if (kind == hir.HirNode.field_decl) {
        return 1;
    }
    if (kind == hir.HirNode.func_decl) {
        return 1;
    }
    if (kind == hir.HirNode.type_name) {
        return 1;
    }
    if (kind == hir.HirNode.slice_type) {
        return 1;
    }
    if (kind == hir.HirNode.array_type) {
        return 1;
    }
    if (kind == hir.HirNode.pointer_type) {
        return 1;
    }
    if (kind == hir.HirNode.ident) {
        return 1;
    }
    if (kind == hir.HirNode.string_lit) {
        return 1;
    }
    if (kind == hir.HirNode.bool_lit) {
        return 1;
    }
    if (kind == hir.HirNode.param) {
        return 1;
    }
    if (kind == hir.HirNode.field_init) {
        return 1;
    }
    if (kind == hir.HirNode.local_decl) {
        return 1;
    }
    if (kind == hir.HirNode.global_decl) {
        return 1;
    }
    if (kind == hir.HirNode.int_lit) {
        return 1;
    }
    if (kind == hir.HirNode.call_expr) {
        return 1;
    }
    if (kind == hir.HirNode.member_expr) {
        return 1;
    }
    if (kind == hir.HirNode.optional_member_expr) {
        return 1;
    }
    if (kind == hir.HirNode.index_expr) {
        return 1;
    }
    if (kind == hir.HirNode.optional_index_expr) {
        return 1;
    }
    if (kind == hir.HirNode.range_expr) {
        return 1;
    }
    if (kind == hir.HirNode.shorthand_member_expr) {
        return 1;
    }
    if (kind == hir.HirNode.struct_init_expr) {
        return 1;
    }
    if (kind == hir.HirNode.array_lit) {
        return 1;
    }
    if (kind == hir.HirNode.unary_expr) {
        return 1;
    }
    if (kind == hir.HirNode.binary_expr) {
        return 1;
    }
    if (kind == hir.HirNode.ternary_expr) {
        return 1;
    }
    if (kind == hir.HirNode.union_pattern_expr) {
        return 1;
    }
    return kind == hir.HirNode.array_to_slice_expr;
}

() verify_resolved_node(Int node, Int parent, Int is_first_child) {
    if (diagnostic.diagnostic_has_error()) {
        return;
    }
    Int kind = hir.hir_store_node_kinds[node];
    if (node_requires_symbol(kind)) {
        Int require_symbol = 1;
        if (kind == hir.HirNode.ident) {
            if (parent != 0) {
                Int parent_kind = hir.hir_store_node_kinds[parent];
                if (parent_kind == hir.HirNode.func_decl) {
                    if (is_first_child == 0) {
                        require_symbol = 0;
                    }
                }
                if (parent_kind == hir.HirNode.param) {
                    if (is_first_child == 0) {
                        require_symbol = 0;
                    }
                }
                if (parent_kind == hir.HirNode.local_decl) {
                    if (is_first_child == 0) {
                        require_symbol = 0;
                    }
                }
                if (parent_kind == hir.HirNode.global_decl) {
                    if (is_first_child == 0) {
                        require_symbol = 0;
                    }
                }
                if (parent_kind == hir.HirNode.field_decl) {
                    if (is_first_child == 0) {
                        require_symbol = 0;
                    }
                }
                if (parent_kind == hir.HirNode.struct_decl) {
                    if (is_first_child != 0) {
                        require_symbol = 0;
                    }
                }
                if (parent_kind == hir.HirNode.union_decl) {
                    if (is_first_child == 0) {
                        if (hir.hir_store_node_next_sibling[hir.hir_store_node_first_child[parent]] == node) {
                            require_symbol = 0;
                        }
                    }
                }
                if (parent_kind == hir.HirNode.enum_decl) {
                    if (is_first_child != 0) {
                        require_symbol = 0;
                    }
                }
                if (parent_kind == hir.HirNode.enum_member) {
                    if (is_first_child != 0) {
                        require_symbol = 0;
                    }
                }
                if (parent_kind == hir.HirNode.member_expr) {
                    if (is_first_child == 0) {
                        require_symbol = 0;
                    }
                }
                if (parent_kind == hir.HirNode.optional_member_expr) {
                    if (is_first_child == 0) {
                        require_symbol = 0;
                    }
                }
                if (parent_kind == hir.HirNode.shorthand_member_expr) {
                    require_symbol = 0;
                }
                if (parent_kind == hir.HirNode.field_init) {
                    if (is_first_child != 0) {
                        require_symbol = 0;
                    }
                }
                if (parent_kind == hir.HirNode.for_stmt) {
                    Int mode = hir.hir_store_node_aux[parent];
                    if (mode == 0) {
                        Int loop_type = hir.hir_store_node_first_child[parent];
                        if (loop_type != 0) {
                            if (hir.hir_store_node_next_sibling[loop_type] == node) {
                                require_symbol = 0;
                            }
                        }
                    } else {
                        if (mode == 3) {
                            Int loop_type = hir.hir_store_node_first_child[parent];
                            if (loop_type != 0) {
                                if (hir.hir_store_node_next_sibling[loop_type] == node) {
                                    require_symbol = 0;
                                }
                            }
                        } else {
                            if (hir.hir_store_node_first_child[parent] == node) {
                                require_symbol = 0;
                            }
                        }
                    }
                }
            }
        }
        if (kind == hir.HirNode.member_expr) {
            Int base = hir.hir_store_node_first_child[node];
            if (base != 0) {
                Int base_type = type_member_base_type(hir.hir_store_node_type_ids[base]);
                if (type_is_slice(base_type)) {
                    Int member = hir.hir_store_node_next_sibling[base];
                    if (member != 0) {
                        if (hir_member_name_is(member, "length")) {
                            require_symbol = 0;
                        }
                    }
                }
                if (type_is_enum(base_type)) {
                    Int member = hir.hir_store_node_next_sibling[base];
                    if (member != 0) {
                        if (hir_member_name_is(member, "value")) {
                            if (hir.hir_store_node_symbol_ids[base] == 0) {
                                require_symbol = 0;
                            } else if (symbol_store.symbol_store_kinds[hir.hir_store_node_symbol_ids[base]] != symbol_store.SymbolKind.enum_name) {
                                require_symbol = 0;
                            }
                        }
                    }
                }
                if (type_is_union(base_type)) {
                    Int member = hir.hir_store_node_next_sibling[base];
                    if (member != 0) {
                        if (hir_member_name_is(member, "tag")) {
                            require_symbol = 0;
                        }
                    }
                }
            }
        }
        if (kind == hir.HirNode.optional_member_expr) {
            Int base = hir.hir_store_node_first_child[node];
            if (base != 0) {
                Int payload_type = type_optional_payload(hir.hir_store_node_type_ids[base]);
                if (type_is_slice(payload_type)) {
                    Int member = hir.hir_store_node_next_sibling[base];
                    if (member != 0) {
                        if (hir_member_name_is(member, "length")) {
                            require_symbol = 0;
                        }
                    }
                }
                if (type_is_enum(payload_type)) {
                    Int member = hir.hir_store_node_next_sibling[base];
                    if (member != 0) {
                        if (hir_member_name_is(member, "value")) {
                            require_symbol = 0;
                        }
                    }
                }
                if (type_is_union(payload_type)) {
                    Int member = hir.hir_store_node_next_sibling[base];
                    if (member != 0) {
                        if (hir_member_name_is(member, "tag")) {
                            require_symbol = 0;
                        }
                    }
                }
            }
        }
        if (require_symbol != 0) {
            if (hir.hir_store_node_symbol_ids[node] == 0) {
                diagnostic.diagnostic_error(
                    current_path,
                    hir.hir_store_node_starts[node],
                    hir.hir_store_node_ends[node],
                    "unresolved symbol"
                );
                return;
            }
        }
    }
    if (node_requires_known_type(kind)) {
        Int require_type = 1;
        if (kind == hir.HirNode.ident) {
            if (parent != 0) {
                Int parent_kind = hir.hir_store_node_kinds[parent];
                if (parent_kind == hir.HirNode.func_decl) {
                    if (is_first_child == 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.param) {
                    if (is_first_child == 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.slice_type) {
                    require_type = 0;
                }
                if (parent_kind == hir.HirNode.array_type) {
                    require_type = 0;
                }
                if (parent_kind == hir.HirNode.pointer_type) {
                    require_type = 0;
                }
                if (parent_kind == hir.HirNode.optional_type) {
                    require_type = 0;
                }
                if (parent_kind == hir.HirNode.mutable_type) {
                    require_type = 0;
                }
                if (parent_kind == hir.HirNode.tuple_type) {
                    require_type = 0;
                }
                if (parent_kind == hir.HirNode.local_decl) {
                    if (is_first_child == 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.global_decl) {
                    if (is_first_child == 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.field_decl) {
                    if (is_first_child == 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.struct_decl) {
                    if (is_first_child != 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.union_decl) {
                    if (is_first_child != 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.enum_decl) {
                    if (is_first_child != 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.enum_member) {
                    if (is_first_child != 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.member_expr) {
                    if (is_first_child == 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.optional_member_expr) {
                    if (is_first_child == 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.shorthand_member_expr) {
                    require_type = 0;
                }
                if (parent_kind == hir.HirNode.field_init) {
                    if (is_first_child != 0) {
                        require_type = 0;
                    }
                }
                if (parent_kind == hir.HirNode.for_stmt) {
                    Int mode = hir.hir_store_node_aux[parent];
                    if (mode == 0) {
                        Int loop_type = hir.hir_store_node_first_child[parent];
                        if (loop_type != 0) {
                            if (hir.hir_store_node_next_sibling[loop_type] == node) {
                                require_type = 0;
                            }
                        }
                    } else {
                        if (mode == 3) {
                            Int loop_type = hir.hir_store_node_first_child[parent];
                            if (loop_type != 0) {
                                if (hir.hir_store_node_next_sibling[loop_type] == node) {
                                    require_type = 0;
                                }
                            }
                        } else {
                            if (hir.hir_store_node_first_child[parent] == node) {
                                require_type = 0;
                            }
                        }
                    }
                }
            }
        }
        if (require_type != 0) {
            if (!is_known_type(hir.hir_store_node_type_ids[node])) {
                diagnostic.diagnostic_error(
                    current_path,
                    hir.hir_store_node_starts[node],
                    hir.hir_store_node_ends[node],
                    "unresolved type"
                );
                return;
            }
        }
    }
    Int child = hir.hir_store_node_first_child[node];
    Int first = 1;
    while (child != 0) {
        verify_resolved_node(child, node, first);
        first = 0;
        child = hir.hir_store_node_next_sibling[child];
    }
}

Bool type_is_array(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (type_id <= 0) {
        return 0;
    }
    if (type_id >= type_store.type_store_count) {
        return 0;
    }
    return type_store.type_store_kinds[type_id] == type_store.TypeKind.array;
}

Bool type_is_inferred_array(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (!type_is_array(type_id)) {
        return 0;
    }
    return type_store.type_store_array_lengths[type_id] < 0;
}

Bool type_is_slice(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (type_id <= 0) {
        return 0;
    }
    if (type_id >= type_store.type_store_count) {
        return 0;
    }
    return type_store.type_store_kinds[type_id] == type_store.TypeKind.slice;
}

Bool type_is_pointer(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (type_id <= 0) {
        return 0;
    }
    if (type_id >= type_store.type_store_count) {
        return 0;
    }
    return type_store.type_store_kinds[type_id] == type_store.TypeKind.pointer;
}

Int proxy_operand_node(Int node) {
    if (node == 0) {
        return 0;
    }
    if (hir.hir_store_node_kinds[node] != hir.HirNode.unary_expr) {
        return 0;
    }
    if (hir.hir_store_node_aux[node] != hir.HirUnaryOp.proxy) {
        return 0;
    }
    return hir.hir_store_node_first_child[node];
}

Int free_target_symbol_from_proxy_member(Int callee) {
    if (callee == 0) {
        return 0;
    }
    if (hir.hir_store_node_kinds[callee] != hir.HirNode.member_expr) {
        return 0;
    }
    Int base = hir.hir_store_node_first_child[callee];
    Int operand = proxy_operand_node(base);
    if (operand == 0) {
        return 0;
    }
    if (hir.hir_store_node_kinds[operand] != hir.HirNode.ident) {
        return 0;
    }
    Int symbol_id = hir.hir_store_node_symbol_ids[operand];
    if (symbol_id == 0) {
        return 0;
    }
    Int kind = symbol_store.symbol_store_kinds[symbol_id];
    if (kind != symbol_store.SymbolKind.local) {
        if (kind != symbol_store.SymbolKind.global) {
            return 0;
        }
    }
    if (!type_is_pointer(hir.hir_store_node_type_ids[operand])) {
        return 0;
    }
    return symbol_id;
}

Bool proxy_member_is_free_call(UInt8[] source, Int parse_call_node, Int lowered_call_node) {
    Int callee_parse = parser.parser_store_node_first_child[parse_call_node];
    if (callee_parse == 0) {
        return 0;
    }
    lowered_call_node = lowered_call_node;
    return parse_is_proxy_free_member(source, callee_parse);
}

Bool parse_is_proxy_free_member(UInt8[] source, Int parse_node) {
    if (parse_node == 0) {
        return 0;
    }
    if (parser.parser_store_node_kinds[parse_node] != parser.ParserNode.member_expr) {
        return 0;
    }
    Int base = parser.parser_store_node_first_child[parse_node];
    if (base == 0) {
        return 0;
    }
    if (parser.parser_store_node_kinds[base] != parser.ParserNode.unary_expr) {
        return 0;
    }
    if (parser.parser_store_node_aux[base] != parser.UnaryOp.proxy) {
        return 0;
    }
    Int member = parser.parser_store_node_next_sibling[base];
    if (member == 0) {
        return 0;
    }
    return member_name_is(source, member, "free");
}

() rewrite_proxy_free_call(Int node) {
    Int callee = hir.hir_store_node_first_child[node];
    Int target_symbol = free_target_symbol_from_proxy_member(callee);
    if (target_symbol == 0) {
        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "$ptr.free() requires a pointer variable");
        return;
    }
    Int arg = hir.hir_store_node_next_sibling[callee];
    if (arg != 0) {
        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "$ptr.free() does not take arguments");
        return;
    }
    if (symbol_is_freed(target_symbol)) {
        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "symbol was freed");
        return;
    }
    Int proxy_base = hir.hir_store_node_first_child[callee];
    Int operand = proxy_operand_node(proxy_base);
    Int free_callee = make_synthetic_ident_node(builtin_free_symbol, symbol_store.symbol_store_type_ids[builtin_free_symbol], hir.hir_store_node_starts[node], hir.hir_store_node_starts[node]);
    hir.hir_store_set_first_child(node, free_callee);
    hir.hir_store_set_next_sibling(free_callee, operand);
    hir.hir_store_set_next_sibling(operand, 0);
    hir.hir_store_set_type_id(callee, symbol_store.symbol_store_type_ids[builtin_free_symbol]);
    hir.hir_store_set_symbol_id(callee, builtin_free_symbol);
    hir.hir_store_set_symbol_id(node, 0);
    hir.hir_store_set_type_id(node, type_store.type_store_builtin_void);
    mark_symbol_freed(target_symbol);
}

Bool type_is_enum(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (type_id <= 0) {
        return 0;
    }
    if (type_id >= type_store.type_store_count) {
        return 0;
    }
    return type_store.type_store_kinds[type_id] == type_store.TypeKind.enum_type;
}

Bool type_is_union(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (type_id <= 0) {
        return 0;
    }
    if (type_id >= type_store.type_store_count) {
        return 0;
    }
    return type_store.type_store_kinds[type_id] == type_store.TypeKind.union_type;
}

Bool type_is_tuple(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (type_id <= 0) {
        return 0;
    }
    if (type_id >= type_store.type_store_count) {
        return 0;
    }
    return type_store.type_store_kinds[type_id] == type_store.TypeKind.tuple;
}

Int type_member_base_type(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (type_is_pointer(type_id)) {
        return type_store.type_store_elem_type_ids[type_id];
    }
    return type_id;
}

Bool type_supports_ternary_result(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (type_id == type_store.type_store_builtin_bool) {
        return 1;
    }
    if (type_id == type_store.type_store_builtin_int) {
        return 1;
    }
    if (type_id == type_store.type_store_builtin_uint8) {
        return 1;
    }
    if (type_is_enum(type_id)) {
        return 1;
    }
    return type_is_pointer(type_id);
}

Bool instance_method_base_is_supported(Int base_node) {
    Int base_type = type_strip_mutable(hir.hir_store_node_type_ids[base_node]);
    if (type_is_pointer(base_type)) {
        return 1;
    }
    return is_assignable_node(base_node);
}

Bool type_supports_coalesce_result(Int type_id) {
    return type_supports_ternary_result(type_id);
}

Int union_tag_type(Int type_id) {
    type_id = type_strip_mutable(type_id);
    if (!type_is_union(type_id)) {
        return type_store.type_store_builtin_unknown;
    }
    return type_store.type_store_elem_type_ids[type_id];
}

Int parse_int_literal_value(Int start, Int end_pos) {
    Int value = 0;
    Int i = start;
    while (i < end_pos) {
        value = value * 10 + (current_source[i] - 48);
        i = i + 1;
    }
    return value;
}

Int eval_const_int_expr(Int node_id) {
    Int kind = hir.hir_store_node_kinds[node_id];
    if (kind == hir.HirNode.int_lit) {
        return parse_int_literal_value(hir.hir_store_node_starts[node_id], hir.hir_store_node_ends[node_id]);
    }
    if (kind == hir.HirNode.unary_expr) {
        Int operand = hir.hir_store_node_first_child[node_id];
        if (hir.hir_store_node_aux[node_id] == parser.UnaryOp.neg) {
            return 0 - eval_const_int_expr(operand);
        }
    }
    if (kind == hir.HirNode.binary_expr) {
        Int left = hir.hir_store_node_first_child[node_id];
        Int right = hir.hir_store_node_next_sibling[left];
        Int left_value = eval_const_int_expr(left);
        Int right_value = eval_const_int_expr(right);
        if (hir.hir_store_node_aux[node_id] == parser.BinaryOp.add) {
            return left_value + right_value;
        }
        if (hir.hir_store_node_aux[node_id] == parser.BinaryOp.sub) {
            return left_value - right_value;
        }
        if (hir.hir_store_node_aux[node_id] == parser.BinaryOp.mul) {
            return left_value * right_value;
        }
        if (hir.hir_store_node_aux[node_id] == parser.BinaryOp.div) {
            return left_value / right_value;
        }
    }
    diagnostic.diagnostic_error(
        current_path,
        hir.hir_store_node_starts[node_id],
        hir.hir_store_node_ends[node_id],
        "enum value must be an integer constant expression"
    );
    return 0;
}

Bool type_is_integer_like(Int type_id) {
    if (type_id == type_store.type_store_builtin_int) {
        return 1;
    }
    if (type_id == type_store.type_store_builtin_uint8) {
        return 1;
    }
    return type_is_enum(type_id);
}

Bool member_name_is(UInt8[] source, Int parse_node, UInt8[] expected) {
    Int start = parser.parser_store_node_starts[parse_node];
    Int end_pos = parser.parser_store_node_ends[parse_node];
    if (end_pos - start != expected.length) {
        return 0;
    }
    Int i = 0;
    while (i < expected.length) {
        if (source[start + i] != expected[i]) {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

Bool hir_member_name_is(Int node, UInt8[] expected) {
    return span_eq(
        current_source,
        hir.hir_store_node_starts[node],
        hir.hir_store_node_ends[node],
        expected
    );
}

Bool ident_requires_value_resolution(Int parse_node) {
    Int parent = parser.parser_store_node_parent[parse_node];
    if (parent == 0) {
        return 1;
    }
    Int parent_kind = parser.parser_store_node_kinds[parent];
    if (parent_kind == parser.ParserNode.func_decl) {
        if (parser.parser_store_node_next_sibling[parser.parser_store_node_first_child[parent]] == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.param) {
        if (parser.parser_store_node_next_sibling[parser.parser_store_node_first_child[parent]] == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.local_decl) {
        if (parser.parser_store_node_next_sibling[parser.parser_store_node_first_child[parent]] == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.global_decl) {
        if (parser.parser_store_node_next_sibling[parser.parser_store_node_first_child[parent]] == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.tuple_local_decl) {
        Int count = tuple_decl_binding_count(parent);
        Int i = 0;
        while (i < count) {
            if (tuple_decl_binding_name_parse(parent, i) == parse_node) {
                return 0;
            }
            i = i + 1;
        }
    }
    if (parent_kind == parser.ParserNode.tuple_global_decl) {
        Int count = tuple_decl_binding_count(parent);
        Int i = 0;
        while (i < count) {
            if (tuple_decl_binding_name_parse(parent, i) == parse_node) {
                return 0;
            }
            i = i + 1;
        }
    }
    if (parent_kind == parser.ParserNode.field_decl) {
        if (parser.parser_store_node_next_sibling[parser.parser_store_node_first_child[parent]] == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.tuple_type) {
        return 0;
    }
    if (parent_kind == parser.ParserNode.struct_decl) {
        if (parser.parser_store_node_first_child[parent] == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.union_decl) {
        Int tag_type = union_parse_tag_type_node(parent);
        if (tag_type == parse_node) {
            return 0;
        }
        if (union_parse_name_node(parent) == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.enum_decl) {
        if (parser.parser_store_node_first_child[parent] == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.enum_member) {
        if (parser.parser_store_node_first_child[parent] == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.alias_decl) {
        if (parser.parser_store_node_first_child[parent] == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.member_expr) {
        if (parser.parser_store_node_first_child[parent] != parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.optional_member_expr) {
        if (parser.parser_store_node_first_child[parent] != parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.shorthand_member_expr) {
        return 0;
    }
    if (parent_kind == parser.ParserNode.field_init) {
        if (parser.parser_store_node_first_child[parent] == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.for_stmt) {
        Int mode = parser.parser_store_node_aux[parent];
        if (mode == 0) {
            Int type_node = parser.parser_store_node_first_child[parent];
            if (type_node != 0) {
                if (parser.parser_store_node_next_sibling[type_node] == parse_node) {
                    return 0;
                }
            }
        } else {
            if (mode == 3) {
                Int type_node = parser.parser_store_node_first_child[parent];
                if (type_node != 0) {
                    if (parser.parser_store_node_next_sibling[type_node] == parse_node) {
                        return 0;
                    }
                }
            } else {
                if (parser.parser_store_node_first_child[parent] == parse_node) {
                    return 0;
                }
            }
        }
    }
    if (parent_kind == parser.ParserNode.switch_case) {
        if (parser.parser_store_node_first_child[parent] == parse_node) {
            return 0;
        }
    }
    if (parent_kind == parser.ParserNode.union_pattern_expr) {
        return 0;
    }
    return 1;
}

() check_assignment_target(Int left_node) {
    if (!is_assignable_node(left_node)) {
        diagnostic.diagnostic_error(
            current_path,
            hir.hir_store_node_starts[left_node],
            hir.hir_store_node_ends[left_node],
            "assignment target is not assignable"
        );
    }
}

Bool is_string_compatible_array(Int declared_type, Int right_node) {
    declared_type = type_strip_mutable(declared_type);
    if (!type_is_array(declared_type)) {
        return 0;
    }
    if (type_is_inferred_array(declared_type)) {
        return 0;
    }
    if (hir.hir_store_node_kinds[right_node] != hir.HirNode.string_lit) {
        return 0;
    }
    if (type_store.type_store_elem_type_ids[declared_type] != type_store.type_store_builtin_uint8) {
        return 0;
    }
    return type_store.type_store_array_lengths[declared_type] == (
        hir.hir_store_node_ends[right_node] - hir.hir_store_node_starts[right_node] - 2
    );
}

Bool is_uint8_array_to_slice(Int expected_type, Int actual_type) {
    if (expected_type != type_store.type_store_builtin_uint8_slice) {
        return 0;
    }
    if (!type_is_array(actual_type)) {
        return 0;
    }
    return type_store.type_store_elem_type_ids[actual_type] == type_store.type_store_builtin_uint8;
}

Bool is_array_to_same_slice(Int expected_type, Int actual_type) {
    if (!type_is_slice(expected_type)) {
        return 0;
    }
    if (!type_is_array(actual_type)) {
        return 0;
    }
    return type_store.type_store_elem_type_ids[expected_type] == type_store.type_store_elem_type_ids[actual_type];
}

Int array_literal_item_count(Int node) {
    Int count = 0;
    Int child = hir.hir_store_node_first_child[node];
    while (child != 0) {
        count = count + 1;
        child = hir.hir_store_node_next_sibling[child];
    }
    return count;
}

Int array_init_expr_item_count(Int node) {
    Int count = 0;
    Int child = hir.hir_store_node_first_child[node];
    if (child != 0) {
        child = hir.hir_store_node_next_sibling[child];
    }
    while (child != 0) {
        count = count + 1;
        child = hir.hir_store_node_next_sibling[child];
    }
    return count;
}

Bool array_element_type_compatible(Int expected_elem_type, Int actual_elem_type) {
    expected_elem_type = type_strip_mutable(expected_elem_type);
    actual_elem_type = type_strip_mutable(actual_elem_type);
    if (expected_elem_type == actual_elem_type) {
        return 1;
    }
    if (type_is_inferred_array(expected_elem_type)) {
        if (!type_is_array(actual_elem_type)) {
            return 0;
        }
        return array_element_type_compatible(
            type_store.type_store_elem_type_ids[expected_elem_type],
            type_store.type_store_elem_type_ids[actual_elem_type]
        );
    }
    return 0;
}

Int infer_concrete_array_type_from_value(Int declared_type, Int value_node) {
    declared_type = type_strip_mutable(declared_type);
    if (!type_is_inferred_array(declared_type)) {
        return declared_type;
    }
    Int elem_type = type_store.type_store_elem_type_ids[declared_type];
    Int actual_type = type_strip_mutable(hir.hir_store_node_type_ids[value_node]);
    if (type_is_array(actual_type)) {
        if (array_element_type_compatible(elem_type, type_store.type_store_elem_type_ids[actual_type])) {
            return actual_type;
        }
        return type_store.type_store_builtin_unknown;
    }
    if (hir.hir_store_node_kinds[value_node] == hir.HirNode.string_lit) {
        if (elem_type != type_store.type_store_builtin_uint8) {
            return type_store.type_store_builtin_unknown;
        }
        Int length = hir.hir_store_node_ends[value_node] - hir.hir_store_node_starts[value_node] - 2;
        return type_store.type_store_new_array_type(elem_type, length);
    }
    if (hir.hir_store_node_kinds[value_node] == hir.HirNode.array_init_expr) {
        Int count = array_init_expr_item_count(value_node);
        return type_store.type_store_new_array_type(elem_type, count);
    }
    if (hir.hir_store_node_kinds[value_node] != hir.HirNode.array_lit) {
        return type_store.type_store_builtin_unknown;
    }
    Int count = array_literal_item_count(value_node);
    if (type_is_inferred_array(elem_type)) {
        Int child = hir.hir_store_node_first_child[value_node];
        Int concrete_elem_type = 0;
        while (child != 0) {
            Int child_type = infer_concrete_array_type_from_value(elem_type, child);
            if (!is_known_type(child_type)) {
                return type_store.type_store_builtin_unknown;
            }
            if (concrete_elem_type == 0) {
                concrete_elem_type = child_type;
            } else if (concrete_elem_type != child_type) {
                return type_store.type_store_builtin_unknown;
            }
            child = hir.hir_store_node_next_sibling[child];
        }
        if (concrete_elem_type == 0) {
            concrete_elem_type = elem_type;
        }
        return type_store.type_store_new_array_type(concrete_elem_type, count);
    }
    return type_store.type_store_new_array_type(elem_type, count);
}

() hir_text_buffer_push_int(Int buffer, Int value) {
    if (value < 0) {
        text.text_buffer_push_text(buffer, "-");
        hir_text_buffer_push_int(buffer, 0 - value);
        return;
    }
    if (value >= 10) {
        hir_text_buffer_push_int(buffer, value / 10);
    }
    UInt8[] digits = "0123456789";
    Int digit = value;
    if (value >= 10) {
        digit = value - ((value / 10) * 10);
    }
    text.text_buffer_push_byte(buffer, digits[digit]);
}

UInt8[] next_tuple_temp_name() {
    Int buffer = text.text_buffer_new(24);
    text.text_buffer_clear(buffer);
    text.text_buffer_push_text(buffer, "__tuple_tmp_");
    hir_text_buffer_push_int(buffer, tuple_temp_counter);
    tuple_temp_counter = tuple_temp_counter + 1;
    return text.text_buffer_slice(buffer);
}

UInt8[] next_optional_narrow_name() {
    Int buffer = text.text_buffer_new(32);
    text.text_buffer_clear(buffer);
    text.text_buffer_push_text(buffer, "__optional_narrow_");
    hir_text_buffer_push_int(buffer, tuple_temp_counter);
    tuple_temp_counter = tuple_temp_counter + 1;
    return text.text_buffer_slice(buffer);
}

UInt8[] next_implicit_union_tag_name() {
    Int buffer = text.text_buffer_new(40);
    text.text_buffer_clear(buffer);
    text.text_buffer_push_text(buffer, "__jiang_union_tag_");
    hir_text_buffer_push_int(buffer, implicit_union_tag_counter);
    implicit_union_tag_counter = implicit_union_tag_counter + 1;
    return text.text_buffer_slice(buffer);
}

Int new_synthetic_local_symbol(UInt8[] name, Int type_id, Int parent_id) {
    return symbol_store.symbol_store_new_symbol(
        name,
        symbol_store.SymbolKind.local,
        0,
        name.length,
        type_id,
        parent_id,
        register_module_id
    );
}

() register_for_binding_symbols(UInt8[] source, Int binding_parse, Int scope_id) {
    if (for_binding_parse_is_leaf(binding_parse)) {
        Int type_node = for_binding_leaf_type_parse(binding_parse);
        Int name_node = for_binding_leaf_name_parse(binding_parse);
        Int binding_type = type_store.type_store_builtin_unknown;
        if (!type_parse_is_infer(source, type_node)) {
            binding_type = resolve_type_node_from_source(source, type_node);
        }
        register_unique_symbol(
            source,
            symbol_store.SymbolKind.local,
            parser.parser_store_node_starts[name_node],
            parser.parser_store_node_ends[name_node],
            binding_type,
            scope_id,
            "duplicate local"
        );
        return;
    }
    Int child = parser.parser_store_node_first_child[binding_parse];
    while (child != 0) {
        register_for_binding_symbols(source, child, scope_id);
        child = parser.parser_store_node_next_sibling[child];
    }
}

() seed_for_binding_symbol_types(Int binding_parse, Int value_type, Int scope_id, UInt8[] mismatch_message) {
    if (for_binding_parse_is_leaf(binding_parse)) {
        Int type_parse = for_binding_leaf_type_parse(binding_parse);
        Int name_parse = for_binding_leaf_name_parse(binding_parse);
        if (!type_parse_is_infer(current_source, type_parse)) {
            Int declared_type = resolve_type_node_from_source(current_source, type_parse);
            if (is_known_type(declared_type)) {
                if (type_strip_mutable(declared_type) != type_strip_mutable(value_type)) {
                    diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[type_parse], parser.parser_store_node_ends[type_parse], mismatch_message);
                }
            }
        }
        Int symbol_id = resolve_symbol(current_source, name_parse, symbol_store.SymbolKind.local, scope_id);
        if (symbol_id != 0) {
            symbol_store.symbol_store_set_type_id(symbol_id, infer_wrapped_type_from_parse(type_parse, value_type));
        }
        return;
    }
    if (!type_is_tuple(value_type)) {
        diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[binding_parse], parser.parser_store_node_ends[binding_parse], "for tuple binding requires tuple element");
        return;
    }
    Int count = for_binding_parse_count(binding_parse);
    if (type_store.type_store_tuple_count(value_type) != count) {
        diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[binding_parse], parser.parser_store_node_ends[binding_parse], "for tuple binding arity mismatch");
        return;
    }
    Int i = 0;
    while (i < count) {
        seed_for_binding_symbol_types(
            for_binding_parse_child(binding_parse, i),
            type_store.type_store_tuple_item_type(value_type, i),
            scope_id,
            mismatch_message
        );
        i = i + 1;
    }
}

Int make_synthetic_type_node(Int type_id, Int start, Int end_pos) {
    Int node = hir.hir_store_new_node(hir.HirNode.type_name, start, end_pos);
    hir.hir_store_set_type_id(node, type_id);
    return node;
}

Int make_synthetic_ident_node(Int symbol_id, Int type_id, Int start, Int end_pos) {
    Int node = hir.hir_store_new_node(hir.HirNode.ident, start, end_pos);
    hir.hir_store_set_symbol_id(node, symbol_id);
    hir.hir_store_set_type_id(node, type_id);
    return node;
}

Int build_synthetic_generic_field_decl(Int field_symbol) {
    Int field_type = symbol_store.symbol_store_type_ids[field_symbol];
    Int node = hir.hir_store_new_node(hir.HirNode.field_decl, 0, 0);
    hir.hir_store_set_symbol_id(node, field_symbol);
    hir.hir_store_set_type_id(node, field_type);
    Int type_node = make_synthetic_type_node(field_type, 0, 0);
    Int name_node = make_synthetic_ident_node(field_symbol, field_type, 0, 0);
    hir.hir_store_append_child(node, type_node);
    hir.hir_store_append_child(node, name_node);
    symbol_store.symbol_store_set_aux(field_symbol, node);
    return node;
}

Int build_synthetic_generic_struct_decl(Int inst_id) {
    Int owner_symbol = ints.buffer_int_get(generic_struct_inst_owner_symbol_handle, inst_id);
    Int owner_type = ints.buffer_int_get(generic_struct_inst_type_id_handle, inst_id);
    Int node = hir.hir_store_new_node(hir.HirNode.struct_decl, 0, 0);
    hir.hir_store_set_symbol_id(node, owner_symbol);
    hir.hir_store_set_type_id(node, owner_type);
    Int name_node = make_synthetic_ident_node(owner_symbol, owner_type, 0, 0);
    hir.hir_store_append_child(node, name_node);
    Int child_symbol = 1;
    while (child_symbol < symbol_store.symbol_store_count) {
        if (symbol_store.symbol_store_parent_ids[child_symbol] == owner_symbol) {
            if (symbol_store.symbol_store_kinds[child_symbol] == symbol_store.SymbolKind.field) {
                hir.hir_store_append_child(node, build_synthetic_generic_field_decl(child_symbol));
            }
        }
        child_symbol = child_symbol + 1;
    }
    return node;
}

Int make_tuple_item_index_expr(Int base_expr, Int item_index, Int item_type, Int start, Int end_pos) {
    Int node = hir.hir_store_new_node(hir.HirNode.index_expr, start, end_pos);
    Int base_copy = make_synthetic_ident_node(
        hir.hir_store_node_symbol_ids[base_expr],
        hir.hir_store_node_type_ids[base_expr],
        start,
        end_pos
    );
    Int index_node = hir.hir_store_new_node(hir.HirNode.int_lit, start, end_pos);
    hir.hir_store_set_type_id(index_node, type_store.type_store_builtin_int);
    hir.hir_store_set_aux(index_node, item_index);
    hir.hir_store_append_child(node, base_copy);
    hir.hir_store_append_child(node, index_node);
    hir.hir_store_set_aux(node, item_index);
    hir.hir_store_set_type_id(node, item_type);
    return node;
}

Int build_for_binding_decl_stmt(Int binding_parse, Int lowered_value, Int value_type, Int scope_id, UInt8[] mismatch_message) {
    if (for_binding_parse_is_leaf(binding_parse)) {
        Int type_parse = for_binding_leaf_type_parse(binding_parse);
        Int name_parse = for_binding_leaf_name_parse(binding_parse);
        Int node = hir.hir_store_new_node(
            hir.HirNode.local_decl,
            parser.parser_store_node_starts[name_parse],
            hir.hir_store_node_ends[lowered_value]
        );
        Int lowered_type = 0;
        Int declared_type = infer_wrapped_type_from_parse(type_parse, value_type);
        if (type_parse_is_infer(current_source, type_parse)) {
            lowered_type = make_synthetic_type_node(declared_type, parser.parser_store_node_starts[name_parse], parser.parser_store_node_starts[name_parse]);
        } else {
            lowered_type = lower_node(type_parse);
        }
        Int lowered_name = lower_node(name_parse);
        Int lowered_init = coerce_expr_to_type(lowered_value, declared_type);
        hir.hir_store_append_child(node, lowered_type);
        hir.hir_store_append_child(node, lowered_name);
        hir.hir_store_append_child(node, lowered_init);
        Int symbol_id = resolve_symbol(current_source, name_parse, symbol_store.SymbolKind.local, scope_id);
        if (symbol_id != 0) {
            symbol_store.symbol_store_set_type_id(symbol_id, declared_type);
            hir.hir_store_set_symbol_id(node, symbol_id);
            hir.hir_store_set_type_id(node, declared_type);
            hir.hir_store_set_symbol_id(lowered_name, symbol_id);
            hir.hir_store_set_type_id(lowered_name, declared_type);
            hir.hir_store_set_type_id(lowered_type, declared_type);
        }
        return node;
    }

    Int node = hir.hir_store_new_node(
        hir.HirNode.tuple_local_decl,
        parser.parser_store_node_starts[binding_parse],
        hir.hir_store_node_ends[lowered_value]
    );
    if (!type_is_tuple(value_type)) {
        return node;
    }
    Int count = for_binding_parse_count(binding_parse);
    if (type_store.type_store_tuple_count(value_type) != count) {
        return node;
    }
    UInt8[] temp_name = next_tuple_temp_name();
    Int temp_symbol = new_synthetic_local_symbol(temp_name, value_type, scope_id);
    Int temp_decl = hir.hir_store_new_node(
        hir.HirNode.local_decl,
        hir.hir_store_node_starts[lowered_value],
        hir.hir_store_node_ends[lowered_value]
    );
    Int temp_type = make_synthetic_type_node(value_type, hir.hir_store_node_starts[lowered_value], hir.hir_store_node_starts[lowered_value]);
    Int temp_name_node = make_synthetic_ident_node(temp_symbol, value_type, 0, 0);
    hir.hir_store_append_child(temp_decl, temp_type);
    hir.hir_store_append_child(temp_decl, temp_name_node);
    hir.hir_store_append_child(temp_decl, lowered_value);
    hir.hir_store_set_symbol_id(temp_decl, temp_symbol);
    hir.hir_store_set_type_id(temp_decl, value_type);
    hir.hir_store_append_child(node, temp_decl);

    Int temp_ident = make_synthetic_ident_node(temp_symbol, value_type, hir.hir_store_node_starts[lowered_value], hir.hir_store_node_ends[lowered_value]);
    Int i = 0;
    while (i < count) {
        Int child_parse = for_binding_parse_child(binding_parse, i);
        Int item_type = type_store.type_store_tuple_item_type(value_type, i);
        Int item_value = make_tuple_item_index_expr(
            temp_ident,
            i,
            item_type,
            hir.hir_store_node_starts[lowered_value],
            hir.hir_store_node_ends[lowered_value]
        );
        Int child_stmt = build_for_binding_decl_stmt(child_parse, item_value, item_type, scope_id, mismatch_message);
        hir.hir_store_append_child(node, child_stmt);
        i = i + 1;
    }
    return node;
}

() hir_prepend_child(Int parent, Int child) {
    hir.hir_store_set_next_sibling(child, hir.hir_store_node_first_child[parent]);
    hir.hir_store_set_first_child(parent, child);
}

() hir_insert_child_after(Int parent, Int after_child, Int child) {
    parent = parent;
    hir.hir_store_set_next_sibling(child, hir.hir_store_node_next_sibling[after_child]);
    hir.hir_store_set_next_sibling(after_child, child);
}

Int make_synthetic_self_param_node(Int owner_symbol, Int func_symbol, Int start, Int end_pos) {
    Int owner_type = symbol_store.symbol_store_type_ids[owner_symbol];
    Int self_symbol = symbol_store.symbol_store_find_symbol_by_name_id(
        intern_pool.intern_pool_intern("self"),
        symbol_store.SymbolKind.param,
        func_symbol
    );
    if (self_symbol == 0) {
        return 0;
    }
    Int param_node = hir.hir_store_new_node(hir.HirNode.param, start, end_pos);
    hir.hir_store_set_symbol_id(param_node, self_symbol);
    hir.hir_store_set_type_id(param_node, symbol_store.symbol_store_type_ids[self_symbol]);
    Int base_type = hir.hir_store_new_node(hir.HirNode.type_name, start, end_pos);
    hir.hir_store_set_symbol_id(base_type, owner_symbol);
    hir.hir_store_set_type_id(base_type, owner_type);
    Int pointer_type = hir.hir_store_new_node(hir.HirNode.pointer_type, start, end_pos);
    hir.hir_store_set_type_id(pointer_type, symbol_store.symbol_store_type_ids[self_symbol]);
    hir.hir_store_append_child(pointer_type, base_type);
    Int name_node = hir.hir_store_new_node(hir.HirNode.ident, start, end_pos);
    hir.hir_store_set_symbol_id(name_node, self_symbol);
    hir.hir_store_set_type_id(name_node, symbol_store.symbol_store_type_ids[self_symbol]);
    hir.hir_store_append_child(param_node, pointer_type);
    hir.hir_store_append_child(param_node, name_node);
    return param_node;
}

Int wrap_array_to_slice(Int child_node) {
    Int child_type = hir.hir_store_node_type_ids[child_node];
    Int slice_type = type_store.type_store_builtin_uint8_slice;
    if (type_is_array(child_type)) {
        slice_type = type_store.type_store_new_slice_type(type_store.type_store_elem_type_ids[child_type]);
    }
    Int wrapper = hir.hir_store_new_node(
        hir.HirNode.array_to_slice_expr,
        hir.hir_store_node_starts[child_node],
        hir.hir_store_node_ends[child_node]
    );
    hir.hir_store_set_type_id(wrapper, slice_type);
    hir.hir_store_append_child(wrapper, child_node);
    return wrapper;
}

Int resolve_shorthand_member_symbol_for_type(Int member_node, Int expected_type) {
    expected_type = type_strip_mutable(expected_type);
    if (!is_known_type(expected_type)) {
        return 0;
    }
    Int owner_symbol = find_type_owner_symbol(expected_type);
    if (owner_symbol == 0) {
        return 0;
    }
    Int name_id = intern_pool.intern_pool_intern(current_source[
        hir.hir_store_node_starts[member_node]..hir.hir_store_node_ends[member_node]
    ]);
    if (type_is_enum(expected_type)) {
        return symbol_store.symbol_store_find_symbol_by_name_id(name_id, symbol_store.SymbolKind.enum_member, owner_symbol);
    }
    if (type_is_union(expected_type)) {
        return symbol_store.symbol_store_find_symbol_by_name_id(name_id, symbol_store.SymbolKind.union_member, owner_symbol);
    }
    return 0;
}

Int wrap_optional_value(Int expr_node, Int expected_type) {
    Int wrapper = hir.hir_store_new_node(
        hir.HirNode.optional_wrap_expr,
        hir.hir_store_node_starts[expr_node],
        hir.hir_store_node_ends[expr_node]
    );
    hir.hir_store_set_type_id(wrapper, expected_type);
    hir.hir_store_append_child(wrapper, expr_node);
    return wrapper;
}

Int make_optional_value_expr(Int base_symbol, Int base_type, Int payload_type, Int start, Int end_pos) {
    if (optional_value_field_symbol == 0) {
        UInt8[] value_name = "value";
        optional_value_field_symbol = symbol_store.symbol_store_new_symbol(
            value_name,
            symbol_store.SymbolKind.field,
            0,
            value_name.length,
            type_store.type_store_builtin_unknown,
            0,
            0
        );
    }
    Int unwrap = hir.hir_store_new_node(hir.HirNode.member_expr, start, end_pos);
    Int base_ident = make_synthetic_ident_node(base_symbol, base_type, start, end_pos);
    Int member = hir.hir_store_new_node(hir.HirNode.ident, 0, 0);
    hir.hir_store_append_child(unwrap, base_ident);
    hir.hir_store_append_child(unwrap, member);
    hir.hir_store_set_symbol_id(unwrap, optional_value_field_symbol);
    hir.hir_store_set_type_id(unwrap, payload_type);
    return unwrap;
}

Int ensure_optional_value_field_symbol(Int payload_type) {
    if (optional_value_field_symbol == 0) {
        UInt8[] value_name = "value";
        optional_value_field_symbol = symbol_store.symbol_store_new_symbol(
            value_name,
            symbol_store.SymbolKind.field,
            0,
            value_name.length,
            type_store.type_store_builtin_unknown,
            0,
            0
        );
    }
    if (payload_type != type_store.type_store_builtin_unknown) {
        symbol_store.symbol_store_set_type_id(optional_value_field_symbol, payload_type);
    }
    return optional_value_field_symbol;
}

Bool parse_is_option_ident(Int parse_node) {
    if (parse_node == 0) {
        return 0;
    }
    if (parser.parser_store_node_kinds[parse_node] != parser.ParserNode.ident) {
        return 0;
    }
    return parse_node_is(current_source, parse_node, "Option");
}

Bool parse_is_option_member_expr(Int parse_node) {
    if (parse_node == 0) {
        return 0;
    }
    if (parser.parser_store_node_kinds[parse_node] != parser.ParserNode.member_expr) {
        return 0;
    }
    return parse_is_option_ident(parser.parser_store_node_first_child[parse_node]);
}

Int optional_pattern_kind_parse(Int parse_node) {
    if (parse_node == 0) {
        return 0;
    }
    if (!parse_is_option_member_expr(parse_node)) {
        return 0;
    }
    Int base = parser.parser_store_node_first_child[parse_node];
    Int member = parser.parser_store_node_next_sibling[base];
    if (member == 0) {
        return 0;
    }
    if (member_name_is(current_source, member, "some")) {
        return 1;
    }
    if (member_name_is(current_source, member, "none")) {
        return 2;
    }
    return 0;
}

Int make_optional_pattern_label_hir(Int is_some, Int start, Int end_pos) {
    Int label = hir.hir_store_new_node(hir.HirNode.bool_lit, start, end_pos);
    hir.hir_store_set_aux(label, is_some);
    hir.hir_store_set_type_id(label, type_store.type_store_builtin_bool);
    return label;
}

() prepend_block_stmt(Int block_node, Int stmt_node) {
    Int first = hir.hir_store_node_first_child[block_node];
    hir.hir_store_set_next_sibling(stmt_node, first);
    hir.hir_store_set_first_child(block_node, stmt_node);
}

Bool hir_node_uses_symbol(Int node, Int symbol_id) {
    if (node == 0) {
        return 0;
    }
    if (hir.hir_store_node_symbol_ids[node] == symbol_id) {
        return 1;
    }
    Int child = hir.hir_store_node_first_child[node];
    while (child != 0) {
        if (hir_node_uses_symbol(child, symbol_id)) {
            return 1;
        }
        child = hir.hir_store_node_next_sibling[child];
    }
    return 0;
}

Int build_optional_narrow_decl(Int optional_ident, Int shadow_symbol) {
    Int base_symbol = hir.hir_store_node_symbol_ids[optional_ident];
    if (base_symbol == 0) {
        return 0;
    }
    Int narrowed_type = symbol_store.symbol_store_type_ids[shadow_symbol];
    Int start = hir.hir_store_node_starts[optional_ident];
    Int end_pos = hir.hir_store_node_ends[optional_ident];
    Int decl = hir.hir_store_new_node(hir.HirNode.local_decl, start, end_pos);
    Int type_node = make_synthetic_type_node(narrowed_type, start, start);
    Int name_node = make_synthetic_ident_node(shadow_symbol, narrowed_type, 0, 0);
    Int init_node = make_optional_value_expr(
        base_symbol,
        hir.hir_store_node_type_ids[optional_ident],
        narrowed_type,
        start,
        end_pos
    );
    hir.hir_store_append_child(decl, type_node);
    hir.hir_store_append_child(decl, name_node);
    hir.hir_store_append_child(decl, init_node);
    hir.hir_store_set_symbol_id(decl, shadow_symbol);
    hir.hir_store_set_type_id(decl, narrowed_type);
    return decl;
}

Int optional_compare_narrow_ident(Int condition_node) {
    if (condition_node == 0) {
        return 0;
    }
    if (hir.hir_store_node_kinds[condition_node] != hir.HirNode.binary_expr) {
        return 0;
    }
    Int op = hir.hir_store_node_aux[condition_node];
    if (op != hir.HirBinaryOp.eq) {
        if (op != hir.HirBinaryOp.ne) {
            return 0;
        }
    }
    Int left = hir.hir_store_node_first_child[condition_node];
    if (left == 0) {
        return 0;
    }
    Int right = hir.hir_store_node_next_sibling[left];
    if (right == 0) {
        return 0;
    }
    Int optional_ident = 0;
    if (is_null_like_expr(left) != 0) {
        if (hir.hir_store_node_kinds[right] == hir.HirNode.ident) {
            if (type_is_optional(hir.hir_store_node_type_ids[right])) {
                optional_ident = right;
            }
        }
    } else if (is_null_like_expr(right) != 0) {
        if (hir.hir_store_node_kinds[left] == hir.HirNode.ident) {
            if (type_is_optional(hir.hir_store_node_type_ids[left])) {
                optional_ident = left;
            }
        }
    }
    return optional_ident;
}

Int register_optional_narrow_symbol(Int condition_node, Int branch_parse) {
    Int optional_ident = optional_compare_narrow_ident(condition_node);
    if (optional_ident == 0) {
        return 0;
    }
    Int narrowed_type = type_narrow_optional_binding(hir.hir_store_node_type_ids[optional_ident]);
    if (!is_known_type(narrowed_type)) {
        return 0;
    }
    Int base_symbol = hir.hir_store_node_symbol_ids[optional_ident];
    if (base_symbol == 0) {
        return 0;
    }
    UInt8[] name = current_source[symbol_store.symbol_store_starts[base_symbol]..symbol_store.symbol_store_ends[base_symbol]];
    return new_synthetic_local_symbol(name, narrowed_type, 0 - branch_parse);
}

() prepend_if_optional_narrow_decl(Int condition_node, Int block_node, Int shadow_symbol) {
    if (shadow_symbol == 0) {
        return;
    }
    if (hir_node_uses_symbol(block_node, shadow_symbol) == 0) {
        return;
    }
    Int optional_ident = optional_compare_narrow_ident(condition_node);
    if (optional_ident == 0) {
        return;
    }
    Int decl = build_optional_narrow_decl(optional_ident, shadow_symbol);
    if (decl != 0) {
        prepend_block_stmt(block_node, decl);
        symbol_store.symbol_store_set_name_id(
            shadow_symbol,
            intern_pool.intern_pool_intern(next_optional_narrow_name())
        );
    }
}

() check_union_pattern_against_type(Int pattern_node, Int expected_union_type) {
    Int label_node = union_pattern_label_hir(pattern_node);
    Int bind_count = union_pattern_binding_count_hir(pattern_node);
    if (type_is_optional(expected_union_type)) {
        Int payload_type = type_optional_payload(expected_union_type);
        hir.hir_store_set_type_id(pattern_node, expected_union_type);
        hir.hir_store_set_symbol_id(pattern_node, ensure_optional_value_field_symbol(payload_type));
        hir.hir_store_set_type_id(label_node, type_store.type_store_builtin_bool);
        Int has_payload = hir.hir_store_node_aux[label_node];
        if (bind_count != 0) {
            if (has_payload == 0) {
                Int bind_node = union_pattern_binding_hir_item(pattern_node, 0);
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[bind_node], hir.hir_store_node_ends[bind_node], "option none has no payload");
                return;
            }
            if (payload_type == type_store.type_store_builtin_void) {
                Int bind_node = union_pattern_binding_hir_item(pattern_node, 0);
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[bind_node], hir.hir_store_node_ends[bind_node], "option some has no payload");
                return;
            }
            if (bind_count == 1) {
                Int bind_node = union_pattern_binding_hir_item(pattern_node, 0);
                hir.hir_store_set_type_id(bind_node, payload_type);
            } else {
                if (!type_is_tuple(payload_type)) {
                    Int bind_node = union_pattern_binding_hir_item(pattern_node, 0);
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[bind_node], hir.hir_store_node_ends[bind_node], "option tuple binding requires tuple payload");
                    return;
                }
                if (type_store.type_store_tuple_count(payload_type) != bind_count) {
                    Int bind_node = union_pattern_binding_hir_item(pattern_node, 0);
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[bind_node], hir.hir_store_node_ends[bind_node], "option tuple binding arity mismatch");
                    return;
                }
                Int i = 0;
                while (i < bind_count) {
                    Int bind_node = union_pattern_binding_hir_item(pattern_node, i);
                    hir.hir_store_set_type_id(bind_node, type_store.type_store_tuple_item_type(payload_type, i));
                    i = i + 1;
                }
            }
        }
        return;
    }
    if (!type_is_union(expected_union_type)) {
        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[pattern_node], hir.hir_store_node_ends[pattern_node], "union pattern requires union operand");
        return;
    }
    Int coerced_label = coerce_expr_to_type(label_node, expected_union_type);
    if (coerced_label != label_node) {
        hir.hir_store_set_first_child(pattern_node, coerced_label);
        label_node = coerced_label;
    }
    Int owner_symbol = find_type_owner_symbol(expected_union_type);
    Int label_symbol = hir.hir_store_node_symbol_ids[label_node];
    if (label_symbol == 0) {
        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[label_node], hir.hir_store_node_ends[label_node], "switch case type mismatch");
        return;
    }
    if (symbol_store.symbol_store_kinds[label_symbol] != symbol_store.SymbolKind.union_member) {
        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[label_node], hir.hir_store_node_ends[label_node], "switch case type mismatch");
        return;
    }
    if (symbol_store.symbol_store_parent_ids[label_symbol] != owner_symbol) {
        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[label_node], hir.hir_store_node_ends[label_node], "switch case type mismatch");
        return;
    }
    hir.hir_store_set_symbol_id(pattern_node, label_symbol);
    hir.hir_store_set_type_id(pattern_node, expected_union_type);
    if (bind_count != 0) {
        Int payload_type = symbol_store.symbol_store_type_ids[label_symbol];
        if (payload_type == type_store.type_store_builtin_void) {
            Int bind_node = union_pattern_binding_hir_item(pattern_node, 0);
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[bind_node], hir.hir_store_node_ends[bind_node], "union case has no payload");
        } else if (bind_count == 1) {
            Int bind_node = union_pattern_binding_hir_item(pattern_node, 0);
            hir.hir_store_set_type_id(bind_node, payload_type);
        } else {
            if (!type_is_tuple(payload_type)) {
                Int bind_node = union_pattern_binding_hir_item(pattern_node, 0);
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[bind_node], hir.hir_store_node_ends[bind_node], "union tuple binding requires tuple payload");
                return;
            }
            if (type_store.type_store_tuple_count(payload_type) != bind_count) {
                Int bind_node = union_pattern_binding_hir_item(pattern_node, 0);
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[bind_node], hir.hir_store_node_ends[bind_node], "union tuple binding arity mismatch");
                return;
            }
            Int i = 0;
            while (i < bind_count) {
                Int bind_node = union_pattern_binding_hir_item(pattern_node, i);
                hir.hir_store_set_type_id(bind_node, type_store.type_store_tuple_item_type(payload_type, i));
                i = i + 1;
            }
        }
    }
}

Int coerce_expr_to_type(Int expr_node, Int expected_type) {
    expected_type = type_strip_mutable(expected_type);
    Int actual_type = type_strip_mutable(hir.hir_store_node_type_ids[expr_node]);
    if (hir.hir_store_node_kinds[expr_node] == hir.HirNode.ternary_expr) {
        if (type_supports_ternary_result(expected_type)) {
            Int condition = hir.hir_store_node_first_child[expr_node];
            Int then_expr = hir.hir_store_node_next_sibling[condition];
            Int else_expr = hir.hir_store_node_next_sibling[then_expr];
            Int coerced_then = coerce_expr_to_type(then_expr, expected_type);
            if (coerced_then != then_expr) {
                hir.hir_store_set_next_sibling(condition, coerced_then);
                hir.hir_store_set_next_sibling(coerced_then, else_expr);
                then_expr = coerced_then;
            }
            Int coerced_else = coerce_expr_to_type(else_expr, expected_type);
            if (coerced_else != else_expr) {
                hir.hir_store_set_next_sibling(then_expr, coerced_else);
                else_expr = coerced_else;
            }
            expect_type(then_expr, expected_type, "ternary branch type mismatch");
            expect_type(else_expr, expected_type, "ternary branch type mismatch");
            hir.hir_store_set_type_id(expr_node, expected_type);
            return expr_node;
        }
    }
    if (hir.hir_store_node_kinds[expr_node] == hir.HirNode.null_lit) {
        if (type_is_optional(expected_type)) {
            hir.hir_store_set_type_id(expr_node, expected_type);
            return expr_node;
        }
        if (is_known_type(expected_type)) {
            hir.hir_store_set_type_id(expr_node, type_store.type_store_builtin_void);
        }
        return expr_node;
    }
    if (type_is_optional(expected_type)) {
        if (actual_type == expected_type) {
            hir.hir_store_set_type_id(expr_node, expected_type);
            return expr_node;
        }
        if (actual_type == type_optional_payload(expected_type)) {
            return wrap_optional_value(expr_node, expected_type);
        }
    }
    if (hir.hir_store_node_kinds[expr_node] == hir.HirNode.shorthand_member_expr) {
        Int member = hir.hir_store_node_first_child[expr_node];
        Int member_symbol = resolve_shorthand_member_symbol_for_type(member, expected_type);
        if (member_symbol != 0) {
            hir.hir_store_set_symbol_id(expr_node, member_symbol);
            hir.hir_store_set_type_id(expr_node, expected_type);
            hir.hir_store_set_symbol_id(member, member_symbol);
            hir.hir_store_set_type_id(member, symbol_store.symbol_store_type_ids[member_symbol]);
            return expr_node;
        }
        return expr_node;
    }
    if (hir.hir_store_node_kinds[expr_node] == hir.HirNode.call_expr) {
        Int callee = hir.hir_store_node_first_child[expr_node];
        if (callee != 0) {
            if (hir.hir_store_node_kinds[callee] == hir.HirNode.shorthand_member_expr) {
                if (type_is_union(expected_type)) {
                    Int member = hir.hir_store_node_first_child[callee];
                    Int member_symbol = resolve_shorthand_member_symbol_for_type(member, expected_type);
                    if (member_symbol != 0) {
                        Int payload_type = symbol_store.symbol_store_type_ids[member_symbol];
                        Int arg = hir.hir_store_node_next_sibling[callee];
                        Int arg_count = 0;
                        while (arg != 0) {
                            arg_count = arg_count + 1;
                            arg = hir.hir_store_node_next_sibling[arg];
                        }
                        hir.hir_store_set_symbol_id(callee, member_symbol);
                        hir.hir_store_set_type_id(callee, payload_type);
                        hir.hir_store_set_symbol_id(member, member_symbol);
                        hir.hir_store_set_type_id(member, payload_type);
                        if (payload_type == type_store.type_store_builtin_void) {
                            if (arg_count != 0) {
                                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[expr_node], hir.hir_store_node_ends[expr_node], "argument count mismatch");
                            }
                        } else {
                            if (arg_count != 1) {
                                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[expr_node], hir.hir_store_node_ends[expr_node], "argument count mismatch");
                            } else {
                                Int value_arg = hir.hir_store_node_next_sibling[callee];
                                Int coerced_arg = coerce_expr_to_type(value_arg, payload_type);
                                if (coerced_arg != value_arg) {
                                    hir.hir_store_set_next_sibling(callee, coerced_arg);
                                    value_arg = coerced_arg;
                                }
                                expect_type(value_arg, payload_type, "argument type mismatch");
                            }
                        }
                        hir.hir_store_set_type_id(expr_node, expected_type);
                        return expr_node;
                    }
                }
            }
        }
    }
    if (hir.hir_store_node_kinds[expr_node] == hir.HirNode.tuple_lit) {
        if (expected_type == type_store.type_store_builtin_void) {
            if (hir.hir_store_node_first_child[expr_node] == 0) {
                hir.hir_store_set_type_id(expr_node, expected_type);
                return expr_node;
            }
        }
        if (type_is_tuple(expected_type)) {
            Int expected_count = type_store.type_store_tuple_count(expected_type);
            Int count = 0;
            Int child = hir.hir_store_node_first_child[expr_node];
            while (child != 0) {
                count = count + 1;
                child = hir.hir_store_node_next_sibling[child];
            }
            if (count != expected_count) {
                return expr_node;
            }
            child = hir.hir_store_node_first_child[expr_node];
            Int index = 0;
            while (child != 0) {
                Int expected_item_type = type_store.type_store_tuple_item_type(expected_type, index);
                Int coerced_child = coerce_expr_to_type(child, expected_item_type);
                if (coerced_child != child) {
                    if (index == 0) {
                        hir.hir_store_set_first_child(expr_node, coerced_child);
                    } else {
                        Int prev = hir.hir_store_node_first_child[expr_node];
                        Int step = 1;
                        while (step < index) {
                            prev = hir.hir_store_node_next_sibling[prev];
                            step = step + 1;
                        }
                        hir.hir_store_set_next_sibling(prev, coerced_child);
                    }
                    hir.hir_store_set_next_sibling(coerced_child, hir.hir_store_node_next_sibling[child]);
                    child = coerced_child;
                }
                expect_type(child, expected_item_type, "tuple item type mismatch");
                child = hir.hir_store_node_next_sibling[child];
                index = index + 1;
            }
            hir.hir_store_set_type_id(expr_node, expected_type);
            return expr_node;
        }
    }
    if (expected_type == type_store.type_store_builtin_int) {
        if (type_is_enum(actual_type)) {
            hir.hir_store_set_type_id(expr_node, type_store.type_store_builtin_int);
            return expr_node;
        }
        if (actual_type == type_store.type_store_builtin_uint8) {
            hir.hir_store_set_type_id(expr_node, type_store.type_store_builtin_int);
            return expr_node;
        }
    }
    if (hir.hir_store_node_kinds[expr_node] == hir.HirNode.int_lit) {
        if (expected_type == type_store.type_store_builtin_bool) {
            if (hir.hir_store_node_starts[expr_node] + 1 == hir.hir_store_node_ends[expr_node]) {
                UInt8 ch = current_source[hir.hir_store_node_starts[expr_node]];
                if (ch == 48) {
                    hir.hir_store_set_type_id(expr_node, type_store.type_store_builtin_bool);
                    hir.hir_store_set_aux(expr_node, 0);
                    return expr_node;
                }
                if (ch == 49) {
                    hir.hir_store_set_type_id(expr_node, type_store.type_store_builtin_bool);
                    hir.hir_store_set_aux(expr_node, 1);
                    return expr_node;
                }
            }
        }
        if (expected_type == type_store.type_store_builtin_uint8) {
            hir.hir_store_set_type_id(expr_node, type_store.type_store_builtin_uint8);
            return expr_node;
        }
        if (type_is_enum(expected_type)) {
            hir.hir_store_set_type_id(expr_node, expected_type);
            return expr_node;
        }
    }
    if (is_uint8_array_to_slice(expected_type, actual_type)) {
        return wrap_array_to_slice(expr_node);
    }
    if (is_array_to_same_slice(expected_type, actual_type)) {
        return wrap_array_to_slice(expr_node);
    }
    return expr_node;
}

Int for_loop_symbol_type_from_iterable(Int iterable_node) {
    Int iterable_type = hir.hir_store_node_type_ids[iterable_node];
    if (type_is_array(iterable_type)) {
        return type_store.type_store_elem_type_ids[iterable_type];
    }
    if (type_is_slice(iterable_type)) {
        return type_store.type_store_elem_type_ids[iterable_type];
    }
    return type_store.type_store_builtin_unknown;
}

() check_array_items_against_type(Int node, Int first_item, Int declared_type) {
    declared_type = type_strip_mutable(declared_type);
    if (!type_is_array(declared_type)) {
        diagnostic.diagnostic_error(
            current_path,
            hir.hir_store_node_starts[node],
            hir.hir_store_node_ends[node],
            "array literal requires array type"
        );
        return;
    }
    Int elem_type = type_store.type_store_elem_type_ids[declared_type];
    Int expected_count = type_store.type_store_array_lengths[declared_type];
    Int count = 0;
    Int child = first_item;
    Int prev = 0;
    if (hir.hir_store_node_first_child[node] != first_item) {
        prev = hir.hir_store_node_first_child[node];
        while (prev != 0) {
            if (hir.hir_store_node_next_sibling[prev] == first_item) {
                break;
            }
            prev = hir.hir_store_node_next_sibling[prev];
        }
    }
    while (child != 0) {
        count = count + 1;
        if (hir.hir_store_node_kinds[child] == hir.HirNode.array_lit) {
            check_array_literal_against_type(child, elem_type);
        } else {
            Int coerced_child = coerce_expr_to_type(child, elem_type);
            if (coerced_child != child) {
                if (prev == 0) {
                    hir.hir_store_set_first_child(node, coerced_child);
                } else {
                    hir.hir_store_set_next_sibling(prev, coerced_child);
                }
                hir.hir_store_set_next_sibling(coerced_child, hir.hir_store_node_next_sibling[child]);
                child = coerced_child;
            }
            expect_type(child, elem_type, "array element type mismatch");
        }
        prev = child;
        child = hir.hir_store_node_next_sibling[child];
    }
    if (type_is_inferred_array(declared_type)) {
        declared_type = infer_concrete_array_type_from_value(declared_type, node);
        if (!is_known_type(declared_type)) {
            diagnostic.diagnostic_error(
                current_path,
                hir.hir_store_node_starts[node],
                hir.hir_store_node_ends[node],
                "cannot infer array length"
            );
            return;
        }
        expected_count = count;
    }
    if (count != expected_count) {
        diagnostic.diagnostic_error(
            current_path,
            hir.hir_store_node_starts[node],
            hir.hir_store_node_ends[node],
            "array literal length mismatch"
        );
    }
    hir.hir_store_set_type_id(node, declared_type);
}

() check_array_literal_against_type(Int node, Int declared_type) {
    check_array_items_against_type(node, hir.hir_store_node_first_child[node], declared_type);
}

() check_array_init_expr(Int node) {
    Int type_expr = hir.hir_store_node_first_child[node];
    Int declared_type = hir.hir_store_node_type_ids[type_expr];
    if (!type_is_array(declared_type)) {
        diagnostic.diagnostic_error(
            current_path,
            hir.hir_store_node_starts[node],
            hir.hir_store_node_ends[node],
            "typed array constructor requires array type"
        );
        return;
    }
    Int first_item = hir.hir_store_node_next_sibling[type_expr];
    check_array_items_against_type(node, first_item, declared_type);
    if (is_known_type(hir.hir_store_node_type_ids[node])) {
        hir.hir_store_set_type_id(type_expr, hir.hir_store_node_type_ids[node]);
    }
}

UInt8[] import_string_value(UInt8[] source, Int string_node) {
    return source[parser.parser_store_node_starts[string_node] + 1..parser.parser_store_node_ends[string_node] - 1];
}

Int parse_const_int_expr(UInt8[] source, Int parse_node) {
    Int kind = parser.parser_store_node_kinds[parse_node];
    if (kind == parser.ParserNode.int_lit) {
        Int value = 0;
        Int i = parser.parser_store_node_starts[parse_node];
        while (i < parser.parser_store_node_ends[parse_node]) {
            value = value * 10 + (source[i] - 48);
            i = i + 1;
        }
        return value;
    }
    if (kind == parser.ParserNode.unary_expr) {
        Int child = parser.parser_store_node_first_child[parse_node];
        if (parser.parser_store_node_aux[parse_node] == parser.UnaryOp.neg) {
            return 0 - parse_const_int_expr(source, child);
        }
    }
    if (kind == parser.ParserNode.binary_expr) {
        Int left = parser.parser_store_node_first_child[parse_node];
        Int right = parser.parser_store_node_next_sibling[left];
        Int left_value = parse_const_int_expr(source, left);
        Int right_value = parse_const_int_expr(source, right);
        if (parser.parser_store_node_aux[parse_node] == parser.BinaryOp.add) {
            return left_value + right_value;
        }
        if (parser.parser_store_node_aux[parse_node] == parser.BinaryOp.sub) {
            return left_value - right_value;
        }
        if (parser.parser_store_node_aux[parse_node] == parser.BinaryOp.mul) {
            return left_value * right_value;
        }
        if (parser.parser_store_node_aux[parse_node] == parser.BinaryOp.div) {
            return left_value / right_value;
        }
    }
    return 0;
}

Int import_decl_alias_node(Int import_node) {
    Int first = parser.parser_store_node_first_child[import_node];
    if (first == 0) {
        return 0;
    }
    Int second = parser.parser_store_node_next_sibling[first];
    if (second == 0) {
        return 0;
    }
    return first;
}

Int import_decl_path_node(Int import_node) {
    Int first = parser.parser_store_node_first_child[import_node];
    if (first == 0) {
        return 0;
    }
    Int second = parser.parser_store_node_next_sibling[first];
    if (second == 0) {
        return first;
    }
    return second;
}

Bool has_visited_import(Int module_id) {
    Int i = 0;
    while (i < ints.buffer_int_length(import_visit_set)) {
        if (ints.buffer_int_get(import_visit_set, i) == module_id) {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

Bool visible_import_contains_module(Int module_id) {
    if (visible_import_module_ids == 0) {
        return 0;
    }
    Int i = 0;
    while (i < ints.buffer_int_length(visible_import_module_ids)) {
        if (ints.buffer_int_get(visible_import_module_ids, i) == module_id) {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

Bool is_top_level_namespace_kind(Int kind) {
    if (kind == symbol_store.SymbolKind.module_alias) {
        return 1;
    }
    if (kind == symbol_store.SymbolKind.type_name) {
        return 1;
    }
    if (kind == symbol_store.SymbolKind.enum_name) {
        return 1;
    }
    if (kind == symbol_store.SymbolKind.func) {
        return 1;
    }
    return kind == symbol_store.SymbolKind.global;
}

Int find_top_level_namespace_symbol_in_module(Int name_id, Int module_id) {
    Int resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.module_alias, 0, module_id);
    if (resolved != 0) {
        return resolved;
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.type_name, 0, module_id);
    if (resolved != 0) {
        return resolved;
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.enum_name, 0, module_id);
    if (resolved != 0) {
        return resolved;
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.func, 0, module_id);
    if (resolved != 0) {
        return resolved;
    }
    return symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.global, 0, module_id);
}

Int find_exported_top_level_namespace_symbol(Int module_id, Int name_id) {
    Int resolved = module_loader.module_loader_find_export(module_id, name_id, symbol_store.SymbolKind.type_name);
    if (resolved != 0) {
        return resolved;
    }
    resolved = module_loader.module_loader_find_export(module_id, name_id, symbol_store.SymbolKind.enum_name);
    if (resolved != 0) {
        return resolved;
    }
    resolved = module_loader.module_loader_find_export(module_id, name_id, symbol_store.SymbolKind.func);
    if (resolved != 0) {
        return resolved;
    }
    return module_loader.module_loader_find_export(module_id, name_id, symbol_store.SymbolKind.global);
}

Int find_conflicting_top_level_symbol(Int name_id, Int kind) {
    Int symbol_id = 0;
    if (is_top_level_namespace_kind(kind)) {
        symbol_id = find_top_level_namespace_symbol_in_module(name_id, register_module_id);
    } else {
        symbol_id = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, kind, 0, register_module_id);
    }
    if (symbol_id != 0) {
        return symbol_id;
    }
    if (register_module_id == current_module_id) {
        if (visible_import_module_ids != 0) {
            Int i = 0;
            while (i < ints.buffer_int_length(visible_import_module_ids)) {
                if (is_top_level_namespace_kind(kind)) {
                    symbol_id = find_exported_top_level_namespace_symbol(
                        ints.buffer_int_get(visible_import_module_ids, i),
                        name_id
                    );
                } else {
                    symbol_id = module_loader.module_loader_find_export(
                        ints.buffer_int_get(visible_import_module_ids, i),
                        name_id,
                        kind
                    );
                }
                if (symbol_id != 0) {
                    return symbol_id;
                }
                i = i + 1;
            }
        }
    }
    return 0;
}

Int register_unique_symbol(UInt8[] source, Int kind, Int start, Int end_pos, Int type_id, Int parent_id, UInt8[] message) {
    Int existing = 0;
    if (parent_id == 0) {
        Int name_id = intern_pool.intern_pool_intern(source[start..end_pos]);
        existing = find_conflicting_top_level_symbol(name_id, kind);
    } else {
        existing = symbol_store.symbol_store_find_symbol(source, start, end_pos, kind, parent_id);
    }
    if (existing != 0) {
        diagnostic.diagnostic_error(current_path, start, end_pos, message);
        return existing;
    }
    return symbol_store.symbol_store_new_symbol(source, kind, start, end_pos, type_id, parent_id, register_module_id);
}

Int resolve_top_level_symbol_in_module(UInt8[] source, Int parse_node, Int module_id) {
    Int start = parser.parser_store_node_starts[parse_node];
    Int end_pos = parser.parser_store_node_ends[parse_node];
    Int name_id = intern_pool.intern_pool_intern(source[start..end_pos]);
    Int resolved = module_loader.module_loader_find_export(module_id, name_id, symbol_store.SymbolKind.func);
    if (resolved != 0) {
        return resolved;
    }
    resolved = module_loader.module_loader_find_export(module_id, name_id, symbol_store.SymbolKind.type_name);
    if (resolved != 0) {
        return resolved;
    }
    resolved = module_loader.module_loader_find_export(module_id, name_id, symbol_store.SymbolKind.enum_name);
    if (resolved != 0) {
        return resolved;
    }
    resolved = module_loader.module_loader_find_export(module_id, name_id, symbol_store.SymbolKind.global);
    if (resolved != 0) {
        return resolved;
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.func, 0, module_id);
    if (resolved != 0) {
        if (symbol_is_public(resolved)) {
            return symbol_store.symbol_store_resolve_target(resolved);
        }
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.type_name, 0, module_id);
    if (resolved != 0) {
        if (symbol_is_public(resolved)) {
            return symbol_store.symbol_store_resolve_target(resolved);
        }
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.enum_name, 0, module_id);
    if (resolved != 0) {
        if (symbol_is_public(resolved)) {
            return symbol_store.symbol_store_resolve_target(resolved);
        }
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.global, 0, module_id);
    if (resolved != 0) {
        if (symbol_is_public(resolved)) {
            return symbol_store.symbol_store_resolve_target(resolved);
        }
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id(name_id, symbol_store.SymbolKind.func, 0);
    if (resolved != 0) {
        return symbol_store.symbol_store_resolve_target(resolved);
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id(name_id, symbol_store.SymbolKind.type_name, 0);
    if (resolved != 0) {
        return symbol_store.symbol_store_resolve_target(resolved);
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id(name_id, symbol_store.SymbolKind.enum_name, 0);
    if (resolved != 0) {
        return symbol_store.symbol_store_resolve_target(resolved);
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id(name_id, symbol_store.SymbolKind.global, 0);
    if (resolved != 0) {
        return symbol_store.symbol_store_resolve_target(resolved);
    }
    return 0;
}

Int resolve_registered_top_level_symbol(UInt8[] source, Int parse_node, Int kind) {
    Int start = parser.parser_store_node_starts[parse_node];
    Int end_pos = parser.parser_store_node_ends[parse_node];
    return symbol_store.symbol_store_find_symbol_by_name_id_in_module(
        intern_pool.intern_pool_intern(source[start..end_pos]),
        kind,
        0,
        register_module_id
    );
}

Int resolve_alias_target_symbol(Int parse_node) {
    Int kind = parser.parser_store_node_kinds[parse_node];
    if (kind == parser.ParserNode.ident) {
        Int resolved = resolve_visible_top_level_symbol(
            intern_pool.intern_pool_intern(current_source[
                parser.parser_store_node_starts[parse_node]..parser.parser_store_node_ends[parse_node]
            ]),
            symbol_store.SymbolKind.type_name
        );
        if (resolved != 0) {
            return resolved;
        }
        resolved = resolve_visible_top_level_symbol(
            intern_pool.intern_pool_intern(current_source[
                parser.parser_store_node_starts[parse_node]..parser.parser_store_node_ends[parse_node]
            ]),
            symbol_store.SymbolKind.enum_name
        );
        if (resolved != 0) {
            return resolved;
        }
        return resolve_visible_top_level_symbol(
            intern_pool.intern_pool_intern(current_source[
                parser.parser_store_node_starts[parse_node]..parser.parser_store_node_ends[parse_node]
            ]),
            symbol_store.SymbolKind.func
        );
    }
    if (kind == parser.ParserNode.member_expr) {
        Int base = parser.parser_store_node_first_child[parse_node];
        Int member = parser.parser_store_node_next_sibling[base];
        Int base_symbol = resolve_symbol(current_source, base, symbol_store.SymbolKind.module_alias, 0);
        if (base_symbol == 0) {
            return 0;
        }
        return resolve_top_level_symbol_in_module(
            current_source,
            member,
            symbol_store.symbol_store_type_ids[base_symbol]
        );
    }
    return 0;
}

Int find_any_alias_target_symbol_in_module(Int parse_node, Int module_id) {
    Int name_id = intern_pool.intern_pool_intern(current_source[
        parser.parser_store_node_starts[parse_node]..parser.parser_store_node_ends[parse_node]
    ]);
    Int resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.func, 0, module_id);
    if (resolved != 0) {
        return resolved;
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.type_name, 0, module_id);
    if (resolved != 0) {
        return resolved;
    }
    resolved = symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.enum_name, 0, module_id);
    if (resolved != 0) {
        return resolved;
    }
    return symbol_store.symbol_store_find_symbol_by_name_id_in_module(name_id, symbol_store.SymbolKind.global, 0, module_id);
}

() maybe_mark_public(Int parse_node, Int symbol_id) {
    if (symbol_id == 0) {
        return;
    }
    if (decl_is_public(decl_node_flags(parse_node))) {
        symbol_store.symbol_store_set_flag(symbol_id, symbol_store.SymbolFlag.public_flag);
        module_loader.module_loader_register_export(
            register_module_id,
            symbol_store.symbol_store_name_ids[symbol_id],
            symbol_store.symbol_store_kinds[symbol_id],
            symbol_id
        );
    }
}

() register_top_level_aliases(UInt8[] source, Int parse_root) {
    Int child = parser.parser_store_node_first_child[parse_root];
    while (child != 0) {
        if (parser.parser_store_node_kinds[child] == parser.ParserNode.alias_decl) {
            Int alias_name = parser.parser_store_node_first_child[child];
            Int target_node = parser.parser_store_node_next_sibling[alias_name];
            Int target_symbol = resolve_alias_target_symbol(target_node);
            if (target_symbol == 0) {
                if (decl_is_public(decl_node_flags(child))) {
                    if (parser.parser_store_node_kinds[target_node] == parser.ParserNode.member_expr) {
                        Int base = parser.parser_store_node_first_child[target_node];
                        Int member = parser.parser_store_node_next_sibling[base];
                        Int base_symbol = resolve_symbol(current_source, base, symbol_store.SymbolKind.module_alias, 0);
                        if (base_symbol != 0) {
                            Int private_target = find_any_alias_target_symbol_in_module(
                                member,
                                symbol_store.symbol_store_type_ids[base_symbol]
                            );
                            if (private_target != 0) {
                                diagnostic.diagnostic_error(
                                    current_path,
                                    parser.parser_store_node_starts[target_node],
                                    parser.parser_store_node_ends[target_node],
                                    "public alias target must be public"
                                );
                                child = parser.parser_store_node_next_sibling[child];
                                continue;
                            }
                        }
                    }
                }
                diagnostic.diagnostic_error(
                    current_path,
                    parser.parser_store_node_starts[target_node],
                    parser.parser_store_node_ends[target_node],
                    "alias target must be function or type"
                );
            } else {
                Int target_kind = symbol_store.symbol_store_kinds[target_symbol];
                Int alias_symbol = register_unique_symbol(
                    source,
                    target_kind,
                    parser.parser_store_node_starts[alias_name],
                    parser.parser_store_node_ends[alias_name],
                    symbol_store.symbol_store_type_ids[target_symbol],
                    0,
                    "duplicate alias"
                );
                if (alias_symbol != target_symbol) {
                    symbol_store.symbol_store_set_target_id(alias_symbol, target_symbol);
                    if (decl_is_public(decl_node_flags(child))) {
                        if (!symbol_is_public(target_symbol)) {
                            diagnostic.diagnostic_error(
                                current_path,
                                parser.parser_store_node_starts[target_node],
                                parser.parser_store_node_ends[target_node],
                                "public alias target must be public"
                            );
                        } else {
                            symbol_store.symbol_store_set_flag(alias_symbol, symbol_store.SymbolFlag.public_flag);
                            module_loader.module_loader_register_export(
                                register_module_id,
                                symbol_store.symbol_store_name_ids[alias_symbol],
                                target_kind,
                                target_symbol
                            );
                        }
                    }
                }
            }
        }
        child = parser.parser_store_node_next_sibling[child];
    }
}

Int find_field_symbol_by_type_and_name(Int owner_type_id, Int parse_node) {
    Int owner_symbol = find_type_owner_symbol(owner_type_id);
    if (owner_symbol == 0) {
        return 0;
    }
    Int name_id = intern_pool.intern_pool_intern(current_source[
        hir.hir_store_node_starts[parse_node]..hir.hir_store_node_ends[parse_node]
    ]);
    return symbol_store.symbol_store_find_symbol_by_name_id(name_id, symbol_store.SymbolKind.field, owner_symbol);
}

Bool struct_init_seen_field(Int seen_fields, Int field_symbol) {
    Int i = 0;
    while (i < ints.buffer_int_length(seen_fields)) {
        if (ints.buffer_int_get(seen_fields, i) == field_symbol) {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

Int struct_type_field_count(Int owner_type_id) {
    Int owner_symbol = find_type_owner_symbol(owner_type_id);
    if (owner_symbol == 0) {
        return 0;
    }
    Int count = 0;
    Int symbol_id = 1;
    while (symbol_id < symbol_store.symbol_store_count) {
        if (symbol_store.symbol_store_kinds[symbol_id] == symbol_store.SymbolKind.field) {
            if (symbol_store.symbol_store_parent_ids[symbol_id] == owner_symbol) {
                count = count + 1;
            }
        }
        symbol_id = symbol_id + 1;
    }
    return count;
}

Int struct_type_missing_required_field(Int owner_type_id, Int seen_fields) {
    Int owner_symbol = find_type_owner_symbol(owner_type_id);
    if (owner_symbol == 0) {
        return 0;
    }
    Int symbol_id = 1;
    while (symbol_id < symbol_store.symbol_store_count) {
        if (symbol_store.symbol_store_kinds[symbol_id] == symbol_store.SymbolKind.field) {
            if (symbol_store.symbol_store_parent_ids[symbol_id] == owner_symbol) {
                if (!struct_init_seen_field(seen_fields, symbol_id)) {
                    if (!type_is_optional(symbol_store.symbol_store_type_ids[symbol_id])) {
                        if (!field_has_default_expr(symbol_id)) {
                        return symbol_id;
                        }
                    }
                }
            }
        }
        symbol_id = symbol_id + 1;
    }
    return 0;
}

() check_call_args(Int call_node, Int func_symbol) {
    if (is_builtin_print_symbol(func_symbol)) {
        Int arg = hir.hir_store_node_next_sibling[hir.hir_store_node_first_child[call_node]];
        if (arg == 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[call_node], hir.hir_store_node_ends[call_node], "argument count mismatch");
            return;
        }
        expect_type(arg, type_store.type_store_builtin_uint8_slice, "print format must be UInt8[]");
        return;
    }
    Int arg = hir.hir_store_node_next_sibling[hir.hir_store_node_first_child[call_node]];
    Int prev_arg = hir.hir_store_node_first_child[call_node];
    Int param_symbol = 1;
    Bool skip_self = symbol_requires_hidden_self_arg(func_symbol);
    while (param_symbol < symbol_store.symbol_store_count) {
        if (symbol_store.symbol_store_kinds[param_symbol] == symbol_store.SymbolKind.param) {
            if (symbol_store.symbol_store_parent_ids[param_symbol] == func_symbol) {
                if (skip_self != 0) {
                    if (symbol_store.symbol_store_name_ids[param_symbol] == intern_pool.intern_pool_intern("self")) {
                        skip_self = 0;
                        param_symbol = param_symbol + 1;
                        continue;
                    }
                }
                if (arg == 0) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[call_node], hir.hir_store_node_ends[call_node], "argument count mismatch");
                    return;
                }
                Int expected_type = symbol_store.symbol_store_type_ids[param_symbol];
                Int coerced_arg = coerce_expr_to_type(arg, expected_type);
                if (coerced_arg != arg) {
                    hir.hir_store_set_next_sibling(prev_arg, coerced_arg);
                    hir.hir_store_set_next_sibling(coerced_arg, hir.hir_store_node_next_sibling[arg]);
                    arg = coerced_arg;
                }
                if (hir.hir_store_node_kinds[arg] == hir.HirNode.array_lit) {
                    check_array_literal_against_type(arg, expected_type);
                } else if (is_known_type(hir.hir_store_node_type_ids[arg])) {
                    if (type_strip_mutable(hir.hir_store_node_type_ids[arg]) != type_strip_mutable(expected_type)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[arg], hir.hir_store_node_ends[arg], "argument type mismatch");
                        return;
                    }
                }
                prev_arg = arg;
                arg = hir.hir_store_node_next_sibling[arg];
            }
        }
        param_symbol = param_symbol + 1;
    }
    if (arg != 0) {
        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[call_node], hir.hir_store_node_ends[call_node], "argument count mismatch");
    }
}

() check_struct_init_fields(Int node) {
    Int type_expr = hir.hir_store_node_first_child[node];
    Int owner_type = hir.hir_store_node_type_ids[type_expr];
    if (owner_type == 0) {
        return;
    }
    Int seen_fields = ints.buffer_int_new(8);
    Int field_init = hir.hir_store_node_next_sibling[type_expr];
    Int provided_fields = 0;
    while (field_init != 0) {
        Int field_name = hir.hir_store_node_first_child[field_init];
        Int field_value = hir.hir_store_node_next_sibling[field_name];
        Int field_symbol = find_field_symbol_by_type_and_name(owner_type, field_name);
        if (field_symbol == 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[field_name], hir.hir_store_node_ends[field_name], "unknown field");
            return;
        }
        if (struct_init_seen_field(seen_fields, field_symbol)) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[field_name], hir.hir_store_node_ends[field_name], "duplicate field");
            return;
        }
        ints.buffer_int_push(seen_fields, field_symbol);
        provided_fields = provided_fields + 1;
        hir.hir_store_set_symbol_id(field_init, field_symbol);
        hir.hir_store_set_type_id(field_init, symbol_store.symbol_store_type_ids[field_symbol]);
        Int expected_type = symbol_store.symbol_store_type_ids[field_symbol];
        Int coerced_value = coerce_expr_to_type(field_value, expected_type);
        if (coerced_value != field_value) {
            hir.hir_store_set_next_sibling(field_name, coerced_value);
            field_value = coerced_value;
        }
        if (hir.hir_store_node_kinds[field_value] == hir.HirNode.array_lit) {
            check_array_literal_against_type(field_value, expected_type);
        } else if (is_string_compatible_array(expected_type, field_value) == 0) {
            if (is_known_type(hir.hir_store_node_type_ids[field_value])) {
                if (type_strip_mutable(hir.hir_store_node_type_ids[field_value]) != type_strip_mutable(expected_type)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[field_value], hir.hir_store_node_ends[field_value], "field initializer type mismatch");
                    return;
                }
            }
        }
        field_init = hir.hir_store_node_next_sibling[field_init];
    }
    if (provided_fields != struct_type_field_count(owner_type)) {
        if (struct_type_missing_required_field(owner_type, seen_fields) != 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "missing field");
        }
    }
}

Bool struct_init_field_is_mutable(Int field_symbol) {
    Int field_type = symbol_store.symbol_store_type_ids[field_symbol];
    if (field_type <= 0) {
        return 0;
    }
    if (field_type >= type_store.type_store_count) {
        return 0;
    }
    return type_store.type_store_kinds[field_type] == type_store.TypeKind.mutable;
}

Bool struct_init_field_is_initially_initialized(Int field_symbol) {
    if (field_has_default_expr(field_symbol)) {
        return 1;
    }
    return type_is_optional(symbol_store.symbol_store_type_ids[field_symbol]);
}

Int struct_init_state_clone(Int state_handle) {
    Int cloned = ints.buffer_int_new(8);
    Int i = 0;
    while (i < ints.buffer_int_length(state_handle)) {
        ints.buffer_int_push(cloned, ints.buffer_int_get(state_handle, i));
        i = i + 1;
    }
    return cloned;
}

Bool struct_init_state_has(Int state_handle, Int field_symbol) {
    Int i = 0;
    while (i < ints.buffer_int_length(state_handle)) {
        if (ints.buffer_int_get(state_handle, i) == field_symbol) {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

() struct_init_state_mark(Int state_handle, Int field_symbol) {
    if (!struct_init_state_has(state_handle, field_symbol)) {
        ints.buffer_int_push(state_handle, field_symbol);
    }
}

Int struct_init_entry_state(Int owner_symbol) {
    Int state = ints.buffer_int_new(8);
    Int symbol_id = 1;
    while (symbol_id < symbol_store.symbol_store_count) {
        if (symbol_store.symbol_store_kinds[symbol_id] == symbol_store.SymbolKind.field) {
            if (symbol_store.symbol_store_parent_ids[symbol_id] == owner_symbol) {
                if (struct_init_field_is_initially_initialized(symbol_id)) {
                    ints.buffer_int_push(state, symbol_id);
                }
            }
        }
        symbol_id = symbol_id + 1;
    }
    return state;
}

Int struct_init_state_intersection(Int left_state, Int right_state) {
    Int merged = ints.buffer_int_new(8);
    Int i = 0;
    while (i < ints.buffer_int_length(left_state)) {
        Int field_symbol = ints.buffer_int_get(left_state, i);
        if (struct_init_state_has(right_state, field_symbol)) {
            ints.buffer_int_push(merged, field_symbol);
        }
        i = i + 1;
    }
    return merged;
}

Int struct_init_missing_required_field(Int owner_symbol, Int state_handle) {
    Int owner_type = symbol_store.symbol_store_type_ids[owner_symbol];
    return struct_type_missing_required_field(owner_type, state_handle);
}

Bool struct_init_is_self_ident(Int node, Int self_symbol) {
    if (node == 0) {
        return 0;
    }
    if (hir.hir_store_node_kinds[node] != hir.HirNode.ident) {
        return 0;
    }
    return hir.hir_store_node_symbol_ids[node] == self_symbol;
}

Bool struct_init_is_direct_self_field(Int node, Int owner_symbol, Int self_symbol) {
    if (node == 0) {
        return 0;
    }
    if (hir.hir_store_node_kinds[node] != hir.HirNode.member_expr) {
        return 0;
    }
    Int base = hir.hir_store_node_first_child[node];
    if (!struct_init_is_self_ident(base, self_symbol)) {
        return 0;
    }
    Int field_symbol = hir.hir_store_node_symbol_ids[node];
    if (field_symbol == 0) {
        return 0;
    }
    if (symbol_store.symbol_store_kinds[field_symbol] != symbol_store.SymbolKind.field) {
        return 0;
    }
    return symbol_store.symbol_store_parent_ids[field_symbol] == owner_symbol;
}

() check_struct_init_expr_usage(Int node, Int owner_symbol, Int self_symbol, Int init_state, Bool lhs_target) {
    if (node == 0) {
        return;
    }
    if (struct_init_is_self_ident(node, self_symbol)) {
        if (lhs_target == 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "self cannot escape init");
        }
        return;
    }
    if (struct_init_is_direct_self_field(node, owner_symbol, self_symbol)) {
        Int field_symbol = hir.hir_store_node_symbol_ids[node];
        if (lhs_target == 0) {
            if (!struct_init_state_has(init_state, field_symbol)) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "field read before init");
            }
        }
        return;
    }
    Int kind = hir.hir_store_node_kinds[node];
    if (kind == hir.HirNode.binary_expr) {
        if (hir.hir_store_node_aux[node] == hir.HirBinaryOp.assign) {
            Int left = hir.hir_store_node_first_child[node];
            Int right = hir.hir_store_node_next_sibling[left];
            check_struct_init_expr_usage(right, owner_symbol, self_symbol, init_state, 0);
            if (struct_init_is_self_ident(left, self_symbol)) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[left], hir.hir_store_node_ends[left], "self cannot escape init");
                return;
            }
            if (struct_init_is_direct_self_field(left, owner_symbol, self_symbol)) {
                Int field_symbol = hir.hir_store_node_symbol_ids[left];
                if (!struct_init_field_is_mutable(field_symbol)) {
                    if (struct_init_state_has(init_state, field_symbol)) {
                        if (field_has_default_expr(field_symbol)) {
                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[left], hir.hir_store_node_ends[left], "immutable field with default cannot be reassigned in init");
                        } else {
                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[left], hir.hir_store_node_ends[left], "immutable field cannot be reassigned in init");
                        }
                        return;
                    }
                }
                struct_init_state_mark(init_state, field_symbol);
                return;
            }
            check_struct_init_expr_usage(left, owner_symbol, self_symbol, init_state, 1);
            return;
        }
    }
    Int child = hir.hir_store_node_first_child[node];
    while (child != 0) {
        check_struct_init_expr_usage(child, owner_symbol, self_symbol, init_state, 0);
        child = hir.hir_store_node_next_sibling[child];
    }
}

Int check_struct_init_switch(Int switch_node, Int owner_symbol, Int self_symbol, Int init_state) {
    Int condition = hir.hir_store_node_first_child[switch_node];
    if (condition == 0) {
        return struct_init_state_clone(init_state);
    }
    check_struct_init_expr_usage(condition, owner_symbol, self_symbol, init_state, 0);
    Int branch = hir.hir_store_node_next_sibling[condition];
    Bool has_else = 0;
    Int merged = 0;
    while (branch != 0) {
        Int branch_kind = hir.hir_store_node_kinds[branch];
        if (branch_kind == hir.HirNode.switch_case) {
            Int label = hir.hir_store_node_first_child[branch];
            Int bind = hir.hir_store_node_next_sibling[label];
            Int body = 0;
            if (bind != 0) {
                if (hir.hir_store_node_kinds[bind] == hir.HirNode.block) {
                    body = bind;
                    bind = 0;
                } else if (hir.hir_store_node_kinds[bind] == hir.HirNode.expr_stmt) {
                    body = bind;
                    bind = 0;
                } else {
                    body = hir.hir_store_node_next_sibling[bind];
                }
            }
            check_struct_init_expr_usage(label, owner_symbol, self_symbol, init_state, 0);
            if (bind != 0) {
                check_struct_init_expr_usage(bind, owner_symbol, self_symbol, init_state, 0);
            }
            Int branch_state = struct_init_state_clone(init_state);
            if (body != 0) {
                branch_state = check_struct_init_stmt(body, owner_symbol, self_symbol, branch_state);
            }
            if (branch_state != 0) {
                if (merged == 0) {
                    merged = branch_state;
                } else {
                    merged = struct_init_state_intersection(merged, branch_state);
                }
            }
        } else if (branch_kind == hir.HirNode.switch_else) {
            has_else = 1;
            Int body = hir.hir_store_node_first_child[branch];
            Int branch_state = struct_init_state_clone(init_state);
            if (body != 0) {
                branch_state = check_struct_init_stmt(body, owner_symbol, self_symbol, branch_state);
            }
            if (branch_state != 0) {
                if (merged == 0) {
                    merged = branch_state;
                } else {
                    merged = struct_init_state_intersection(merged, branch_state);
                }
            }
        }
        branch = hir.hir_store_node_next_sibling[branch];
    }
    if (has_else == 0) {
        Int else_state = struct_init_state_clone(init_state);
        if (merged == 0) {
            merged = else_state;
        } else {
            merged = struct_init_state_intersection(merged, else_state);
        }
    }
    return merged;
}

Int check_struct_init_stmt(Int stmt, Int owner_symbol, Int self_symbol, Int init_state) {
    if (stmt == 0) {
        return init_state;
    }
    Int kind = hir.hir_store_node_kinds[stmt];
    if (kind == hir.HirNode.block) {
        Int current_state = init_state;
        Int child_stmt = hir.hir_store_node_first_child[stmt];
        while (child_stmt != 0) {
            if (current_state == 0) {
                return 0;
            }
            current_state = check_struct_init_stmt(child_stmt, owner_symbol, self_symbol, current_state);
            child_stmt = hir.hir_store_node_next_sibling[child_stmt];
        }
        return current_state;
    }
    if (kind == hir.HirNode.return_stmt) {
        Int expr = hir.hir_store_node_first_child[stmt];
        if (expr != 0) {
            check_struct_init_expr_usage(expr, owner_symbol, self_symbol, init_state, 0);
            return 0;
        }
        Int missing_field = struct_init_missing_required_field(owner_symbol, init_state);
        if (missing_field != 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[stmt], hir.hir_store_node_ends[stmt], "missing field initialization in init");
        }
        return 0;
    }
    if (kind == hir.HirNode.if_stmt) {
        Int condition = hir.hir_store_node_first_child[stmt];
        Int then_stmt = hir.hir_store_node_next_sibling[condition];
        Int else_stmt = hir.hir_store_node_next_sibling[then_stmt];
        check_struct_init_expr_usage(condition, owner_symbol, self_symbol, init_state, 0);
        Int then_state = struct_init_state_clone(init_state);
        then_state = check_struct_init_stmt(then_stmt, owner_symbol, self_symbol, then_state);
        Int else_state = 0;
        if (else_stmt != 0) {
            else_state = struct_init_state_clone(init_state);
            else_state = check_struct_init_stmt(else_stmt, owner_symbol, self_symbol, else_state);
        } else {
            else_state = struct_init_state_clone(init_state);
        }
        if (then_state == 0) {
            return else_state;
        }
        if (else_state == 0) {
            return then_state;
        }
        return struct_init_state_intersection(then_state, else_state);
    }
    if (kind == hir.HirNode.while_stmt) {
        Int condition = hir.hir_store_node_first_child[stmt];
        Int body = hir.hir_store_node_next_sibling[condition];
        check_struct_init_expr_usage(condition, owner_symbol, self_symbol, init_state, 0);
        Int body_state = struct_init_state_clone(init_state);
        check_struct_init_stmt(body, owner_symbol, self_symbol, body_state);
        return init_state;
    }
    if (kind == hir.HirNode.for_stmt) {
        Int child = hir.hir_store_node_first_child[stmt];
        while (child != 0) {
            Int next = hir.hir_store_node_next_sibling[child];
            if (next == 0) {
                Int body_state = struct_init_state_clone(init_state);
                check_struct_init_stmt(child, owner_symbol, self_symbol, body_state);
            } else {
                check_struct_init_expr_usage(child, owner_symbol, self_symbol, init_state, 0);
            }
            child = next;
        }
        return init_state;
    }
    if (kind == hir.HirNode.switch_stmt) {
        return check_struct_init_switch(stmt, owner_symbol, self_symbol, init_state);
    }
    check_struct_init_expr_usage(stmt, owner_symbol, self_symbol, init_state, 0);
    return init_state;
}

Int struct_init_body_node(Int func_node) {
    Int child = hir.hir_store_node_first_child[func_node];
    Int last = 0;
    while (child != 0) {
        last = child;
        child = hir.hir_store_node_next_sibling[child];
    }
    return last;
}

() check_struct_init_function(Int func_node) {
    Int func_symbol = hir.hir_store_node_symbol_ids[func_node];
    if (!symbol_is_struct_init(func_symbol)) {
        return;
    }
    Int owner_symbol = symbol_store.symbol_store_parent_ids[func_symbol];
    Int self_symbol = symbol_store.symbol_store_find_symbol_by_name_id(
        intern_pool.intern_pool_intern("self"),
        symbol_store.SymbolKind.param,
        func_symbol
    );
    if (owner_symbol == 0) {
        return;
    }
    if (self_symbol == 0) {
        return;
    }
    Int body = struct_init_body_node(func_node);
    if (body == 0) {
        return;
    }
    Int exit_state = check_struct_init_stmt(body, owner_symbol, self_symbol, struct_init_entry_state(owner_symbol));
    if (exit_state != 0) {
        Int missing_field = struct_init_missing_required_field(owner_symbol, exit_state);
        if (missing_field != 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[func_node], hir.hir_store_node_ends[func_node], "missing field initialization in init");
        }
    }
}

() register_named_types(UInt8[] source, Int parse_root) {
    Int child = parser.parser_store_node_first_child[parse_root];
    while (child != 0) {
        generic_context_push(source, child);
        Int kind = parser.parser_store_node_kinds[child];
        if (kind == parser.ParserNode.struct_decl) {
            Int name_node = parser.parser_store_node_first_child[child];
            Int type_id = type_store.type_store_new_named_type(
                source,
                type_store.TypeKind.struct_type,
                parser.parser_store_node_starts[name_node],
                parser.parser_store_node_ends[name_node],
                register_module_id
            );
            Int symbol_id = register_unique_symbol(
                source,
                symbol_store.SymbolKind.type_name,
                parser.parser_store_node_starts[name_node],
                parser.parser_store_node_ends[name_node],
                type_id,
                0,
                "duplicate type"
            );
            if (parse_node_has_generic_items(child)) {
                symbol_set_generic_template(source, symbol_id, child);
            }
            maybe_mark_public(child, symbol_id);
        }
        if (kind == parser.ParserNode.union_decl) {
            Int name_node = union_parse_name_node(child);
            Int type_id = type_store.type_store_new_named_type(
                source,
                type_store.TypeKind.union_type,
                parser.parser_store_node_starts[name_node],
                parser.parser_store_node_ends[name_node],
                register_module_id
            );
            Int symbol_id = register_unique_symbol(
                source,
                symbol_store.SymbolKind.type_name,
                parser.parser_store_node_starts[name_node],
                parser.parser_store_node_ends[name_node],
                type_id,
                0,
                "duplicate type"
            );
            if (union_parse_has_implicit_tag(child) != 0) {
                UInt8[] hidden_tag_name = next_implicit_union_tag_name();
                Int tag_type_id = type_store.type_store_new_named_type(
                    source,
                    type_store.TypeKind.enum_type,
                    parser.parser_store_node_starts[name_node],
                    parser.parser_store_node_ends[name_node],
                    register_module_id
                );
                symbol_store.symbol_store_new_symbol(
                    hidden_tag_name,
                    symbol_store.SymbolKind.enum_name,
                    0,
                    hidden_tag_name.length,
                    tag_type_id,
                    0,
                    register_module_id
                );
                type_store.type_store_set_elem_type_id(type_id, tag_type_id);
            } else {
                Int tag_type_node = union_parse_tag_type_node(child);
                type_store.type_store_set_elem_type_id(type_id, resolve_type_node_from_source(source, tag_type_node));
            }
            maybe_mark_public(child, symbol_id);
        }
        if (kind == parser.ParserNode.enum_decl) {
            Int name_node = parser.parser_store_node_first_child[child];
            Int type_id = type_store.type_store_new_named_type(
                source,
                type_store.TypeKind.enum_type,
                parser.parser_store_node_starts[name_node],
                parser.parser_store_node_ends[name_node],
                register_module_id
            );
            Int symbol_id = register_unique_symbol(
                source,
                symbol_store.SymbolKind.enum_name,
                parser.parser_store_node_starts[name_node],
                parser.parser_store_node_ends[name_node],
                type_id,
                0,
                "duplicate enum"
            );
            maybe_mark_public(child, symbol_id);
        }
        generic_context_pop(child);
        child = parser.parser_store_node_next_sibling[child];
    }
}

() register_top_level_funcs(UInt8[] source, Int parse_root) {
    Int child = parser.parser_store_node_first_child[parse_root];
    while (child != 0) {
        if (parser.parser_store_node_kinds[child] == parser.ParserNode.func_decl) {
            generic_context_push(source, child);
            Int type_node = parser.parser_store_node_first_child[child];
            Int name_node = parser.parser_store_node_next_sibling[type_node];
            Int symbol_id = register_unique_symbol(
                source,
                symbol_store.SymbolKind.func,
                parser.parser_store_node_starts[name_node],
                parser.parser_store_node_ends[name_node],
                resolve_type_node_from_source(source, type_node),
                0,
                "duplicate function"
            );
            if (parse_node_has_generic_items(child)) {
                symbol_set_generic_template(source, symbol_id, child);
            }
            maybe_mark_public(child, symbol_id);
            generic_context_pop(child);
        }
        child = parser.parser_store_node_next_sibling[child];
    }
}

() register_top_level_globals(UInt8[] source, Int parse_root) {
    Int child = parser.parser_store_node_first_child[parse_root];
    while (child != 0) {
        if (parser.parser_store_node_kinds[child] == parser.ParserNode.global_decl) {
            Int type_node = parser.parser_store_node_first_child[child];
            Int name_node = parser.parser_store_node_next_sibling[type_node];
            Int symbol_id = register_unique_symbol(
                source,
                symbol_store.SymbolKind.global,
                parser.parser_store_node_starts[name_node],
                parser.parser_store_node_ends[name_node],
                resolve_type_node_from_source(source, type_node),
                0,
                "duplicate global"
            );
            maybe_mark_public(child, symbol_id);
        }
        if (parser.parser_store_node_kinds[child] == parser.ParserNode.tuple_global_decl) {
            Int count = tuple_decl_binding_count(child);
            Int i = 0;
            while (i < count) {
                Int type_node = tuple_decl_binding_type_parse(child, i);
                Int name_node = tuple_decl_binding_name_parse(child, i);
                Int symbol_id = register_unique_symbol(
                    source,
                    symbol_store.SymbolKind.global,
                    parser.parser_store_node_starts[name_node],
                    parser.parser_store_node_ends[name_node],
                    resolve_type_node_from_source(source, type_node),
                    0,
                    "duplicate global"
                );
                maybe_mark_public(child, symbol_id);
                i = i + 1;
            }
        }
        child = parser.parser_store_node_next_sibling[child];
    }
}

Bool nominal_method_name_conflicts(UInt8[] source, Int name_node, Int owner_symbol) {
    if (symbol_store.symbol_store_find_symbol(source, parser.parser_store_node_starts[name_node], parser.parser_store_node_ends[name_node], symbol_store.SymbolKind.field, owner_symbol) != 0) {
        return 1;
    }
    if (symbol_store.symbol_store_find_symbol(source, parser.parser_store_node_starts[name_node], parser.parser_store_node_ends[name_node], symbol_store.SymbolKind.union_member, owner_symbol) != 0) {
        return 1;
    }
    return symbol_store.symbol_store_find_symbol(source, parser.parser_store_node_starts[name_node], parser.parser_store_node_ends[name_node], symbol_store.SymbolKind.enum_member, owner_symbol) != 0;
}

() register_nominal_method_symbol(UInt8[] source, Int member, Int owner_symbol, Int allow_init) {
    generic_context_push(source, member);
    Int type_node = parser.parser_store_node_first_child[member];
    Int method_name = parser.parser_store_node_next_sibling[type_node];
    if (nominal_method_name_conflicts(source, method_name, owner_symbol)) {
        diagnostic.diagnostic_error(
            current_path,
            parser.parser_store_node_starts[method_name],
            parser.parser_store_node_ends[method_name],
            "field and method names must not conflict"
        );
        generic_context_pop(member);
        return;
    }
    if (func_parse_is_init(source, member)) {
        Int init_symbol = register_unique_symbol(
            source,
            symbol_store.SymbolKind.func,
            parser.parser_store_node_starts[method_name],
            parser.parser_store_node_ends[method_name],
            symbol_store.symbol_store_type_ids[owner_symbol],
            owner_symbol,
            "duplicate init"
        );
        if (init_symbol != 0) {
            symbol_store.symbol_store_set_aux(init_symbol, symbol_store.func_aux_struct_init);
            if (decl_is_public(decl_node_flags(member))) {
                symbol_store.symbol_store_set_flag(init_symbol, symbol_store.SymbolFlag.public_flag);
            }
        }
        generic_context_pop(member);
        return;
    }
    if (parse_node_is(source, method_name, "init")) {
        if (allow_init != 0) {
            if (func_parse_is_nominal_static(source, member)) {
                diagnostic.diagnostic_error(
                    current_path,
                    parser.parser_store_node_starts[method_name],
                    parser.parser_store_node_ends[method_name],
                    "static init is invalid"
                );
                generic_context_pop(member);
                return;
            }
            diagnostic.diagnostic_error(
                current_path,
                parser.parser_store_node_starts[method_name],
                parser.parser_store_node_ends[method_name],
                "init cannot declare return type"
            );
        } else {
            diagnostic.diagnostic_error(
                current_path,
                parser.parser_store_node_starts[method_name],
                parser.parser_store_node_ends[method_name],
                "init is only valid in struct"
            );
        }
        generic_context_pop(member);
        return;
    }
    Int method_symbol = register_unique_symbol(
        source,
        symbol_store.SymbolKind.func,
        parser.parser_store_node_starts[method_name],
        parser.parser_store_node_ends[method_name],
        resolve_type_node_from_source(source, type_node),
        owner_symbol,
        "duplicate method"
    );
    if (method_symbol == 0) {
        generic_context_pop(member);
        return;
    }
    if (func_parse_is_nominal_static(source, member)) {
        symbol_store.symbol_store_set_aux(method_symbol, symbol_store.func_aux_struct_static);
    } else if (func_parse_is_nominal_instance(source, member)) {
        symbol_store.symbol_store_set_aux(method_symbol, symbol_store.func_aux_struct_instance);
    }
    if (decl_is_public(decl_node_flags(member))) {
        symbol_store.symbol_store_set_flag(method_symbol, symbol_store.SymbolFlag.public_flag);
    }
    generic_context_pop(member);
}

() register_member_symbols(UInt8[] source, Int parse_root) {
    Int child = parser.parser_store_node_first_child[parse_root];
    while (child != 0) {
        Int kind = parser.parser_store_node_kinds[child];
        if (kind == parser.ParserNode.struct_decl) {
            generic_context_push(source, child);
            Int name_node = parser.parser_store_node_first_child[child];
            Int owner_symbol = resolve_registered_top_level_symbol(source, name_node, symbol_store.SymbolKind.type_name);
            Int member = parser.parser_store_node_next_sibling[name_node];
            while (member != 0) {
                if (parser.parser_store_node_kinds[member] == parser.ParserNode.field_decl) {
                    Int type_node = parser.parser_store_node_first_child[member];
                    Int field_name = parser.parser_store_node_next_sibling[type_node];
                    Int existing_method = symbol_store.symbol_store_find_symbol(source, parser.parser_store_node_starts[field_name], parser.parser_store_node_ends[field_name], symbol_store.SymbolKind.func, owner_symbol);
                    if (existing_method != 0) {
                        diagnostic.diagnostic_error(
                            current_path,
                            parser.parser_store_node_starts[field_name],
                            parser.parser_store_node_ends[field_name],
                            "field and method names must not conflict"
                        );
                    } else {
                        register_unique_symbol(
                            source,
                            symbol_store.SymbolKind.field,
                            parser.parser_store_node_starts[field_name],
                            parser.parser_store_node_ends[field_name],
                            resolve_type_node_from_source(source, type_node),
                            owner_symbol,
                            "duplicate field"
                        );
                    }
                } else if (parser.parser_store_node_kinds[member] == parser.ParserNode.func_decl) {
                    register_nominal_method_symbol(source, member, owner_symbol, 1);
                }
                member = parser.parser_store_node_next_sibling[member];
            }
            generic_context_pop(child);
        }
        if (kind == parser.ParserNode.union_decl) {
            generic_context_push(source, child);
            Int tag_type_node = union_parse_tag_type_node(child);
            Int name_node = union_parse_name_node(child);
            Int owner_symbol = resolve_registered_top_level_symbol(source, name_node, symbol_store.SymbolKind.type_name);
            Int tag_type_id = symbol_store.symbol_store_type_ids[owner_symbol];
            Int tag_enum_type = union_tag_type(tag_type_id);
            Int tag_owner = find_type_owner_symbol(tag_enum_type);
            Int field = union_parse_first_member(child);
            while (field != 0) {
                if (parser.parser_store_node_kinds[field] == parser.ParserNode.field_decl) {
                    Int type_node = parser.parser_store_node_first_child[field];
                    Int field_name = parser.parser_store_node_next_sibling[type_node];
                    Int existing_method = symbol_store.symbol_store_find_symbol(source, parser.parser_store_node_starts[field_name], parser.parser_store_node_ends[field_name], symbol_store.SymbolKind.func, owner_symbol);
                    if (existing_method != 0) {
                        diagnostic.diagnostic_error(
                            current_path,
                            parser.parser_store_node_starts[field_name],
                            parser.parser_store_node_ends[field_name],
                            "field and method names must not conflict"
                        );
                    } else {
                        Int member_symbol = register_unique_symbol(
                            source,
                            symbol_store.SymbolKind.union_member,
                            parser.parser_store_node_starts[field_name],
                            parser.parser_store_node_ends[field_name],
                            resolve_type_node_from_source(source, type_node),
                            owner_symbol,
                            "duplicate union member"
                        );
                        if (member_symbol != 0) {
                            if (tag_owner != 0) {
                                Int tag_member = resolve_symbol(source, field_name, symbol_store.SymbolKind.enum_member, tag_owner);
                                if (tag_member == 0) {
                                    if (union_parse_has_implicit_tag(child) != 0) {
                                        Int next_tag_value = count_child_symbols_of_kind(tag_owner, symbol_store.SymbolKind.enum_member);
                                        tag_member = register_unique_symbol(
                                            source,
                                            symbol_store.SymbolKind.enum_member,
                                            parser.parser_store_node_starts[field_name],
                                            parser.parser_store_node_ends[field_name],
                                            tag_enum_type,
                                            tag_owner,
                                            "duplicate union member"
                                        );
                                        if (tag_member != 0) {
                                            symbol_store.symbol_store_set_aux(tag_member, next_tag_value);
                                        }
                                    }
                                }
                                if (tag_member != 0) {
                                    symbol_store.symbol_store_set_target_id(member_symbol, tag_member);
                                    symbol_store.symbol_store_set_aux(member_symbol, symbol_store.symbol_store_aux[tag_member]);
                                } else {
                                    if (union_parse_has_implicit_tag(child) == 0) {
                                        diagnostic.diagnostic_error(
                                            current_path,
                                            parser.parser_store_node_starts[field_name],
                                            parser.parser_store_node_ends[field_name],
                                            "union member must exist in tag enum"
                                        );
                                    }
                                }
                            } else {
                                if (union_parse_has_implicit_tag(child) != 0) {
                                    diagnostic.diagnostic_error(
                                        current_path,
                                        parser.parser_store_node_starts[name_node],
                                        parser.parser_store_node_ends[name_node],
                                        "implicit union tag must be enum"
                                    );
                                } else {
                                    diagnostic.diagnostic_error(
                                        current_path,
                                        parser.parser_store_node_starts[tag_type_node],
                                        parser.parser_store_node_ends[tag_type_node],
                                        "union tag type must be enum"
                                    );
                                }
                            }
                        }
                    }
                } else if (parser.parser_store_node_kinds[field] == parser.ParserNode.func_decl) {
                    register_nominal_method_symbol(source, field, owner_symbol, 0);
                }
                field = parser.parser_store_node_next_sibling[field];
            }
            generic_context_pop(child);
        }
        if (kind == parser.ParserNode.enum_decl) {
            generic_context_push(source, child);
            Int name_node = parser.parser_store_node_first_child[child];
            Int owner_symbol = resolve_registered_top_level_symbol(source, name_node, symbol_store.SymbolKind.enum_name);
            Int member = parser.parser_store_node_next_sibling[name_node];
            Int next_value = 0;
            while (member != 0) {
                if (parser.parser_store_node_kinds[member] == parser.ParserNode.enum_member) {
                    Int member_name = parser.parser_store_node_first_child[member];
                    Int existing_method = symbol_store.symbol_store_find_symbol(source, parser.parser_store_node_starts[member_name], parser.parser_store_node_ends[member_name], symbol_store.SymbolKind.func, owner_symbol);
                    if (existing_method != 0) {
                        diagnostic.diagnostic_error(
                            current_path,
                            parser.parser_store_node_starts[member_name],
                            parser.parser_store_node_ends[member_name],
                            "field and method names must not conflict"
                        );
                    } else {
                        Int member_symbol = register_unique_symbol(
                            source,
                            symbol_store.SymbolKind.enum_member,
                            parser.parser_store_node_starts[member_name],
                            parser.parser_store_node_ends[member_name],
                            symbol_store.symbol_store_type_ids[owner_symbol],
                            owner_symbol,
                            "duplicate enum member"
                        );
                        Int explicit_value = parser.parser_store_node_next_sibling[member_name];
                        if (member_symbol != 0) {
                            if (explicit_value != 0) {
                                symbol_store.symbol_store_set_aux(member_symbol, parse_const_int_expr(source, explicit_value));
                                next_value = symbol_store.symbol_store_aux[member_symbol] + 1;
                            } else {
                                symbol_store.symbol_store_set_aux(member_symbol, next_value);
                                next_value = next_value + 1;
                            }
                        }
                    }
                } else if (parser.parser_store_node_kinds[member] == parser.ParserNode.func_decl) {
                    register_nominal_method_symbol(source, member, owner_symbol, 0);
                }
                member = parser.parser_store_node_next_sibling[member];
            }
            generic_context_pop(child);
        }
        child = parser.parser_store_node_next_sibling[child];
    }
}

() register_param_symbols_in_func_subtree(UInt8[] source, Int parse_node, Int func_symbol) {
    Int kind = parser.parser_store_node_kinds[parse_node];
    if (kind == parser.ParserNode.param) {
        Int type_node = parser.parser_store_node_first_child[parse_node];
        Int name_node = parser.parser_store_node_next_sibling[type_node];
        register_unique_symbol(
            source,
            symbol_store.SymbolKind.param,
            parser.parser_store_node_starts[name_node],
            parser.parser_store_node_ends[name_node],
            resolve_type_node_from_source(source, type_node),
            func_symbol,
            "duplicate parameter"
        );
    }

    Int child = parser.parser_store_node_first_child[parse_node];
    while (child != 0) {
        register_param_symbols_in_func_subtree(source, child, func_symbol);
        child = parser.parser_store_node_next_sibling[child];
    }
}

() register_self_symbol(Int owner_symbol, Int func_symbol) {
    if (owner_symbol == 0) {
        return;
    }
    symbol_store.symbol_store_new_symbol(
        "self",
        symbol_store.SymbolKind.param,
        0,
        4,
        type_store.type_store_new_pointer_type(symbol_store.symbol_store_type_ids[owner_symbol]),
        func_symbol,
        register_module_id
    );
}

() register_local_symbols_in_func_subtree(UInt8[] source, Int parse_node, Int func_symbol) {
    Int kind = parser.parser_store_node_kinds[parse_node];
    if (kind == parser.ParserNode.local_decl) {
        Int type_node = parser.parser_store_node_first_child[parse_node];
        Int name_node = parser.parser_store_node_next_sibling[type_node];
        Int scope_id = local_scope_id(parse_node);
        if (scope_id == 0) {
            scope_id = func_symbol;
        }
        register_unique_symbol(
            source,
            symbol_store.SymbolKind.local,
            parser.parser_store_node_starts[name_node],
            parser.parser_store_node_ends[name_node],
            resolve_type_node_from_source(source, type_node),
            scope_id,
            "duplicate local"
        );
    }
    if (kind == parser.ParserNode.tuple_local_decl) {
        if (tuple_decl_init_parse(parse_node) == 0) {
            return;
        }
        Int scope_id = local_scope_id(parse_node);
        if (scope_id == 0) {
            scope_id = func_symbol;
        }
        Int count = tuple_decl_binding_count(parse_node);
        Int i = 0;
        while (i < count) {
            Int type_node = tuple_decl_binding_type_parse(parse_node, i);
            Int name_node = tuple_decl_binding_name_parse(parse_node, i);
            register_unique_symbol(
                source,
                symbol_store.SymbolKind.local,
                parser.parser_store_node_starts[name_node],
                parser.parser_store_node_ends[name_node],
                resolve_type_node_from_source(source, type_node),
                scope_id,
                "duplicate local"
            );
            i = i + 1;
        }
    }
    if (kind == parser.ParserNode.for_stmt) {
        Int mode = parser.parser_store_node_aux[parse_node];
        if (mode == 0) {
            Int type_node = parser.parser_store_node_first_child[parse_node];
            Int name_node = parser.parser_store_node_next_sibling[type_node];
            Int start_expr = parser.parser_store_node_next_sibling[name_node];
            Int end_expr = parser.parser_store_node_next_sibling[start_expr];
            Int body_node = parser.parser_store_node_next_sibling[end_expr];
            register_unique_symbol(
                source,
                symbol_store.SymbolKind.local,
                parser.parser_store_node_starts[name_node],
                parser.parser_store_node_ends[name_node],
                resolve_type_node_from_source(source, type_node),
                0 - body_node,
                "duplicate local"
            );
        } else {
            if (mode == 4) {
                Int binding_node = parser.parser_store_node_first_child[parse_node];
                Int iterable_expr = parser.parser_store_node_next_sibling[binding_node];
                Int body_node = parser.parser_store_node_next_sibling[iterable_expr];
                register_for_binding_symbols(source, binding_node, 0 - body_node);
            } else if (mode == 5) {
                Int binding_node = parser.parser_store_node_first_child[parse_node];
                Int iterable_expr = parser.parser_store_node_next_sibling[binding_node];
                Int body_node = parser.parser_store_node_next_sibling[iterable_expr];
                register_for_binding_symbols(source, binding_node, 0 - body_node);
            } else if (mode == 3) {
                Int type_node = parser.parser_store_node_first_child[parse_node];
                Int name_node = parser.parser_store_node_next_sibling[type_node];
                Int iterable_expr = parser.parser_store_node_next_sibling[name_node];
                Int body_node = parser.parser_store_node_next_sibling[iterable_expr];
                register_unique_symbol(
                    source,
                    symbol_store.SymbolKind.local,
                    parser.parser_store_node_starts[name_node],
                    parser.parser_store_node_ends[name_node],
                    resolve_type_node_from_source(source, type_node),
                    0 - body_node,
                    "duplicate local"
                );
            } else {
                Int name_node = parser.parser_store_node_first_child[parse_node];
                Int body_node = 0;
                if (mode == 1) {
                    Int start_expr = parser.parser_store_node_next_sibling[name_node];
                    Int end_expr = parser.parser_store_node_next_sibling[start_expr];
                    body_node = parser.parser_store_node_next_sibling[end_expr];
                } else {
                    Int iterable_expr = parser.parser_store_node_next_sibling[name_node];
                    body_node = parser.parser_store_node_next_sibling[iterable_expr];
                }
                register_unique_symbol(
                    source,
                    symbol_store.SymbolKind.local,
                    parser.parser_store_node_starts[name_node],
                    parser.parser_store_node_ends[name_node],
                    type_store.type_store_builtin_unknown,
                    0 - body_node,
                    "duplicate local"
                );
            }
        }
    }

    Int child = parser.parser_store_node_first_child[parse_node];
    while (child != 0) {
        register_local_symbols_in_func_subtree(source, child, func_symbol);
        child = parser.parser_store_node_next_sibling[child];
    }
}

() register_function_symbols(UInt8[] source, Int parse_root, Int include_locals) {
    Int child = parser.parser_store_node_first_child[parse_root];
    while (child != 0) {
        if (parser.parser_store_node_kinds[child] == parser.ParserNode.func_decl) {
            generic_context_push(source, child);
            Int type_node = parser.parser_store_node_first_child[child];
            Int name_node = parser.parser_store_node_next_sibling[type_node];
            Int func_symbol = resolve_registered_top_level_symbol(source, name_node, symbol_store.SymbolKind.func);
            register_param_symbols_in_func_subtree(source, child, func_symbol);
            if (include_locals != 0) {
                register_local_symbols_in_func_subtree(source, child, func_symbol);
            }
            generic_context_pop(child);
        } else if (parser.parser_store_node_kinds[child] == parser.ParserNode.struct_decl) {
            generic_context_push(source, child);
            Int name_node = parser.parser_store_node_first_child[child];
            Int owner_kind = symbol_store.SymbolKind.type_name;
            if (parser.parser_store_node_kinds[child] == parser.ParserNode.union_decl) {
                name_node = parser.parser_store_node_next_sibling[name_node];
            }
            if (parser.parser_store_node_kinds[child] == parser.ParserNode.enum_decl) {
                owner_kind = symbol_store.SymbolKind.enum_name;
            }
            Int owner_symbol = resolve_registered_top_level_symbol(source, name_node, owner_kind);
            Int member = parser.parser_store_node_next_sibling[name_node];
            while (member != 0) {
                if (func_parse_is_init(source, member)) {
                    Int type_node = parser.parser_store_node_first_child[member];
                    Int init_name = parser.parser_store_node_next_sibling[type_node];
                    Int func_symbol = resolve_symbol(source, init_name, symbol_store.SymbolKind.func, owner_symbol);
                    if (func_symbol != 0) {
                        generic_context_push(source, member);
                        register_self_symbol(owner_symbol, func_symbol);
                        register_param_symbols_in_func_subtree(source, member, func_symbol);
                        if (include_locals != 0) {
                            register_local_symbols_in_func_subtree(source, member, func_symbol);
                        }
                        generic_context_pop(member);
                    }
                } else if (func_parse_is_nominal_static(source, member)) {
                    Int type_node = parser.parser_store_node_first_child[member];
                    Int method_name = parser.parser_store_node_next_sibling[type_node];
                    Int func_symbol = resolve_symbol(source, method_name, symbol_store.SymbolKind.func, owner_symbol);
                    if (func_symbol != 0) {
                        generic_context_push(source, member);
                        register_param_symbols_in_func_subtree(source, member, func_symbol);
                        if (include_locals != 0) {
                            register_local_symbols_in_func_subtree(source, member, func_symbol);
                        }
                        generic_context_pop(member);
                    }
                } else if (func_parse_is_nominal_instance(source, member)) {
                    Int type_node = parser.parser_store_node_first_child[member];
                    Int method_name = parser.parser_store_node_next_sibling[type_node];
                    Int func_symbol = resolve_symbol(source, method_name, symbol_store.SymbolKind.func, owner_symbol);
                    if (func_symbol != 0) {
                        generic_context_push(source, member);
                        register_self_symbol(owner_symbol, func_symbol);
                        register_param_symbols_in_func_subtree(source, member, func_symbol);
                        if (include_locals != 0) {
                            register_local_symbols_in_func_subtree(source, member, func_symbol);
                        }
                        generic_context_pop(member);
                    }
                }
                member = parser.parser_store_node_next_sibling[member];
            }
            generic_context_pop(child);
        } else if (parser.parser_store_node_kinds[child] == parser.ParserNode.union_decl) {
            generic_context_push(source, child);
            Int name_node = union_parse_name_node(child);
            Int owner_kind = symbol_store.SymbolKind.type_name;
            Int owner_symbol = resolve_registered_top_level_symbol(source, name_node, owner_kind);
            Int member = union_parse_first_member(child);
            while (member != 0) {
                if (func_parse_is_nominal_static(source, member)) {
                    Int type_node = parser.parser_store_node_first_child[member];
                    Int method_name = parser.parser_store_node_next_sibling[type_node];
                    Int func_symbol = resolve_symbol(source, method_name, symbol_store.SymbolKind.func, owner_symbol);
                    if (func_symbol != 0) {
                        generic_context_push(source, member);
                        register_param_symbols_in_func_subtree(source, member, func_symbol);
                        if (include_locals != 0) {
                            register_local_symbols_in_func_subtree(source, member, func_symbol);
                        }
                        generic_context_pop(member);
                    }
                } else if (func_parse_is_nominal_instance(source, member)) {
                    Int type_node = parser.parser_store_node_first_child[member];
                    Int method_name = parser.parser_store_node_next_sibling[type_node];
                    Int func_symbol = resolve_symbol(source, method_name, symbol_store.SymbolKind.func, owner_symbol);
                    if (func_symbol != 0) {
                        generic_context_push(source, member);
                        register_self_symbol(owner_symbol, func_symbol);
                        register_param_symbols_in_func_subtree(source, member, func_symbol);
                        if (include_locals != 0) {
                            register_local_symbols_in_func_subtree(source, member, func_symbol);
                        }
                        generic_context_pop(member);
                    }
                }
                member = parser.parser_store_node_next_sibling[member];
            }
            generic_context_pop(child);
        } else if (parser.parser_store_node_kinds[child] == parser.ParserNode.enum_decl) {
            generic_context_push(source, child);
            Int name_node = parser.parser_store_node_first_child[child];
            Int owner_symbol = resolve_registered_top_level_symbol(source, name_node, symbol_store.SymbolKind.enum_name);
            Int member = parser.parser_store_node_next_sibling[name_node];
            while (member != 0) {
                if (func_parse_is_nominal_static(source, member)) {
                    Int type_node = parser.parser_store_node_first_child[member];
                    Int method_name = parser.parser_store_node_next_sibling[type_node];
                    Int func_symbol = resolve_symbol(source, method_name, symbol_store.SymbolKind.func, owner_symbol);
                    if (func_symbol != 0) {
                        generic_context_push(source, member);
                        register_param_symbols_in_func_subtree(source, member, func_symbol);
                        if (include_locals != 0) {
                            register_local_symbols_in_func_subtree(source, member, func_symbol);
                        }
                        generic_context_pop(member);
                    }
                } else if (func_parse_is_nominal_instance(source, member)) {
                    Int type_node = parser.parser_store_node_first_child[member];
                    Int method_name = parser.parser_store_node_next_sibling[type_node];
                    Int func_symbol = resolve_symbol(source, method_name, symbol_store.SymbolKind.func, owner_symbol);
                    if (func_symbol != 0) {
                        generic_context_push(source, member);
                        register_self_symbol(owner_symbol, func_symbol);
                        register_param_symbols_in_func_subtree(source, member, func_symbol);
                        if (include_locals != 0) {
                            register_local_symbols_in_func_subtree(source, member, func_symbol);
                        }
                        generic_context_pop(member);
                    }
                }
                member = parser.parser_store_node_next_sibling[member];
            }
            generic_context_pop(child);
        }
        child = parser.parser_store_node_next_sibling[child];
    }
}

() register_import_aliases(UInt8[] source, Int parse_root, UInt8[] owner_path) {
    Int child = parser.parser_store_node_first_child[parse_root];
    while (child != 0) {
        if (parser.parser_store_node_kinds[child] == parser.ParserNode.import_decl) {
            Int alias_node = import_decl_alias_node(child);
            if (alias_node != 0) {
                Int path_node = import_decl_path_node(child);
                UInt8[] import_path = import_string_value(source, path_node);
                if (path_utils.is_relative_import(import_path)) {
                    UInt8[] resolved_import = path_utils.resolve_local_import(owner_path, import_path);
                    Int import_module_id = module_loader.module_loader_ensure_module(resolved_import);
                    register_unique_symbol(
                        source,
                        symbol_store.SymbolKind.module_alias,
                        parser.parser_store_node_starts[alias_node],
                        parser.parser_store_node_ends[alias_node],
                        import_module_id,
                        0,
                        "duplicate import alias"
                    );
                }
            }
        }
        child = parser.parser_store_node_next_sibling[child];
    }
}

() register_imported_scope(UInt8[] path) {
    Int import_module_id = module_loader.module_loader_ensure_module(path);
    if (has_visited_import(import_module_id)) {
        return;
    }
    ints.buffer_int_push(import_visit_set, import_module_id);

    UInt8[] source = module_loader.load_source(path);
    if (diagnostic.diagnostic_has_error()) {
        return;
    }
    Int saved_register_module_id = register_module_id;
    Int saved_current_module_id = current_module_id;
    UInt8[] saved_source = current_source;
    UInt8[] saved_path = current_path;
    Int saved_visible_import_module_ids = visible_import_module_ids;
    current_module_id = import_module_id;
    register_module_id = import_module_id;
    current_source = source;
    current_path = path;
    Int parse_root = parser_frontend.parse_source(path, source);
    if (diagnostic.diagnostic_has_error()) {
        register_module_id = saved_register_module_id;
        current_source = saved_source;
        current_path = saved_path;
        return;
    }

    Int child = parser.parser_store_node_first_child[parse_root];
    Int pending_import_modules = ints.buffer_int_new(8);
    visible_import_module_ids = ints.buffer_int_new(8);
    while (child != 0) {
        if (parser.parser_store_node_kinds[child] == parser.ParserNode.import_decl) {
            Int path_node = import_decl_path_node(child);
            UInt8[] import_path = import_string_value(source, path_node);
            if (path_utils.is_relative_import(import_path)) {
                UInt8[] resolved_import = path_utils.resolve_local_import(path, import_path);
                Int child_module_id = module_loader.module_loader_ensure_module(resolved_import);
                if (import_decl_alias_node(child) == 0) {
                    ints.buffer_int_push(visible_import_module_ids, child_module_id);
                }
                ints.buffer_int_push(pending_import_modules, child_module_id);
            }
        }
        child = parser.parser_store_node_next_sibling[child];
    }

    child = 0;
    while (child < ints.buffer_int_length(pending_import_modules)) {
        register_imported_scope(module_loader.module_loader_module_path(ints.buffer_int_get(pending_import_modules, child)));
        if (diagnostic.diagnostic_has_error()) {
            register_module_id = saved_register_module_id;
            current_module_id = saved_current_module_id;
            current_source = saved_source;
            current_path = saved_path;
            visible_import_module_ids = saved_visible_import_module_ids;
            return;
        }
        child = child + 1;
    }

    parse_root = parser_frontend.parse_source(path, source);
    if (diagnostic.diagnostic_has_error()) {
        register_module_id = saved_register_module_id;
        current_module_id = saved_current_module_id;
        current_source = saved_source;
        current_path = saved_path;
        visible_import_module_ids = saved_visible_import_module_ids;
        return;
    }
    register_import_aliases(source, parse_root, path);
    register_named_types(source, parse_root);
    register_top_level_funcs(source, parse_root);
    register_top_level_globals(source, parse_root);
    register_top_level_aliases(source, parse_root);
    register_member_symbols(source, parse_root);
    register_function_symbols(source, parse_root, 0);
    Int parse_snapshot_id = parser.parser_store_snapshot_current();
    module_loader.module_loader_register_parse_snapshot(import_module_id, parse_snapshot_id);
    register_module_id = saved_register_module_id;
    current_module_id = saved_current_module_id;
    current_source = saved_source;
    current_path = saved_path;
    visible_import_module_ids = saved_visible_import_module_ids;
}

Int lower_node(Int parse_node) {
    Int kind = parser.parser_store_node_kinds[parse_node];
    Int hir_kind = hir_kind_from_parser_kind(kind);
    Int node = hir.hir_store_new_node(
        hir_kind,
        parser.parser_store_node_starts[parse_node],
        parser.parser_store_node_ends[parse_node]
    );
    hir.hir_store_set_aux(node, parser.parser_store_node_aux[parse_node]);
    if (parse_node_is_generic_decl(parse_node)) {
        if (parse_node != current_generic_func_lowering_parse) {
        hir.hir_store_set_aux(node, hir.hir_store_node_aux[node] + hir_decl_flag_generic);
        }
    }

    if (kind == parser.ParserNode.type_name) {
        Int resolved_type = resolve_type_node(parse_node);
        hir.hir_store_set_type_id(node, resolved_type);
        if (!is_known_type(resolved_type)) {
            if (!type_parse_is_infer(current_source, parse_node)) {
                if (!is_builtin_type_name(current_source, parse_node)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown type");
                }
            }
        }
    }
    if (kind == parser.ParserNode.slice_type) {
        Int resolved_type = resolve_type_node(parse_node);
        hir.hir_store_set_type_id(node, resolved_type);
        if (!is_known_type(resolved_type)) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown type");
        }
    }
    if (kind == parser.ParserNode.array_type) {
        Int resolved_type = resolve_type_node(parse_node);
        hir.hir_store_set_type_id(node, resolved_type);
        if (!is_known_type(resolved_type)) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown type");
        } else if (type_is_inferred_array(resolved_type)) {
            Int parent = parser.parser_store_node_parent[parse_node];
            if (parent != 0) {
                Int parent_kind = parser.parser_store_node_kinds[parent];
                if (parent_kind != parser.ParserNode.local_decl) {
                    if (parent_kind != parser.ParserNode.global_decl) {
                        if (parent_kind != parser.ParserNode.tuple_local_decl) {
                            if (parent_kind != parser.ParserNode.tuple_global_decl) {
                                if (parent_kind != parser.ParserNode.array_init_expr) {
                                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "cannot infer array length here");
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    if (kind == parser.ParserNode.pointer_type) {
        Int resolved_type = resolve_type_node(parse_node);
        hir.hir_store_set_type_id(node, resolved_type);
        if (!is_known_type(resolved_type)) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown type");
        }
    }
    if (kind == parser.ParserNode.optional_type) {
        Int resolved_type = resolve_type_node(parse_node);
        hir.hir_store_set_type_id(node, resolved_type);
        if (!is_known_type(resolved_type)) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown type");
        }
    }
    if (kind == parser.ParserNode.mutable_type) {
        Int resolved_type = resolve_type_node(parse_node);
        hir.hir_store_set_type_id(node, resolved_type);
        if (!is_known_type(resolved_type)) {
            if (!type_parse_is_infer(current_source, parse_node)) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown type");
            }
        }
    }
    if (kind == parser.ParserNode.tuple_type) {
        Int resolved_type = resolve_type_node(parse_node);
        hir.hir_store_set_type_id(node, resolved_type);
        if (!is_known_type(resolved_type)) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown type");
        }
    }
    if (kind == parser.ParserNode.int_lit) {
        hir.hir_store_set_type_id(node, type_store.type_store_builtin_int);
    }
    if (kind == parser.ParserNode.bool_lit) {
        hir.hir_store_set_type_id(node, type_store.type_store_builtin_bool);
    }
    if (kind == parser.ParserNode.null_lit) {
        hir.hir_store_set_type_id(node, type_store.type_store_builtin_unknown);
    }
    if (kind == parser.ParserNode.string_lit) {
        hir.hir_store_set_type_id(node, type_store.type_store_builtin_uint8_slice);
    }
    if (kind == parser.ParserNode.array_lit) {
        hir.hir_store_set_type_id(node, type_store.type_store_builtin_unknown);
    }
    if (kind == parser.ParserNode.array_init_expr) {
        hir.hir_store_set_type_id(node, type_store.type_store_builtin_unknown);
    }
    if (kind == parser.ParserNode.tuple_lit) {
        hir.hir_store_set_type_id(node, type_store.type_store_builtin_unknown);
    }

    Int saved_type_owner = current_type_owner_symbol;
    Int saved_func_symbol = current_func_symbol;
    Int saved_return_type = current_return_type;
    Int saved_loop_depth = current_loop_depth;
    Int saved_switch_type = current_switch_type;
    Int saved_pattern_type = current_pattern_type;
    Int saved_pattern_bind_scope = current_pattern_bind_scope;
    Int saved_pattern_allow_binding = current_pattern_allow_binding;
    Int saved_init_owner_symbol = current_init_owner_symbol;
    Int saved_init_self_symbol = current_init_self_symbol;
    Int saved_static_method_symbol = current_static_method_symbol;
    Int saved_generic_context_count = current_generic_context_count;

    if (kind == parser.ParserNode.func_decl) {
        free_state_reset();
    }
    if (kind == parser.ParserNode.global_decl) {
        free_state_reset();
    }

    if (kind == parser.ParserNode.struct_decl) {
        Int name_node = parser.parser_store_node_first_child[parse_node];
        Int symbol_id = resolve_symbol(current_source, name_node, symbol_store.SymbolKind.type_name, 0);
        hir.hir_store_set_symbol_id(node, symbol_id);
        hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[symbol_id]);
        current_type_owner_symbol = symbol_id;
    }
    if (kind == parser.ParserNode.union_decl) {
        Int name_node = union_parse_name_node(parse_node);
        Int symbol_id = resolve_symbol(current_source, name_node, symbol_store.SymbolKind.type_name, 0);
        hir.hir_store_set_symbol_id(node, symbol_id);
        hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[symbol_id]);
        current_type_owner_symbol = symbol_id;
    }
    if (kind == parser.ParserNode.enum_decl) {
        Int name_node = parser.parser_store_node_first_child[parse_node];
        Int symbol_id = resolve_symbol(current_source, name_node, symbol_store.SymbolKind.enum_name, 0);
        hir.hir_store_set_symbol_id(node, symbol_id);
        hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[symbol_id]);
        current_type_owner_symbol = symbol_id;
        current_enum_next_value = 0;
    }
    if (kind == parser.ParserNode.func_decl) {
        Int type_node = parser.parser_store_node_first_child[parse_node];
        Int name_node = parser.parser_store_node_next_sibling[type_node];
        Int symbol_id = 0;
        if (parse_node == current_generic_func_lowering_parse) {
            symbol_id = current_generic_func_lowering_symbol;
        } else {
            Int parent = parser.parser_store_node_parent[parse_node];
            if (parent != 0) {
                Int parent_kind = parser.parser_store_node_kinds[parent];
                if (parent_kind == parser.ParserNode.struct_decl) {
                    symbol_id = resolve_symbol(current_source, name_node, symbol_store.SymbolKind.func, saved_type_owner);
                } else if (parent_kind == parser.ParserNode.union_decl) {
                    symbol_id = resolve_symbol(current_source, name_node, symbol_store.SymbolKind.func, saved_type_owner);
                } else if (parent_kind == parser.ParserNode.enum_decl) {
                    symbol_id = resolve_symbol(current_source, name_node, symbol_store.SymbolKind.func, saved_type_owner);
                }
            }
            if (symbol_id == 0) {
                symbol_id = resolve_symbol(current_source, name_node, symbol_store.SymbolKind.func, 0);
            }
        }
        hir.hir_store_set_symbol_id(node, symbol_id);
        hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[symbol_id]);
        current_func_symbol = symbol_id;
        current_return_type = symbol_store.symbol_store_type_ids[symbol_id];
        if (symbol_is_struct_init(symbol_id)) {
            current_return_type = type_store.type_store_builtin_void;
            current_init_owner_symbol = symbol_store.symbol_store_parent_ids[symbol_id];
            current_init_self_symbol = symbol_store.symbol_store_find_symbol_by_name_id(
                intern_pool.intern_pool_intern("self"),
                symbol_store.SymbolKind.param,
                symbol_id
            );
            current_type_owner_symbol = current_init_owner_symbol;
        } else if (symbol_is_nominal_static_func(symbol_id)) {
            current_type_owner_symbol = 0;
            current_static_method_symbol = symbol_id;
        } else if (symbol_is_nominal_instance_func(symbol_id)) {
            current_type_owner_symbol = 0;
        }
    }
    if (kind == parser.ParserNode.while_stmt) {
        current_loop_depth = current_loop_depth + 1;
    }
    if (kind == parser.ParserNode.for_stmt) {
        current_loop_depth = current_loop_depth + 1;
    }
    if (parse_node_is_generic_decl(parse_node)) {
        generic_context_push(current_source, parse_node);
    }

    if (kind == parser.ParserNode.for_stmt) {
        Int mode = parser.parser_store_node_aux[parse_node];
        if (mode == 0) {
            Int child = parser.parser_store_node_first_child[parse_node];
            while (child != 0) {
                Int lowered = lower_node(child);
                hir.hir_store_append_child(node, lowered);
                child = parser.parser_store_node_next_sibling[child];
            }
        } else if (mode == 1) {
            Int name_parse = parser.parser_store_node_first_child[parse_node];
            Int start_parse = parser.parser_store_node_next_sibling[name_parse];
            Int end_parse = parser.parser_store_node_next_sibling[start_parse];
            Int body_parse = parser.parser_store_node_next_sibling[end_parse];
            Int lowered_name = lower_node(name_parse);
            hir.hir_store_append_child(node, lowered_name);
            Int lowered_start = lower_node(start_parse);
            hir.hir_store_append_child(node, lowered_start);
            Int lowered_end = lower_node(end_parse);
            hir.hir_store_append_child(node, lowered_end);
            Int symbol_id = resolve_symbol(current_source, name_parse, symbol_store.SymbolKind.local, 0 - body_parse);
            if (symbol_id != 0) {
                symbol_store.symbol_store_set_type_id(symbol_id, type_store.type_store_builtin_int);
                hir.hir_store_set_symbol_id(node, symbol_id);
                hir.hir_store_set_type_id(node, type_store.type_store_builtin_int);
            }
            Int lowered_body = lower_node(body_parse);
            hir.hir_store_append_child(node, lowered_body);
        } else if (mode == 2) {
            Int name_parse = parser.parser_store_node_first_child[parse_node];
            Int iterable_parse = parser.parser_store_node_next_sibling[name_parse];
            Int body_parse = parser.parser_store_node_next_sibling[iterable_parse];
            Int lowered_name = lower_node(name_parse);
            hir.hir_store_append_child(node, lowered_name);
            Int lowered_iterable = lower_node(iterable_parse);
            Int iterable_type = hir.hir_store_node_type_ids[lowered_iterable];
            if (type_is_array(iterable_type)) {
                lowered_iterable = wrap_array_to_slice(lowered_iterable);
                iterable_type = hir.hir_store_node_type_ids[lowered_iterable];
            }
            hir.hir_store_append_child(node, lowered_iterable);
            Int loop_type = for_loop_symbol_type_from_iterable(lowered_iterable);
            Int symbol_id = resolve_symbol(current_source, name_parse, symbol_store.SymbolKind.local, 0 - body_parse);
            if (symbol_id != 0) {
                symbol_store.symbol_store_set_type_id(symbol_id, loop_type);
                hir.hir_store_set_symbol_id(node, symbol_id);
                hir.hir_store_set_type_id(node, loop_type);
            }
            Int lowered_body = lower_node(body_parse);
            hir.hir_store_append_child(node, lowered_body);
        } else if (mode == 4) {
            Int binding_parse = parser.parser_store_node_first_child[parse_node];
            Int iterable_parse = parser.parser_store_node_next_sibling[binding_parse];
            Int body_parse = parser.parser_store_node_next_sibling[iterable_parse];
            if (parse_is_indexed_call(iterable_parse)) {
                Int indexed_count = for_binding_parse_count(binding_parse);
                if (indexed_count != 2) {
                    diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[binding_parse], parser.parser_store_node_ends[binding_parse], "for indexed binding arity mismatch");
                    Int lowered_iterable = lower_node(parse_indexed_call_base(iterable_parse));
                    hir.hir_store_append_child(node, lowered_iterable);
                    Int lowered_body = hir.hir_store_new_node(
                        hir.HirNode.block,
                        parser.parser_store_node_starts[body_parse],
                        parser.parser_store_node_ends[body_parse]
                    );
                    hir.hir_store_append_child(node, lowered_body);
                } else {
                    Int lowered_iterable = lower_node(parse_indexed_call_base(iterable_parse));
                    Int iterable_type = hir.hir_store_node_type_ids[lowered_iterable];
                    if (type_is_array(iterable_type)) {
                        lowered_iterable = wrap_array_to_slice(lowered_iterable);
                        iterable_type = hir.hir_store_node_type_ids[lowered_iterable];
                    }
                    Int item_type = for_loop_symbol_type_from_iterable(lowered_iterable);
                    if (!is_known_type(item_type)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_iterable], hir.hir_store_node_ends[lowered_iterable], "for iterable must be array or slice");
                    }
                    Int index_binding_parse = for_binding_parse_child(binding_parse, 0);
                    Int item_binding_parse = for_binding_parse_child(binding_parse, 1);
                    if (!for_binding_parse_is_leaf(index_binding_parse)) {
                        diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[index_binding_parse], parser.parser_store_node_ends[index_binding_parse], "for indexed binding index must be single name");
                        hir.hir_store_append_child(node, lowered_iterable);
                        Int lowered_body = hir.hir_store_new_node(
                            hir.HirNode.block,
                            parser.parser_store_node_starts[body_parse],
                            parser.parser_store_node_ends[body_parse]
                        );
                        hir.hir_store_append_child(node, lowered_body);
                    } else {
                        Int index_name_parse = for_binding_leaf_name_parse(index_binding_parse);
                        Int index_type_parse = for_binding_leaf_type_parse(index_binding_parse);
                        Int index_symbol = resolve_symbol(current_source, index_name_parse, symbol_store.SymbolKind.local, 0 - body_parse);
                        if (index_symbol != 0) {
                            symbol_store.symbol_store_set_type_id(index_symbol, type_store.type_store_builtin_int);
                        }
                        hir.hir_store_set_aux(node, 5);
                        if (index_symbol != 0) {
                            hir.hir_store_set_symbol_id(node, index_symbol);
                        }
                        Int lowered_index_name = lower_node(index_name_parse);
                        if (index_symbol != 0) {
                            hir.hir_store_set_symbol_id(lowered_index_name, index_symbol);
                            hir.hir_store_set_type_id(lowered_index_name, type_store.type_store_builtin_int);
                        }
                        if (!type_parse_is_infer(current_source, index_type_parse)) {
                            Int lowered_index_type = lower_node(index_type_parse);
                            if (hir.hir_store_node_type_ids[lowered_index_type] != type_store.type_store_builtin_int) {
                                diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[index_type_parse], parser.parser_store_node_ends[index_type_parse], "for indexed binding index type mismatch");
                            }
                        }

                        Int item_symbol = 0;
                        Int lowered_item_name = 0;
                        if (for_binding_parse_is_leaf(item_binding_parse)) {
                            Int item_name_parse = for_binding_leaf_name_parse(item_binding_parse);
                            Int item_type_parse = for_binding_leaf_type_parse(item_binding_parse);
                            item_symbol = resolve_symbol(current_source, item_name_parse, symbol_store.SymbolKind.local, 0 - body_parse);
                            if (item_symbol != 0) {
                                symbol_store.symbol_store_set_type_id(item_symbol, item_type);
                            }
                            lowered_item_name = lower_node(item_name_parse);
                            if (item_symbol != 0) {
                                hir.hir_store_set_symbol_id(lowered_item_name, item_symbol);
                                hir.hir_store_set_type_id(lowered_item_name, item_type);
                            }
                            if (!type_parse_is_infer(current_source, item_type_parse)) {
                                Int lowered_item_type = lower_node(item_type_parse);
                                if (is_known_type(hir.hir_store_node_type_ids[lowered_item_type])) {
                                    if (hir.hir_store_node_type_ids[lowered_item_type] != item_type) {
                                        diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[item_type_parse], parser.parser_store_node_ends[item_type_parse], "for indexed binding item type mismatch");
                                    }
                                }
                            }
                        } else {
                            seed_for_binding_symbol_types(item_binding_parse, item_type, 0 - body_parse, "for indexed binding item type mismatch");
                            UInt8[] temp_name = next_tuple_temp_name();
                            item_symbol = new_synthetic_local_symbol(temp_name, item_type, 0 - body_parse);
                            lowered_item_name = make_synthetic_ident_node(item_symbol, item_type, hir.hir_store_node_starts[lowered_iterable], hir.hir_store_node_ends[lowered_iterable]);
                        }
                        hir.hir_store_append_child(node, lowered_index_name);
                        hir.hir_store_append_child(node, lowered_item_name);
                        hir.hir_store_append_child(node, lowered_iterable);
                        Int lowered_body = lower_node(body_parse);
                        if (!for_binding_parse_is_leaf(item_binding_parse)) {
                            Int lowered_item_value = make_synthetic_ident_node(item_symbol, item_type, hir.hir_store_node_starts[lowered_iterable], hir.hir_store_node_ends[lowered_iterable]);
                            Int binding_stmt = build_for_binding_decl_stmt(
                                item_binding_parse,
                                lowered_item_value,
                                item_type,
                                0 - body_parse,
                                "for indexed binding item type mismatch"
                            );
                            hir_prepend_child(lowered_body, binding_stmt);
                        }
                        hir.hir_store_append_child(node, lowered_body);
                    }
                }
            } else {
                Int lowered_iterable = lower_node(iterable_parse);
                Int iterable_type = hir.hir_store_node_type_ids[lowered_iterable];
                if (type_is_array(iterable_type)) {
                    lowered_iterable = wrap_array_to_slice(lowered_iterable);
                    iterable_type = hir.hir_store_node_type_ids[lowered_iterable];
                }
                Int loop_type = for_loop_symbol_type_from_iterable(lowered_iterable);
                if (!type_is_tuple(loop_type)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_iterable], hir.hir_store_node_ends[lowered_iterable], "for tuple binding requires tuple element");
                    hir.hir_store_append_child(node, lowered_iterable);
                    Int lowered_body = lower_node(body_parse);
                    hir.hir_store_append_child(node, lowered_body);
                } else {
                    seed_for_binding_symbol_types(binding_parse, loop_type, 0 - body_parse, "for iterable element type mismatch");
                    UInt8[] temp_name = next_tuple_temp_name();
                    Int temp_symbol = new_synthetic_local_symbol(temp_name, loop_type, 0 - body_parse);
                    Int lowered_name = make_synthetic_ident_node(temp_symbol, loop_type, hir.hir_store_node_starts[lowered_iterable], hir.hir_store_node_starts[lowered_iterable]);
                    hir.hir_store_set_aux(node, 2);
                    hir.hir_store_set_symbol_id(node, temp_symbol);
                    hir.hir_store_set_type_id(node, loop_type);
                    hir.hir_store_append_child(node, lowered_name);
                    hir.hir_store_append_child(node, lowered_iterable);
                    Int lowered_body = lower_node(body_parse);
                    Int temp_ident = make_synthetic_ident_node(temp_symbol, loop_type, hir.hir_store_node_starts[lowered_iterable], hir.hir_store_node_ends[lowered_iterable]);
                    Int binding_stmt = build_for_binding_decl_stmt(
                        binding_parse,
                        temp_ident,
                        loop_type,
                        0 - body_parse,
                        "for iterable element type mismatch"
                    );
                    hir_prepend_child(lowered_body, binding_stmt);
                    hir.hir_store_append_child(node, lowered_body);
                }
            }
        } else {
            Int type_parse = parser.parser_store_node_first_child[parse_node];
            Int name_parse = parser.parser_store_node_next_sibling[type_parse];
            Int iterable_parse = parser.parser_store_node_next_sibling[name_parse];
            Int body_parse = parser.parser_store_node_next_sibling[iterable_parse];
            Int lowered_type = lower_node(type_parse);
            hir.hir_store_append_child(node, lowered_type);
            Int lowered_name = lower_node(name_parse);
            hir.hir_store_append_child(node, lowered_name);
            Int lowered_iterable = lower_node(iterable_parse);
            Int iterable_type = hir.hir_store_node_type_ids[lowered_iterable];
            if (type_is_array(iterable_type)) {
                lowered_iterable = wrap_array_to_slice(lowered_iterable);
                iterable_type = hir.hir_store_node_type_ids[lowered_iterable];
            }
            hir.hir_store_append_child(node, lowered_iterable);
            Int expected_type = hir.hir_store_node_type_ids[lowered_type];
            Int loop_type = for_loop_symbol_type_from_iterable(lowered_iterable);
            if (type_parse_is_infer(current_source, type_parse)) {
                expected_type = infer_wrapped_type_from_parse(type_parse, loop_type);
                if (is_known_type(expected_type)) {
                    set_inferred_type_on_lowered_type_node(lowered_type, expected_type);
                }
            }
            Int symbol_id = resolve_symbol(current_source, name_parse, symbol_store.SymbolKind.local, 0 - body_parse);
            if (symbol_id != 0) {
                symbol_store.symbol_store_set_type_id(symbol_id, expected_type);
                hir.hir_store_set_symbol_id(node, symbol_id);
                hir.hir_store_set_type_id(node, expected_type);
                hir.hir_store_set_symbol_id(lowered_name, symbol_id);
                hir.hir_store_set_type_id(lowered_name, expected_type);
            }
            if (is_known_type(loop_type)) {
                if (is_known_type(expected_type)) {
                    if (type_strip_mutable(loop_type) != type_strip_mutable(expected_type)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_iterable], hir.hir_store_node_ends[lowered_iterable], "for iterable element type mismatch");
                    }
                }
            }
            Int lowered_body = lower_node(body_parse);
            hir.hir_store_append_child(node, lowered_body);
        }
    } else if (kind == parser.ParserNode.tuple_local_decl) {
        Int count = tuple_decl_binding_count(parse_node);
        Int init_parse = tuple_decl_init_parse(parse_node);
        if (init_parse == 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "tuple destructuring requires initializer");
        } else {
            Int scope_id = local_scope_id(parse_node);
            if (scope_id == 0) {
                scope_id = saved_func_symbol;
            }
            Int lowered_init_value = lower_node(init_parse);
            Int init_type = hir.hir_store_node_type_ids[lowered_init_value];
            if (!type_is_tuple(init_type)) {
                diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[init_parse], parser.parser_store_node_ends[init_parse], "tuple destructuring requires tuple value");
                return node;
            }
            if (type_store.type_store_tuple_count(init_type) != count) {
                diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[init_parse], parser.parser_store_node_ends[init_parse], "tuple destructuring arity mismatch");
                return node;
            }
            Bool use_temp = parser.parser_store_node_kinds[init_parse] != parser.ParserNode.tuple_lit;
            Int temp_ident = 0;
            if (use_temp != 0) {
                UInt8[] temp_name = next_tuple_temp_name();
                Int temp_symbol = new_synthetic_local_symbol(temp_name, init_type, scope_id);
                Int temp_decl = hir.hir_store_new_node(
                    hir.HirNode.local_decl,
                    parser.parser_store_node_starts[init_parse],
                    parser.parser_store_node_ends[init_parse]
                );
                Int temp_type = make_synthetic_type_node(init_type, parser.parser_store_node_starts[init_parse], parser.parser_store_node_starts[init_parse]);
                Int temp_name_node = make_synthetic_ident_node(temp_symbol, init_type, 0, 0);
                hir.hir_store_append_child(temp_decl, temp_type);
                hir.hir_store_append_child(temp_decl, temp_name_node);
                hir.hir_store_append_child(temp_decl, lowered_init_value);
                hir.hir_store_set_symbol_id(temp_decl, temp_symbol);
                hir.hir_store_set_type_id(temp_decl, init_type);
                hir.hir_store_append_child(node, temp_decl);
                temp_ident = make_synthetic_ident_node(temp_symbol, init_type, 0, 0);
            }
            Int i = 0;
            while (i < count) {
                Int type_parse = tuple_decl_binding_type_parse(parse_node, i);
                Int name_parse = tuple_decl_binding_name_parse(parse_node, i);
                Int item_parse = 0;
                if (parser.parser_store_node_kinds[init_parse] == parser.ParserNode.tuple_lit) {
                    item_parse = tuple_lit_item_parse(init_parse, i);
                }
                Int child_decl = hir.hir_store_new_node(
                    hir.HirNode.local_decl,
                    parser.parser_store_node_starts[type_parse],
                    parser.parser_store_node_ends[init_parse]
                );
                Int lowered_type = lower_node(type_parse);
                Int lowered_name = lower_node(name_parse);
                Int lowered_init = 0;
                if (use_temp != 0) {
                    lowered_init = make_tuple_item_index_expr(
                        temp_ident,
                        i,
                        type_store.type_store_tuple_item_type(init_type, i),
                        parser.parser_store_node_starts[init_parse],
                        parser.parser_store_node_ends[init_parse]
                    );
                } else {
                    lowered_init = lower_node(item_parse);
                }
                hir.hir_store_append_child(child_decl, lowered_type);
                hir.hir_store_append_child(child_decl, lowered_name);
                hir.hir_store_append_child(child_decl, lowered_init);
                Int symbol_id = resolve_symbol(current_source, name_parse, symbol_store.SymbolKind.local, scope_id);
                if (symbol_id != 0) {
                    hir.hir_store_set_symbol_id(child_decl, symbol_id);
                    hir.hir_store_set_type_id(child_decl, symbol_store.symbol_store_type_ids[symbol_id]);
                    Int declared_type = hir.hir_store_node_type_ids[lowered_type];
                    if (type_parse_is_infer(current_source, type_parse)) {
                        declared_type = infer_wrapped_type_from_parse(type_parse, hir.hir_store_node_type_ids[lowered_init]);
                        if (!is_known_type(declared_type)) {
                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_init], hir.hir_store_node_ends[lowered_init], "cannot infer local type");
                        } else {
                            symbol_store.symbol_store_set_type_id(symbol_id, declared_type);
                            set_inferred_type_on_lowered_type_node(lowered_type, declared_type);
                            hir.hir_store_set_type_id(lowered_name, declared_type);
                            hir.hir_store_set_type_id(child_decl, declared_type);
                        }
                    }
                    if (type_is_inferred_array(declared_type)) {
                        declared_type = infer_concrete_array_type_from_value(declared_type, lowered_init);
                        if (!is_known_type(declared_type)) {
                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_init], hir.hir_store_node_ends[lowered_init], "cannot infer array length");
                        } else {
                            symbol_store.symbol_store_set_type_id(symbol_id, declared_type);
                            hir.hir_store_set_type_id(lowered_type, declared_type);
                            hir.hir_store_set_type_id(lowered_name, declared_type);
                            hir.hir_store_set_type_id(child_decl, declared_type);
                        }
                    }
                    if (is_known_type(declared_type)) {
                        Int coerced_init = coerce_expr_to_type(lowered_init, declared_type);
                        if (coerced_init != lowered_init) {
                            hir.hir_store_set_next_sibling(lowered_name, coerced_init);
                            lowered_init = coerced_init;
                        }
                        if (hir.hir_store_node_kinds[lowered_init] == hir.HirNode.array_lit) {
                            check_array_literal_against_type(lowered_init, declared_type);
                        } else if (!is_string_compatible_array(declared_type, lowered_init)) {
                            expect_same_type(lowered_type, lowered_init, "local initializer type mismatch");
                        }
                    }
                }
                hir.hir_store_append_child(node, child_decl);
                i = i + 1;
            }
        }
    } else if (kind == parser.ParserNode.tuple_global_decl) {
        Int count = tuple_decl_binding_count(parse_node);
        Int init_parse = tuple_decl_init_parse(parse_node);
        if (init_parse == 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "tuple destructuring requires initializer");
        } else if (parser.parser_store_node_kinds[init_parse] != parser.ParserNode.tuple_lit) {
            diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[init_parse], parser.parser_store_node_ends[init_parse], "tuple destructuring currently requires tuple literal");
        } else if (parser.parser_store_node_aux[init_parse] != count) {
            diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[init_parse], parser.parser_store_node_ends[init_parse], "tuple destructuring arity mismatch");
        } else {
            Int i = 0;
            while (i < count) {
                Int type_parse = tuple_decl_binding_type_parse(parse_node, i);
                Int name_parse = tuple_decl_binding_name_parse(parse_node, i);
                Int item_parse = tuple_lit_item_parse(init_parse, i);
                Int child_decl = hir.hir_store_new_node(
                    hir.HirNode.global_decl,
                    parser.parser_store_node_starts[type_parse],
                    parser.parser_store_node_ends[item_parse]
                );
                Int lowered_type = lower_node(type_parse);
                Int lowered_name = lower_node(name_parse);
                Int lowered_init = lower_node(item_parse);
                hir.hir_store_append_child(child_decl, lowered_type);
                hir.hir_store_append_child(child_decl, lowered_name);
                hir.hir_store_append_child(child_decl, lowered_init);
                Int symbol_id = resolve_symbol(current_source, name_parse, symbol_store.SymbolKind.global, 0);
                if (symbol_id != 0) {
                    hir.hir_store_set_symbol_id(child_decl, symbol_id);
                    hir.hir_store_set_type_id(child_decl, symbol_store.symbol_store_type_ids[symbol_id]);
                    Int declared_type = hir.hir_store_node_type_ids[lowered_type];
                    if (type_parse_is_infer(current_source, type_parse)) {
                        declared_type = infer_wrapped_type_from_parse(type_parse, hir.hir_store_node_type_ids[lowered_init]);
                        if (!is_known_type(declared_type)) {
                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_init], hir.hir_store_node_ends[lowered_init], "cannot infer global type");
                        } else {
                            symbol_store.symbol_store_set_type_id(symbol_id, declared_type);
                            set_inferred_type_on_lowered_type_node(lowered_type, declared_type);
                            hir.hir_store_set_type_id(lowered_name, declared_type);
                            hir.hir_store_set_type_id(child_decl, declared_type);
                        }
                    }
                    if (type_is_inferred_array(declared_type)) {
                        declared_type = infer_concrete_array_type_from_value(declared_type, lowered_init);
                        if (!is_known_type(declared_type)) {
                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_init], hir.hir_store_node_ends[lowered_init], "cannot infer array length");
                        } else {
                            symbol_store.symbol_store_set_type_id(symbol_id, declared_type);
                            hir.hir_store_set_type_id(lowered_type, declared_type);
                            hir.hir_store_set_type_id(lowered_name, declared_type);
                            hir.hir_store_set_type_id(child_decl, declared_type);
                        }
                    }
                    if (is_known_type(declared_type)) {
                        Int coerced_init = coerce_expr_to_type(lowered_init, declared_type);
                        if (coerced_init != lowered_init) {
                            hir.hir_store_set_next_sibling(lowered_name, coerced_init);
                            lowered_init = coerced_init;
                        }
                        if (hir.hir_store_node_kinds[lowered_init] == hir.HirNode.array_lit) {
                            check_array_literal_against_type(lowered_init, declared_type);
                        } else if (!is_string_compatible_array(declared_type, lowered_init)) {
                            expect_same_type(lowered_type, lowered_init, "global initializer type mismatch");
                        }
                    }
                }
                hir.hir_store_append_child(node, child_decl);
                i = i + 1;
            }
        }
    } else if (kind == parser.ParserNode.if_stmt) {
        Int condition_parse = parser.parser_store_node_first_child[parse_node];
        Int then_parse = parser.parser_store_node_next_sibling[condition_parse];
        Int else_parse = parser.parser_store_node_next_sibling[then_parse];
        Bool lowered_pattern_condition = 0;
        if (condition_parse != 0) {
            if (parser.parser_store_node_kinds[condition_parse] == parser.ParserNode.binary_expr) {
                Int condition_op = parser.parser_store_node_aux[condition_parse];
                Int left_parse = parser.parser_store_node_first_child[condition_parse];
                Int right_parse = parser.parser_store_node_next_sibling[left_parse];
                if (right_parse != 0) {
                    if (parser.parser_store_node_kinds[right_parse] == parser.ParserNode.union_pattern_expr) {
                        Int condition_node = hir.hir_store_new_node(
                            hir.HirNode.binary_expr,
                            parser.parser_store_node_starts[condition_parse],
                            parser.parser_store_node_ends[condition_parse]
                        );
                        hir.hir_store_set_aux(condition_node, condition_op);
                        Int lowered_left = lower_node(left_parse);
                        hir.hir_store_append_child(condition_node, lowered_left);
                        current_pattern_type = hir.hir_store_node_type_ids[lowered_left];
                        if (condition_op == hir.HirBinaryOp.eq) {
                            current_pattern_bind_scope = 0 - then_parse;
                            current_pattern_allow_binding = 1;
                        } else {
                            current_pattern_bind_scope = 0;
                            current_pattern_allow_binding = 0;
                        }
                        Int lowered_right = lower_node(right_parse);
                        hir.hir_store_append_child(condition_node, lowered_right);
                        hir.hir_store_set_type_id(condition_node, type_store.type_store_builtin_bool);
                        current_pattern_type = saved_pattern_type;
                        current_pattern_bind_scope = saved_pattern_bind_scope;
                        current_pattern_allow_binding = saved_pattern_allow_binding;
                        hir.hir_store_append_child(node, condition_node);
                        Int then_narrow_symbol = 0;
                        Int else_narrow_symbol = 0;
                        if (condition_op == hir.HirBinaryOp.ne) {
                            if (then_parse != 0) {
                                if (parser.parser_store_node_kinds[then_parse] == parser.ParserNode.block) {
                                    then_narrow_symbol = register_optional_narrow_symbol(condition_node, then_parse);
                                }
                            }
                        } else if (condition_op == hir.HirBinaryOp.eq) {
                            if (else_parse != 0) {
                                if (parser.parser_store_node_kinds[else_parse] == parser.ParserNode.block) {
                                    else_narrow_symbol = register_optional_narrow_symbol(condition_node, else_parse);
                                }
                            }
                        }
                        Int lowered_then = lower_node(then_parse);
                        hir.hir_store_append_child(node, lowered_then);
                        Int lowered_else = 0;
                        if (else_parse != 0) {
                            lowered_else = lower_node(else_parse);
                            hir.hir_store_append_child(node, lowered_else);
                        }
                        prepend_if_optional_narrow_decl(condition_node, lowered_then, then_narrow_symbol);
                        prepend_if_optional_narrow_decl(condition_node, lowered_else, else_narrow_symbol);
                        lowered_pattern_condition = 1;
                    }
                }
            }
        }
        if (lowered_pattern_condition == 0) {
            Int lowered_condition = lower_node(condition_parse);
            hir.hir_store_append_child(node, lowered_condition);
            Int then_narrow_symbol = 0;
            Int else_narrow_symbol = 0;
            Int narrowed_op = hir.hir_store_node_aux[lowered_condition];
            if (narrowed_op == hir.HirBinaryOp.ne) {
                if (parser.parser_store_node_kinds[then_parse] == parser.ParserNode.block) {
                    then_narrow_symbol = register_optional_narrow_symbol(lowered_condition, then_parse);
                }
            } else if (narrowed_op == hir.HirBinaryOp.eq) {
                if (else_parse != 0) {
                    if (parser.parser_store_node_kinds[else_parse] == parser.ParserNode.block) {
                        else_narrow_symbol = register_optional_narrow_symbol(lowered_condition, else_parse);
                    }
                }
            }
            Int lowered_then = lower_node(then_parse);
            hir.hir_store_append_child(node, lowered_then);
            Int lowered_else = 0;
            if (else_parse != 0) {
                lowered_else = lower_node(else_parse);
                hir.hir_store_append_child(node, lowered_else);
            }
            prepend_if_optional_narrow_decl(lowered_condition, lowered_then, then_narrow_symbol);
            prepend_if_optional_narrow_decl(lowered_condition, lowered_else, else_narrow_symbol);
        }
    } else if (kind == parser.ParserNode.union_pattern_expr) {
        Int label_parse = union_pattern_label_parse(parse_node);
        Int bind_count = union_pattern_binding_count_parse(parse_node);
        Int optional_pattern_kind = optional_pattern_kind_parse(label_parse);
        Bool option_member_label = parse_is_option_member_expr(label_parse);
        Int lowered_label = 0;
        if (option_member_label != 0) {
            Int optional_pattern_is_some = 0;
            if (optional_pattern_kind == 1) {
                optional_pattern_is_some = 1;
            }
            lowered_label = make_optional_pattern_label_hir(
                optional_pattern_is_some,
                parser.parser_store_node_starts[label_parse],
                parser.parser_store_node_ends[label_parse]
            );
        } else {
            lowered_label = lower_node(label_parse);
        }
        hir.hir_store_append_child(node, lowered_label);
        Int label_symbol = hir.hir_store_node_symbol_ids[lowered_label];
        if (type_is_union(current_pattern_type)) {
            Int owner_symbol = find_type_owner_symbol(current_pattern_type);
            Int coerced_label = coerce_expr_to_type(lowered_label, current_pattern_type);
            if (coerced_label != lowered_label) {
                hir.hir_store_set_first_child(node, coerced_label);
                lowered_label = coerced_label;
            }
            label_symbol = hir.hir_store_node_symbol_ids[lowered_label];
            if (parser.parser_store_node_kinds[label_parse] == parser.ParserNode.ident) {
                if (owner_symbol != 0) {
                    Int member_symbol = resolve_symbol(current_source, label_parse, symbol_store.SymbolKind.union_member, owner_symbol);
                    if (member_symbol != 0) {
                        hir.hir_store_set_symbol_id(lowered_label, member_symbol);
                        hir.hir_store_set_type_id(lowered_label, union_tag_type(current_pattern_type));
                        label_symbol = member_symbol;
                    }
                }
            }
            hir.hir_store_set_type_id(node, current_pattern_type);
        } else if (type_is_optional(current_pattern_type)) {
            hir.hir_store_set_type_id(node, current_pattern_type);
            if (optional_pattern_kind == 0) {
                diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[label_parse], parser.parser_store_node_ends[label_parse], "optional pattern requires Option.some or Option.none");
            } else {
                hir.hir_store_set_symbol_id(node, ensure_optional_value_field_symbol(type_optional_payload(current_pattern_type)));
            }
        }
        if (bind_count != 0) {
            if (current_pattern_allow_binding == 0) {
                Int bind_parse = union_pattern_binding_parse_item(parse_node, 0);
                diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[bind_parse], parser.parser_store_node_ends[bind_parse], "union pattern binding requires == condition");
            } else if (type_is_optional(current_pattern_type)) {
                Int payload_type = type_optional_payload(current_pattern_type);
                if (optional_pattern_kind == 0) {
                    bind_count = 0;
                } else if (optional_pattern_kind != 1) {
                    Int bind_parse = union_pattern_binding_parse_item(parse_node, 0);
                    diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[bind_parse], parser.parser_store_node_ends[bind_parse], "option none has no payload");
                } else if (payload_type == type_store.type_store_builtin_void) {
                    Int bind_parse = union_pattern_binding_parse_item(parse_node, 0);
                    diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[bind_parse], parser.parser_store_node_ends[bind_parse], "option some has no payload");
                } else if (bind_count == 1) {
                    Int bind_parse = union_pattern_binding_parse_item(parse_node, 0);
                    payload_type = mutable_binding_type(bind_parse, payload_type);
                    register_unique_symbol(
                        current_source,
                        symbol_store.SymbolKind.local,
                        parser.parser_store_node_starts[bind_parse],
                        parser.parser_store_node_ends[bind_parse],
                        payload_type,
                        current_pattern_bind_scope,
                        "duplicate local"
                    );
                    Int lowered_bind = hir.hir_store_new_node(
                        hir.HirNode.ident,
                        parser.parser_store_node_starts[bind_parse],
                        parser.parser_store_node_ends[bind_parse]
                    );
                    Int bind_symbol = resolve_symbol(current_source, bind_parse, symbol_store.SymbolKind.local, current_pattern_bind_scope);
                    if (bind_symbol != 0) {
                        hir.hir_store_set_symbol_id(lowered_bind, bind_symbol);
                        hir.hir_store_set_type_id(lowered_bind, symbol_store.symbol_store_type_ids[bind_symbol]);
                    }
                    hir.hir_store_append_child(node, lowered_bind);
                } else {
                    if (!type_is_tuple(payload_type)) {
                        Int bind_parse = union_pattern_binding_parse_item(parse_node, 0);
                        diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[bind_parse], parser.parser_store_node_ends[bind_parse], "option tuple binding requires tuple payload");
                    } else if (type_store.type_store_tuple_count(payload_type) != bind_count) {
                        Int bind_parse = union_pattern_binding_parse_item(parse_node, 0);
                        diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[bind_parse], parser.parser_store_node_ends[bind_parse], "option tuple binding arity mismatch");
                    } else {
                        Int i = 0;
                        while (i < bind_count) {
                            Int bind_parse = union_pattern_binding_parse_item(parse_node, i);
                            Int bind_type = type_store.type_store_tuple_item_type(payload_type, i);
                            bind_type = mutable_binding_type(bind_parse, bind_type);
                            register_unique_symbol(
                                current_source,
                                symbol_store.SymbolKind.local,
                                parser.parser_store_node_starts[bind_parse],
                                parser.parser_store_node_ends[bind_parse],
                                bind_type,
                                current_pattern_bind_scope,
                                "duplicate local"
                            );
                            Int lowered_bind = hir.hir_store_new_node(
                                hir.HirNode.ident,
                                parser.parser_store_node_starts[bind_parse],
                                parser.parser_store_node_ends[bind_parse]
                            );
                            Int bind_symbol = resolve_symbol(current_source, bind_parse, symbol_store.SymbolKind.local, current_pattern_bind_scope);
                            if (bind_symbol != 0) {
                                hir.hir_store_set_symbol_id(lowered_bind, bind_symbol);
                                hir.hir_store_set_type_id(lowered_bind, symbol_store.symbol_store_type_ids[bind_symbol]);
                            }
                            hir.hir_store_append_child(node, lowered_bind);
                            i = i + 1;
                        }
                    }
                }
            } else if (label_symbol != 0) {
                Int payload_type = symbol_store.symbol_store_type_ids[label_symbol];
                if (payload_type == type_store.type_store_builtin_void) {
                    Int bind_parse = union_pattern_binding_parse_item(parse_node, 0);
                    diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[bind_parse], parser.parser_store_node_ends[bind_parse], "union case has no payload");
                } else if (bind_count == 1) {
                    Int bind_parse = union_pattern_binding_parse_item(parse_node, 0);
                    payload_type = mutable_binding_type(bind_parse, payload_type);
                    register_unique_symbol(
                        current_source,
                        symbol_store.SymbolKind.local,
                        parser.parser_store_node_starts[bind_parse],
                        parser.parser_store_node_ends[bind_parse],
                        payload_type,
                        current_pattern_bind_scope,
                        "duplicate local"
                    );
                    Int lowered_bind = hir.hir_store_new_node(
                        hir.HirNode.ident,
                        parser.parser_store_node_starts[bind_parse],
                        parser.parser_store_node_ends[bind_parse]
                    );
                    Int bind_symbol = resolve_symbol(current_source, bind_parse, symbol_store.SymbolKind.local, current_pattern_bind_scope);
                    if (bind_symbol != 0) {
                        hir.hir_store_set_symbol_id(lowered_bind, bind_symbol);
                        hir.hir_store_set_type_id(lowered_bind, symbol_store.symbol_store_type_ids[bind_symbol]);
                    }
                    hir.hir_store_append_child(node, lowered_bind);
                } else {
                    if (!type_is_tuple(payload_type)) {
                        Int bind_parse = union_pattern_binding_parse_item(parse_node, 0);
                        diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[bind_parse], parser.parser_store_node_ends[bind_parse], "union tuple binding requires tuple payload");
                    } else if (type_store.type_store_tuple_count(payload_type) != bind_count) {
                        Int bind_parse = union_pattern_binding_parse_item(parse_node, 0);
                        diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[bind_parse], parser.parser_store_node_ends[bind_parse], "union tuple binding arity mismatch");
                    } else {
                        Int i = 0;
                        while (i < bind_count) {
                            Int bind_parse = union_pattern_binding_parse_item(parse_node, i);
                            Int bind_type = type_store.type_store_tuple_item_type(payload_type, i);
                            bind_type = mutable_binding_type(bind_parse, bind_type);
                            register_unique_symbol(
                                current_source,
                                symbol_store.SymbolKind.local,
                                parser.parser_store_node_starts[bind_parse],
                                parser.parser_store_node_ends[bind_parse],
                                bind_type,
                                current_pattern_bind_scope,
                                "duplicate local"
                            );
                            Int lowered_bind = hir.hir_store_new_node(
                                hir.HirNode.ident,
                                parser.parser_store_node_starts[bind_parse],
                                parser.parser_store_node_ends[bind_parse]
                            );
                            Int bind_symbol = resolve_symbol(current_source, bind_parse, symbol_store.SymbolKind.local, current_pattern_bind_scope);
                            if (bind_symbol != 0) {
                                hir.hir_store_set_symbol_id(lowered_bind, bind_symbol);
                                hir.hir_store_set_type_id(lowered_bind, symbol_store.symbol_store_type_ids[bind_symbol]);
                            }
                            hir.hir_store_append_child(node, lowered_bind);
                            i = i + 1;
                        }
                    }
                }
            }
        }
    } else if (kind == parser.ParserNode.switch_case) {
        Int label_parse = switch_case_label_parse(parse_node);
        Int bind_parse = switch_case_binding_parse(parse_node);
        Int body_parse = switch_case_body_parse(parse_node);
        Int saved_case_pattern_type = current_pattern_type;
        Int saved_case_pattern_bind_scope = current_pattern_bind_scope;
        Int saved_case_pattern_allow_binding = current_pattern_allow_binding;
        if (type_is_union(saved_switch_type)) {
            if (parser.parser_store_node_kinds[label_parse] == parser.ParserNode.union_pattern_expr) {
                current_pattern_type = saved_switch_type;
                current_pattern_bind_scope = 0 - parse_node;
                current_pattern_allow_binding = 1;
            }
        } else if (type_is_optional(saved_switch_type)) {
            if (parser.parser_store_node_kinds[label_parse] == parser.ParserNode.union_pattern_expr) {
                current_pattern_type = saved_switch_type;
                current_pattern_bind_scope = 0 - parse_node;
                current_pattern_allow_binding = 1;
            }
        }
        Int lowered_label = lower_node(label_parse);
        current_pattern_type = saved_case_pattern_type;
        current_pattern_bind_scope = saved_case_pattern_bind_scope;
        current_pattern_allow_binding = saved_case_pattern_allow_binding;
        hir.hir_store_append_child(node, lowered_label);
        Bool should_lower_bind = bind_parse != 0;
        if (type_is_union(saved_switch_type)) {
            Int owner_symbol = find_type_owner_symbol(saved_switch_type);
            Int label_symbol = hir.hir_store_node_symbol_ids[lowered_label];
            if (hir.hir_store_node_kinds[lowered_label] == hir.HirNode.union_pattern_expr) {
                check_union_pattern_against_type(lowered_label, saved_switch_type);
                label_symbol = hir.hir_store_node_symbol_ids[lowered_label];
            }
            if (parser.parser_store_node_kinds[label_parse] == parser.ParserNode.ident) {
                if (owner_symbol != 0) {
                    Int member_symbol = resolve_symbol(current_source, label_parse, symbol_store.SymbolKind.union_member, owner_symbol);
                    if (member_symbol != 0) {
                        hir.hir_store_set_symbol_id(lowered_label, member_symbol);
                        hir.hir_store_set_type_id(lowered_label, union_tag_type(saved_switch_type));
                        label_symbol = member_symbol;
                    }
                }
            }
                if (bind_parse != 0) {
                    if (label_symbol != 0) {
                        Int payload_type = symbol_store.symbol_store_type_ids[label_symbol];
                        if (payload_type == type_store.type_store_builtin_void) {
                            diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[bind_parse], parser.parser_store_node_ends[bind_parse], "union case has no payload");
                            should_lower_bind = 0;
                        } else {
                            payload_type = mutable_binding_type(bind_parse, payload_type);
                            register_unique_symbol(
                                current_source,
                                symbol_store.SymbolKind.local,
                                parser.parser_store_node_starts[bind_parse],
                            parser.parser_store_node_ends[bind_parse],
                            payload_type,
                            0 - parse_node,
                            "duplicate local"
                        );
                    }
                }
            }
        } else if (type_is_optional(saved_switch_type)) {
            if (hir.hir_store_node_kinds[lowered_label] == hir.HirNode.union_pattern_expr) {
                check_union_pattern_against_type(lowered_label, saved_switch_type);
            }
        } else {
            if (bind_parse != 0) {
                diagnostic.diagnostic_error(current_path, parser.parser_store_node_starts[bind_parse], parser.parser_store_node_ends[bind_parse], "switch binding requires union case");
                should_lower_bind = 0;
            }
        }
        if (should_lower_bind) {
            Int lowered_bind = lower_node(bind_parse);
            hir.hir_store_append_child(node, lowered_bind);
        }
        Int lowered_body = lower_node(body_parse);
        hir.hir_store_append_child(node, lowered_body);
    } else if (kind == parser.ParserNode.switch_stmt) {
        Int child = parser.parser_store_node_first_child[parse_node];
        if (child != 0) {
            Int lowered_condition = lower_node(child);
            hir.hir_store_append_child(node, lowered_condition);
            current_switch_type = hir.hir_store_node_type_ids[lowered_condition];
            child = parser.parser_store_node_next_sibling[child];
            while (child != 0) {
                Int lowered = lower_node(child);
                hir.hir_store_append_child(node, lowered);
                child = parser.parser_store_node_next_sibling[child];
            }
        }
    } else {
        Int child = parser.parser_store_node_first_child[parse_node];
        while (child != 0) {
            Int lowered = lower_node(child);
            hir.hir_store_append_child(node, lowered);
            child = parser.parser_store_node_next_sibling[child];
        }
        if (kind == parser.ParserNode.func_decl) {
            if (symbol_is_nominal_instance_func(hir.hir_store_node_symbol_ids[node])) {
                Int owner_symbol = symbol_store.symbol_store_parent_ids[hir.hir_store_node_symbol_ids[node]];
                Int type_node = hir.hir_store_node_first_child[node];
                if (type_node != 0) {
                    Int name_node = hir.hir_store_node_next_sibling[type_node];
                    if (name_node != 0) {
                        Int self_param = make_synthetic_self_param_node(
                            owner_symbol,
                            hir.hir_store_node_symbol_ids[node],
                            hir.hir_store_node_starts[name_node],
                            hir.hir_store_node_ends[name_node]
                        );
                        if (self_param != 0) {
                            hir_insert_child_after(node, name_node, self_param);
                        }
                    }
                }
            }
        }
    }

    current_type_owner_symbol = saved_type_owner;
    current_func_symbol = saved_func_symbol;
    current_return_type = saved_return_type;
    current_loop_depth = saved_loop_depth;
    current_switch_type = saved_switch_type;
    current_pattern_type = saved_pattern_type;
    current_pattern_bind_scope = saved_pattern_bind_scope;
    current_pattern_allow_binding = saved_pattern_allow_binding;
    current_init_owner_symbol = saved_init_owner_symbol;
    current_init_self_symbol = saved_init_self_symbol;
    current_static_method_symbol = saved_static_method_symbol;
    current_generic_context_count = saved_generic_context_count;

    if (kind == parser.ParserNode.ident) {
        if (parse_node_has_generic_items(parse_node)) {
            Int resolved_type = resolve_type_node(parse_node);
            if (is_known_type(resolved_type)) {
                hir.hir_store_set_type_id(node, resolved_type);
                hir.hir_store_set_symbol_id(node, find_type_owner_symbol(resolved_type));
                return node;
            }
        }
        Int resolved = resolve_ident_symbol(parse_node);
        if (resolved != 0) {
            hir.hir_store_set_symbol_id(node, resolved);
            hir.hir_store_set_type_id(node, type_strip_mutable(symbol_store.symbol_store_type_ids[resolved]));
        } else if (current_static_method_symbol != 0) {
            if (parse_node_is(current_source, parse_node, "self")) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "self used in static function");
            }
        } else if (ident_requires_value_resolution(parse_node)) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown symbol");
        }
    }
    if (kind == parser.ParserNode.member_expr) {
        if (parse_node_has_generic_items(parse_node)) {
            Int resolved_type = resolve_type_node(parse_node);
            if (is_known_type(resolved_type)) {
                hir.hir_store_set_type_id(node, resolved_type);
                hir.hir_store_set_symbol_id(node, find_type_owner_symbol(resolved_type));
            }
        }
    }

    if (kind == parser.ParserNode.param) {
        Int type_node = parser.parser_store_node_first_child[parse_node];
        Int name_node = parser.parser_store_node_next_sibling[type_node];
        Int symbol_id = resolve_symbol(current_source, name_node, symbol_store.SymbolKind.param, saved_func_symbol);
        if (symbol_id != 0) {
            hir.hir_store_set_symbol_id(node, symbol_id);
            hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[symbol_id]);
        }
    }
    if (kind == parser.ParserNode.local_decl) {
        Int type_node = parser.parser_store_node_first_child[parse_node];
        Int name_node = parser.parser_store_node_next_sibling[type_node];
        Int scope_id = local_scope_id(parse_node);
        if (scope_id == 0) {
            scope_id = saved_func_symbol;
        }
        Int symbol_id = resolve_symbol(current_source, name_node, symbol_store.SymbolKind.local, scope_id);
        if (symbol_id != 0) {
            hir.hir_store_set_symbol_id(node, symbol_id);
            hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[symbol_id]);
            Int lowered_type = hir.hir_store_node_first_child[node];
            Int lowered_name = hir.hir_store_node_next_sibling[lowered_type];
            Int lowered_init = hir.hir_store_node_next_sibling[lowered_name];
            Int declared_type = hir.hir_store_node_type_ids[lowered_type];
            if (lowered_init == 0) {
                if (type_is_inferred_array(declared_type)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_type], hir.hir_store_node_ends[lowered_type], "inferred array length requires initializer");
                }
                return node;
            }
            if (type_parse_is_infer(current_source, type_node)) {
                declared_type = infer_wrapped_type_from_parse(type_node, hir.hir_store_node_type_ids[lowered_init]);
                if (!is_known_type(declared_type)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_init], hir.hir_store_node_ends[lowered_init], "cannot infer local type");
                    return node;
                }
                symbol_store.symbol_store_set_type_id(symbol_id, declared_type);
                set_inferred_type_on_lowered_type_node(lowered_type, declared_type);
                hir.hir_store_set_type_id(lowered_name, declared_type);
                hir.hir_store_set_type_id(node, declared_type);
            }
            if (type_is_inferred_array(declared_type)) {
                declared_type = infer_concrete_array_type_from_value(declared_type, lowered_init);
                if (!is_known_type(declared_type)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_init], hir.hir_store_node_ends[lowered_init], "cannot infer array length");
                    return node;
                }
                symbol_store.symbol_store_set_type_id(symbol_id, declared_type);
                hir.hir_store_set_type_id(lowered_type, declared_type);
                hir.hir_store_set_type_id(lowered_name, declared_type);
                hir.hir_store_set_type_id(node, declared_type);
            }
            Int coerced_init = coerce_expr_to_type(lowered_init, declared_type);
            if (coerced_init != lowered_init) {
                hir.hir_store_set_next_sibling(lowered_name, coerced_init);
                lowered_init = coerced_init;
            }
            if (hir.hir_store_node_kinds[lowered_init] == hir.HirNode.array_lit) {
                check_array_literal_against_type(lowered_init, declared_type);
            } else if (!is_string_compatible_array(declared_type, lowered_init)) {
                expect_same_type(lowered_type, lowered_init, "local initializer type mismatch");
            }
        }
    }
    if (kind == parser.ParserNode.for_stmt) {
        Int mode = parser.parser_store_node_aux[parse_node];
        if (mode == 0) {
            Int type_node = parser.parser_store_node_first_child[parse_node];
            Int name_node = parser.parser_store_node_next_sibling[type_node];
            Int start_expr = parser.parser_store_node_next_sibling[name_node];
            Int end_expr = parser.parser_store_node_next_sibling[start_expr];
            Int body_parse = parser.parser_store_node_next_sibling[end_expr];
            Int symbol_id = resolve_symbol(current_source, name_node, symbol_store.SymbolKind.local, 0 - body_parse);
            if (symbol_id != 0) {
                hir.hir_store_set_symbol_id(node, symbol_id);
                hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[symbol_id]);
            }
        }
    }
    if (kind == parser.ParserNode.switch_case) {
        Int label_parse = switch_case_label_parse(parse_node);
        Int bind_parse = switch_case_binding_parse(parse_node);
        Int label_node = hir.hir_store_node_first_child[node];
        Int bind_node = 0;
        if (label_node != 0) {
            Int next_after_label = hir.hir_store_node_next_sibling[label_node];
            if (next_after_label != 0) {
                if (hir.hir_store_node_next_sibling[next_after_label] != 0) {
                    bind_node = next_after_label;
                }
            }
        }
        if (label_node != 0) {
            if (type_is_union(saved_switch_type)) {
                if (hir.hir_store_node_kinds[label_node] == hir.HirNode.union_pattern_expr) {
                    check_union_pattern_against_type(label_node, saved_switch_type);
                } else {
                    Int coerced_label = coerce_expr_to_type(label_node, saved_switch_type);
                    if (coerced_label != label_node) {
                        hir.hir_store_set_first_child(node, coerced_label);
                        label_node = coerced_label;
                    }
                    Int owner_symbol = find_type_owner_symbol(saved_switch_type);
                    Int label_symbol = hir.hir_store_node_symbol_ids[label_node];
                    if (label_symbol == 0) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[label_node], hir.hir_store_node_ends[label_node], "switch case type mismatch");
                    } else if (symbol_store.symbol_store_kinds[label_symbol] != symbol_store.SymbolKind.union_member) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[label_node], hir.hir_store_node_ends[label_node], "switch case type mismatch");
                    } else if (symbol_store.symbol_store_parent_ids[label_symbol] != owner_symbol) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[label_node], hir.hir_store_node_ends[label_node], "switch case type mismatch");
                    }
                }
                if (bind_node != 0) {
                    Int pattern_symbol = hir.hir_store_node_symbol_ids[label_node];
                    Int payload_type = symbol_store.symbol_store_type_ids[pattern_symbol];
                    if (payload_type == type_store.type_store_builtin_void) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[bind_node], hir.hir_store_node_ends[bind_node], "union case has no payload");
                    } else {
                        hir.hir_store_set_type_id(bind_node, payload_type);
                    }
                }
                return node;
            } else if (type_is_optional(saved_switch_type)) {
                if (hir.hir_store_node_kinds[label_node] == hir.HirNode.union_pattern_expr) {
                    check_union_pattern_against_type(label_node, saved_switch_type);
                } else {
                    Int coerced_label = coerce_expr_to_type(label_node, saved_switch_type);
                    if (coerced_label != label_node) {
                        hir.hir_store_set_first_child(node, coerced_label);
                        label_node = coerced_label;
                    }
                }
                if (bind_node != 0) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[bind_node], hir.hir_store_node_ends[bind_node], "switch binding requires union case");
                }
                if (hir.hir_store_node_kinds[label_node] != hir.HirNode.union_pattern_expr) {
                    expect_type(label_node, saved_switch_type, "switch case type mismatch");
                }
                return node;
            }
            if (bind_node != 0) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[bind_node], hir.hir_store_node_ends[bind_node], "switch binding requires union case");
            }
            if (parser.parser_store_node_kinds[label_parse] == parser.ParserNode.ident) {
                if (type_is_enum(saved_switch_type)) {
                    Int owner_symbol = find_type_owner_symbol(saved_switch_type);
                    if (owner_symbol != 0) {
                        Int member_symbol = resolve_symbol(current_source, label_parse, symbol_store.SymbolKind.enum_member, owner_symbol);
                        if (member_symbol != 0) {
                            hir.hir_store_set_symbol_id(label_node, member_symbol);
                            hir.hir_store_set_type_id(label_node, symbol_store.symbol_store_type_ids[member_symbol]);
                        } else {
                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[label_node], hir.hir_store_node_ends[label_node], "unknown member");
                        }
                    }
                } else {
                    Int resolved = resolve_ident_symbol(label_parse);
                    if (resolved != 0) {
                        hir.hir_store_set_symbol_id(label_node, resolved);
                        hir.hir_store_set_type_id(label_node, symbol_store.symbol_store_type_ids[resolved]);
                    } else {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[label_node], hir.hir_store_node_ends[label_node], "unknown symbol");
                    }
                }
            }
            if (is_known_type(saved_switch_type)) {
                Int coerced_label = coerce_expr_to_type(label_node, saved_switch_type);
                if (coerced_label != label_node) {
                    hir.hir_store_set_first_child(node, coerced_label);
                    label_node = coerced_label;
                }
                expect_type(label_node, saved_switch_type, "switch case type mismatch");
            }
        }
    }
    if (kind == parser.ParserNode.global_decl) {
        Int type_node = parser.parser_store_node_first_child[parse_node];
        Int name_node = parser.parser_store_node_next_sibling[type_node];
        Int symbol_id = resolve_symbol(current_source, name_node, symbol_store.SymbolKind.global, 0);
        if (symbol_id != 0) {
            hir.hir_store_set_symbol_id(node, symbol_id);
            hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[symbol_id]);
            Int lowered_type = hir.hir_store_node_first_child[node];
            Int lowered_name = hir.hir_store_node_next_sibling[lowered_type];
            Int lowered_init = hir.hir_store_node_next_sibling[lowered_name];
            if (lowered_init == 0) {
                if (type_parse_is_infer(current_source, type_node)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_type], hir.hir_store_node_ends[lowered_type], "inferred global requires initializer");
                } else if (type_is_inferred_array(hir.hir_store_node_type_ids[lowered_type])) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_type], hir.hir_store_node_ends[lowered_type], "inferred array length requires initializer");
                }
                return node;
            }
            Int declared_type = hir.hir_store_node_type_ids[lowered_type];
            if (type_parse_is_infer(current_source, type_node)) {
                declared_type = infer_wrapped_type_from_parse(type_node, hir.hir_store_node_type_ids[lowered_init]);
                if (!is_known_type(declared_type)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_init], hir.hir_store_node_ends[lowered_init], "cannot infer global type");
                    return node;
                }
                symbol_store.symbol_store_set_type_id(symbol_id, declared_type);
                set_inferred_type_on_lowered_type_node(lowered_type, declared_type);
                hir.hir_store_set_type_id(lowered_name, declared_type);
                hir.hir_store_set_type_id(node, declared_type);
            }
            if (type_is_inferred_array(declared_type)) {
                declared_type = infer_concrete_array_type_from_value(declared_type, lowered_init);
                if (!is_known_type(declared_type)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[lowered_init], hir.hir_store_node_ends[lowered_init], "cannot infer array length");
                    return node;
                }
                symbol_store.symbol_store_set_type_id(symbol_id, declared_type);
                hir.hir_store_set_type_id(lowered_type, declared_type);
                hir.hir_store_set_type_id(lowered_name, declared_type);
                hir.hir_store_set_type_id(node, declared_type);
            }
            Int coerced_init = coerce_expr_to_type(lowered_init, declared_type);
            if (coerced_init != lowered_init) {
                hir.hir_store_set_next_sibling(lowered_name, coerced_init);
                lowered_init = coerced_init;
            }
            if (hir.hir_store_node_kinds[lowered_init] == hir.HirNode.array_lit) {
                check_array_literal_against_type(lowered_init, declared_type);
            } else if (!is_string_compatible_array(declared_type, lowered_init)) {
                expect_same_type(lowered_type, lowered_init, "global initializer type mismatch");
            }
        }
    }
    if (kind == parser.ParserNode.tuple_lit) {
        if (hir.hir_store_node_first_child[node] == 0) {
            hir.hir_store_set_type_id(node, type_store.type_store_builtin_void);
        } else {
            Int item_types = ints.buffer_int_new(4);
            Int child = hir.hir_store_node_first_child[node];
            Bool all_known = 1;
            while (child != 0) {
                Int child_type = hir.hir_store_node_type_ids[child];
                if (!is_known_type(child_type)) {
                    all_known = 0;
                }
                ints.buffer_int_push(item_types, child_type);
                child = hir.hir_store_node_next_sibling[child];
            }
            if (all_known != 0) {
                hir.hir_store_set_type_id(node, type_store.type_store_new_tuple_type(ints.buffer_int_slice(item_types)));
            }
        }
    }
    if (kind == parser.ParserNode.field_decl) {
        Int type_node = parser.parser_store_node_first_child[parse_node];
        Int name_node = parser.parser_store_node_next_sibling[type_node];
        Int init_expr = parser.parser_store_node_next_sibling[name_node];
        Int field_kind = symbol_store.SymbolKind.field;
        Int parent = parser.parser_store_node_parent[parse_node];
        if (parent != 0) {
            if (parser.parser_store_node_kinds[parent] == parser.ParserNode.union_decl) {
                field_kind = symbol_store.SymbolKind.union_member;
            }
        }
        Int field_symbol = resolve_symbol(current_source, name_node, field_kind, saved_type_owner);
        if (field_symbol != 0) {
            hir.hir_store_set_symbol_id(node, field_symbol);
            hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[field_symbol]);
            symbol_store.symbol_store_set_aux(field_symbol, node);
            if (init_expr != 0) {
                Int lowered_type = hir.hir_store_node_first_child[node];
                Int lowered_name = hir.hir_store_node_next_sibling[lowered_type];
                Int lowered_init = hir.hir_store_node_next_sibling[lowered_name];
                Int expected_type = symbol_store.symbol_store_type_ids[field_symbol];
                Int coerced_init = coerce_expr_to_type(lowered_init, expected_type);
                if (coerced_init != lowered_init) {
                    hir.hir_store_set_next_sibling(lowered_name, coerced_init);
                    lowered_init = coerced_init;
                }
                if (hir.hir_store_node_kinds[lowered_init] == hir.HirNode.array_lit) {
                    check_array_literal_against_type(lowered_init, expected_type);
                } else if (!is_string_compatible_array(expected_type, lowered_init)) {
                    expect_same_type(lowered_type, lowered_init, "field initializer type mismatch");
                }
            }
        }
    }
    if (kind == parser.ParserNode.enum_member) {
        Int member_name = parser.parser_store_node_first_child[parse_node];
        Int member_symbol = resolve_symbol(current_source, member_name, symbol_store.SymbolKind.enum_member, saved_type_owner);
        if (member_symbol != 0) {
            hir.hir_store_set_symbol_id(node, member_symbol);
            hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[member_symbol]);
        }
        Int explicit_value = hir.hir_store_node_next_sibling[hir.hir_store_node_first_child[node]];
        if (explicit_value != 0) {
            expect_type(explicit_value, type_store.type_store_builtin_int, "enum value must be Int");
            if (hir.hir_store_node_type_ids[explicit_value] == type_store.type_store_builtin_int) {
                hir.hir_store_set_aux(node, eval_const_int_expr(explicit_value));
            } else {
                hir.hir_store_set_aux(node, 0);
            }
            current_enum_next_value = hir.hir_store_node_aux[node] + 1;
        } else {
            hir.hir_store_set_aux(node, current_enum_next_value);
            current_enum_next_value = current_enum_next_value + 1;
        }
        if (member_symbol != 0) {
            symbol_store.symbol_store_set_aux(member_symbol, hir.hir_store_node_aux[node]);
        }
    }
    if (kind == parser.ParserNode.member_expr) {
        Int base = hir.hir_store_node_first_child[node];
        Int member = hir.hir_store_node_next_sibling[base];
        Int owner_symbol = 0;
        Int member_parse = parser.parser_store_node_next_sibling[parser.parser_store_node_first_child[parse_node]];
        if (parse_is_proxy_free_member(current_source, parse_node)) {
            hir.hir_store_set_symbol_id(node, builtin_free_symbol);
            hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[builtin_free_symbol]);
            return node;
        }
        Int base_type = type_member_base_type(hir.hir_store_node_type_ids[base]);
        if (type_is_slice(hir.hir_store_node_type_ids[base])) {
            if (member_name_is(current_source, member_parse, "length")) {
                hir.hir_store_set_type_id(node, type_store.type_store_builtin_int);
                member = member;
                return node;
            }
        }
        if (type_is_union(base_type)) {
            if (member_name_is(current_source, member_parse, "tag")) {
                hir.hir_store_set_type_id(node, union_tag_type(base_type));
                member = member;
                return node;
            }
        }
        if (type_is_optional(hir.hir_store_node_type_ids[base])) {
            member = member;
        }
        Int base_symbol = hir.hir_store_node_symbol_ids[base];
        if (type_is_enum(base_type)) {
            if (member_name_is(current_source, member_parse, "value")) {
                if (base_symbol == 0) {
                    hir.hir_store_set_type_id(node, type_store.type_store_builtin_int);
                    member = member;
                    return node;
                }
                if (symbol_store.symbol_store_kinds[base_symbol] != symbol_store.SymbolKind.enum_name) {
                    hir.hir_store_set_type_id(node, type_store.type_store_builtin_int);
                    member = member;
                    return node;
                }
            }
        }
        if (base_symbol != 0) {
            Int base_kind = symbol_store.symbol_store_kinds[base_symbol];
            if (base_kind == symbol_store.SymbolKind.module_alias) {
                Int member_symbol = resolve_top_level_symbol_in_module(
                    current_source,
                    member_parse,
                    symbol_store.symbol_store_type_ids[base_symbol]
                );
                if (member_symbol != 0) {
                    hir.hir_store_set_symbol_id(node, member_symbol);
                    hir.hir_store_set_type_id(node, type_strip_mutable(symbol_store.symbol_store_type_ids[member_symbol]));
                } else {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown member");
                }
                member = member;
                return node;
            }
            if (base_kind == symbol_store.SymbolKind.type_name) {
                owner_symbol = base_symbol;
                if (member_name_is(current_source, member_parse, "init")) {
                    Int init_symbol = find_struct_init_symbol(owner_symbol);
                    if (init_symbol != 0) {
                        if (!nominal_method_visible(init_symbol)) {
                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "method is private");
                            return node;
                        }
                        hir.hir_store_set_symbol_id(node, init_symbol);
                        hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[init_symbol]);
                        return node;
                    }
                }
                Int method_symbol = resolve_symbol(current_source, member_parse, symbol_store.SymbolKind.func, owner_symbol);
                if (method_symbol != 0) {
                    if (!nominal_method_visible(method_symbol)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "method is private");
                        return node;
                    }
                    if (symbol_is_nominal_static_func(method_symbol)) {
                        hir.hir_store_set_symbol_id(node, method_symbol);
                        hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[method_symbol]);
                        return node;
                    }
                    if (symbol_is_nominal_instance_func(method_symbol)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "instance method called through type");
                        return node;
                    }
                }
            }
            if (base_kind == symbol_store.SymbolKind.enum_name) {
                owner_symbol = base_symbol;
                Int enum_member_symbol = resolve_symbol(current_source, member_parse, symbol_store.SymbolKind.enum_member, owner_symbol);
                if (enum_member_symbol != 0) {
                    hir.hir_store_set_symbol_id(node, enum_member_symbol);
                    hir.hir_store_set_type_id(node, type_strip_mutable(symbol_store.symbol_store_type_ids[enum_member_symbol]));
                    return node;
                }
                Int method_symbol = resolve_symbol(current_source, member_parse, symbol_store.SymbolKind.func, owner_symbol);
                if (method_symbol != 0) {
                    if (!nominal_method_visible(method_symbol)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "method is private");
                        return node;
                    }
                    if (symbol_is_nominal_static_func(method_symbol)) {
                        hir.hir_store_set_symbol_id(node, method_symbol);
                        hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[method_symbol]);
                        return node;
                    }
                    if (symbol_is_nominal_instance_func(method_symbol)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "instance method called through type");
                        return node;
                    }
                }
            }
        }
        if (owner_symbol == 0) {
            owner_symbol = find_type_owner_symbol(base_type);
        }
        if (owner_symbol != 0) {
            Int member_symbol = resolve_symbol(current_source, member_parse, symbol_store.SymbolKind.field, owner_symbol);
            if (member_symbol == 0) {
                member_symbol = resolve_symbol(current_source, member_parse, symbol_store.SymbolKind.union_member, owner_symbol);
            }
            if (member_symbol == 0) {
                member_symbol = resolve_symbol(current_source, member_parse, symbol_store.SymbolKind.enum_member, owner_symbol);
            }
            if (member_symbol == 0) {
                Int method_symbol = resolve_symbol(current_source, member_parse, symbol_store.SymbolKind.func, owner_symbol);
                if (method_symbol != 0) {
                    if (!nominal_method_visible(method_symbol)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "method is private");
                        return node;
                    }
                    if (symbol_is_nominal_instance_func(method_symbol)) {
                        hir.hir_store_set_symbol_id(node, method_symbol);
                        hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[method_symbol]);
                        return node;
                    }
                    if (symbol_is_nominal_static_func(method_symbol)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "static function called through instance");
                        return node;
                    }
                }
            }
            if (member_symbol != 0) {
                hir.hir_store_set_symbol_id(node, member_symbol);
                if (symbol_store.symbol_store_kinds[member_symbol] == symbol_store.SymbolKind.union_member) {
                    Int owner_type = symbol_store.symbol_store_type_ids[owner_symbol];
                    if (type_is_union(owner_type)) {
                        hir.hir_store_set_type_id(node, union_tag_type(owner_type));
                    } else {
                        hir.hir_store_set_type_id(node, type_strip_mutable(symbol_store.symbol_store_type_ids[member_symbol]));
                    }
                } else {
                    hir.hir_store_set_type_id(node, type_strip_mutable(symbol_store.symbol_store_type_ids[member_symbol]));
                }
            } else {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown member");
            }
        } else {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown member");
        }
        member = member;
    }
    if (kind == parser.ParserNode.optional_member_expr) {
        Int base = hir.hir_store_node_first_child[node];
        Int member = hir.hir_store_node_next_sibling[base];
        Int member_parse = parser.parser_store_node_next_sibling[parser.parser_store_node_first_child[parse_node]];
        Int base_type = hir.hir_store_node_type_ids[base];
        if (!type_is_optional(base_type)) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "optional chain requires optional operand");
            member = member;
        } else if (is_simple_optional_chain_base(base) == 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "optional chain currently requires simple base expression");
            member = member;
        } else {
            Int payload_type = type_optional_payload(base_type);
            Int member_type = type_store.type_store_builtin_unknown;
            Int owner_symbol = 0;
            if (type_is_slice(payload_type)) {
                if (member_name_is(current_source, member_parse, "length")) {
                    member_type = type_store.type_store_builtin_int;
                }
            }
            if (member_type == type_store.type_store_builtin_unknown) {
                if (type_is_union(payload_type)) {
                    if (member_name_is(current_source, member_parse, "tag")) {
                        member_type = union_tag_type(payload_type);
                    }
                }
            }
            if (member_type == type_store.type_store_builtin_unknown) {
                if (type_is_enum(payload_type)) {
                    if (member_name_is(current_source, member_parse, "value")) {
                        member_type = type_store.type_store_builtin_int;
                    }
                }
            }
            if (member_type == type_store.type_store_builtin_unknown) {
                owner_symbol = find_type_owner_symbol(payload_type);
                if (owner_symbol != 0) {
                    Int member_symbol = resolve_symbol(current_source, member_parse, symbol_store.SymbolKind.field, owner_symbol);
                    if (member_symbol == 0) {
                        member_symbol = resolve_symbol(current_source, member_parse, symbol_store.SymbolKind.union_member, owner_symbol);
                    }
                    if (member_symbol == 0) {
                        member_symbol = resolve_symbol(current_source, member_parse, symbol_store.SymbolKind.enum_member, owner_symbol);
                    }
                    if (member_symbol != 0) {
                        hir.hir_store_set_symbol_id(node, member_symbol);
                        member_type = type_strip_mutable(symbol_store.symbol_store_type_ids[member_symbol]);
                        if (symbol_store.symbol_store_kinds[member_symbol] == symbol_store.SymbolKind.union_member) {
                            Int owner_type = symbol_store.symbol_store_type_ids[owner_symbol];
                            if (type_is_union(owner_type)) {
                                member_type = union_tag_type(owner_type);
                            }
                        }
                    }
                }
            }
            if (is_known_type(member_type)) {
                hir.hir_store_set_type_id(node, type_optional_chain_result(member_type));
            } else {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "unknown member");
            }
        }
        member = member;
    }
    if (kind == parser.ParserNode.index_expr) {
        Int base = hir.hir_store_node_first_child[node];
        Int index_expr = hir.hir_store_node_next_sibling[base];
        expect_type(index_expr, type_store.type_store_builtin_int, "index requires Int");
        Int base_type = hir.hir_store_node_type_ids[base];
        if (type_is_slice(base_type)) {
            hir.hir_store_set_type_id(node, type_strip_mutable(type_store.type_store_elem_type_ids[type_strip_mutable(base_type)]));
        } else if (type_is_array(base_type)) {
            hir.hir_store_set_type_id(node, type_strip_mutable(type_store.type_store_elem_type_ids[type_strip_mutable(base_type)]));
        } else if (type_is_tuple(base_type)) {
            if (hir.hir_store_node_kinds[index_expr] != hir.HirNode.int_lit) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[index_expr], hir.hir_store_node_ends[index_expr], "tuple index must be integer literal");
            } else {
                Int item_index = parse_int_literal_value(hir.hir_store_node_starts[index_expr], hir.hir_store_node_ends[index_expr]);
                if (item_index >= 0) {
                    if (item_index < type_store.type_store_tuple_count(base_type)) {
                        hir.hir_store_set_aux(node, item_index);
                        hir.hir_store_set_type_id(node, type_store.type_store_tuple_item_type(base_type, item_index));
                    } else {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[index_expr], hir.hir_store_node_ends[index_expr], "tuple index out of range");
                    }
                } else {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[index_expr], hir.hir_store_node_ends[index_expr], "tuple index out of range");
                }
            }
        } else {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "index target must be array, slice, or tuple");
        }
    }
    if (kind == parser.ParserNode.optional_index_expr) {
        Int base = hir.hir_store_node_first_child[node];
        Int index_expr = hir.hir_store_node_next_sibling[base];
        Int base_type = hir.hir_store_node_type_ids[base];
        if (!type_is_optional(base_type)) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "optional chain requires optional operand");
        } else if (is_simple_optional_chain_base(base) == 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "optional chain currently requires simple base expression");
        } else {
            Int payload_type = type_optional_payload(base_type);
            expect_type(index_expr, type_store.type_store_builtin_int, "index requires Int");
            if (type_is_slice(payload_type)) {
                hir.hir_store_set_type_id(
                    node,
                    type_optional_chain_result(
                        type_strip_mutable(type_store.type_store_elem_type_ids[type_strip_mutable(payload_type)])
                    )
                );
            } else if (type_is_array(payload_type)) {
                hir.hir_store_set_type_id(
                    node,
                    type_optional_chain_result(
                        type_strip_mutable(type_store.type_store_elem_type_ids[type_strip_mutable(payload_type)])
                    )
                );
            } else if (type_is_tuple(payload_type)) {
                if (hir.hir_store_node_kinds[index_expr] != hir.HirNode.int_lit) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[index_expr], hir.hir_store_node_ends[index_expr], "tuple index must be integer literal");
                } else {
                    Int item_index = parse_int_literal_value(hir.hir_store_node_starts[index_expr], hir.hir_store_node_ends[index_expr]);
                    if (item_index >= 0) {
                        if (item_index < type_store.type_store_tuple_count(payload_type)) {
                            hir.hir_store_set_aux(node, item_index);
                            hir.hir_store_set_type_id(
                                node,
                                type_optional_chain_result(type_store.type_store_tuple_item_type(payload_type, item_index))
                            );
                        } else {
                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[index_expr], hir.hir_store_node_ends[index_expr], "tuple index out of range");
                        }
                    } else {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[index_expr], hir.hir_store_node_ends[index_expr], "tuple index out of range");
                    }
                }
            } else {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "optional chain index target must be array, slice, or tuple");
            }
        }
    }
    if (kind == parser.ParserNode.range_expr) {
        Int base = hir.hir_store_node_first_child[node];
        Int start_expr = hir.hir_store_node_next_sibling[base];
        Int end_expr = hir.hir_store_node_next_sibling[start_expr];
        expect_type(start_expr, type_store.type_store_builtin_int, "range start requires Int");
        expect_type(end_expr, type_store.type_store_builtin_int, "range end requires Int");
        Int base_type = hir.hir_store_node_type_ids[base];
        if (type_is_slice(base_type)) {
            hir.hir_store_set_type_id(node, base_type);
        } else if (type_is_array(base_type)) {
            hir.hir_store_set_type_id(node, type_store.type_store_new_slice_type(type_store.type_store_elem_type_ids[base_type]));
        } else {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "range target must be array or slice");
        }
    }
    if (kind == parser.ParserNode.call_expr) {
        if (proxy_member_is_free_call(current_source, parse_node, node)) {
            rewrite_proxy_free_call(node);
            return node;
        }
        Int callee = hir.hir_store_node_first_child[node];
        Int callee_symbol = hir.hir_store_node_symbol_ids[callee];
        Int callee_parse = parser.parser_store_node_first_child[parse_node];
        if (parse_node_has_generic_items(callee_parse)) {
            if (callee_symbol != 0) {
                if (symbol_store.symbol_store_kinds[callee_symbol] == symbol_store.SymbolKind.func) {
                    if (!symbol_is_generic_template(callee_symbol)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[callee], hir.hir_store_node_ends[callee], "function is not generic");
                        return node;
                    }
                    Int template_decl = symbol_generic_template_decl(callee_symbol);
                    if (template_decl == 0) {
                        Int template_module_id = symbol_store.symbol_store_module_ids[callee_symbol];
                        Int template_snapshot_id = module_loader.module_loader_find_parse_snapshot(template_module_id);
                        if (template_snapshot_id == 0) {
                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[callee], hir.hir_store_node_ends[callee], "missing parse snapshot for imported generic function");
                            return node;
                        }
                        Int saved_parse_snapshot_id = current_parse_snapshot_id;
                        Int saved_module_id = current_module_id;
                        Int saved_register_module_id = register_module_id;
                        UInt8[] saved_source = current_source;
                        UInt8[] saved_path = current_path;
                        Int saved_visible_import_module_ids = visible_import_module_ids;
                        parser.parser_store_restore_snapshot(template_snapshot_id);
                        current_parse_snapshot_id = template_snapshot_id;
                        current_module_id = template_module_id;
                        register_module_id = template_module_id;
                        current_path = module_loader.module_loader_module_path(template_module_id);
                        current_source = module_loader.load_source(current_path);
                        visible_import_module_ids = collect_visible_import_modules_for_parse(current_source, current_path, 1);
                        template_decl = symbol_generic_template_decl(callee_symbol);
                        parser.parser_store_restore_snapshot(saved_parse_snapshot_id);
                        current_parse_snapshot_id = saved_parse_snapshot_id;
                        current_module_id = saved_module_id;
                        register_module_id = saved_register_module_id;
                        current_source = saved_source;
                        current_path = saved_path;
                        visible_import_module_ids = saved_visible_import_module_ids;
                    }
                    if (template_decl == 0) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[callee], hir.hir_store_node_ends[callee], "function is not generic");
                        return node;
                    }
                    Int generic_offset = parser.parser_store_node_generic_item_offsets[callee_parse];
                    Int generic_count = parser.parser_store_node_generic_item_counts[callee_parse];
                    if (symbol_generic_template_type_count(callee_symbol) != generic_count) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[callee], hir.hir_store_node_ends[callee], "generic argument count mismatch");
                        return node;
                    }
                    Int arg_types_handle = ints.buffer_int_new(generic_count);
                    Int generic_i = 0;
                    while (generic_i < generic_count) {
                        Int arg_type = resolve_type_node_from_source(current_source, parser.parser_store_generic_item_ids[generic_offset + generic_i]);
                        if (!is_known_type(arg_type)) {
                            return node;
                        }
                        if (arg_type < type_store.type_store_count) {
                            if (type_store.type_store_kinds[arg_type] == type_store.TypeKind.generic_param) {
                                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[callee], hir.hir_store_node_ends[callee], "concrete generic arguments are required here");
                                return node;
                            }
                        }
                        ints.buffer_int_push(arg_types_handle, arg_type);
                        generic_i = generic_i + 1;
                    }
                    callee_symbol = instantiate_generic_func_symbol(current_source, callee_symbol, ints.buffer_int_slice(arg_types_handle));
                    hir.hir_store_set_symbol_id(callee, callee_symbol);
                    hir.hir_store_set_type_id(callee, symbol_store.symbol_store_type_ids[callee_symbol]);
                } else if (symbol_store.symbol_store_kinds[callee_symbol] != symbol_store.SymbolKind.type_name) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[callee], hir.hir_store_node_ends[callee], "generic arguments require function template");
                    return node;
                }
            }
        } else if (callee_symbol != 0) {
            if (symbol_store.symbol_store_kinds[callee_symbol] == symbol_store.SymbolKind.func) {
                if (symbol_is_generic_template(callee_symbol)) {
                    Int instantiated_symbol = infer_generic_func_symbol(current_source, callee_symbol, node);
                    if (instantiated_symbol == 0) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[callee], hir.hir_store_node_ends[callee], "cannot infer generic arguments");
                        return node;
                    }
                    callee_symbol = instantiated_symbol;
                    hir.hir_store_set_symbol_id(callee, callee_symbol);
                    hir.hir_store_set_type_id(callee, symbol_store.symbol_store_type_ids[callee_symbol]);
                }
            }
        }
        if (callee_symbol != 0) {
            if (symbol_store.symbol_store_kinds[callee_symbol] == symbol_store.SymbolKind.type_name) {
                Int init_symbol = find_struct_init_symbol(callee_symbol);
                if (init_symbol != 0) {
                    if (!nominal_method_visible(init_symbol)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "method is private");
                        return node;
                    }
                    hir.hir_store_set_symbol_id(callee, init_symbol);
                    hir.hir_store_set_type_id(callee, symbol_store.symbol_store_type_ids[init_symbol]);
                    hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[init_symbol]);
                    check_call_args(node, init_symbol);
                    return node;
                }
            }
        }
        if (callee_symbol != 0) {
            if (symbol_store.symbol_store_kinds[callee_symbol] == symbol_store.SymbolKind.union_member) {
                Int owner_symbol = symbol_store.symbol_store_parent_ids[callee_symbol];
                Int payload_type = symbol_store.symbol_store_type_ids[callee_symbol];
                Int owner_type = symbol_store.symbol_store_type_ids[owner_symbol];
                Int arg = hir.hir_store_node_next_sibling[callee];
                Int arg_count = 0;
                while (arg != 0) {
                    arg_count = arg_count + 1;
                    arg = hir.hir_store_node_next_sibling[arg];
                }
                if (payload_type == type_store.type_store_builtin_void) {
                    if (arg_count != 0) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "argument count mismatch");
                    }
                } else {
                    if (arg_count != 1) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "argument count mismatch");
                    } else {
                        Int value_arg = hir.hir_store_node_next_sibling[callee];
                        Int coerced_arg = coerce_expr_to_type(value_arg, payload_type);
                        if (coerced_arg != value_arg) {
                            hir.hir_store_set_next_sibling(callee, coerced_arg);
                            value_arg = coerced_arg;
                        }
                        expect_type(value_arg, payload_type, "argument type mismatch");
                    }
                }
            hir.hir_store_set_type_id(node, owner_type);
            return node;
        }
        }
        if (callee_symbol == 0) {
            if (hir.hir_store_node_kinds[callee] != hir.HirNode.ident) {
                if (hir.hir_store_node_kinds[callee] == hir.HirNode.shorthand_member_expr) {
                    return node;
                }
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "call target must be a function");
            }
        } else if (symbol_store.symbol_store_kinds[callee_symbol] != symbol_store.SymbolKind.func) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "call target must be a function");
        } else {
            if (symbol_is_nominal_instance_func(callee_symbol)) {
                if (hir.hir_store_node_kinds[callee] != hir.HirNode.member_expr) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "instance method called through type");
                    return node;
                }
                Int receiver = hir.hir_store_node_first_child[callee];
                if (!instance_method_base_is_supported(receiver)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[receiver], hir.hir_store_node_ends[receiver], "instance method requires addressable or pointer receiver");
                    return node;
                }
            }
            hir.hir_store_set_type_id(node, symbol_store.symbol_store_type_ids[callee_symbol]);
            check_call_args(node, callee_symbol);
        }
    }
    if (kind == parser.ParserNode.union_pattern_expr) {
        check_union_pattern_against_type(node, current_pattern_type);
    }
    if (kind == parser.ParserNode.struct_init_expr) {
        Int type_expr = hir.hir_store_node_first_child[node];
        Int type_id = hir.hir_store_node_type_ids[type_expr];
        hir.hir_store_set_type_id(node, type_id);
        check_struct_init_fields(node);
    }
    if (kind == parser.ParserNode.array_init_expr) {
        check_array_init_expr(node);
    }
    if (kind == parser.ParserNode.unary_expr) {
        Int operand = hir.hir_store_node_first_child[node];
        if (hir.hir_store_node_aux[node] == hir.HirUnaryOp.neg) {
            expect_type(operand, type_store.type_store_builtin_int, "unary - requires Int");
            hir.hir_store_set_type_id(node, type_store.type_store_builtin_int);
        } else if (hir.hir_store_node_aux[node] == hir.HirUnaryOp.not) {
            expect_type(operand, type_store.type_store_builtin_bool, "unary ! requires Bool");
            hir.hir_store_set_type_id(node, type_store.type_store_builtin_bool);
        } else if (hir.hir_store_node_aux[node] == hir.HirUnaryOp.addr) {
            if (!is_assignable_node(operand)) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "address-of requires assignable target");
            } else {
                Int operand_type = hir.hir_store_node_type_ids[operand];
                if (is_known_type(operand_type)) {
                    hir.hir_store_set_type_id(node, type_store.type_store_new_pointer_type(operand_type));
                }
            }
        } else if (hir.hir_store_node_aux[node] == hir.HirUnaryOp.new_expr) {
            Int operand_type = type_strip_mutable(hir.hir_store_node_type_ids[operand]);
            if (!is_known_type(operand_type)) {
                operand_type = operand_type;
            } else if (type_store.type_store_kinds[operand_type] != type_store.TypeKind.struct_type) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "new requires struct value");
            } else {
                hir.hir_store_set_type_id(node, type_store.type_store_new_pointer_type(operand_type));
            }
        } else if (hir.hir_store_node_aux[node] == hir.HirUnaryOp.proxy) {
            Int operand_type = hir.hir_store_node_type_ids[operand];
            if (parse_is_proxy_free_member(current_source, parser.parser_store_node_parent[parse_node])) {
                hir.hir_store_set_type_id(node, operand_type);
            } else if (!type_is_pointer(operand_type)) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "$ requires pointer");
            } else {
                hir.hir_store_set_type_id(node, operand_type);
            }
        } else {
            Int operand_type = hir.hir_store_node_type_ids[operand];
            if (operand_type <= 0) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "dereference requires pointer");
            } else if (operand_type >= type_store.type_store_count) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "dereference requires pointer");
            } else if (type_store.type_store_kinds[operand_type] != type_store.TypeKind.pointer) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "dereference requires pointer");
            } else {
                hir.hir_store_set_type_id(node, type_store.type_store_elem_type_ids[operand_type]);
            }
        }
    }
    if (kind == parser.ParserNode.binary_expr) {
        Int left = hir.hir_store_node_first_child[node];
        Int right = hir.hir_store_node_next_sibling[left];
        Int op = hir.hir_store_node_aux[node];
        if (op == hir.HirBinaryOp.coalesce) {
            Int left_type = type_strip_mutable(hir.hir_store_node_type_ids[left]);
            if (!type_is_optional(left_type)) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[left], hir.hir_store_node_ends[left], "null coalescing requires optional left operand");
            } else if (is_simple_optional_chain_base(left) == 0) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "null coalescing currently requires simple left expression");
            } else {
                Int result_type = type_optional_payload(left_type);
                Int coerced_right = coerce_expr_to_type(right, result_type);
                if (coerced_right != right) {
                    hir.hir_store_set_next_sibling(left, coerced_right);
                    right = coerced_right;
                }
                expect_type(right, result_type, "null coalescing fallback type mismatch");
                if (!type_supports_coalesce_result(result_type)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "null coalescing result currently requires scalar type");
                }
                hir.hir_store_set_type_id(node, result_type);
            }
        } else if (op == hir.HirBinaryOp.assign) {
            check_assignment_target(left);
            Int coerced_right = coerce_expr_to_type(right, hir.hir_store_node_type_ids[left]);
            if (coerced_right != right) {
                hir.hir_store_set_next_sibling(left, coerced_right);
                right = coerced_right;
            }
            if (hir.hir_store_node_kinds[right] == hir.HirNode.array_lit) {
                check_array_literal_against_type(right, hir.hir_store_node_type_ids[left]);
            } else if (!is_string_compatible_array(hir.hir_store_node_type_ids[left], right)) {
                expect_same_type(left, right, "assignment type mismatch");
            }
            hir.hir_store_set_type_id(node, hir.hir_store_node_type_ids[left]);
        } else if (hir.hir_store_node_kinds[right] == hir.HirNode.union_pattern_expr) {
            Int left_type = hir.hir_store_node_type_ids[left];
            if (!type_is_union(left_type)) {
                if (!type_is_optional(left_type)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[left], hir.hir_store_node_ends[left], "union pattern requires union operand");
                } else {
                    hir.hir_store_set_type_id(right, left_type);
                }
            } else {
                hir.hir_store_set_type_id(right, left_type);
            }
            if (op == hir.HirBinaryOp.ne) {
                if (union_pattern_binding_count_hir(right) != 0) {
                    Int bind_node = union_pattern_binding_hir_item(right, 0);
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[bind_node], hir.hir_store_node_ends[bind_node], "union pattern binding requires == condition");
                }
            } else if (op != hir.HirBinaryOp.eq) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "union pattern requires equality comparison");
            }
            hir.hir_store_set_type_id(node, type_store.type_store_builtin_bool);
        } else if (op == hir.HirBinaryOp.eq) {
            if (is_null_like_expr(left) != 0) {
                Int right_type = hir.hir_store_node_type_ids[right];
                if (type_is_optional(right_type)) {
                    hir.hir_store_set_type_id(left, type_strip_mutable(right_type));
                }
            } else {
                Int coerced_right = coerce_expr_to_type(right, hir.hir_store_node_type_ids[left]);
                if (coerced_right != right) {
                    hir.hir_store_set_next_sibling(left, coerced_right);
                    right = coerced_right;
                }
            }
            Int left_type = hir.hir_store_node_type_ids[left];
            Int right_type = hir.hir_store_node_type_ids[right];
            Int compare_left_type = type_strip_mutable(left_type);
            Int compare_right_type = type_strip_mutable(right_type);
            if (type_is_optional(compare_left_type) != 0) {
                if (is_null_like_expr(left) == 0) {
                    if (is_null_like_expr(right) == 0) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "optional comparison currently requires null");
                    }
                }
            } else if (type_is_optional(compare_right_type) != 0) {
                if (is_null_like_expr(left) == 0) {
                    if (is_null_like_expr(right) == 0) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "optional comparison currently requires null");
                    }
                }
            }
            if (compare_left_type != compare_right_type) {
                if (!type_is_integer_like(compare_left_type)) {
                    expect_same_type(left, right, "comparison operands must match");
                } else if (!type_is_integer_like(compare_right_type)) {
                    expect_same_type(left, right, "comparison operands must match");
                }
            }
            hir.hir_store_set_type_id(node, type_store.type_store_builtin_bool);
        } else if (op == hir.HirBinaryOp.ne) {
            if (is_null_like_expr(left) != 0) {
                Int right_type = hir.hir_store_node_type_ids[right];
                if (type_is_optional(right_type)) {
                    hir.hir_store_set_type_id(left, type_strip_mutable(right_type));
                }
            } else {
                Int coerced_right = coerce_expr_to_type(right, hir.hir_store_node_type_ids[left]);
                if (coerced_right != right) {
                    hir.hir_store_set_next_sibling(left, coerced_right);
                    right = coerced_right;
                }
            }
            Int left_type = hir.hir_store_node_type_ids[left];
            Int right_type = hir.hir_store_node_type_ids[right];
            Int compare_left_type = type_strip_mutable(left_type);
            Int compare_right_type = type_strip_mutable(right_type);
            if (type_is_optional(compare_left_type) != 0) {
                if (is_null_like_expr(left) == 0) {
                    if (is_null_like_expr(right) == 0) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "optional comparison currently requires null");
                    }
                }
            } else if (type_is_optional(compare_right_type) != 0) {
                if (is_null_like_expr(left) == 0) {
                    if (is_null_like_expr(right) == 0) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "optional comparison currently requires null");
                    }
                }
            }
            if (compare_left_type != compare_right_type) {
                if (!type_is_integer_like(compare_left_type)) {
                    expect_same_type(left, right, "comparison operands must match");
                } else if (!type_is_integer_like(compare_right_type)) {
                    expect_same_type(left, right, "comparison operands must match");
                }
            }
            hir.hir_store_set_type_id(node, type_store.type_store_builtin_bool);
        } else if (op == hir.HirBinaryOp.lt) {
            Int coerced_right = coerce_expr_to_type(right, hir.hir_store_node_type_ids[left]);
            if (coerced_right != right) {
                hir.hir_store_set_next_sibling(left, coerced_right);
                right = coerced_right;
            }
            if (!type_is_integer_like(hir.hir_store_node_type_ids[left])) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[left], hir.hir_store_node_ends[left], "comparison requires Int");
            } else if (!type_is_integer_like(hir.hir_store_node_type_ids[right])) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[right], hir.hir_store_node_ends[right], "comparison requires Int");
            }
            hir.hir_store_set_type_id(node, type_store.type_store_builtin_bool);
        } else if (op == hir.HirBinaryOp.le) {
            Int coerced_right = coerce_expr_to_type(right, hir.hir_store_node_type_ids[left]);
            if (coerced_right != right) {
                hir.hir_store_set_next_sibling(left, coerced_right);
                right = coerced_right;
            }
            if (!type_is_integer_like(hir.hir_store_node_type_ids[left])) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[left], hir.hir_store_node_ends[left], "comparison requires Int");
            } else if (!type_is_integer_like(hir.hir_store_node_type_ids[right])) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[right], hir.hir_store_node_ends[right], "comparison requires Int");
            }
            hir.hir_store_set_type_id(node, type_store.type_store_builtin_bool);
        } else if (op == hir.HirBinaryOp.gt) {
            Int coerced_right = coerce_expr_to_type(right, hir.hir_store_node_type_ids[left]);
            if (coerced_right != right) {
                hir.hir_store_set_next_sibling(left, coerced_right);
                right = coerced_right;
            }
            if (!type_is_integer_like(hir.hir_store_node_type_ids[left])) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[left], hir.hir_store_node_ends[left], "comparison requires Int");
            } else if (!type_is_integer_like(hir.hir_store_node_type_ids[right])) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[right], hir.hir_store_node_ends[right], "comparison requires Int");
            }
            hir.hir_store_set_type_id(node, type_store.type_store_builtin_bool);
        } else if (op == hir.HirBinaryOp.ge) {
            Int coerced_right = coerce_expr_to_type(right, hir.hir_store_node_type_ids[left]);
            if (coerced_right != right) {
                hir.hir_store_set_next_sibling(left, coerced_right);
                right = coerced_right;
            }
            if (!type_is_integer_like(hir.hir_store_node_type_ids[left])) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[left], hir.hir_store_node_ends[left], "comparison requires Int");
            } else if (!type_is_integer_like(hir.hir_store_node_type_ids[right])) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[right], hir.hir_store_node_ends[right], "comparison requires Int");
            }
            hir.hir_store_set_type_id(node, type_store.type_store_builtin_bool);
        } else {
            Int coerced_right = coerce_expr_to_type(right, hir.hir_store_node_type_ids[left]);
            if (coerced_right != right) {
                hir.hir_store_set_next_sibling(left, coerced_right);
                right = coerced_right;
            }
            if (!type_is_integer_like(hir.hir_store_node_type_ids[left])) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[left], hir.hir_store_node_ends[left], "arithmetic requires Int");
            } else if (!type_is_integer_like(hir.hir_store_node_type_ids[right])) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[right], hir.hir_store_node_ends[right], "arithmetic requires Int");
            }
            hir.hir_store_set_type_id(node, hir.hir_store_node_type_ids[left]);
        }
    }
    if (kind == parser.ParserNode.ternary_expr) {
        Int condition = hir.hir_store_node_first_child[node];
        Int then_expr = hir.hir_store_node_next_sibling[condition];
        Int else_expr = hir.hir_store_node_next_sibling[then_expr];
        expect_type(condition, type_store.type_store_builtin_bool, "ternary condition must be Bool");
        Int result_type = type_strip_mutable(hir.hir_store_node_type_ids[then_expr]);
        Int coerced_else = coerce_expr_to_type(else_expr, result_type);
        if (coerced_else != else_expr) {
            hir.hir_store_set_next_sibling(then_expr, coerced_else);
            else_expr = coerced_else;
        }
        if (type_strip_mutable(hir.hir_store_node_type_ids[then_expr]) != type_strip_mutable(hir.hir_store_node_type_ids[else_expr])) {
            result_type = type_strip_mutable(hir.hir_store_node_type_ids[else_expr]);
            Int coerced_then = coerce_expr_to_type(then_expr, result_type);
            if (coerced_then != then_expr) {
                hir.hir_store_set_next_sibling(condition, coerced_then);
                hir.hir_store_set_next_sibling(coerced_then, else_expr);
                then_expr = coerced_then;
            }
        }
        if (type_strip_mutable(hir.hir_store_node_type_ids[then_expr]) != type_strip_mutable(hir.hir_store_node_type_ids[else_expr])) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "ternary branch type mismatch");
        } else {
            result_type = type_strip_mutable(hir.hir_store_node_type_ids[then_expr]);
            if (!type_supports_ternary_result(result_type)) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "ternary result currently requires scalar type");
            }
            hir.hir_store_set_type_id(node, result_type);
        }
    }
    if (kind == parser.ParserNode.if_stmt) {
        expect_type(hir.hir_store_node_first_child[node], type_store.type_store_builtin_bool, "if condition must be Bool");
    }
    if (kind == parser.ParserNode.while_stmt) {
        expect_type(hir.hir_store_node_first_child[node], type_store.type_store_builtin_bool, "while condition must be Bool");
    }
    if (kind == parser.ParserNode.for_stmt) {
        Int mode = hir.hir_store_node_aux[node];
        if (mode == 0) {
            Int type_node = hir.hir_store_node_first_child[node];
            Int start_expr = hir.hir_store_node_next_sibling[hir.hir_store_node_next_sibling[type_node]];
            Int end_expr = hir.hir_store_node_next_sibling[start_expr];
            if (hir.hir_store_node_type_ids[type_node] != type_store.type_store_builtin_int) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[type_node], hir.hir_store_node_ends[type_node], "for loop variable type must be Int");
            }
            expect_type(start_expr, type_store.type_store_builtin_int, "for range start must be Int");
            expect_type(end_expr, type_store.type_store_builtin_int, "for range end must be Int");
        } else if (mode == 1) {
            Int start_expr = hir.hir_store_node_next_sibling[hir.hir_store_node_first_child[node]];
            Int end_expr = hir.hir_store_node_next_sibling[start_expr];
            expect_type(start_expr, type_store.type_store_builtin_int, "for range start must be Int");
            expect_type(end_expr, type_store.type_store_builtin_int, "for range end must be Int");
        } else {
            Int iterable_node = 0;
            if (mode == 2) {
                iterable_node = hir.hir_store_node_next_sibling[hir.hir_store_node_first_child[node]];
            } else if (mode == 4) {
                iterable_node = hir.hir_store_node_first_child[node];
            } else if (mode == 5) {
                iterable_node = hir.hir_store_node_next_sibling[hir.hir_store_node_next_sibling[hir.hir_store_node_first_child[node]]];
            } else {
                iterable_node = hir.hir_store_node_next_sibling[hir.hir_store_node_next_sibling[hir.hir_store_node_first_child[node]]];
            }
            Int iterable_type = hir.hir_store_node_type_ids[iterable_node];
            if (!type_is_array(iterable_type)) {
                if (!type_is_slice(iterable_type)) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[iterable_node], hir.hir_store_node_ends[iterable_node], "for iterable must be array or slice");
                }
            }
        }
    }
    if (kind == parser.ParserNode.switch_stmt) {
        Int condition = hir.hir_store_node_first_child[node];
        Int condition_type = hir.hir_store_node_type_ids[condition];
        if (condition_type != type_store.type_store_builtin_int) {
            if (!type_is_enum(condition_type)) {
                if (!type_is_union(condition_type)) {
                    if (!type_is_optional(condition_type)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[condition], hir.hir_store_node_ends[condition], "switch expression must be Int, enum, union, or optional");
                    }
                }
            }
        }
        Int child = hir.hir_store_node_next_sibling[condition];
        Int else_count = 0;
        Int duplicate_or_invalid_case = 0;
        while (child != 0) {
            Int child_kind = hir.hir_store_node_kinds[child];
            if (child_kind == hir.HirNode.switch_else) {
                else_count = else_count + 1;
                if (else_count > 1) {
                    diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[child], hir.hir_store_node_ends[child], "duplicate else case");
                }
            }
            if (child_kind == hir.HirNode.switch_case) {
                Int label = switch_case_label_hir(child);
                if (label != 0) {
                    if (type_is_enum(condition_type)) {
                        Int label_symbol = hir.hir_store_node_symbol_ids[label];
                        if (label_symbol == 0) {
                            duplicate_or_invalid_case = 1;
                        } else {
                            Int earlier = hir.hir_store_node_next_sibling[condition];
                            while (earlier != child) {
                                if (hir.hir_store_node_kinds[earlier] == hir.HirNode.switch_case) {
                                    Int earlier_label = switch_case_label_hir(earlier);
                                    if (earlier_label != 0) {
                                        if (hir.hir_store_node_symbol_ids[earlier_label] == label_symbol) {
                                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[label], hir.hir_store_node_ends[label], "duplicate switch case");
                                            duplicate_or_invalid_case = 1;
                                        }
                                    }
                                }
                                earlier = hir.hir_store_node_next_sibling[earlier];
                            }
                        }
                    } else if (type_is_union(condition_type)) {
                        Int label_symbol = hir.hir_store_node_symbol_ids[label];
                        if (label_symbol == 0) {
                            duplicate_or_invalid_case = 1;
                        } else {
                            Int earlier = hir.hir_store_node_next_sibling[condition];
                            while (earlier != child) {
                                if (hir.hir_store_node_kinds[earlier] == hir.HirNode.switch_case) {
                                    Int earlier_label = switch_case_label_hir(earlier);
                                    if (earlier_label != 0) {
                                        if (hir.hir_store_node_symbol_ids[earlier_label] == label_symbol) {
                                            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[label], hir.hir_store_node_ends[label], "duplicate switch case");
                                            duplicate_or_invalid_case = 1;
                                        }
                                    }
                                }
                                earlier = hir.hir_store_node_next_sibling[earlier];
                            }
                        }
                    } else if (type_is_optional(condition_type)) {
                        Int label_kind = optional_case_kind_hir(label);
                        if (label_kind == 0) {
                            if (hir.hir_store_node_kinds[label] != hir.HirNode.null_lit) {
                                duplicate_or_invalid_case = 1;
                            }
                        }
                        Int earlier = hir.hir_store_node_next_sibling[condition];
                        while (earlier != child) {
                            if (hir.hir_store_node_kinds[earlier] == hir.HirNode.switch_case) {
                                Int earlier_label = switch_case_label_hir(earlier);
                                if (optional_case_kind_hir(earlier_label) == label_kind) {
                                    if (label_kind != 0) {
                                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[label], hir.hir_store_node_ends[label], "duplicate switch case");
                                        duplicate_or_invalid_case = 1;
                                    }
                                }
                            }
                            earlier = hir.hir_store_node_next_sibling[earlier];
                        }
                    }
                }
            }
            child = hir.hir_store_node_next_sibling[child];
        }
        if (else_count == 0) {
            if (duplicate_or_invalid_case == 0) {
                if (type_is_enum(condition_type)) {
                    Int owner_symbol = find_type_owner_symbol(condition_type);
                    Int expected_members = count_child_symbols_of_kind(owner_symbol, symbol_store.SymbolKind.enum_member);
                    Int covered_members = 0;
                    Int i = 1;
                    while (i < symbol_store.symbol_store_count) {
                        if (symbol_store.symbol_store_parent_ids[i] == owner_symbol) {
                            if (symbol_store.symbol_store_kinds[i] == symbol_store.SymbolKind.enum_member) {
                                if (switch_stmt_has_member_case(node, i)) {
                                    covered_members = covered_members + 1;
                                }
                            }
                        }
                        i = i + 1;
                    }
                    if (covered_members != expected_members) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "non-exhaustive switch");
                    }
                } else if (type_is_union(condition_type)) {
                    Int owner_symbol = find_type_owner_symbol(condition_type);
                    Int expected_members = count_child_symbols_of_kind(owner_symbol, symbol_store.SymbolKind.union_member);
                    Int covered_members = 0;
                    Int i = 1;
                    while (i < symbol_store.symbol_store_count) {
                        if (symbol_store.symbol_store_parent_ids[i] == owner_symbol) {
                            if (symbol_store.symbol_store_kinds[i] == symbol_store.SymbolKind.union_member) {
                                if (switch_stmt_has_member_case(node, i)) {
                                    covered_members = covered_members + 1;
                                }
                            }
                        }
                        i = i + 1;
                    }
                    if (covered_members != expected_members) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "non-exhaustive switch");
                    }
                } else if (type_is_optional(condition_type)) {
                    if (switch_stmt_has_optional_case(node, 1) == 0) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "non-exhaustive switch");
                    } else if (switch_stmt_has_optional_case(node, 2) == 0) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "non-exhaustive switch");
                    }
                }
            }
        }
    }
    if (kind == parser.ParserNode.break_stmt) {
        if (current_loop_depth <= 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "break outside loop");
        }
    }
    if (kind == parser.ParserNode.continue_stmt) {
        if (current_loop_depth <= 0) {
            diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "continue outside loop");
        }
    }
    if (kind == parser.ParserNode.return_stmt) {
        Int expr = hir.hir_store_node_first_child[node];
        if (expr == 0) {
            if (current_return_type != type_store.type_store_builtin_void) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "return type mismatch");
            }
        } else {
            Int coerced_expr = coerce_expr_to_type(expr, current_return_type);
            if (coerced_expr != expr) {
                hir.hir_store_set_first_child(node, coerced_expr);
                expr = coerced_expr;
            }
            if (current_return_type == type_store.type_store_builtin_void) {
                diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "return type mismatch");
            } else {
                if (hir.hir_store_node_kinds[expr] == hir.HirNode.array_lit) {
                    check_array_literal_against_type(expr, current_return_type);
                } else if (is_known_type(hir.hir_store_node_type_ids[expr])) {
                    if (type_strip_mutable(hir.hir_store_node_type_ids[expr]) != type_strip_mutable(current_return_type)) {
                        diagnostic.diagnostic_error(current_path, hir.hir_store_node_starts[node], hir.hir_store_node_ends[node], "return type mismatch");
                    }
                }
            }
        }
    }
    if (kind == parser.ParserNode.func_decl) {
        check_struct_init_function(node);
    }
    return node;
}

public Int lower_program(UInt8[] source, UInt8[] path, Int parse_root) {
    current_source = source;
    current_path = path;
    current_type_owner_symbol = 0;
    current_func_symbol = 0;
    current_return_type = 0;
    current_loop_depth = 0;
    current_switch_type = 0;
    tuple_temp_counter = 0;
    current_module_id = module_loader.module_loader_ensure_module(path);
    type_store.type_store_reset();
    symbol_store.symbol_store_reset();
    hir.hir_store_reset();
    generic_context_reset();
    free_state_reset();
    module_loader.module_loader_reset();
    parser.parser_store_reset_snapshots();
    register_builtin_symbols();
    current_module_id = module_loader.module_loader_ensure_module(path);
    register_module_id = current_module_id;
    import_visit_set = ints.buffer_int_new(16);
    visible_import_module_ids = ints.buffer_int_new(8);
    Int child = parser.parser_store_node_first_child[parse_root];
    Int pending_import_modules = ints.buffer_int_new(8);
    while (child != 0) {
        if (parser.parser_store_node_kinds[child] == parser.ParserNode.import_decl) {
            Int path_node = import_decl_path_node(child);
            UInt8[] import_path = import_string_value(source, path_node);
            if (path_utils.is_relative_import(import_path)) {
                UInt8[] resolved_import = path_utils.resolve_local_import(path, import_path);
                Int import_module_id = module_loader.module_loader_ensure_module(resolved_import);
                if (import_decl_alias_node(child) == 0) {
                    ints.buffer_int_push(visible_import_module_ids, import_module_id);
                }
                ints.buffer_int_push(pending_import_modules, import_module_id);
            }
        }
        child = parser.parser_store_node_next_sibling[child];
    }
    child = 0;
    while (child < ints.buffer_int_length(pending_import_modules)) {
        register_imported_scope(module_loader.module_loader_module_path(ints.buffer_int_get(pending_import_modules, child)));
        if (diagnostic.diagnostic_has_error()) {
            return 0;
        }
        child = child + 1;
    }
    parse_root = parser_frontend.parse_source(path, source);
    if (diagnostic.diagnostic_has_error()) {
        return 0;
    }
    register_import_aliases(source, parse_root, path);
    register_named_types(source, parse_root);
    register_top_level_funcs(source, parse_root);
    register_top_level_globals(source, parse_root);
    register_top_level_aliases(source, parse_root);
    register_member_symbols(source, parse_root);
    register_function_symbols(source, parse_root, 1);
    current_parse_snapshot_id = parser.parser_store_snapshot_current();
    module_loader.module_loader_register_parse_snapshot(current_module_id, current_parse_snapshot_id);

    Int root = hir.hir_store_new_node(hir.HirNode.program, 0, parser.parser_store_node_ends[parse_root]);
    child = parser.parser_store_node_first_child[parse_root];
    while (child != 0) {
        if (parser.parser_store_node_kinds[child] != parser.ParserNode.import_decl) {
            if (parser.parser_store_node_kinds[child] != parser.ParserNode.alias_decl) {
            hir.hir_store_append_child(root, lower_node(child));
            }
        }
        child = parser.parser_store_node_next_sibling[child];
    }
    Int inst_id = 1;
    while (inst_id <= generic_struct_inst_count) {
        hir.hir_store_append_child(root, build_synthetic_generic_struct_decl(inst_id));
        inst_id = inst_id + 1;
    }
    inst_id = 1;
    while (inst_id <= generic_func_inst_count) {
        Int func_symbol = ints.buffer_int_get(generic_func_inst_symbol_handle, inst_id);
        Int template_symbol = ints.buffer_int_get(generic_func_inst_template_symbol_handle, inst_id);
        Int template_module_id = symbol_store.symbol_store_module_ids[template_symbol];
        Int saved_module_id = current_module_id;
        Int saved_register_module_id = register_module_id;
        UInt8[] saved_source = current_source;
        UInt8[] saved_path = current_path;
        Int saved_visible_import_module_ids = visible_import_module_ids;
        Int saved_parse_snapshot_id = current_parse_snapshot_id;
        if (template_module_id != current_module_id) {
            Int template_snapshot_id = module_loader.module_loader_find_parse_snapshot(template_module_id);
            if (template_snapshot_id == 0) {
                diagnostic.diagnostic_error(current_path, 0, 0, "missing parse snapshot for imported generic function");
                return 0;
            }
            parser.parser_store_restore_snapshot(template_snapshot_id);
            current_parse_snapshot_id = template_snapshot_id;
            current_module_id = template_module_id;
            register_module_id = template_module_id;
            current_path = module_loader.module_loader_module_path(template_module_id);
            current_source = module_loader.load_source(current_path);
            visible_import_module_ids = collect_visible_import_modules_for_parse(current_source, current_path, 1);
        }
        Int template_decl = symbol_generic_template_decl(template_symbol);
        Int template_first_type_id = symbol_generic_template_first_type_id(template_symbol);
        Int template_type_count = symbol_generic_template_type_count(template_symbol);
        Int saved_subst_first_type_id = current_generic_subst_first_type_id;
        Int saved_subst_type_count = current_generic_subst_type_count;
        Int saved_subst_arg_types_handle = current_generic_subst_arg_types_handle;
        current_generic_subst_first_type_id = template_first_type_id;
        current_generic_subst_type_count = template_type_count;
        current_generic_subst_arg_types_handle = ints.buffer_int_new(ints.buffer_int_get(generic_func_inst_arg_count_handle, inst_id));
        Int arg_offset = ints.buffer_int_get(generic_func_inst_arg_offset_handle, inst_id);
        Int arg_count = ints.buffer_int_get(generic_func_inst_arg_count_handle, inst_id);
        Int arg_i = 0;
        while (arg_i < arg_count) {
            ints.buffer_int_push(current_generic_subst_arg_types_handle, ints.buffer_int_get(generic_func_inst_arg_type_ids_handle, arg_offset + arg_i));
            arg_i = arg_i + 1;
        }
        current_generic_func_lowering_parse = template_decl;
        current_generic_func_lowering_symbol = func_symbol;
        hir.hir_store_append_child(root, lower_node(template_decl));
        current_generic_func_lowering_parse = 0;
        current_generic_func_lowering_symbol = 0;
        current_generic_subst_first_type_id = saved_subst_first_type_id;
        current_generic_subst_type_count = saved_subst_type_count;
        current_generic_subst_arg_types_handle = saved_subst_arg_types_handle;
        if (template_module_id != saved_module_id) {
            parser.parser_store_restore_snapshot(saved_parse_snapshot_id);
            current_parse_snapshot_id = saved_parse_snapshot_id;
            current_module_id = saved_module_id;
            register_module_id = saved_register_module_id;
            current_source = saved_source;
            current_path = saved_path;
            visible_import_module_ids = saved_visible_import_module_ids;
        }
        inst_id = inst_id + 1;
    }
    if (!diagnostic.diagnostic_has_error()) {
        verify_resolved_node(root, 0, 0);
    }
    return root;
}
