Int field_default_expr_hir(Int field_symbol) {
    if (field_symbol == 0) {
        return 0;
    }
    Int field_node = symbol_store.symbol_store_aux[field_symbol];
    if (field_node == 0) {
        return 0;
    }
    Int type_node = hir.hir_store_node_first_child[field_node];
    if (type_node == 0) {
        return 0;
    }
    Int name_node = hir.hir_store_node_next_sibling[type_node];
    if (name_node == 0) {
        return 0;
    }
    return hir.hir_store_node_next_sibling[name_node];
}

Bool field_has_default_expr(Int field_symbol) {
    return field_default_expr_hir(field_symbol) != 0;
}

() register_builtin_symbols() {
    UInt8[] assert_name = "__intrinsic_assert";
    UInt8[] cond_name = "cond";
    UInt8[] print_name = "print";
    UInt8[] write_stdout_name = "__intrinsic_write_stdout";
    UInt8[] file_exists_name = "__intrinsic_file_exists";
    UInt8[] read_file_name = "__intrinsic_read_file";
    UInt8[] malloc_name = "__intrinsic_malloc";
    UInt8[] free_name = "__intrinsic_free";
    UInt8[] memmove_name = "__intrinsic_memmove";
    UInt8[] path_name = "path";
    UInt8[] size_name = "size";
    UInt8[] ptr_name = "ptr";
    UInt8[] dst_name = "dst";
    UInt8[] src_name = "src";
    UInt8[] bytes_name = "bytes";

    builtin_assert_symbol = symbol_store.symbol_store_new_symbol(
        assert_name,
        symbol_store.SymbolKind.func,
        0,
        assert_name.length,
        type_store.type_store_builtin_void,
        0,
        0
    );
    builtin_assert_param = symbol_store.symbol_store_new_symbol(
        cond_name,
        symbol_store.SymbolKind.param,
        0,
        cond_name.length,
        type_store.type_store_builtin_bool,
        builtin_assert_symbol,
        0
    );
    builtin_print_symbol = symbol_store.symbol_store_new_symbol(
        print_name,
        symbol_store.SymbolKind.func,
        0,
        print_name.length,
        type_store.type_store_builtin_void,
        0,
        0
    );
    builtin_write_stdout_symbol = symbol_store.symbol_store_new_symbol(
        write_stdout_name,
        symbol_store.SymbolKind.func,
        0,
        write_stdout_name.length,
        type_store.type_store_builtin_void,
        0,
        0
    );
    builtin_write_stdout_param = symbol_store.symbol_store_new_symbol(
        path_name,
        symbol_store.SymbolKind.param,
        0,
        path_name.length,
        type_store.type_store_builtin_uint8_slice,
        builtin_write_stdout_symbol,
        0
    );
    builtin_file_exists_symbol = symbol_store.symbol_store_new_symbol(
        file_exists_name,
        symbol_store.SymbolKind.func,
        0,
        file_exists_name.length,
        type_store.type_store_builtin_bool,
        0,
        0
    );
    builtin_file_exists_param = symbol_store.symbol_store_new_symbol(
        path_name,
        symbol_store.SymbolKind.param,
        0,
        path_name.length,
        type_store.type_store_builtin_uint8_slice,
        builtin_file_exists_symbol,
        0
    );
    builtin_read_file_symbol = symbol_store.symbol_store_new_symbol(
        read_file_name,
        symbol_store.SymbolKind.func,
        0,
        read_file_name.length,
        type_store.type_store_builtin_uint8_slice,
        0,
        0
    );
    builtin_read_file_param = symbol_store.symbol_store_new_symbol(
        path_name,
        symbol_store.SymbolKind.param,
        0,
        path_name.length,
        type_store.type_store_builtin_uint8_slice,
        builtin_read_file_symbol,
        0
    );
    builtin_malloc_symbol = symbol_store.symbol_store_new_symbol(
        malloc_name,
        symbol_store.SymbolKind.func,
        0,
        malloc_name.length,
        type_store.type_store_new_pointer_type(type_store.type_store_builtin_uint8),
        0,
        0
    );
    builtin_malloc_param = symbol_store.symbol_store_new_symbol(
        size_name,
        symbol_store.SymbolKind.param,
        0,
        size_name.length,
        type_store.type_store_builtin_int,
        builtin_malloc_symbol,
        0
    );
    builtin_free_symbol = symbol_store.symbol_store_new_symbol(
        free_name,
        symbol_store.SymbolKind.func,
        0,
        free_name.length,
        type_store.type_store_builtin_void,
        0,
        0
    );
    builtin_free_param = symbol_store.symbol_store_new_symbol(
        ptr_name,
        symbol_store.SymbolKind.param,
        0,
        ptr_name.length,
        type_store.type_store_new_pointer_type(type_store.type_store_builtin_uint8),
        builtin_free_symbol,
        0
    );
    builtin_memmove_symbol = symbol_store.symbol_store_new_symbol(
        memmove_name,
        symbol_store.SymbolKind.func,
        0,
        memmove_name.length,
        type_store.type_store_builtin_void,
        0,
        0
    );
    builtin_memmove_dst_param = symbol_store.symbol_store_new_symbol(
        dst_name,
        symbol_store.SymbolKind.param,
        0,
        dst_name.length,
        type_store.type_store_new_pointer_type(type_store.type_store_builtin_uint8),
        builtin_memmove_symbol,
        0
    );
    builtin_memmove_src_param = symbol_store.symbol_store_new_symbol(
        src_name,
        symbol_store.SymbolKind.param,
        0,
        src_name.length,
        type_store.type_store_new_pointer_type(type_store.type_store_builtin_uint8),
        builtin_memmove_symbol,
        0
    );
    builtin_memmove_bytes_param = symbol_store.symbol_store_new_symbol(
        bytes_name,
        symbol_store.SymbolKind.param,
        0,
        bytes_name.length,
        type_store.type_store_builtin_int,
        builtin_memmove_symbol,
        0
    );
}

