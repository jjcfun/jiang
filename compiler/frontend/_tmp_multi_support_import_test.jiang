import path_utils = "path_utils.jiang";
import source_loader = "source_loader.jiang";
import diagnostic = "../support/diagnostic.jiang";
import ints = "../support/buffer_int.jiang";
import bytes = "../support/buffer_bytes.jiang";

Int main() {
    diagnostic.diagnostic_reset();
    Int int_handle = ints.buffer_int_new(4);
    Int byte_handle = bytes.buffer_bytes_new(4);
    if (path_utils.has_jiang_suffix("x.jiang")) {
        bytes.buffer_bytes_push(byte_handle, 120);
    }
    return int_handle + byte_handle + source_loader.read_source("compiler/frontend/parser.jiang").length;
}
