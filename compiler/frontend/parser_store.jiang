import ints = "../support/buffer_int.jiang";

public enum ParserNode {
    program,
    import_decl,
    alias_decl,
    struct_decl,
    union_decl,
    enum_decl,
    enum_member,
    field_decl,
    func_decl,
    type_name,
    slice_type,
    array_type,
    pointer_type,
    tuple_type,
    ident,
    string_lit,
    bool_lit,
    param,
    field_init,
    block,
    if_stmt,
    while_stmt,
    for_stmt,
    switch_stmt,
    switch_case,
    switch_else,
    break_stmt,
    continue_stmt,
    return_stmt,
    expr_stmt,
    local_decl,
    tuple_local_decl,
    global_decl,
    tuple_global_decl,
    int_lit,
    call_expr,
    member_expr,
    optional_member_expr,
    index_expr,
    optional_index_expr,
    range_expr,
    shorthand_member_expr,
    union_pattern_expr,
    struct_init_expr,
    array_lit,
    tuple_lit,
    unary_expr,
    binary_expr,
    ternary_expr,
    array_init_expr,
    null_lit,
    optional_type,
    mutable_type,
}

public enum BinaryOp {
    assign,
    eq,
    ne,
    lt,
    le,
    gt,
    ge,
    add,
    sub,
    mul,
    div,
    coalesce,
}

public enum UnaryOp {
    neg,
    not,
    addr,
    deref,
    new_expr,
}

public Int type_aux_builtin_void = 4;

public Int decl_flag_public = 1;
public Int decl_flag_extern = 2;
public Int decl_flag_static = 4;
public Int decl_flag_init = 8;
public Int decl_aux_stride = 16;
public Int union_decl_aux_implicit_tag = 1;
public Int infer_type_aux = 1;
public Int mutable_binding_aux = 2;
public Int infer_array_length_aux = -1;

Int parser_store_node_kinds_handle = 0;
Int parser_store_node_starts_handle = 0;
Int parser_store_node_ends_handle = 0;
Int parser_store_node_aux_handle = 0;
Int parser_store_node_first_child_handle = 0;
Int parser_store_node_next_sibling_handle = 0;
Int parser_store_node_parent_handle = 0;
Int parser_store_node_generic_item_offset_handle = 0;
Int parser_store_node_generic_item_count_handle = 0;
Int parser_store_generic_item_ids_handle = 0;
Int parser_store_snapshot_kinds_handles_handle = 0;
Int parser_store_snapshot_starts_handles_handle = 0;
Int parser_store_snapshot_ends_handles_handle = 0;
Int parser_store_snapshot_aux_handles_handle = 0;
Int parser_store_snapshot_first_child_handles_handle = 0;
Int parser_store_snapshot_next_sibling_handles_handle = 0;
Int parser_store_snapshot_parent_handles_handle = 0;
Int parser_store_snapshot_generic_item_offset_handles_handle = 0;
Int parser_store_snapshot_generic_item_count_handles_handle = 0;
Int parser_store_snapshot_generic_item_ids_handles_handle = 0;
Int parser_store_snapshot_node_counts_handle = 0;
Int parser_store_snapshot_count = 0;
Int parser_store_initialized = 0;

public Int[] parser_store_node_kinds;
public Int[] parser_store_node_starts;
public Int[] parser_store_node_ends;
public Int[] parser_store_node_aux;
public Int[] parser_store_node_first_child;
public Int[] parser_store_node_next_sibling;
public Int[] parser_store_node_parent;
public Int[] parser_store_node_generic_item_offsets;
public Int[] parser_store_node_generic_item_counts;
public Int[] parser_store_generic_item_ids;
public Int parser_store_node_count = 1;

() parser_store_refresh_slices() {
    parser_store_node_kinds = ints.buffer_int_slice(parser_store_node_kinds_handle);
    parser_store_node_starts = ints.buffer_int_slice(parser_store_node_starts_handle);
    parser_store_node_ends = ints.buffer_int_slice(parser_store_node_ends_handle);
    parser_store_node_aux = ints.buffer_int_slice(parser_store_node_aux_handle);
    parser_store_node_first_child = ints.buffer_int_slice(parser_store_node_first_child_handle);
    parser_store_node_next_sibling = ints.buffer_int_slice(parser_store_node_next_sibling_handle);
    parser_store_node_parent = ints.buffer_int_slice(parser_store_node_parent_handle);
    parser_store_node_generic_item_offsets = ints.buffer_int_slice(parser_store_node_generic_item_offset_handle);
    parser_store_node_generic_item_counts = ints.buffer_int_slice(parser_store_node_generic_item_count_handle);
    parser_store_generic_item_ids = ints.buffer_int_slice(parser_store_generic_item_ids_handle);
}

() parser_store_ensure_initialized() {
    if (parser_store_initialized != 0) {
        return;
    }
    parser_store_node_kinds_handle = ints.buffer_int_new(4096);
    parser_store_node_starts_handle = ints.buffer_int_new(4096);
    parser_store_node_ends_handle = ints.buffer_int_new(4096);
    parser_store_node_aux_handle = ints.buffer_int_new(4096);
    parser_store_node_first_child_handle = ints.buffer_int_new(4096);
    parser_store_node_next_sibling_handle = ints.buffer_int_new(4096);
    parser_store_node_parent_handle = ints.buffer_int_new(4096);
    parser_store_node_generic_item_offset_handle = ints.buffer_int_new(4096);
    parser_store_node_generic_item_count_handle = ints.buffer_int_new(4096);
    parser_store_generic_item_ids_handle = ints.buffer_int_new(4096);
    parser_store_snapshot_kinds_handles_handle = ints.buffer_int_new(64);
    parser_store_snapshot_starts_handles_handle = ints.buffer_int_new(64);
    parser_store_snapshot_ends_handles_handle = ints.buffer_int_new(64);
    parser_store_snapshot_aux_handles_handle = ints.buffer_int_new(64);
    parser_store_snapshot_first_child_handles_handle = ints.buffer_int_new(64);
    parser_store_snapshot_next_sibling_handles_handle = ints.buffer_int_new(64);
    parser_store_snapshot_parent_handles_handle = ints.buffer_int_new(64);
    parser_store_snapshot_generic_item_offset_handles_handle = ints.buffer_int_new(64);
    parser_store_snapshot_generic_item_count_handles_handle = ints.buffer_int_new(64);
    parser_store_snapshot_generic_item_ids_handles_handle = ints.buffer_int_new(64);
    parser_store_snapshot_node_counts_handle = ints.buffer_int_new(64);
    parser_store_refresh_slices();
    parser_store_initialized = 1;
}

public () parser_store_reset_snapshots() {
    parser_store_ensure_initialized();
    ints.buffer_int_clear(parser_store_snapshot_kinds_handles_handle);
    ints.buffer_int_clear(parser_store_snapshot_starts_handles_handle);
    ints.buffer_int_clear(parser_store_snapshot_ends_handles_handle);
    ints.buffer_int_clear(parser_store_snapshot_aux_handles_handle);
    ints.buffer_int_clear(parser_store_snapshot_first_child_handles_handle);
    ints.buffer_int_clear(parser_store_snapshot_next_sibling_handles_handle);
    ints.buffer_int_clear(parser_store_snapshot_parent_handles_handle);
    ints.buffer_int_clear(parser_store_snapshot_generic_item_offset_handles_handle);
    ints.buffer_int_clear(parser_store_snapshot_generic_item_count_handles_handle);
    ints.buffer_int_clear(parser_store_snapshot_generic_item_ids_handles_handle);
    ints.buffer_int_clear(parser_store_snapshot_node_counts_handle);
    parser_store_snapshot_count = 0;
}

public () parser_store_reset() {
    parser_store_ensure_initialized();
    ints.buffer_int_clear(parser_store_node_kinds_handle);
    ints.buffer_int_clear(parser_store_node_starts_handle);
    ints.buffer_int_clear(parser_store_node_ends_handle);
    ints.buffer_int_clear(parser_store_node_aux_handle);
    ints.buffer_int_clear(parser_store_node_first_child_handle);
    ints.buffer_int_clear(parser_store_node_next_sibling_handle);
    ints.buffer_int_clear(parser_store_node_parent_handle);
    ints.buffer_int_clear(parser_store_node_generic_item_offset_handle);
    ints.buffer_int_clear(parser_store_node_generic_item_count_handle);
    ints.buffer_int_clear(parser_store_generic_item_ids_handle);
    parser_store_node_count = 1;
    parser_store_refresh_slices();
}

() parser_store_snapshot_copy(Int source_handle, Int target_handle) {
    Int i = 0;
    while (i < ints.buffer_int_length(source_handle)) {
        ints.buffer_int_set(target_handle, i, ints.buffer_int_get(source_handle, i));
        i = i + 1;
    }
}

public Int parser_store_snapshot_current() {
    parser_store_ensure_initialized();
    Int snapshot_id = parser_store_snapshot_count + 1;
    Int kinds_handle = ints.buffer_int_new(ints.buffer_int_length(parser_store_node_kinds_handle) + 4);
    Int starts_handle = ints.buffer_int_new(ints.buffer_int_length(parser_store_node_starts_handle) + 4);
    Int ends_handle = ints.buffer_int_new(ints.buffer_int_length(parser_store_node_ends_handle) + 4);
    Int aux_handle = ints.buffer_int_new(ints.buffer_int_length(parser_store_node_aux_handle) + 4);
    Int first_child_handle = ints.buffer_int_new(ints.buffer_int_length(parser_store_node_first_child_handle) + 4);
    Int next_sibling_handle = ints.buffer_int_new(ints.buffer_int_length(parser_store_node_next_sibling_handle) + 4);
    Int parent_handle = ints.buffer_int_new(ints.buffer_int_length(parser_store_node_parent_handle) + 4);
    Int generic_item_offset_handle = ints.buffer_int_new(ints.buffer_int_length(parser_store_node_generic_item_offset_handle) + 4);
    Int generic_item_count_handle = ints.buffer_int_new(ints.buffer_int_length(parser_store_node_generic_item_count_handle) + 4);
    Int generic_item_ids_handle = ints.buffer_int_new(ints.buffer_int_length(parser_store_generic_item_ids_handle) + 4);
    parser_store_snapshot_copy(parser_store_node_kinds_handle, kinds_handle);
    parser_store_snapshot_copy(parser_store_node_starts_handle, starts_handle);
    parser_store_snapshot_copy(parser_store_node_ends_handle, ends_handle);
    parser_store_snapshot_copy(parser_store_node_aux_handle, aux_handle);
    parser_store_snapshot_copy(parser_store_node_first_child_handle, first_child_handle);
    parser_store_snapshot_copy(parser_store_node_next_sibling_handle, next_sibling_handle);
    parser_store_snapshot_copy(parser_store_node_parent_handle, parent_handle);
    parser_store_snapshot_copy(parser_store_node_generic_item_offset_handle, generic_item_offset_handle);
    parser_store_snapshot_copy(parser_store_node_generic_item_count_handle, generic_item_count_handle);
    parser_store_snapshot_copy(parser_store_generic_item_ids_handle, generic_item_ids_handle);
    ints.buffer_int_set(parser_store_snapshot_kinds_handles_handle, snapshot_id, kinds_handle);
    ints.buffer_int_set(parser_store_snapshot_starts_handles_handle, snapshot_id, starts_handle);
    ints.buffer_int_set(parser_store_snapshot_ends_handles_handle, snapshot_id, ends_handle);
    ints.buffer_int_set(parser_store_snapshot_aux_handles_handle, snapshot_id, aux_handle);
    ints.buffer_int_set(parser_store_snapshot_first_child_handles_handle, snapshot_id, first_child_handle);
    ints.buffer_int_set(parser_store_snapshot_next_sibling_handles_handle, snapshot_id, next_sibling_handle);
    ints.buffer_int_set(parser_store_snapshot_parent_handles_handle, snapshot_id, parent_handle);
    ints.buffer_int_set(parser_store_snapshot_generic_item_offset_handles_handle, snapshot_id, generic_item_offset_handle);
    ints.buffer_int_set(parser_store_snapshot_generic_item_count_handles_handle, snapshot_id, generic_item_count_handle);
    ints.buffer_int_set(parser_store_snapshot_generic_item_ids_handles_handle, snapshot_id, generic_item_ids_handle);
    ints.buffer_int_set(parser_store_snapshot_node_counts_handle, snapshot_id, parser_store_node_count);
    parser_store_snapshot_count = snapshot_id;
    return snapshot_id;
}

public () parser_store_restore_snapshot(Int snapshot_id) {
    parser_store_ensure_initialized();
    if (snapshot_id <= 0) {
        return;
    }
    parser_store_node_kinds_handle = ints.buffer_int_get(parser_store_snapshot_kinds_handles_handle, snapshot_id);
    parser_store_node_starts_handle = ints.buffer_int_get(parser_store_snapshot_starts_handles_handle, snapshot_id);
    parser_store_node_ends_handle = ints.buffer_int_get(parser_store_snapshot_ends_handles_handle, snapshot_id);
    parser_store_node_aux_handle = ints.buffer_int_get(parser_store_snapshot_aux_handles_handle, snapshot_id);
    parser_store_node_first_child_handle = ints.buffer_int_get(parser_store_snapshot_first_child_handles_handle, snapshot_id);
    parser_store_node_next_sibling_handle = ints.buffer_int_get(parser_store_snapshot_next_sibling_handles_handle, snapshot_id);
    parser_store_node_parent_handle = ints.buffer_int_get(parser_store_snapshot_parent_handles_handle, snapshot_id);
    parser_store_node_generic_item_offset_handle = ints.buffer_int_get(parser_store_snapshot_generic_item_offset_handles_handle, snapshot_id);
    parser_store_node_generic_item_count_handle = ints.buffer_int_get(parser_store_snapshot_generic_item_count_handles_handle, snapshot_id);
    parser_store_generic_item_ids_handle = ints.buffer_int_get(parser_store_snapshot_generic_item_ids_handles_handle, snapshot_id);
    parser_store_node_count = ints.buffer_int_get(parser_store_snapshot_node_counts_handle, snapshot_id);
    parser_store_refresh_slices();
}

public Int parser_store_new_node(Int kind, Int start, Int end_pos) {
    parser_store_ensure_initialized();
    Int id = parser_store_node_count;
    ints.buffer_int_set(parser_store_node_kinds_handle, id, kind);
    ints.buffer_int_set(parser_store_node_starts_handle, id, start);
    ints.buffer_int_set(parser_store_node_ends_handle, id, end_pos);
    ints.buffer_int_set(parser_store_node_aux_handle, id, 0);
    ints.buffer_int_set(parser_store_node_first_child_handle, id, 0);
    ints.buffer_int_set(parser_store_node_next_sibling_handle, id, 0);
    ints.buffer_int_set(parser_store_node_parent_handle, id, 0);
    ints.buffer_int_set(parser_store_node_generic_item_offset_handle, id, 0);
    ints.buffer_int_set(parser_store_node_generic_item_count_handle, id, 0);
    parser_store_node_count = parser_store_node_count + 1;
    parser_store_refresh_slices();
    return id;
}

public () parser_store_set_aux(Int node_id, Int value) {
    ints.buffer_int_set(parser_store_node_aux_handle, node_id, value);
    parser_store_refresh_slices();
}

public () parser_store_set_start(Int node_id, Int value) {
    ints.buffer_int_set(parser_store_node_starts_handle, node_id, value);
    parser_store_refresh_slices();
}

public () parser_store_set_end(Int node_id, Int value) {
    ints.buffer_int_set(parser_store_node_ends_handle, node_id, value);
    parser_store_refresh_slices();
}

public () parser_store_set_next_sibling(Int node_id, Int value) {
    ints.buffer_int_set(parser_store_node_next_sibling_handle, node_id, value);
    parser_store_refresh_slices();
}

public () parser_store_append_child(Int parent, Int child) {
    ints.buffer_int_set(parser_store_node_parent_handle, child, parent);
    if (parser_store_node_first_child[parent] == 0) {
        ints.buffer_int_set(parser_store_node_first_child_handle, parent, child);
        parser_store_refresh_slices();
        return;
    }

    Int cursor = parser_store_node_first_child[parent];
    while (parser_store_node_next_sibling[cursor] != 0) {
        cursor = parser_store_node_next_sibling[cursor];
    }
    ints.buffer_int_set(parser_store_node_next_sibling_handle, cursor, child);
    parser_store_refresh_slices();
}

public () parser_store_append_generic_item(Int node_id, Int item_id) {
    if (parser_store_node_generic_item_counts[node_id] == 0) {
        ints.buffer_int_set(
            parser_store_node_generic_item_offset_handle,
            node_id,
            ints.buffer_int_length(parser_store_generic_item_ids_handle)
        );
    }
    ints.buffer_int_push(parser_store_generic_item_ids_handle, item_id);
    ints.buffer_int_set(
        parser_store_node_generic_item_count_handle,
        node_id,
        parser_store_node_generic_item_counts[node_id] + 1
    );
    parser_store_refresh_slices();
}
