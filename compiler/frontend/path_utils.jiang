public Bool has_jiang_suffix(UInt8[] path) {
    if (path.length < 6) {
        return 0;
    }
    Int start = path.length - 6;
    if (path[start] != 46) {
        return 0;
    }
    if (path[start + 1] != 106) {
        return 0;
    }
    if (path[start + 2] != 105) {
        return 0;
    }
    if (path[start + 3] != 97) {
        return 0;
    }
    if (path[start + 4] != 110) {
        return 0;
    }
    if (path[start + 5] != 103) {
        return 0;
    }
    return 1;
}
