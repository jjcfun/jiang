import std;
import ast = "ast.jiang";

() hir_dump_slice(UInt8[] source, Int start, Int end) {
    Int! i = start;
    while (i < end) {
        __intrinsic_print("%c", source[i]);
        i = i + 1;
    }
}

() hir_dump_field(UInt8[] source, Int node) {
    __intrinsic_print("    field_decl name=");
    hir_dump_slice(source, ast.ast_name_start(node), ast.ast_name_end(node));
    __intrinsic_print(" type=");
    hir_dump_slice(source, ast.ast_aux_start(node), ast.ast_aux_end(node));
    __intrinsic_print("\n");
}

() hir_dump_struct(UInt8[] source, Int node) {
    __intrinsic_print("  struct_decl ");
    if (ast.ast_is_public(node) != 0) {
        __intrinsic_print("public ");
    }
    __intrinsic_print("sym=");
    hir_dump_slice(source, ast.ast_name_start(node), ast.ast_name_end(node));
    __intrinsic_print("\n");

    Int child = ast.ast_first_child(node);
    while (child != 0) {
        if (ast.ast_kind(child) == ast.ast_node_field_decl) {
            hir_dump_field(source, child);
        }
        child = ast.ast_next_sibling(child);
    }
}

public () dump_hir(UInt8[] source, Int root) {
    std.io.print("stage2 hir dump:");
    __intrinsic_print("program\n");

    Int child = ast.ast_first_child(root);
    while (child != 0) {
        if (ast.ast_kind(child) == ast.ast_node_struct_decl) {
            hir_dump_struct(source, child);
        }
        child = ast.ast_next_sibling(child);
    }
}
